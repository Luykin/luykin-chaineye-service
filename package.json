{
  "name": "enterprise-admin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development nodemon ./src/apiServer.js",
    "dev:pro": "NODE_ENV=production nodemon ./src/apiServer.js",
    "dev-crawler": "NODE_ENV=development nodemon ./src/crawlerServer.js",
    "start": "pm2 start ecosystem.config.js --env production",
    "start:dev": "pm2 start ecosystem.config.js --env development",
    "stop": "pm2 stop luykin-chaineye-api luykin-chaineye-crawler luykin-chaineye-bot",
    "restart-api": "pm2 restart luykin-chaineye-api",
    "restart": "pm2 restart luykin-chaineye-api luykin-chaineye-crawler luykin-chaineye-bot",
    "delete": "pm2 delete luykin-chaineye-api luykin-chaineye-crawler luykin-chaineye-bot",
    "logs": "pm2 logs luykin-chaineye-api luykin-chaineye-crawler luykin-chaineye-bot",
    "logs-crawler": "pm2 logs luykin-chaineye-crawler --env production",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "test-start": "pm2 start dev.ecosystem.config.js --env development",
    "test-restart": "pm2 restart dev.ecosystem.config.js --env development",
    "test-logs": "pm2 logs dev-luykin-chaineye-api"
  },
  "dependencies": {
    "@lem0-packages/puppeteer-page-proxy": "^1.3.3",
    "async-retry": "^1.3.3",
    "axios": "^1.9.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dd-trace": "^5.53.0",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.10",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-forge": "^1.3.1",
    "node-schedule": "^2.1.1",
    "node-telegram-bot-api": "^0.66.0",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "puppeteer": "^24.4.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-anonymize-ua": "^2.4.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "redis": "^4.7.0",
    "sequelize": "^6.35.2",
    "sqlite3": "^5.1.7",
    "telegraf": "^4.16.3",
    "twitter-api-v2": "^1.23.0",
    "uuid": "^11.0.3",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "hot-shots": "^10.2.1",
    "nodemon": "^3.0.2"
  },
  "packageManager": "yarn@4.9.1"
}