        <p class="export-description">
          包含已登录我们插件的用户信息：Twitter ID、用户名和显示名称。
        </p>
        <div class="export-actions">
          <button id="export-users-excel" class="export-btn secondary">
            <span class="btn-icon">📊</span>
            导出用户Excel
          </button>
          <div class="export-info">
            <small>将下载包含所有已登录用户信息的Excel文件</small>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 导出状态显示 -->
  <div id="export-status" class="export-status" style="display: none">
    <div class="status-content">
      <div class="status-icon">⏳</div>
      <div class="status-text">正在处理导出请求...</div>
    </div>
  </div>

  <!-- 导出历史 -->
  <div class="export-history">
    <h3>📋 导出说明</h3>
    <div class="history-list">
      <div class="history-item">
