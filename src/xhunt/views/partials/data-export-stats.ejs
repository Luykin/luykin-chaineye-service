        </div>
      </div>
      <div class="history-item">
        <div class="history-icon">👥</div>
        <div class="history-content">
          <strong>用户数据</strong>
          <p>仅包含已登录我们插件的用户信息</p>
        </div>
      </div>
    </div>
  </div>
</div>

