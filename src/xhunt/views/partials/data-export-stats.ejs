        </p>
        <div class="export-actions">
          <button id="backup-all-dau" class="export-btn primary">
            <span class="btn-icon">💾</span>
            备份所有DAU数据
          </button>
          <button id="download-latest-backup" class="export-btn secondary">
            <span class="btn-icon">⬇️</span>
            下载备份文件
          </button>
          <div class="export-info">
            <small
              >备份：生成/更新累加备份文件（去重） |
              下载：下载最新的备份文件</small
            >
          </div>
        </div>
      </div>
    </div>

    <!-- 用户数据导出 -->
    <div class="export-card">
      <div class="export-card-header">
        <h3>👥 用户数据导出</h3>
