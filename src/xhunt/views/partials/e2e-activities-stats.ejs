<div class="panel">
  <h2>🎯 E2E 活动管理（仅 luykin）</h2>
  <p class="muted">在这里新增活动、查看并管理现有活动的状态与结束时间。</p>

  <!-- 新增活动表单 -->
  <form id="e2e-create-form" class="form-grid">
    <div class="grid-2">
      <label>
        Title
        <input name="title" type="text" placeholder="Activity title" required />
      </label>
      <label>
        Activity Slug
        <input name="activitySlug" type="text" placeholder="unique-slug (optional)" />
      </label>
    </div>
    <div class="grid-2">
      <label>
        External ID
        <input name="externalId" type="text" placeholder="external id (optional)" />
      </label>
      <label>
        Avatar Image URL
        <input name="avatarImage" type="url" placeholder="https://..." />
      </label>
    </div>
    <div class="grid-2">
      <label>
        Tweet Link
        <input name="tweetLink" type="url" placeholder="https://x.com/... (optional)" />
      </label>
      <label>
        Reward Label
        <input name="rewardLabel" type="text" placeholder="$1,000 in USDC / Points" />
      </label>
    </div>
    <div class="grid-2">
      <label>
        Reward Amount (USD)
        <input name="rewardAmountUsd" type="number" step="0.01" placeholder="1000.00" />
      </label>
      <label>
        Status
        <select name="status">
          <option value="announced">announced</option>
          <option value="not_started">not_started</option>
          <option value="active">active</option>
          <option value="rewarding">rewarding</option>
          <option value="ended">ended</option>
        </select>
      </label>
    </div>
    <div class="grid-2">
      <label>
        Start At (UTC)
        <input name="startAt" type="datetime-local" />
      </label>
      <label>
        End At (UTC)
        <input name="endAt" type="datetime-local" />
      </label>
    </div>
    <div class="grid-3">
      <label>
        Limit Pro Only
        <input name="limitProOnly" type="checkbox" />
      </label>
      <label>
        Limit By Followers
        <input name="limitByFollowers" type="checkbox" />
      </label>
      <label>
        Min Followers
        <input name="minFollowers" type="number" min="0" value="0" />
      </label>
    </div>
    <div class="grid-1">
      <label>
        Requires EVM Bound
        <input name="requiresEvmBound" type="checkbox" />
      </label>
    </div>
    <div class="grid-1">
      <label>
        Description
        <textarea name="description" rows="3" placeholder="Activity description (optional)"></textarea>
      </label>
    </div>
    <div>
      <button type="submit" class="btn-primary">Create Activity</button>
      <span id="e2e-create-msg" class="muted"></span>
    </div>
  </form>

  <hr />

  <!-- 活动列表 -->
  <div class="list-header">
    <h3>Existing Activities</h3>
    <button id="e2e-refresh" class="btn">Refresh</button>
  </div>
  <div id="e2e-list" class="card-list"></div>
</div>

<script>
  (function() {
    const listEl = document.getElementById('e2e-list');
    const refreshBtn = document.getElementById('e2e-refresh');
    const form = document.getElementById('e2e-create-form');
    const msgEl = document.getElementById('e2e-create-msg');

    async function fetchActivities() {
      listEl.innerHTML = '<div class="muted">Loading...</div>';
      try {
        const res = await fetch('/api/xhunt/stats/e2e/activities?page=1&limit=50', { credentials: 'include' });
        const data = await res.json();
        if (!data || !data.success) throw new Error(data?.error || 'Load failed');
        renderList(data.data || []);
      } catch (e) {
        listEl.innerHTML = '<div class="error">Failed to load activities</div>';
      }
    }

    function renderList(items) {
      if (!items.length) {
        listEl.innerHTML = '<div class="muted">No activities yet</div>';
        return;
      }
      listEl.innerHTML = items.map(item => {
        const endAt = item.endAt ? new Date(item.endAt).toISOString().slice(0,16) : '';
        return `
          <div class="card">
            <div class="card-body">
              <div class="row">
                <div class="col">
                  <div class="title">${escapeHtml(item.title || '')}</div>
                  <div class="muted">slug: ${escapeHtml(item.activitySlug || '-')}, ext: ${escapeHtml(item.externalId || '-')}</div>
                  <div class="muted">status: <strong>${escapeHtml(item.status)}</strong> · followers >= ${item.minFollowers} · proOnly: ${item.limitProOnly ? 'yes' : 'no'} · requireEVM: ${item.requiresEvmBound ? 'yes' : 'no'}</div>
                </div>
                <div class="col actions">
                  <label>Status
                    <select data-action="status" data-id="${item.id}">
                      ${['announced','not_started','active','rewarding','ended'].map(st => `<option value="${st}" ${st===item.status?'selected':''}>${st}</option>`).join('')}
                    </select>
                  </label>
                  <label>End At
                    <input data-action="endAt" data-id="${item.id}" type="datetime-local" value="${endAt}" />
                  </label>
                  <button class="btn" data-action="save" data-id="${item.id}">Save</button>
                </div>
              </div>
            </div>
          </div>`;
      }).join('');

      // attach events
      listEl.querySelectorAll('button[data-action="save"]').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const id = e.currentTarget.getAttribute('data-id');
          const status = listEl.querySelector(`select[data-action="status"][data-id="${id}"]`).value;
          const endAtVal = listEl.querySelector(`input[data-action="endAt"][data-id="${id}"]`).value;
          const payload = { status };
          if (endAtVal !== undefined) payload.endAt = endAtVal || null;
          e.currentTarget.disabled = true;
          try {
            const res = await fetch(`/api/xhunt/stats/e2e/activities/${id}`, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'include',
              body: JSON.stringify(payload)
            });
            const data = await res.json();
            if (!data || !data.success) throw new Error(data?.error || 'Update failed');
            await fetchActivities();
          } catch (err) {
            alert('Update failed');
          } finally {
            e.currentTarget.disabled = false;
          }
        });
      });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      msgEl.textContent = '';
      const fd = new FormData(form);
      const payload = Object.fromEntries(fd.entries());
      payload.limitProOnly = form.limitProOnly.checked;
      payload.limitByFollowers = form.limitByFollowers.checked;
      payload.requiresEvmBound = form.requiresEvmBound.checked;
      if (payload.minFollowers) payload.minFollowers = Number(payload.minFollowers) || 0;
      try {
        const res = await fetch('/api/xhunt/stats/e2e/activities', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (!data || !data.success) throw new Error(data?.error || 'Create failed');
        form.reset();
        msgEl.textContent = 'Created';
        fetchActivities();
      } catch (err) {
        msgEl.textContent = 'Create failed';
      }
    });

    function escapeHtml(str) {
      return String(str).replace(/[&<>"])/g, function(c) {
        return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;','\'':'&#39;','(':'&#40;',')':'&#41;'}[c] || c);
      });
    }

    // 首次加载
    fetchActivities();
    refreshBtn.addEventListener('click', fetchActivities);
  })();
</script>
