<div class="e2e-management-container">
  <div class="e2e-management-header">
    <h2>🎯 E2E 活动管理</h2>
    <p>创建和管理 Engage-to-Earn 活动</p>
  </div>

  <!-- 新增活动 -->
  <div class="e2e-create-section">
    <div class="section-card">
      <div class="section-card-header">
        <h3>✨ 新增活动</h3>
        <p>创建新的 Engage-to-Earn 活动</p>
      </div>
      <div class="section-card-content">
        <form id="e2e-create-form" class="e2e-form">
          <div class="form-row">
            <div class="form-group">
              <label>活动标题 *</label>
              <input name="title" type="text" placeholder="Activity title" required />
            </div>
            <div class="form-group">
              <label>Activity Slug</label>
              <input name="activitySlug" type="text" placeholder="unique-slug (optional)" />
            </div>
            <div class="form-group">
              <label>External ID</label>
              <input name="externalId" type="text" placeholder="external id (optional)" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label>奖励标签</label>
              <input name="rewardLabel" type="text" placeholder="$1,000 in USDC" />
            </div>
            <div class="form-group">
              <label>奖励金额 (USD)</label>
              <input name="rewardAmountUsd" type="number" step="0.01" placeholder="1000.00" />
            </div>
            <div class="form-group">
              <label>状态</label>
              <select name="status">
                <option value="announced">announced</option>
                <option value="not_started">not_started</option>
                <option value="active">active</option>
                <option value="rewarding">rewarding</option>
                <option value="ended">ended</option>
              </select>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label>开始时间 (UTC)</label>
              <input name="startAt" type="datetime-local" />
            </div>
            <div class="form-group">
              <label>结束时间 (UTC)</label>
              <input name="endAt" type="datetime-local" />
            </div>
            <div class="form-group">
              <label>最低粉丝数</label>
              <input name="minFollowers" type="number" min="0" value="0" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label>头像图片 URL</label>
              <input name="avatarImage" type="url" placeholder="https://..." />
            </div>
            <div class="form-group">
              <label>推文链接</label>
              <input name="tweetLink" type="url" placeholder="https://x.com/..." />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group full-width">
              <label>活动描述</label>
              <textarea name="description" rows="2" placeholder="Activity description (optional)"></textarea>
            </div>
          </div>

          <div class="form-row checkbox-row">
            <label class="checkbox-label">
              <input name="limitProOnly" type="checkbox" />
              <span>仅限 Pro 用户</span>
            </label>
            <label class="checkbox-label">
              <input name="limitByFollowers" type="checkbox" />
              <span>限制粉丝数</span>
            </label>
            <label class="checkbox-label">
              <input name="requiresEvmBound" type="checkbox" />
              <span>要求绑定 EVM</span>
            </label>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary">
              <span class="btn-icon">✨</span>
              创建活动
            </button>
            <button type="reset" class="btn btn-secondary">重置</button>
          </div>
        </form>

        <div id="e2e-create-result" class="result-message" style="display: none">
          <div class="result-content"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- 活动列表 -->
  <div class="e2e-list-section">
    <div class="section-card">
      <div class="section-card-header">
        <h3>📋 活动列表</h3>
        <p>管理现有活动状态</p>
      </div>
      <div class="section-card-content">
        <div class="list-controls">
          <button id="e2e-refresh" class="btn btn-secondary">
            <span class="btn-icon">🔄</span>
            刷新列表
          </button>
          <div class="list-stats">
            <span id="e2e-activity-count">加载中...</span>
          </div>
        </div>

        <div id="e2e-list" class="activities-list"></div>
      </div>
    </div>
  </div>
</div>

<style>
  .e2e-management-container { padding: 20px; max-width: 1400px; margin: 0 auto; }
  .e2e-management-header { text-align: center; margin-bottom: 30px; }
  .e2e-management-header h2 { color: #2c3e50; margin-bottom: 10px; }
  .e2e-management-header p { color: #7f8c8d; font-size: 16px; }
  .e2e-create-section, .e2e-list-section { margin-bottom: 30px; }
  .section-card { background: #fff; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); overflow: hidden; }
  .section-card-header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 20px; }
  .section-card-header h3 { margin: 0 0 8px 0; font-size: 18px; }
  .section-card-header p { margin: 0; opacity: 0.9; font-size: 14px; }
  .section-card-content { padding: 30px; }
  .e2e-form { max-width: 100%; }
  .form-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 15px; }
  .form-row.checkbox-row { grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); }
  .form-group { display: flex; flex-direction: column; }
  .form-group.full-width { grid-column: 1 / -1; }
  .form-group label { display: block; margin-bottom: 6px; color: #2c3e50; font-weight: 600; font-size: 14px; }
  .form-group input[type="text"], .form-group input[type="url"], .form-group input[type="number"], .form-group input[type="datetime-local"], .form-group select, .form-group textarea {
    width: 100%; padding: 10px 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 14px; transition: border-color 0.3s ease;
  }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline: none; border-color: #667eea; }
  .checkbox-label { display: flex; align-items: center; gap: 8px; color: #2c3e50; font-weight: 600; font-size: 14px; }
  .checkbox-label input[type="checkbox"] { width: auto; margin: 0; }
  .form-actions { display: flex; gap: 10px; justify-content: center; margin-top: 20px; }
  .btn { display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; border: none; border-radius: 8px; font-size: 16px; font-weight: 600; cursor: pointer; transition: all 0.2s ease; }
  .btn-primary { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; }
  .btn-primary:hover { background: linear-gradient(135deg, #5568d3 0%, #6a3f8f 100%); transform: translateY(-1px); box-shadow: 0 4px 8px rgba(102,126,234,0.3); }
  .btn-secondary { background: #ecf0f1; color: #2c3e50; }
  .btn-secondary:hover { background: #d5dbdb; }
  .btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .btn-icon { font-size: 18px; }
  .result-message { margin-top: 20px; padding: 15px; border-radius: 8px; animation: slideIn 0.3s ease; }
  @keyframes slideIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
  .result-message.success { background: #d4edda; border: 1px solid #c3e6cb; color: #155724; }
  .result-message.error { background: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; }
  .list-controls { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
  .list-stats { color: #7f8c8d; font-size: 14px; }
  .activities-list { display: grid; gap: 20px; }
  
  /* 活动卡片 */
  .e2e-activity-card { background: white; border: 1px solid #e5e7eb; border-radius: 16px; overflow: hidden; transition: all 0.3s ease; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
  .e2e-activity-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.12); transform: translateY(-4px); }
  
  /* 头部区域 */
  .card-header-section { display: flex; gap: 16px; padding: 20px; background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%); border-bottom: 1px solid #e5e7eb; }
  .activity-avatar { width: 64px; height: 64px; border-radius: 12px; object-fit: cover; border: 2px solid #e5e7eb; }
  .activity-avatar-placeholder { width: 64px; height: 64px; border-radius: 12px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; font-size: 32px; }
  .header-content { flex: 1; min-width: 0; }
  .title-row { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
  .card-title { font-size: 18px; font-weight: 700; color: #111827; margin: 0; flex: 1; }
  .card-description { font-size: 14px; color: #6b7280; margin: 0; line-height: 1.5; }
  
  /* 状态徽章 */
  .status-badge { display: inline-flex; align-items: center; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; white-space: nowrap; }
  .status-badge.announced { background: #dbeafe; color: #1e40af; }
  .status-badge.not_started { background: #fef3c7; color: #92400e; }
  .status-badge.active { background: #d1fae5; color: #065f46; }
  .status-badge.rewarding { background: #fce7f3; color: #9f1239; }
  .status-badge.ended { background: #f3f4f6; color: #374151; }
  
  /* 信息区域 */
  .card-info-section { padding: 20px; }
  .info-grid { display: grid; gap: 16px; }
  .info-item { display: flex; gap: 12px; align-items: flex-start; }
  .info-icon { font-size: 20px; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; background: #f3f4f6; border-radius: 8px; flex-shrink: 0; }
  .info-content { flex: 1; min-width: 0; }
  .info-label { font-size: 12px; color: #6b7280; font-weight: 600; text-transform: uppercase; margin-bottom: 4px; }
  .info-value { font-size: 14px; color: #111827; font-weight: 500; }
  .reward-item .info-value { font-size: 15px; font-weight: 600; color: #7c3aed; }
  .reward-item .amount { color: #059669; margin-left: 8px; }
  
  /* 标签 */
  .constraint-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag { display: inline-flex; align-items: center; padding: 4px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; white-space: nowrap; }
  .tag-pro { background: #fef3c7; color: #92400e; }
  .tag-followers { background: #dbeafe; color: #1e40af; }
  .tag-evm { background: #e0e7ff; color: #4338ca; }
  .tag-open { background: #d1fae5; color: #065f46; }
  
  /* 推文链接 */
  .tweet-link { color: #1d9bf0; text-decoration: none; font-weight: 600; display: inline-flex; align-items: center; gap: 4px; }
  .tweet-link:hover { text-decoration: underline; }
  
  /* 技术信息 */
  .tech-details { padding: 0 20px 12px; }
  .tech-details summary { cursor: pointer; font-size: 13px; color: #6b7280; font-weight: 600; padding: 8px 0; user-select: none; }
  .tech-details summary:hover { color: #111827; }
  .tech-content { background: #f9fafb; border-radius: 8px; padding: 12px; margin-top: 8px; }
  .tech-row { display: flex; gap: 8px; margin-bottom: 6px; font-size: 13px; }
  .tech-row:last-child { margin-bottom: 0; }
  .tech-label { color: #6b7280; font-weight: 600; min-width: 80px; }
  .tech-row code { background: #ffffff; padding: 2px 6px; border-radius: 4px; font-family: 'Monaco', 'Menlo', monospace; font-size: 12px; color: #7c3aed; }
  
  /* 管理操作区 */
  .card-actions { padding: 16px 20px; background: #f9fafb; border-top: 1px solid #e5e7eb; display: flex; gap: 16px; align-items: flex-end; flex-wrap: wrap; }
  .action-controls { display: flex; gap: 12px; flex: 1; flex-wrap: wrap; }
  .control-label { display: flex; flex-direction: column; gap: 6px; font-size: 12px; font-weight: 600; color: #374151; }
  .control-select, .control-input { padding: 8px 12px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; background: white; }
  .control-select:focus, .control-input:focus { outline: none; border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,0.1); }
  .btn-save { display: inline-flex; align-items: center; gap: 6px; white-space: nowrap; }
  
  @media (max-width: 768px) {
    .card-header-section { flex-direction: column; }
    .info-grid { grid-template-columns: 1fr; }
    .action-controls { flex-direction: column; width: 100%; }
    .control-label { width: 100%; }
  }
  @media (max-width: 920px) { 
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<script>
(function() {
  const listEl = document.getElementById('e2e-list');
  const countEl = document.getElementById('e2e-activity-count');
  const refreshBtn = document.getElementById('e2e-refresh');
  const form = document.getElementById('e2e-create-form');
  const resultEl = document.getElementById('e2e-create-result');
  const resultContent = resultEl.querySelector('.result-content');

  function showResult(message, isSuccess) {
    resultContent.textContent = message;
    resultEl.className = 'result-message ' + (isSuccess ? 'success' : 'error');
    resultEl.style.display = 'block';
    setTimeout(() => { resultEl.style.display = 'none'; }, 5000);
  }

  async function fetchActivities() {
    listEl.innerHTML = '<div style="text-align:center;padding:40px;color:#7f8c8d;">加载中...</div>';
    try {
      const res = await fetch('/api/xhunt/stats/e2e/activities?page=1&limit=50', { credentials: 'include' });
      const data = await res.json();
      if (!data || !data.success) throw new Error(data?.error || '加载失败');
      renderList(data.data || []);
      countEl.textContent = `共 ${data.data.length} 个活动`;
    } catch (e) {
      listEl.innerHTML = '<div style="text-align:center;padding:40px;color:#e74c3c;">加载失败</div>';
      countEl.textContent = '加载失败';
    }
  }

  function renderList(items) {
    if (!items.length) {
      listEl.innerHTML = '<div style="text-align:center;padding:40px;color:#7f8c8d;">暂无活动</div>';
      return;
    }
    listEl.innerHTML = items.map(item => {
      const endAt = item.endAt ? new Date(item.endAt).toISOString().slice(0,16) : '';
      const startAt = item.startAt ? new Date(item.startAt).toISOString().slice(0,16) : '';
      const statusClass = item.status === 'active' ? 'active' : item.status === 'ended' ? 'ended' : 'announced';
      const formatDate = (dateStr) => {
        if (!dateStr) return '-';
        const d = new Date(dateStr);
        return d.toLocaleString('zh-CN', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
      };
      
      // 图片代理函数
      const getProxiedImageUrl = (imageUrl) => {
        if (!imageUrl) return '';
        return `/api/proxy?url=${encodeURIComponent(imageUrl)}`;
      };
      
      return `
        <div class="e2e-activity-card">
          <!-- 头部区域：头像 + 标题 + 状态 -->
          <div class="card-header-section">
            ${item.avatarImage ? `<img src="${getProxiedImageUrl(item.avatarImage)}" class="activity-avatar" onerror="this.style.display='none'" />` : '<div class="activity-avatar-placeholder">🎯</div>'}
            <div class="header-content">
              <div class="title-row">
                <h3 class="card-title">${escapeHtml(item.title)}</h3>
                <span class="status-badge ${statusClass}">${item.status}</span>
              </div>
              ${item.description ? `<p class="card-description">${escapeHtml(item.description)}</p>` : ''}
            </div>
          </div>

          <!-- 信息区域：奖励 + 时间 + 条件 -->
          <div class="card-info-section">
            <div class="info-grid">
              <!-- 奖励信息 -->
              ${item.rewardLabel || item.rewardAmountUsd ? `
              <div class="info-item reward-item">
                <div class="info-icon">🎁</div>
                <div class="info-content">
                  <div class="info-label">奖励</div>
                  <div class="info-value">
                    ${item.rewardLabel ? escapeHtml(item.rewardLabel) : ''}
                    ${item.rewardAmountUsd ? `<span class="amount">$${parseFloat(item.rewardAmountUsd).toLocaleString()}</span>` : ''}
                  </div>
                </div>
              </div>` : ''}

              <!-- 时间信息 -->
              <div class="info-item">
                <div class="info-icon">⏰</div>
                <div class="info-content">
                  <div class="info-label">活动时间</div>
                  <div class="info-value">${formatDate(item.startAt)} ~ ${formatDate(item.endAt)}</div>
                </div>
              </div>

              <!-- 参与条件 -->
              <div class="info-item">
                <div class="info-icon">📊</div>
                <div class="info-content">
                  <div class="info-label">参与条件</div>
                  <div class="info-value">
                    <div class="constraint-tags">
                      ${item.limitProOnly ? '<span class="tag tag-pro">👑 Pro限定</span>' : ''}
                      ${item.limitByFollowers ? `<span class="tag tag-followers">👥 粉丝≥${item.minFollowers}</span>` : ''}
                      ${item.requiresEvmBound ? '<span class="tag tag-evm">🔗 需绑定EVM</span>' : ''}
                      ${!item.limitProOnly && !item.limitByFollowers && !item.requiresEvmBound ? '<span class="tag tag-open">✅ 无限制</span>' : ''}
                    </div>
                  </div>
                </div>
              </div>

              <!-- 推文链接 -->
              ${item.tweetLink ? `
              <div class="info-item">
                <div class="info-icon">🐦</div>
                <div class="info-content">
                  <div class="info-label">推文链接</div>
                  <div class="info-value">
                    <a href="${escapeHtml(item.tweetLink)}" target="_blank" class="tweet-link">
                      🔗 查看推文
                    </a>
                  </div>
                </div>
              </div>` : ''}
            </div>
          </div>

          <!-- 技术信息（折叠） -->
          <details class="tech-details">
            <summary>🔧 技术信息</summary>
            <div class="tech-content">
              <div class="tech-row">
                <span class="tech-label">ID:</span>
                <code>${item.id}</code>
              </div>
              ${item.activitySlug ? `
              <div class="tech-row">
                <span class="tech-label">Slug:</span>
                <code>${escapeHtml(item.activitySlug)}</code>
              </div>` : ''}
              ${item.externalId ? `
              <div class="tech-row">
                <span class="tech-label">External ID:</span>
                <code>${escapeHtml(item.externalId)}</code>
              </div>` : ''}
              <div class="tech-row">
                <span class="tech-label">创建时间:</span>
                <span>${new Date(item.createdAt).toLocaleString('zh-CN')}</span>
              </div>
            </div>
          </details>

          <!-- 管理操作区 -->
          <div class="card-actions">
            <div class="action-controls">
              <label class="control-label">
                状态
                <select data-action="status" data-id="${item.id}" class="control-select">
                  ${['announced','not_started','active','rewarding','ended'].map(st => `<option value="${st}" ${st===item.status?'selected':''}>${st}</option>`).join('')}
                </select>
              </label>
              <label class="control-label">
                结束时间
                <input data-action="endAt" data-id="${item.id}" type="datetime-local" value="${endAt}" class="control-input" />
              </label>
            </div>
            <button class="btn btn-primary btn-save" data-action="save" data-id="${item.id}">
              <span>✔️</span> 保存更改
            </button>
          </div>
        </div>`;
    }).join('');

    listEl.querySelectorAll('button[data-action="save"]').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const id = e.currentTarget.getAttribute('data-id');
        const status = listEl.querySelector(`select[data-action="status"][data-id="${id}"]`).value;
        const endAtVal = listEl.querySelector(`input[data-action="endAt"][data-id="${id}"]`).value;
        const payload = { status };
        if (endAtVal !== undefined) payload.endAt = endAtVal || null;
        e.currentTarget.disabled = true;
        try {
          const res = await fetch(`/api/xhunt/stats/e2e/activities/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify(payload)
          });
          const data = await res.json();
          if (!data || !data.success) throw new Error(data?.error || '更新失败');
          await fetchActivities();
          showResult('更新成功', true);
        } catch (err) {
          showResult('更新失败: ' + err.message, false);
        } finally {
          e.currentTarget.disabled = false;
        }
      });
    });
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector('button[type="submit"]');
    submitBtn.disabled = true;
    const fd = new FormData(form);
    const payload = Object.fromEntries(fd.entries());
    payload.limitProOnly = form.limitProOnly.checked;
    payload.limitByFollowers = form.limitByFollowers.checked;
    payload.requiresEvmBound = form.requiresEvmBound.checked;
    if (payload.minFollowers) payload.minFollowers = Number(payload.minFollowers) || 0;
    try {
      const res = await fetch('/api/xhunt/stats/e2e/activities', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (!data || !data.success) throw new Error(data?.error || '创建失败');
      form.reset();
      showResult('活动创建成功！', true);
      await fetchActivities();
    } catch (err) {
      showResult('创建失败: ' + err.message, false);
    } finally {
      submitBtn.disabled = false;
    }
  });

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  fetchActivities();
  refreshBtn.addEventListener('click', fetchActivities);
})();
</script>
