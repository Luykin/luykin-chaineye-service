<div class="generic-stats-page">
  <div class="section">
    <div class="generic-stats-header">
      <div>
        <h2 class="section-title">通用统计</h2>
        <p class="generic-stats-desc">
          统一查看低频统计事件，支持按 type、时间、对象、用户筛选，并提供按对象维度的聚合查看。
        </p>
      </div>
      <button id="generic-stats-refresh" class="btn-primary">刷新</button>
    </div>

    <div class="generic-stats-filters">
      <div class="form-item">
        <label for="generic-stats-type">统计类型</label>
        <select id="generic-stats-type"></select>
      </div>
      <div class="form-item">
        <label for="generic-stats-date-from">开始时间</label>
        <input id="generic-stats-date-from" type="datetime-local" />
      </div>
      <div class="form-item">
        <label for="generic-stats-date-to">结束时间</label>
        <input id="generic-stats-date-to" type="datetime-local" />
      </div>
      <div class="form-item">
        <label for="generic-stats-subject-id">对象 ID</label>
        <input id="generic-stats-subject-id" type="text" placeholder="如 cz" />
      </div>
      <div class="form-item">
        <label for="generic-stats-actor-id">用户 ID</label>
        <input id="generic-stats-actor-id" type="text" placeholder="用户 UUID" />
      </div>
    </div>

    <div id="generic-stats-summary" class="generic-summary-grid" style="display:none;">
      <div class="stat-card">
        <div class="stat-title">对象数量</div>
        <div class="stat-value stat-value-lg" id="generic-total-kols">0</div>
      </div>
      <div class="stat-card">
        <div class="stat-title">事件条数</div>
        <div class="stat-value stat-value-lg" id="generic-total-calls">0</div>
      </div>
      <div class="stat-card">
        <div class="stat-title">累计计数</div>
        <div class="stat-value stat-value-lg" id="generic-total-questions">0</div>
      </div>
      <div class="stat-card">
        <div class="stat-title">去重触发者数</div>
        <div class="stat-value stat-value-lg" id="generic-total-users">0</div>
      </div>
    </div>

    <div class="generic-card">
      <div class="generic-card-header">
        <h3 class="generic-card-title">对象聚合</h3>
        <span class="generic-card-hint" id="generic-aggregate-hint"></span>
      </div>
      <div id="generic-aggregate-empty" class="generic-empty">
        当前筛选条件下暂无聚合数据
      </div>
      <div id="generic-aggregate-wrap" class="table-container" style="display:none;">
        <table class="data-table">
          <thead>
            <tr>
              <th>对象 ID</th>
              <th>对象名称</th>
              <th>事件条数</th>
              <th>累计计数</th>
              <th>去重触发者数</th>
            </tr>
          </thead>
          <tbody id="generic-aggregate-tbody"></tbody>
        </table>
      </div>
    </div>

    <div class="generic-card">
      <div class="generic-card-header">
        <h3 class="generic-card-title">原始事件</h3>
        <span class="generic-card-hint" id="generic-events-page-hint">第 1 页</span>
      </div>
      <div class="table-container">
        <table class="data-table generic-events-table">
          <thead>
            <tr>
              <th>时间</th>
              <th>Type</th>
              <th>对象</th>
              <th>用户</th>
              <th>计数</th>
              <th>事件信息</th>
            </tr>
          </thead>
          <tbody id="generic-events-tbody"></tbody>
        </table>
      </div>
      <div id="generic-events-empty" class="generic-empty" style="display:none;">
        当前筛选条件下暂无数据
      </div>
      <div class="generic-pagination">
        <button id="generic-events-prev" class="btn btn-sm">上一页</button>
        <span id="generic-events-pagination-text">1 / 1</span>
        <button id="generic-events-next" class="btn btn-sm">下一页</button>
      </div>
    </div>

    <div id="generic-stats-loading" class="loading-state" style="display:none;">
      <div class="spinner"></div>
      <p>加载中...</p>
    </div>
  </div>
</div>

<style>
  .generic-stats-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 16px;
  }

  .generic-stats-desc {
    margin: 6px 0 0;
    color: #6b7280;
    font-size: 14px;
  }

  .generic-stats-filters {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
    margin-bottom: 16px;
  }

  .generic-stats-filters .form-item label {
    display: block;
    font-size: 12px;
    color: #6b7280;
    margin-bottom: 4px;
  }

  .generic-stats-filters .form-item input,
  .generic-stats-filters .form-item select {
    width: 100%;
    padding: 8px 10px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    background: #fff;
    font-size: 13px;
    box-sizing: border-box;
  }

  .generic-stats-filters .form-item input:focus,
  .generic-stats-filters .form-item select:focus {
    outline: none;
    border-color: #3b82f6;
  }

  .generic-summary-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 16px;
  }

  .generic-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 16px;
    margin-bottom: 16px;
  }

  .generic-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }

  .generic-card-title {
    margin: 0;
    font-size: 16px;
    color: #111827;
  }

  .generic-card-hint {
    color: #6b7280;
    font-size: 12px;
  }

  .generic-events-table td {
    vertical-align: top;
    word-break: break-word;
  }

  .generic-events-table th:last-child,
  .generic-events-table td:last-child {
    width: 38%;
  }

  .generic-empty {
    padding: 16px;
    color: #6b7280;
    font-size: 14px;
    background: #f9fafb;
    border-radius: 6px;
  }

  .generic-pagination {
    margin-top: 12px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 10px;
  }

  .generic-json {
    white-space: pre-wrap;
    font-size: 12px;
    color: #4b5563;
    margin: 0;
    max-width: 340px;
  }

  .generic-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 999px;
    background: #eef2ff;
    color: #4338ca;
    font-size: 12px;
    font-weight: 500;
  }

  .generic-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
    max-width: 100%;
  }

  .generic-pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 8px;
    border-radius: 999px;
    background: #f3f4f6;
    color: #374151;
    font-size: 12px;
    line-height: 1;
    white-space: nowrap;
  }

  .generic-pill-key {
    color: #6b7280;
  }

  .generic-type-text {
    font-weight: 600;
    color: #374151;
  }

  .generic-subtext {
    color: #6b7280;
    font-size: 12px;
    margin-top: 4px;
    line-height: 1.4;
  }

  .generic-mainline {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .generic-entity-line {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .generic-name {
    color: #6b7280;
    font-size: 12px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 220px;
  }

  @media (max-width: 1024px) {
    .generic-summary-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .generic-stats-header {
      flex-direction: column;
    }

    .generic-summary-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  (function () {
    const TAB_ID = "generic-stats";
    const AGGREGATE_TYPE = "xhunt.kol_chat.chat";
    const state = {
      initialized: false,
      loadedTypes: false,
      page: 1,
      totalPages: 1,
    };

    const typeSelect = document.getElementById("generic-stats-type");
    const dateFromInput = document.getElementById("generic-stats-date-from");
    const dateToInput = document.getElementById("generic-stats-date-to");
    const subjectIdInput = document.getElementById("generic-stats-subject-id");
    const actorIdInput = document.getElementById("generic-stats-actor-id");
    const refreshBtn = document.getElementById("generic-stats-refresh");
    const loadingEl = document.getElementById("generic-stats-loading");
    const eventsTbody = document.getElementById("generic-events-tbody");
    const eventsEmpty = document.getElementById("generic-events-empty");
    const eventsPageHint = document.getElementById("generic-events-page-hint");
    const paginationText = document.getElementById("generic-events-pagination-text");
    const prevBtn = document.getElementById("generic-events-prev");
    const nextBtn = document.getElementById("generic-events-next");
    const aggregateHint = document.getElementById("generic-aggregate-hint");
    const aggregateWrap = document.getElementById("generic-aggregate-wrap");
    const aggregateEmpty = document.getElementById("generic-aggregate-empty");
    const aggregateTbody = document.getElementById("generic-aggregate-tbody");
    const summaryEl = document.getElementById("generic-stats-summary");

    function formatDateTimeLocal(date) {
      const d = new Date(date);
      const pad = (n) => String(n).padStart(2, "0");
      return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(
        d.getHours()
      )}:${pad(d.getMinutes())}`;
    }

    function setDefaultDateRange() {
      const now = new Date();
      const sevenDaysAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
      dateToInput.value = formatDateTimeLocal(now);
      dateFromInput.value = formatDateTimeLocal(sevenDaysAgo);
    }

    function setLoading(loading) {
      loadingEl.style.display = loading ? "block" : "none";
    }

    function escapeHtml(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/\"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function formatJson(obj) {
      if (!obj || typeof obj !== "object") return "-";
      try {
        return JSON.stringify(obj, null, 2);
      } catch (_) {
        return "-";
      }
    }

    function formatDateTimeCell(value) {
      if (!value) return "-";
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return "-";
      return date.toLocaleString("zh-CN", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
        hour12: false,
      });
    }

    function formatNumber(num) {
      const value = Number(num || 0);
      return value.toLocaleString("zh-CN");
    }

    function summarizeObject(obj, preferredOrder = []) {
      if (!obj || typeof obj !== "object") return [];
      const entries = Object.entries(obj).filter(([, value]) => {
        if (value === null || value === undefined || value === "") return false;
        if (Array.isArray(value) && value.length === 0) return false;
        return true;
      });

      const orderMap = new Map(preferredOrder.map((key, index) => [key, index]));
      entries.sort(([a], [b]) => {
        const aIndex = orderMap.has(a) ? orderMap.get(a) : 999;
        const bIndex = orderMap.has(b) ? orderMap.get(b) : 999;
        if (aIndex !== bIndex) return aIndex - bIndex;
        return a.localeCompare(b);
      });

      return entries;
    }

    function formatMetaValue(value) {
      if (typeof value === "boolean") return value ? "是" : "否";
      if (Array.isArray(value)) return value.join(", ");
      if (typeof value === "object") return formatJson(value);
      return String(value);
    }

    function renderPills(obj, preferredOrder = [], emptyText = "—") {
      const entries = summarizeObject(obj, preferredOrder);
      if (!entries.length) {
        return `<span class="generic-subtext">${emptyText}</span>`;
      }

      return `
        <div class="generic-meta">
          ${entries
            .map(
              ([key, value]) => `
                <span class="generic-pill">
                  <span class="generic-pill-key">${escapeHtml(key)}:</span>
                  <span>${escapeHtml(formatMetaValue(value))}</span>
                </span>
              `
            )
            .join("")}
        </div>
      `;
    }

    function getFilters() {
      return {
        type: typeSelect.value || "",
        dateFrom: dateFromInput.value || "",
        dateTo: dateToInput.value || "",
        subjectId: subjectIdInput.value.trim(),
        actorId: actorIdInput.value.trim(),
      };
    }

    async function fetchJson(url) {
      const response = await fetch(url, {
        headers: { Accept: "application/json" },
      });
      const data = await response.json();
      if (!response.ok || !data.success) {
        throw new Error(data.error || "请求失败");
      }
      return data;
    }

    async function loadTypes() {
      const data = await fetchJson("/api/xhunt/stats/generic-stats/types");
      const items = Array.isArray(data.data) ? data.data : [];
      const options = [
        '<option value="">全部类型</option>',
        ...items.map(
          (item) =>
            `<option value="${escapeHtml(item.type)}">${escapeHtml(item.type)} (${formatNumber(
              item.count
            )})</option>`
        ),
      ];
      typeSelect.innerHTML = options.join("");

      if (items.some((item) => item.type === AGGREGATE_TYPE)) {
        typeSelect.value = AGGREGATE_TYPE;
      }

      state.loadedTypes = true;
    }

    async function loadAggregate() {
      const filters = getFilters();
      if (!filters.type) {
        summaryEl.style.display = "none";
        aggregateWrap.style.display = "none";
        aggregateEmpty.style.display = "block";
        aggregateEmpty.textContent = "请选择具体 type 后查看对象聚合";
        aggregateHint.textContent = "未选择 type";
        aggregateTbody.innerHTML = "";
        return;
      }

      if (filters.type !== AGGREGATE_TYPE) {
        summaryEl.style.display = "none";
        aggregateWrap.style.display = "none";
        aggregateEmpty.style.display = "block";
        aggregateEmpty.textContent = "当前 type 暂不支持对象聚合";
        aggregateHint.textContent = "当前 type 暂不支持聚合";
        aggregateTbody.innerHTML = "";
        return;
      }

      const params = new URLSearchParams();
      params.set("type", filters.type);
      if (filters.dateFrom) params.set("dateFrom", filters.dateFrom);
      if (filters.dateTo) params.set("dateTo", filters.dateTo);
      if (filters.subjectId) params.set("subjectId", filters.subjectId);

      let data;
      try {
        data = await fetchJson(`/api/xhunt/stats/generic-stats/aggregate?${params.toString()}`);
      } catch (error) {
        summaryEl.style.display = "none";
        aggregateWrap.style.display = "none";
        aggregateEmpty.style.display = "block";
        aggregateEmpty.textContent = "当前筛选条件下暂无聚合数据";
        aggregateHint.textContent = "当前 type 暂不支持聚合";
        aggregateTbody.innerHTML = "";
        return;
      }

      const items = Array.isArray(data.data?.items) ? data.data.items : [];
      const summary = data.data?.summary || {};

      document.getElementById("generic-total-kols").textContent = formatNumber(summary.totalKols);
      document.getElementById("generic-total-calls").textContent = formatNumber(summary.totalCallCount);
      document.getElementById("generic-total-questions").textContent = formatNumber(summary.totalQuestionCount);
      document.getElementById("generic-total-users").textContent = formatNumber(summary.totalUniqueUserCount);

      summaryEl.style.display = "grid";
      aggregateHint.textContent = `共 ${formatNumber(items.length)} 个对象`;

      if (!items.length) {
        aggregateWrap.style.display = "none";
        aggregateEmpty.style.display = "block";
        aggregateEmpty.textContent = "当前筛选条件下暂无聚合数据";
        aggregateTbody.innerHTML = "";
        return;
      }

      aggregateTbody.innerHTML = items
        .map(
          (item) => `
            <tr>
              <td><span class="generic-badge">${escapeHtml(item.subjectId)}</span></td>
              <td>${escapeHtml(item.subjectName || item.subjectId)}</td>
              <td>${formatNumber(item.callCount)}</td>
              <td>${formatNumber(item.questionCount)}</td>
              <td>${formatNumber(item.uniqueUserCount)}</td>
            </tr>
          `
        )
        .join("");

      aggregateEmpty.style.display = "none";
      aggregateWrap.style.display = "block";
    }

    async function loadEvents() {
      const filters = getFilters();
      const params = new URLSearchParams();
      if (filters.type) params.set("type", filters.type);
      if (filters.dateFrom) params.set("dateFrom", filters.dateFrom);
      if (filters.dateTo) params.set("dateTo", filters.dateTo);
      if (filters.subjectId) params.set("subjectId", filters.subjectId);
      if (filters.actorId) params.set("actorId", filters.actorId);
      params.set("page", String(state.page));
      params.set("pageSize", "20");

      const data = await fetchJson(`/api/xhunt/stats/generic-stats/events?${params.toString()}`);
      const items = Array.isArray(data.data?.items) ? data.data.items : [];
      const pagination = data.data?.pagination || {};

      state.totalPages = Number(pagination.totalPages || 1);
      eventsPageHint.textContent = `第 ${pagination.page || 1} 页 · 共 ${formatNumber(
        pagination.total || 0
      )} 条`;
      paginationText.textContent = `${pagination.page || 1} / ${state.totalPages}`;
      prevBtn.disabled = (pagination.page || 1) <= 1;
      nextBtn.disabled = (pagination.page || 1) >= state.totalPages;

      if (!items.length) {
        eventsTbody.innerHTML = "";
        eventsEmpty.style.display = "block";
        return;
      }

      eventsEmpty.style.display = "none";
      eventsTbody.innerHTML = items
        .map(
          (item) => `
            <tr>
              <td>${escapeHtml(formatDateTimeCell(item.eventAt))}</td>
              <td>
                <div class="generic-type-text">${escapeHtml(item.type)}</div>
                <div class="generic-subtext">${escapeHtml(item.source || "-")} · ${escapeHtml(item.action || "-")}</div>
              </td>
              <td>
                <div class="generic-entity-line">
                  <span class="generic-badge">${escapeHtml(item.subjectType || "-")}</span>
                  <span>${escapeHtml(item.subjectId || "-")}</span>
                </div>
                ${
                  item.subjectName
                    ? `<div class="generic-name">${escapeHtml(item.subjectName)}</div>`
                    : ""
                }
              </td>
              <td>
                <div class="generic-entity-line">
                  <span class="generic-badge">${escapeHtml(item.actorType || "-")}</span>
                  <span>${escapeHtml(item.actorId || "-")}</span>
                </div>
                ${
                  item.actorName
                    ? `<div class="generic-name">${escapeHtml(item.actorName)}</div>`
                    : ""
                }
              </td>
              <td>${formatNumber(item.countValue)}</td>
              <td>
                <div class="generic-mainline">
                  ${renderPills(item.dimensions, ["route", "isVip"])}
                </div>
                <div class="generic-subtext" style="margin-top:8px;">
                  ${renderPills(item.metrics, ["callCount", "questionCount"], "无附加指标")}
                </div>
              </td>
            </tr>
          `
        )
        .join("");
    }

    async function reloadAll() {
      try {
        setLoading(true);
        if (!state.loadedTypes) {
          await loadTypes();
        }
        await Promise.all([loadAggregate(), loadEvents()]);
      } catch (error) {
        console.error("[generic-stats] 加载失败:", error);
        alert(error.message || "加载通用统计失败");
      } finally {
        setLoading(false);
      }
    }

    function bindEvents() {
      refreshBtn?.addEventListener("click", () => {
        state.page = 1;
        reloadAll();
      });

      [typeSelect, dateFromInput, dateToInput, subjectIdInput, actorIdInput].forEach((el) => {
        el?.addEventListener("change", () => {
          state.page = 1;
          reloadAll();
        });
      });

      subjectIdInput?.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          state.page = 1;
          reloadAll();
        }
      });

      actorIdInput?.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          state.page = 1;
          reloadAll();
        }
      });

      prevBtn?.addEventListener("click", () => {
        if (state.page <= 1) return;
        state.page -= 1;
        loadEvents().catch((error) => {
          console.error("[generic-stats] 翻页失败:", error);
          alert(error.message || "翻页失败");
        });
      });

      nextBtn?.addEventListener("click", () => {
        if (state.page >= state.totalPages) return;
        state.page += 1;
        loadEvents().catch((error) => {
          console.error("[generic-stats] 翻页失败:", error);
          alert(error.message || "翻页失败");
        });
      });
    }

    function init() {
      if (state.initialized) return;
      state.initialized = true;
      setDefaultDateRange();
      bindEvents();
      reloadAll();
    }

    document.addEventListener("stats-tab-activated", function (e) {
      if (e.detail?.tabId === TAB_ID) {
        init();
      }
    });
  })();
</script>
