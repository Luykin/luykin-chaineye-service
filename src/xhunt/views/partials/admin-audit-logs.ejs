<div class="export-card">
  <div class="export-header">
    <h3>🧾 管理员操作记录</h3>
    <div class="export-actions" style="display:flex;gap:8px;align-items:center;">
      <input id="audit-email" type="text" placeholder="按邮箱筛选" style="padding:6px 10px;border:1px solid #e5e7eb;border-radius:6px;font-size:13px;width:180px;" />
      <input id="audit-action" type="text" placeholder="按动作筛选" style="padding:6px 10px;border:1px solid #e5e7eb;border-radius:6px;font-size:13px;width:180px;" />
      <button id="audit-refresh" class="btn primary">查询</button>
    </div>
  </div>
  <div class="export-result" style="margin-top:12px;">
    <div style="overflow:auto;max-height:520px;">
      <table class="simple-table">
        <thead>
          <tr>
            <th>时间</th>
            <th>邮箱</th>
            <th>动作</th>
            <th>方法</th>
            <th>路径</th>
            <th>成功</th>
            <th>信息</th>
            <th>IP</th>
          </tr>
        </thead>
        <tbody id="audit-tbody">
          <tr><td colspan="8" style="padding:12px;text-align:center;color:#6b7280;">加载中...</td></tr>
        </tbody>
      </table>
    </div>
  </div>
  <div style="margin-top:12px;display:flex;justify-content:center;align-items:center;gap:12px;">
    <button id="audit-prev" class="btn">上一页</button>
    <span id="audit-page" style="padding:8px 12px;background:#f3f4f6;border-radius:6px;font-size:14px;font-weight:600;color:#374151;">1</span>
    <button id="audit-next" class="btn">下一页</button>
  </div>
</div>

<script>
(function(){
  var page = 1;
  var limit = 50;
  function fmt(ts){ try { return new Date(ts).toLocaleString('zh-CN', { hour12: false }); } catch(e){ return ts; } }
  function load(){
    var email = document.getElementById('audit-email').value.trim();
    var action = document.getElementById('audit-action').value.trim();
    var qs = new URLSearchParams({ page: String(page), limit: String(limit) });
    if (email) qs.set('email', email);
    if (action) qs.set('action', action);
    fetch('/api/xhunt/stats/admin-audit/logs?' + qs.toString(), { credentials: 'include' })
      .then(function(r){ return r.json(); })
      .then(function(resp){
        var tb = document.getElementById('audit-tbody');
        tb.innerHTML = '';
        if (!resp.success || !Array.isArray(resp.data) || resp.data.length === 0){
          tb.innerHTML = '<tr><td colspan="8" style="padding:12px;text-align:center;color:#6b7280;">暂无数据</td></tr>';
          document.getElementById('audit-page').textContent = String(page);
          return;
        }
        resp.data.forEach(function(row){
          var tr = document.createElement('tr');
          tr.innerHTML = [
            '<td style="white-space:nowrap;">' + fmt(row.createdAt) + '</td>',
            '<td>' + (row.email || '') + '</td>',
            '<td><span style="background:#e0e7ff;color:#3730a3;padding:2px 8px;border-radius:4px;font-size:12px;font-weight:500;">' + (row.action || '') + '</span></td>',
            '<td><span style="background:#f3f4f6;color:#374151;padding:2px 8px;border-radius:4px;font-size:12px;font-weight:500;">' + (row.method || '') + '</span></td>',
            '<td style="max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="'+(row.route||'')+'">' + (row.route || '') + '</td>',
            '<td style="text-align:center;">' + (row.success ? '<span style="color:#16a34a;font-weight:600;">✅</span>' : '<span style="color:#dc2626;font-weight:600;">❌</span>') + '</td>',
            '<td style="max-width:320px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="'+(row.message||'')+'">' + (row.message || '') + '</td>',
            '<td style="font-family:monospace;font-size:12px;color:#6b7280;">' + (row.ip || '') + '</td>'
          ].join('');
          tb.appendChild(tr);
        });
        document.getElementById('audit-page').textContent = String(page);
      })
      .catch(function(err){
        console.error('[admin-audit-logs] 加载失败:', err);
        var tb = document.getElementById('audit-tbody');
        tb.innerHTML = '<tr><td colspan="8" style="padding:12px;text-align:center;color:#dc2626;">加载失败: ' + (err.message || '未知错误') + '</td></tr>';
      });
  }
  document.getElementById('audit-refresh').addEventListener('click', function(){ page = 1; load(); });
  document.getElementById('audit-email').addEventListener('keypress', function(e){ if(e.key === 'Enter'){ page = 1; load(); } });
  document.getElementById('audit-action').addEventListener('keypress', function(e){ if(e.key === 'Enter'){ page = 1; load(); } });
  document.getElementById('audit-prev').addEventListener('click', function(){ if (page>1){ page--; load(); } });
  document.getElementById('audit-next').addEventListener('click', function(){ page++; load(); });
  // 初次加载
  load();
})();
</script>
