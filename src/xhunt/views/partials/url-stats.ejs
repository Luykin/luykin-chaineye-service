    background: #fef3c7;
  }

  .url-stats-table tbody tr.rank-1:hover {
    background: #fde68a;
  }

  .url-stats-table tbody tr.rank-2 {
    background: #f3f4f6;
  }

  .url-stats-table tbody tr.rank-2:hover {
    background: #e5e7eb;
  }

  .url-stats-table tbody tr.rank-3 {
    background: #fce7f3;
  }

  .url-stats-table tbody tr.rank-3:hover {
    background: #fbcfe8;
  }
</style>

<script>
(function() {
  // 存储原始数据
  let allUrlStats = [];
  let currentSearchTerm = '';
  let originalTimeWindows = 0;

  // 加载数据
  async function loadUrlStats() {
    const timeRange = document.getElementById('url-stats-time-range').value;
    const loadingEl = document.getElementById('url-stats-loading');
    const errorEl = document.getElementById('url-stats-error');
    const tbody = document.getElementById('url-stats-tbody');
    const summaryEl = document.getElementById('url-stats-summary');

    loadingEl.style.display = 'block';
    errorEl.style.display = 'none';
    summaryEl.style.display = 'none';
    tbody.innerHTML = '<tr><td colspan="4" class="empty-message">加载中...</td></tr>';

    try {
      const response = await fetch(`/api/xhunt/stats/url-stats?timeRange=${timeRange}`, {
        credentials: 'include'
      });

      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }

      const data = await response.json();

      if (!data.success) {
        throw new Error(data.error || '加载失败');
      }

      // 保存原始数据
      allUrlStats = data.data.urlStats || [];
      originalTimeWindows = data.data.timeWindows || 0;

      // 应用搜索过滤
      applySearchFilter();

      loadingEl.style.display = 'none';
    } catch (error) {
      console.error('加载URL统计失败:', error);
      loadingEl.style.display = 'none';
      errorEl.textContent = '加载失败: ' + error.message;
      errorEl.style.display = 'block';
      tbody.innerHTML = '<tr><td colspan="4" class="empty-message">加载失败</td></tr>';
    }
  }

  // 应用搜索过滤
  function applySearchFilter() {
    const tbody = document.getElementById('url-stats-tbody');
    const summaryEl = document.getElementById('url-stats-summary');
    const clearBtn = document.getElementById('url-stats-clear-search');

    // 过滤数据
    let filteredStats = allUrlStats;
    if (currentSearchTerm && currentSearchTerm.trim() !== '') {
      const searchLower = currentSearchTerm.toLowerCase().trim();
      filteredStats = allUrlStats.filter(item => 
        item.urlPath.toLowerCase().includes(searchLower)
      );
    }

    // 计算过滤后的统计信息
    const totalRequests = filteredStats.reduce((sum, item) => sum + item.count, 0);
    const totalUrls = filteredStats.length;

    // 更新统计摘要
    document.getElementById('total-requests').textContent = formatNumber(totalRequests);
    document.getElementById('total-urls').textContent = formatNumber(totalUrls);
    document.getElementById('time-windows').textContent = formatNumber(originalTimeWindows);
    summaryEl.style.display = 'flex';

    // 显示/隐藏清除按钮
    if (currentSearchTerm && currentSearchTerm.trim() !== '') {
      clearBtn.style.display = 'inline-block';
    } else {
      clearBtn.style.display = 'none';
    }

    // 更新表格
    if (filteredStats.length > 0) {
      tbody.innerHTML = filteredStats.map((item, index) => {
        const rank = index + 1;
        const rankClass = rank <= 3 ? `rank-${rank}` : '';
        // 高亮搜索关键词
        const highlightedUrl = highlightSearchTerm(item.urlPath, currentSearchTerm);
        return `
          <tr class="${rankClass}">
            <td class="rank-col">${rank}</td>
            <td class="url-col">${highlightedUrl}</td>
            <td class="count-col">${formatNumber(item.count)}</td>
            <td class="percent-col">${item.percent}%</td>
          </tr>
        `;
      }).join('');
    } else {
      if (currentSearchTerm && currentSearchTerm.trim() !== '') {
        tbody.innerHTML = '<tr><td colspan="4" class="empty-message">未找到匹配的接口路径</td></tr>';
      } else {
        tbody.innerHTML = '<tr><td colspan="4" class="empty-message">暂无数据</td></tr>';
      }
    }
  }

  // 高亮搜索关键词
  function highlightSearchTerm(text, searchTerm) {
    if (!searchTerm || searchTerm.trim() === '') {
      return escapeHtml(text);
    }
    
    const escapedText = escapeHtml(text);
    const escapedSearch = escapeHtml(searchTerm);
    const regex = new RegExp(`(${escapedSearch.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
    
    return escapedText.replace(regex, '<mark style="background: #fef08a; padding: 2px 0;">$1</mark>');
  }


  // 格式化数字（添加千分位分隔符）
  function formatNumber(num) {
    if (num === null || num === undefined || isNaN(num)) {
      return '0';
    }
    return num.toLocaleString();
  }

  // HTML转义
  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // 绑定事件
  document.addEventListener('DOMContentLoaded', function() {
    const timeRangeSelect = document.getElementById('url-stats-time-range');
    const refreshBtn = document.getElementById('url-stats-refresh');
    const searchInput = document.getElementById('url-stats-search');
    const searchBtn = document.getElementById('url-stats-search-btn');
    const clearBtn = document.getElementById('url-stats-clear-search');

    if (timeRangeSelect) {
      timeRangeSelect.addEventListener('change', function() {
        // 切换时间范围时清除搜索
        currentSearchTerm = '';
        if (searchInput) searchInput.value = '';
        if (clearBtn) clearBtn.style.display = 'none';
        loadUrlStats();
      });
    }

    if (refreshBtn) {
      refreshBtn.addEventListener('click', loadUrlStats);
    }

    if (searchInput) {
      // 支持回车搜索
      searchInput.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
          e.preventDefault();
          performSearch();
        }
      });
    }

    if (searchBtn) {
      searchBtn.addEventListener('click', performSearch);
    }

    if (clearBtn) {
      clearBtn.addEventListener('click', function() {
        currentSearchTerm = '';
        if (searchInput) searchInput.value = '';
        clearBtn.style.display = 'none';
        applySearchFilter();
      });
    }

    // 延迟加载数据
    setTimeout(loadUrlStats, 500);
  });

  // 执行搜索
  function performSearch() {
    const searchInput = document.getElementById('url-stats-search');
    if (searchInput) {
      currentSearchTerm = searchInput.value;
      applySearchFilter();
    }
  }

  // 监听 tab 切换事件
  document.addEventListener('click', function(e) {
    const tabBtn = e.target.closest('.tab-btn');
    if (tabBtn && tabBtn.getAttribute('data-tab') === 'url-stats') {
      // 延迟一点加载，确保 tab 已经切换完成
      setTimeout(loadUrlStats, 100);
    }
  });
})();
</script>

