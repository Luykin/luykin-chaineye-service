<div class="url-stats-container">
  <div class="url-stats-header">
    <h2>🔗 接口请求统计</h2>
    <p>查看各接口在不同时间段的请求排行榜</p>
  </div>

  <!-- 时间范围选择 -->
  <div class="time-range-selector">
    <label>时间范围：</label>
    <select id="url-stats-time-range" class="time-range-select">
      <option value="30m">最近30分钟</option>
      <option value="1h">最近1小时</option>
      <option value="2h">最近2小时</option>
      <option value="4h">最近4小时</option>
      <option value="1d">最近1天</option>
      <option value="2d">最近2天</option>
    </select>
    <button id="url-stats-refresh" class="btn-refresh">🔄 刷新</button>
  </div>

  <!-- 搜索框 -->
  <div class="search-container">
    <label for="url-stats-search">搜索接口路径：</label>
    <input 
      type="text" 
      id="url-stats-search" 
      class="search-input" 
      placeholder="例如：/me 或 /api/xhunt/proxy"
    />
    <button id="url-stats-search-btn" class="btn-search">🔍 搜索</button>
    <button id="url-stats-clear-search" class="btn-clear" style="display: none;">清除</button>
  </div>

  <!-- 统计摘要 -->
  <div id="url-stats-summary" class="stats-summary" style="display: none;">
    <div class="summary-item">
      <span class="summary-label">总请求数：</span>
      <span class="summary-value" id="total-requests">0</span>
    </div>
    <div class="summary-item">
      <span class="summary-label">接口数量：</span>
      <span class="summary-value" id="total-urls">0</span>
    </div>
    <div class="summary-item">
      <span class="summary-label">时间窗口数：</span>
      <span class="summary-value" id="time-windows">0</span>
    </div>
  </div>

  <!-- 排行榜表格 -->
  <div class="url-stats-table-container">
    <table id="url-stats-table" class="url-stats-table">
      <thead>
        <tr>
          <th class="rank-col">排名</th>
          <th class="url-col">接口路径</th>
          <th class="count-col">请求数量</th>
          <th class="percent-col">占比</th>
        </tr>
      </thead>
      <tbody id="url-stats-tbody">
        <tr>
          <td colspan="4" class="empty-message">加载中...</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- 加载状态 -->
  <div id="url-stats-loading" class="loading-message" style="display: none;">
    加载中...
  </div>

  <!-- 错误消息 -->
  <div id="url-stats-error" class="error-message" style="display: none;"></div>
</div>

<style>
  .url-stats-container {
    padding: 20px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .url-stats-header {
    margin-bottom: 20px;
  }

  .url-stats-header h2 {
    color: #2c3e50;
    margin-bottom: 8px;
  }

  .url-stats-header p {
    color: #7f8c8d;
    font-size: 14px;
  }

  .time-range-selector {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    padding: 15px;
    background: #f8f9fa;
    border-radius: 8px;
  }

  .time-range-selector label {
    font-weight: 600;
    color: #374151;
  }

  .time-range-select {
    padding: 8px 12px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 14px;
    background: white;
    cursor: pointer;
  }

  .time-range-select:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }

  .btn-refresh {
    padding: 8px 16px;
    background: #3b82f6;
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 14px;
    cursor: pointer;
    transition: background 0.2s;
  }

  .btn-refresh:hover {
    background: #2563eb;
  }

  .search-container {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    padding: 15px;
    background: #f8f9fa;
    border-radius: 8px;
  }

  .search-container label {
    font-weight: 600;
    color: #374151;
    white-space: nowrap;
  }

  .search-input {
    flex: 1;
    padding: 8px 12px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 14px;
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
  }

  .search-input:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }

  .btn-search {
    padding: 8px 16px;
    background: #10b981;
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 14px;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
  }

  .btn-search:hover {
    background: #059669;
  }

  .btn-clear {
    padding: 8px 16px;
    background: #6b7280;
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 14px;
    cursor: pointer;
