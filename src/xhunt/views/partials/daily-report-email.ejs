<div class="export-card">
  <div class="export-header">
    <h3>📧 日报邮件配置</h3>
    <div class="export-actions">
      <button id="dr-send" class="btn primary">手动发送一次</button>
    </div>
  </div>
  <div class="export-result" style="margin-top:12px;">
    <table class="simple-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>邮箱</th>
          <th>是否接收日报</th>
          <th>角色</th>
          <th>状态</th>
        </tr>
      </thead>
      <tbody id="dr-tbody"></tbody>
    </table>
  </div>
  <div id="dr-status" style="margin-top:12px;padding:8px 12px;border-radius:6px;font-size:13px;display:none;"></div>
</div>

<script>
(async function(){
  const tbody = document.getElementById('dr-tbody');
  const statusEl = document.getElementById('dr-status');
  const sendBtn = document.getElementById('dr-send');

  function setStatus(msg, ok=true){
    statusEl.textContent = msg;
    statusEl.style.display = 'block';
    statusEl.style.background = ok ? '#d1fae5' : '#fee2e2';
    statusEl.style.color = ok ? '#065f46' : '#991b1b';
    statusEl.style.border = `1px solid ${ok ? '#a7f3d0' : '#fecaca'}`;
    if(ok){
      setTimeout(() => { statusEl.style.display = 'none'; }, 3000);
    }
  }

  async function loadList(){
    tbody.innerHTML = '<tr><td colspan="5" style="padding:12px;text-align:center;color:#6b7280;">加载中...</td></tr>';
    try{
      const res = await fetch('/admin/users', { credentials: 'include' });
      const data = await res.json();
      if(!data.success){ throw new Error(data.error||'加载失败'); }
      const list = data.data||[];
      if(list.length===0){
        tbody.innerHTML = '<tr><td colspan="5" style="padding:12px;text-align:center;color:#6b7280;">暂无收件人</td></tr>';
        return;
      }
      tbody.innerHTML = '';
      list.forEach(item=>{
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>${item.id}</td>
          <td>${item.email}</td>
          <td>
            <input type="checkbox" ${item.receivesDailyReport?'checked':''} data-id="${item.id}" class="dr-toggle" style="cursor:pointer;" />
          </td>
          <td>${item.role}</td>
          <td>${item.isActive && item.canLogin ? '✅ 可登录' : '❌ 禁用'}</td>`;
        tbody.appendChild(tr);
      });
    }catch(e){
      console.error('[daily-report-email] 加载失败:', e);
      tbody.innerHTML = '<tr><td colspan="5" style="padding:12px;text-align:center;color:#dc2626;">加载失败: ' + (e.message || '未知错误') + '</td></tr>';
    }
  }

  tbody.addEventListener('change', async (ev)=>{
    const t = ev.target;
    if(t && t.classList.contains('dr-toggle')){
      const id = t.getAttribute('data-id');
      const enabled = !!t.checked;
      try{
        const res = await fetch(`/admin/users/${id}`,{
          method:'PATCH',
          headers:{ 'Content-Type':'application/json' },
          body: JSON.stringify({ receivesDailyReport: enabled })
        });
        const data = await res.json();
        if(!data.success){ throw new Error(data.error||'更新失败'); }
        setStatus('状态已更新');
      }catch(e){ setStatus(e.message||'更新失败', false); }
    }
  });

  sendBtn.addEventListener('click', async function(){
    setStatus('正在触发发送...');
    try{
      const res = await fetch('/api/xhunt/stats/report/send',{
        method:'POST',
        headers:{ 'Content-Type':'application/json' },
        credentials: 'include',
        body: JSON.stringify({})
      });
      const data = await res.json();
      if(!data.success){ throw new Error(data.error||'发送失败'); }
      setStatus('已触发发送');
    }catch(e){ setStatus(e.message||'发送失败', false); }
  });

  loadList();
})();
</script>
