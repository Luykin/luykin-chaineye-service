<!-- 内置标签配置（Nacos） -->
<div class="tags-container">
  <div class="tags-header">
    <h2>内置标签配置</h2>
    <p class="tags-subtitle">可视化编辑 Nacos 配置：xhunt_built_in_tag / xhunt_built_in_tag_en</p>
  </div>

  <div class="tags-toolbar">
    <div class="toolbar-left">
      <div class="lang-tabs">
        <button class="lang-tab active" id="tags-lang-zh" data-lang="zh">中文</button>
        <button class="lang-tab" id="tags-lang-en" data-lang="en">English</button>
      </div>
      <span class="muted">dataId: <code id="tags-dataid">xhunt_built_in_tag</code></span>
      <span class="muted">group: <code>DEFAULT_GROUP</code></span>
    </div>
    <div class="toolbar-right">
      <button class="btn" id="tags-refresh">刷新</button>
      <button class="btn" id="tags-new">新增 Handle</button>
      <button class="btn danger" id="tags-delete" disabled>删除</button>
      <button class="btn success" id="tags-publish" disabled>发布</button>
    </div>
  </div>

  <div class="tags-body">
    <!-- 左侧列表 -->
    <div class="tags-panel tags-panel-list">
      <div class="panel-header">
        <div class="list-search">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" id="tags-search" placeholder="搜索 handle..." />
        </div>
        <span class="count-badge" id="tags-count">0</span>
      </div>
      <div class="list-items" id="tags-list">
        <div class="empty-state">暂无数据，点击「新增 Handle」创建</div>
      </div>
    </div>

    <!-- 右侧编辑器 -->
    <div class="tags-panel tags-panel-editor">
      <div class="panel-header">
        <span>编辑标签</span>
        <span class="editor-hint" id="tags-editor-hint">选择左侧 handle 开始编辑</span>
      </div>
      <div id="tags-editor-empty" class="editor-empty">
        <div class="empty-title">请选择一个 Handle</div>
        <div class="empty-desc">从左侧列表选择，或点击「新增 Handle」创建</div>
      </div>
      <div id="tags-editor-body" style="display: none;">
        <div class="field-row">
          <div class="field">
            <label>Handle（推特账号，不带 @）</label>
            <input type="text" id="tags-handle" placeholder="例如：anishagnihotri" />
          </div>
        </div>
        <div class="field-row">
          <div class="field">
            <label>标签列表</label>
            <div class="tags-list-editor" id="tags-list-editor">
              <!-- 动态渲染标签输入行 -->
            </div>
            <button class="btn btn-sm" id="tags-add-tag" type="button">+ 添加标签</button>
          </div>
        </div>
        <div class="preview-section">
          <div class="preview-header">JSON 预览</div>
          <pre class="preview-pre" id="tags-preview"></pre>
        </div>
      </div>
    </div>
  </div>

  <div class="tags-toast" id="tags-toast" style="display: none;"></div>
</div>

<!-- JSON 发布预览模态框 -->
<div class="json-preview-modal-overlay" id="tags-json-modal" style="display: none;">
  <div class="json-preview-modal-panel">
    <div class="json-preview-modal-header">
      <h3>预览 JSON 配置</h3>
      <button class="close-btn" id="tags-json-modal-close" type="button">&times;</button>
    </div>
    <div class="json-preview-modal-body">
      <p class="json-preview-legend">
        即将发布到 Nacos（dataId: <code id="tags-json-modal-dataid">-</code>）
        <span id="tags-json-modal-diff" style="margin-left: 8px; color: #3b82f6; font-weight: 600;"></span>
        <span class="legend-removed">删除</span> | <span class="legend-added">新增</span>
      </p>
      <pre id="tags-json-modal-content"></pre>
    </div>
    <div class="json-preview-modal-footer">
      <button class="btn" id="tags-json-modal-cancel" type="button">取消</button>
      <button class="btn primary" id="tags-json-modal-confirm" type="button">确认发布</button>
    </div>
  </div>
</div>

<style>
