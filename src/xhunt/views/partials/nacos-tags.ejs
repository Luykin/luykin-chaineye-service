<script src="/static/js/diff.min.js"></script>
<script>
(function () {
  let inited = false;
  const DATA_IDS = { zh: "xhunt_built_in_tag", en: "xhunt_built_in_tag_en" };
  const GROUP = "DEFAULT_GROUP";

  let currentLang = "zh";
  let currentHandle = null; // string | null
  let config = {}; // { handle: [tag1, tag2] }
  let originalConfig = null;
  let dirty = false;
  let search = "";

  function $(id) { return document.getElementById(id); }

  function toast(msg, type) {
    const el = $("tags-toast");
    if (!el) return;
    el.textContent = msg;
    el.style.display = "block";
    el.style.background = type === "error" ? "#991b1b" : type === "success" ? "#065f46" : "#111827";
    setTimeout(() => { el.style.display = "none"; }, 2400);
  }

  function escapeHtml(s) {
    const div = document.createElement("div");
    div.textContent = s == null ? "" : String(s);
    return div.innerHTML;
  }

  async function apiGetConfig(dataId) {
    const resp = await fetch(`/api/xhunt/stats/nacos/config?dataId=${encodeURIComponent(dataId)}&group=${encodeURIComponent(GROUP)}`, {
      credentials: "include", headers: { Accept: "application/json" },
    });
    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
    const json = await resp.json();
    if (!json.success) throw new Error(json.error || "加载失败");
    return json.data;
  }

  async function apiPublishConfig({ dataId, content }) {
    const resp = await fetch(`/api/xhunt/stats/nacos/config`, {
      method: "POST", credentials: "include",
      headers: { "Content-Type": "application/json", Accept: "application/json" },
      body: JSON.stringify({ dataId, group: GROUP, content, type: "json", source: "nacos-tags" }),
    });
    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
    const json = await resp.json();
    if (!json.success) throw new Error(json.error || "发布失败");
    return json.data;
  }

  function getSortedEntries() {
    const entries = Object.entries(config);
    const q = String(search || "").trim().toLowerCase();
    const filtered = q ? entries.filter(([handle]) => handle.toLowerCase().includes(q)) : entries;
    return filtered.sort((a, b) => a[0].localeCompare(b[0]));
  }

  function renderList() {
    const listEl = $("tags-list");
    const countEl = $("tags-count");
    if (!listEl) return;
    const entries = getSortedEntries();
    listEl.innerHTML = entries.map(([handle, tags]) => {
      const active = handle === currentHandle ? "active" : "";
      const tagList = Array.isArray(tags) ? tags : [];
      const tagPreview = tagList.slice(0, 3).join("、") + (tagList.length > 3 ? ` ...` : "");
      return `
        <div class="item ${active}" data-handle="${escapeHtml(handle)}">
          <span class="item-tag-count">${tagList.length}</span>
          <div style="min-width:0;">
            <div class="item-handle">${escapeHtml(handle)}</div>
            <div class="item-tags">${escapeHtml(tagPreview || "无标签")}</div>
          </div>
        </div>
      `;
    }).join("") || `<div class="empty-state">暂无数据，点击「新增 Handle」创建</div>`;
    if (countEl) countEl.textContent = String(entries.length);
    listEl.querySelectorAll(".item").forEach(node => {
      node.addEventListener("click", () => {
        selectHandle(node.getAttribute("data-handle"));
      });
    });
  }

  function renderTagInputs() {
    const container = $("tags-list-editor");
    if (!container) return;
    const tags = Array.isArray(config[currentHandle]) ? config[currentHandle] : [];
    container.innerHTML = tags.map((tag, idx) => `
      <div class="tag-input-row" data-idx="${idx}">
        <input type="text" value="${escapeHtml(tag)}" placeholder="输入标签内容..." />
        <button class="btn" type="button" data-action="remove">删除</button>
      </div>
    `).join("");
    container.querySelectorAll('.tag-input-row input').forEach(input => {
      input.addEventListener('input', syncToModel);
    });
    container.querySelectorAll('.tag-input-row button[data-action="remove"]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const row = e.target.closest('.tag-input-row');
        const idx = Number(row.getAttribute('data-idx'));
        if (Array.isArray(config[currentHandle])) {
          config[currentHandle].splice(idx, 1);
          dirty = true;
          renderTagInputs();
          renderPreview();
          renderList();
        }
      });
    });
  }

  function renderPreview() {
    const pre = $("tags-preview");
    if (!pre) return;
    if (!currentHandle) { pre.textContent = ""; return; }
    const payload = {};
    if (config[currentHandle]) payload[currentHandle] = config[currentHandle];
    pre.textContent = JSON.stringify(payload, null, 2);
  }

  function syncToModel() {
    if (!currentHandle) return;
    const rows = $("tags-list-editor").querySelectorAll('.tag-input-row');
    const tags = [];
    rows.forEach(row => {
      const val = row.querySelector('input').value.trim();
      if (val) tags.push(val);
    });
    // 如果 handle 改了
    const newHandle = $("tags-handle").value.trim();
    if (newHandle && newHandle !== currentHandle) {
      const oldTags = config[currentHandle];
      delete config[currentHandle];
      config[newHandle] = tags;
      currentHandle = newHandle;
    } else {
      config[currentHandle] = tags;
    }
    dirty = true;
    renderPreview();
    renderList();
  }

  function selectHandle(handle) {
    currentHandle = handle;
    const exists = handle && Object.prototype.hasOwnProperty.call(config, handle);
    const emptyEl = $("tags-editor-empty");
    const bodyEl = $("tags-editor-body");
    if (!exists) {
      if (emptyEl) emptyEl.style.display = "block";
      if (bodyEl) bodyEl.style.display = "none";
      $("tags-delete").disabled = true;
      $("tags-publish").disabled = !dirty;
      $("tags-editor-hint").textContent = "选择左侧 handle 开始编辑";
      renderList();
      return;
    }
    if (emptyEl) emptyEl.style.display = "none";
    if (bodyEl) bodyEl.style.display = "block";
    $("tags-handle").value = handle;
    $("tags-delete").disabled = false;
    $("tags-publish").disabled = !dirty;
    $("tags-editor-hint").textContent = `正在编辑: ${handle}`;
    renderTagInputs();
    renderPreview();
    renderList();
  }

  function switchLang(lang) {
    currentLang = lang;
    currentHandle = null;
    config = {};
    originalConfig = null;
    dirty = false;
    search = "";
    $("tags-dataid").textContent = DATA_IDS[lang];
    $("tags-lang-zh").classList.toggle("active", lang === "zh");
    $("tags-lang-en").classList.toggle("active", lang === "en");
    $("tags-search").value = "";
    selectHandle(null);
    loadConfig();
  }

  async function loadConfig() {
    try {
      const data = await apiGetConfig(DATA_IDS[currentLang]);
      if (data && data.content) {
        const parsed = JSON.parse(data.content);
        config = parsed && typeof parsed === "object" && !Array.isArray(parsed) ? parsed : {};
        originalConfig = JSON.parse(JSON.stringify(config));
      } else {
        config = {}; originalConfig = {};
      }
      dirty = false;
      renderList();
      $("tags-publish").disabled = true;
    } catch (e) {
      toast("加载配置失败: " + (e.message || ""), "error");
      config = {}; originalConfig = {};
      renderList();
    }
  }

  function newHandle() {
    let idx = 1;
    let newHandle = `_new_handle_${idx}`;
    while (Object.prototype.hasOwnProperty.call(config, newHandle)) {
      idx++;
      newHandle = `_new_handle_${idx}`;
    }
    config[newHandle] = [];
    dirty = true;
    renderList();
    selectHandle(newHandle);
    // 高亮输入框
    setTimeout(() => { $("tags-handle").focus(); $("tags-handle").select(); }, 50);
  }

  function deleteCurrent() {
    if (!currentHandle || !Object.prototype.hasOwnProperty.call(config, currentHandle)) return;
    if (!confirm(`确定删除 handle "${currentHandle}"？`)) return;
    delete config[currentHandle];
    dirty = true;
    const nextEntries = getSortedEntries();
    const nextHandle = nextEntries.length > 0 ? nextEntries[0][0] : null;
    selectHandle(nextHandle);
    toast("已删除，记得点击发布", "success");
  }

  function showPublishPreview() {
    const modal = $("tags-json-modal");
    const pre = $("tags-json-modal-content");
    const dataidEl = $("tags-json-modal-dataid");
    const diffEl = $("tags-json-modal-diff");
    if (!modal || !pre) return;
    dataidEl.textContent = DATA_IDS[currentLang];
    const newJson = JSON.stringify(config, null, 2);
    const oldJson = JSON.stringify(originalConfig || {}, null, 2);
    if (oldJson === newJson) {
      diffEl.textContent = "（无变更）";
      pre.textContent = newJson;
    } else {
      const oldKeys = Object.keys(originalConfig || {});
      const newKeys = Object.keys(config);
      const added = newKeys.filter(k => !oldKeys.includes(k)).length;
      const removed = oldKeys.filter(k => !newKeys.includes(k)).length;
      const parts = [];
      if (added) parts.push(`+${added} handle`);
      if (removed) parts.push(`-${removed} handle`);
      diffEl.textContent = parts.length ? `（${parts.join("，")}）` : "（有变更）";
      const diffHtml = Diff.createPatch("config.json", oldJson, newJson, "原始", "新");
      const lines = diffHtml.split("\n").slice(4);
      const formatted = lines.map(line => {
        if (line.startsWith("+")) return `<span class="added">${escapeHtml(line)}</span>`;
        if (line.startsWith("-")) return `<span class="removed">${escapeHtml(line)}</span>`;
        return escapeHtml(line);
      }).join("\n");
      pre.innerHTML = formatted;
    }
    modal.style.display = "flex";
  }

  async function doPublish() {
    try {
      await apiPublishConfig({ dataId: DATA_IDS[currentLang], content: JSON.stringify(config) });
      originalConfig = JSON.parse(JSON.stringify(config));
      dirty = false;
      toast("发布成功", "success");
      $("tags-json-modal").style.display = "none";
      $("tags-publish").disabled = true;
    } catch (e) {
      toast("发布失败: " + (e.message || ""), "error");
    }
  }

  function init() {
    if (inited) return;
    inited = true;
    loadConfig();

    $("tags-lang-zh").addEventListener("click", () => switchLang("zh"));
    $("tags-lang-en").addEventListener("click", () => switchLang("en"));
    $("tags-refresh").addEventListener("click", loadConfig);
    $("tags-new").addEventListener("click", newHandle);
    $("tags-delete").addEventListener("click", deleteCurrent);
    $("tags-publish").addEventListener("click", showPublishPreview);
    $("tags-handle").addEventListener("input", syncToModel);
    $("tags-add-tag").addEventListener("click", () => {
      if (!currentHandle) return;
      if (!Array.isArray(config[currentHandle])) config[currentHandle] = [];
      config[currentHandle].push("");
      dirty = true;
      renderTagInputs();
      renderPreview();
      renderList();
      // focus 最后一个
      const inputs = $("tags-list-editor").querySelectorAll('input');
      if (inputs.length) { setTimeout(() => { inputs[inputs.length - 1].focus(); }, 50); }
    });
    $("tags-search").addEventListener("input", (e) => {
      search = e.target.value;
      renderList();
    });
    // modal
    $("tags-json-modal-close").addEventListener("click", () => { $("tags-json-modal").style.display = "none"; });
    $("tags-json-modal-cancel").addEventListener("click", () => { $("tags-json-modal").style.display = "none"; });
    $("tags-json-modal-confirm").addEventListener("click", doPublish);
  }

  document.addEventListener("stats-tab-activated", function (e) {
    if (e.detail && e.detail.tabId === "nacos-tags") init();
  });
})();
</script>
