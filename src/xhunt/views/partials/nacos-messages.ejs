<script>
  (function () {
    // 仅在 tab 被点击后再初始化
    let inited = false;

    const DATA_IDS = {
      zh: "xhunt_message",
      en: "xhunt_message_en",
    };

    let currentLang = "zh";
    let currentIndex = -1;
    let items = []; // 当前语言的公告数组
    let dirty = false;

    // editor impl
    let editorMode = null; // 'quill' | 'fallback'
    let quill = null;

    const DEFAULT_FOOTER_HTML = `<br>请加入我们的<a href='https://t.me/xhunt_ai' target='_blank' style='color:rgb(29, 155, 240)'>电报群</a>获取最新资讯。`;

    function $(id) {
      return document.getElementById(id);
    }

    function toast(msg, type) {
      const el = $("nacos-msg-toast");
      if (!el) return;
      el.textContent = msg;
      el.style.display = "block";
      el.style.background =
        type === "error"
          ? "#991b1b"
          : type === "success"
          ? "#065f46"
          : "#111827";
      setTimeout(() => {
        el.style.display = "none";
      }, 2400);
    }

    function fmtTs(ts) {
      const n = Number(ts);
      if (!n) return "-";
      try {
        return new Date(n).toLocaleString("zh-CN", {
          timeZone: "Asia/Shanghai",
        });
      } catch (e) {
        return String(ts);
      }
    }

    function escapeHtml(s) {
      const div = document.createElement("div");
      div.textContent = s == null ? "" : String(s);
      return div.innerHTML;
    }

    function isEditorEnabled() {
      return currentIndex >= 0 && !!items[currentIndex];
    }

    function getEditorHtml() {
      if (editorMode === "quill" && quill) {
        return quill.root.innerHTML || "";
      }
      return $("nacos-msg-content-fallback").innerHTML || "";
    }

    function setEditorHtml(html) {
      const value = html || "";
      if (editorMode === "quill" && quill) {
        // Quill 内部更喜欢 delta，但也支持 pasteHTML
        quill.clipboard.dangerouslyPasteHTML(value);
        return;
      }
      $("nacos-msg-content-fallback").innerHTML = value;
    }

    function setEditorEnabled(enabled) {
      if (editorMode === "quill" && quill) {
        quill.enable(!!enabled);
        // 工具栏显示/隐藏
        $("nacos-quill-toolbar").style.display = enabled ? "block" : "none";
        $("nacos-msg-content").style.display = enabled ? "block" : "none";
        $("nacos-rte-toolbar").style.display = "none";
        $("nacos-msg-content-fallback").style.display = "none";
        return;
      }

      // fallback
      $("nacos-rte-toolbar").style.display = "flex";
      $("nacos-msg-content-fallback").style.display = "block";
      $("nacos-quill-toolbar").style.display = "none";
      $("nacos-msg-content").style.display = "none";

      const editor = $("nacos-msg-content-fallback");
      editor.setAttribute("contenteditable", enabled ? "true" : "false");

      [
        "nacos-rte-bold",
        "nacos-rte-italic",
        "nacos-rte-underline",
        "nacos-rte-br",
        "nacos-rte-link",
        "nacos-rte-unlink",
      ].forEach((id) => {
        const btn = $(id);
        if (btn) btn.disabled = !enabled;
      });
    }

    function setControlsEnabled(enabled) {
      $("nacos-msg-title").disabled = !enabled;
      $("nacos-msg-delete").disabled = !enabled;
      $("nacos-msg-publish").disabled = !enabled;
      setEditorEnabled(enabled);
    }

    function syncToModel() {
      if (!isEditorEnabled()) return;
      const titleEl = $("nacos-msg-title");
      const html = getEditorHtml();
      items[currentIndex] = {
        ...items[currentIndex],
        title: titleEl.value,
        content: html,
      };
      $("nacos-msg-preview").innerHTML = html || "";
      dirty = true;
      renderList();
    }

    function renderList() {
      const listEl = $("nacos-msg-list");
      const countEl = $("nacos-msg-count");
      if (!listEl) return;

      // created 倒序
      const sorted = [...items].sort(
        (a, b) => Number(b.created || 0) - Number(a.created || 0)
      );

      listEl.innerHTML =
        sorted
          .map((it) => {
            // idx 是排序后的索引；我们需要映射回原数组索引
            const originalIndex = items.indexOf(it);
            const active = originalIndex === currentIndex ? "active" : "";
            return `
        <div class="item ${active}" data-idx="${originalIndex}">
          <div class="item-title">${escapeHtml(it.title || "(无标题)")}</div>
          <div class="item-meta">created: ${escapeHtml(
            String(it.created || "")
          )} · ${escapeHtml(fmtTs(it.created))}</div>
        </div>
      `;
          })
          .join("") ||
        `<div style="padding:14px;color:#9ca3af;">暂无公告，点击“新增公告”创建</div>`;

      if (countEl) countEl.textContent = `${items.length} 条`;

      // bind click
      listEl.querySelectorAll(".item").forEach((node) => {
        node.addEventListener("click", () => {
          const idx = Number(node.getAttribute("data-idx"));
          selectItem(idx);
        });
      });
    }

    function selectItem(idx) {
      currentIndex = idx;
      const it = items[idx];
      if (!it) {
        setControlsEnabled(false);
        $("nacos-msg-title").value = "";
        setEditorHtml("");
        $("nacos-msg-preview").innerHTML = "";
        $("nacos-msg-editor-hint").textContent = "选择左侧一条公告开始编辑";
        renderList();
        return;
      }

      setControlsEnabled(true);
      $("nacos-msg-title").value = it.title || "";
      setEditorHtml(it.content || "");
      $("nacos-msg-preview").innerHTML = it.content || "";
      $("nacos-msg-editor-hint").textContent = `正在编辑：created=${
        it.created || ""
      }`;
      renderList();
    }

    function initEditor() {
      // 优先使用 Quill（CDN），失败则 fallback
      if (window.Quill) {
        editorMode = "quill";

        // 构建 quill toolbar
        const toolbarEl = $("nacos-quill-toolbar");
        toolbarEl.innerHTML = `
          <span class="ql-formats">
            <button class="ql-bold"></button>
            <button class="ql-italic"></button>
            <button class="ql-underline"></button>
          </span>
          <span class="ql-formats">
            <button class="ql-link"></button>
          </span>
          <span class="ql-formats">
            <button class="ql-clean"></button>
          </span>
        `;

        quill = new window.Quill("#nacos-msg-content", {
          theme: "snow",
          modules: {
            toolbar: "#nacos-quill-toolbar",
            // 使用 Quill 官方 clipboard matcher 更好地把粘贴的 HTML 转换成 Delta
            clipboard: {
              matchVisual: false,
            },
          },
        });

        quill.on("text-change", () => {
          syncToModel();
        });

        // 支持：直接粘贴 HTML 源码（例如粘贴包含 <br><a> 的字符串）
        // 默认 Quill 会把这类字符串当纯文本，我们在粘贴事件中检测是否像 HTML，若是则用 dangerouslyPasteHTML 解析插入。
        const root = quill.root;
        root.addEventListener("paste", (e) => {
          try {
            const cd = e.clipboardData;
            if (!cd) return;
            const html = cd.getData("text/html");
            const text = cd.getData("text/plain");

            // 两种情况：
            // 1) 系统剪贴板本身带 text/html（最理想） -> 直接 pasteHTML
            // 2) 用户复制的是 HTML 源码字符串（只有 text/plain，但包含 <tag>） -> 也按 HTML 处理
            const looksLikeHtml = (s) =>
              typeof s === "string" && /<\/?[a-z][\s\S]*>/i.test(s);

            const toInsert =
              html && html.trim() ? html : looksLikeHtml(text) ? text : "";
            if (!toInsert) return; // 交给 Quill 默认处理

            e.preventDefault();

            const range = quill.getSelection(true) || {
              index: quill.getLength(),
              length: 0,
            };
            quill.clipboard.dangerouslyPasteHTML(range.index, toInsert, "user");
            quill.setSelection(range.index + 1, 0, "silent");
          } catch (err) {
            // 失败就让 Quill 默认处理
          }
        });

        // 默认隐藏，等选中条目再显示
        $("nacos-quill-toolbar").style.display = "none";
        $("nacos-msg-content").style.display = "none";
        $("nacos-rte-toolbar").style.display = "none";
        $("nacos-msg-content-fallback").style.display = "none";

        return;
      }

      // fallback
      editorMode = "fallback";
      $("nacos-rte-toolbar").style.display = "flex";
      $("nacos-msg-content-fallback").style.display = "block";
      $("nacos-quill-toolbar").style.display = "none";
      $("nacos-msg-content").style.display = "none";

      const titleEl = $("nacos-msg-title");
      const editorEl = $("nacos-msg-content-fallback");

      titleEl.addEventListener("input", syncToModel);
      editorEl.addEventListener("input", syncToModel);
      editorEl.addEventListener("paste", () => setTimeout(syncToModel, 0));

      function cmd(command, value) {
        editorEl.focus();
        document.execCommand(command, false, value);
        syncToModel();
      }

      $("nacos-rte-bold").addEventListener("click", () => cmd("bold"));
      $("nacos-rte-italic").addEventListener("click", () => cmd("italic"));
      $("nacos-rte-underline").addEventListener("click", () =>
        cmd("underline")
      );
      $("nacos-rte-br").addEventListener("click", () =>
        cmd("insertHTML", "<br>")
      );
      $("nacos-rte-link").addEventListener("click", () => {
        const url = window.prompt(
          "请输入链接 URL（例如：https://t.me/xhunt_ai）"
        );
        if (!url) return;
        cmd("createLink", url);
      });
      $("nacos-rte-unlink").addEventListener("click", () => cmd("unlink"));
    }

    async function apiGetConfig(dataId) {
      const resp = await fetch(
        `/api/xhunt/stats/nacos/config?dataId=${encodeURIComponent(
          dataId
        )}&group=DEFAULT_GROUP`,
        {
          credentials: "include",
          headers: { Accept: "application/json" },
        }
      );
      if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
      const json = await resp.json();
      if (!json.success) throw new Error(json.error || "加载失败");
      return json.data;
    }

    async function apiPublishConfig({ dataId, content, group }) {
      const resp = await fetch(`/api/xhunt/stats/nacos/config`, {
        method: "POST",
        credentials: "include",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: JSON.stringify({
          dataId,
          group: group || "DEFAULT_GROUP",
          content,
          type: "json",
        }),
      });
      if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
      const json = await resp.json();
      if (!json.success) throw new Error(json.error || "发布失败");
      return json.data;
    }

    async function loadFromNacos() {
      const did = DATA_IDS[currentLang];
      $("nacos-msg-dataid").textContent = did;

      toast("正在从 Nacos 加载...", "info");
      const data = await apiGetConfig(did);

      // data.content 是字符串（可能是 JSON）
      let parsed;
      try {
        parsed = JSON.parse(data.content || "[]");
      } catch (e) {
        throw new Error("Nacos content 不是合法 JSON，请检查当前配置内容");
      }

      if (!Array.isArray(parsed)) {
        throw new Error("当前配置不是数组结构（期望：公告数组）");
      }

      items = parsed;
      dirty = false;
      currentIndex = -1;
      renderList();
      selectItem(-1);
      toast("加载完成", "success");
    }

    function newItem() {
      const now = Date.now();
      const it = {
        title: "",
        content: DEFAULT_FOOTER_HTML,
        created: String(now),
      };
      items.unshift(it);
      dirty = true;
      renderList();
      selectItem(0);
      toast("已新增一条公告（未发布）", "info");
    }

    async function deleteCurrent() {
      if (currentIndex < 0) return;
      const it = items[currentIndex];
      const ok = window.confirm(
        `确认删除该公告？\n\n标题：${
          it?.title || ""
        }\n\n提示：删除会立即发布到 Nacos 生效。`
      );
      if (!ok) return;

      // 先本地删除
      items.splice(currentIndex, 1);
      dirty = true;

      // 立即发布（使删除立刻生效）
      try {
        toast("正在删除并发布到 Nacos...", "info");
        const did = DATA_IDS[currentLang];
        const content = JSON.stringify(items, null, 2);
        await apiPublishConfig({
          dataId: did,
          content,
          group: "DEFAULT_GROUP",
        });
        dirty = false;

        // 重新从 Nacos 加载，确保与服务端一致
        await loadFromNacos();

        // 退出编辑模式
        currentIndex = -1;
        renderList();
        selectItem(-1);

        toast("删除已生效（已发布）", "success");
      } catch (e) {
        // 发布失败则提示，并保留 dirty 状态方便用户手动发布/重试
        console.error("deleteCurrent publish error:", e);
        toast(
          "删除未能发布：" +
            (e.message || "未知错误") +
            "（你可以点击发布按钮重试）",
          "error"
        );
        // 刷新 UI（此时为本地已删但未发布）
        currentIndex = -1;
        renderList();
        selectItem(-1);
      }
    }

    async function publish() {
      const did = DATA_IDS[currentLang];
      const content = JSON.stringify(items, null, 2);
      const ok = window.confirm(
        `确认发布到 Nacos？\n\n将覆盖 dataId=${did} 的 content（数组整体覆盖）。`
      );
      if (!ok) return;

      toast("正在发布到 Nacos...", "info");
      await apiPublishConfig({ dataId: did, content, group: "DEFAULT_GROUP" });
      dirty = false;
      toast("发布成功", "success");

      // 发布后退出编辑模式（避免误改）
      currentIndex = -1;
      renderList();
      selectItem(-1);
    }

    function setLang(lang) {
      if (lang !== "zh" && lang !== "en") return;
      if (dirty) {
        const ok = window.confirm(
          "你当前有未发布的修改，切换语言会丢失未发布修改。\n确认继续切换？"
        );
        if (!ok) return;
      }
      currentLang = lang;
      // 按钮状态
      $("nacos-msg-lang-zh").classList.toggle("primary", lang === "zh");
      $("nacos-msg-lang-en").classList.toggle("primary", lang === "en");
      loadFromNacos().catch((e) => toast("加载失败：" + e.message, "error"));
    }

    function init() {
      if (inited) return;
      inited = true;

      // init button styles
      $("nacos-msg-lang-zh").classList.add("primary");

      // init editor once
      initEditor();

      // bind model sync (title)
      $("nacos-msg-title").addEventListener("input", syncToModel);

      $("nacos-msg-lang-zh").addEventListener("click", () => setLang("zh"));
      $("nacos-msg-lang-en").addEventListener("click", () => setLang("en"));
      $("nacos-msg-refresh").addEventListener("click", async () => {
        if (dirty) {
          const ok = window.confirm(
            "你当前有未发布的修改，重新加载会丢失这些修改。\n确认重新加载？"
          );
          if (!ok) return;
        }
        try {
          await loadFromNacos();
        } catch (e) {
          toast("加载失败：" + e.message, "error");
        }
      });

      $("nacos-msg-new").addEventListener("click", newItem);
      $("nacos-msg-delete").addEventListener("click", deleteCurrent);
      $("nacos-msg-publish").addEventListener("click", () => {
        publish().catch((e) => toast("发布失败：" + e.message, "error"));
      });

      // first load
      loadFromNacos().catch((e) => toast("加载失败：" + e.message, "error"));
    }

    function tryInitIfActive() {
      const pane = document.getElementById("nacos-messages");
      if (pane && pane.classList.contains("active")) {
        setTimeout(init, 30);
      }
    }

    // 监听 tab 切换事件
    document.addEventListener("click", function (e) {
      const tabBtn = e.target.closest(".tab-btn");
      if (tabBtn && tabBtn.getAttribute("data-tab") === "nacos-messages") {
        setTimeout(init, 80);
      }
    });

    // 若刷新页面时本 tab 就是激活状态（URL hash 直接落在 nacos-messages），也要自动初始化
    document.addEventListener("DOMContentLoaded", tryInitIfActive);
    // 兼容：有些情况下 initTabs 先于/后于 DOMContentLoaded 切换 active，这里再延迟尝试一次
    setTimeout(tryInitIfActive, 300);
  })();
</script>
