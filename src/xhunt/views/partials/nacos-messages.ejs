<div class="nacos-msg-container">
  <div class="nacos-msg-header">
    <h2>📣 公告配置（Nacos）</h2>
    <p>
      可视化编辑 Nacos 配置：<code>xhunt_message</code> /
      <code>xhunt_message_en</code>
    </p>
  </div>

  <div class="nacos-msg-toolbar">
    <div class="lang-switch">
      <span class="label">语言：</span>
      <button class="btn" id="nacos-msg-lang-zh" data-lang="zh">中文</button>
      <button class="btn" id="nacos-msg-lang-en" data-lang="en">English</button>
      <span class="current-did"
        >当前 dataId：<code id="nacos-msg-dataid">-</code></span
      >
    </div>

    <div class="actions">
      <button class="btn primary" id="nacos-msg-refresh">
        🔄 从 Nacos 重新加载
      </button>
      <button class="btn" id="nacos-msg-new">➕ 新增公告</button>
      <button class="btn danger" id="nacos-msg-delete" disabled>
        🗑️ 删除当前
      </button>
      <button class="btn success" id="nacos-msg-publish" disabled>
        🚀 发布到 Nacos
      </button>
    </div>
  </div>

  <div class="nacos-msg-body">
    <div class="list">
      <div class="list-header">
        <strong>公告列表</strong>
        <span class="muted" id="nacos-msg-count">0 条</span>
      </div>
      <div class="list-items" id="nacos-msg-list"></div>
    </div>

    <div class="editor">
      <div class="editor-header">
        <strong>编辑</strong>
        <span class="muted" id="nacos-msg-editor-hint"
          >选择左侧一条公告开始编辑</span
        >
      </div>

      <div class="field">
        <label>标题</label>
        <input
          id="nacos-msg-title"
          type="text"
          placeholder="请输入标题"
          disabled
        />
      </div>

      <div class="field">
        <label>内容（富文本编辑，可输出 HTML）</label>

        <!-- Quill 需要的容器：工具栏 + 编辑器 -->
        <div
          id="nacos-quill-toolbar"
          class="ql-toolbar ql-snow"
          style="display: none"
        ></div>
        <div
          id="nacos-msg-content"
          class="ql-container ql-snow"
          style="display: none"
        ></div>

        <!-- fallback：若 CDN 加载失败，仍可用原生编辑器（保持可用性） -->
        <div class="rte-toolbar" id="nacos-rte-toolbar">
          <button class="btn" type="button" id="nacos-rte-bold" title="加粗">
            <b>B</b>
          </button>
          <button class="btn" type="button" id="nacos-rte-italic" title="斜体">
            <i>I</i>
          </button>
          <button
            class="btn"
            type="button"
            id="nacos-rte-underline"
            title="下划线"
          >
            <u>U</u>
          </button>
          <button class="btn" type="button" id="nacos-rte-br" title="换行">
            ⏎
          </button>
          <button
            class="btn"
            type="button"
            id="nacos-rte-link"
            title="插入链接"
          >
            🔗
          </button>
          <button
            class="btn"
            type="button"
            id="nacos-rte-unlink"
            title="移除链接"
          >
            ✖︎🔗
          </button>
          <span class="muted" style="margin-left: 8px"
            >提示：可直接粘贴 HTML</span
          >
        </div>

        <div
          id="nacos-msg-content-fallback"
          class="rte-editor"
          contenteditable="false"
          data-placeholder="请输入公告内容（支持 HTML）"
          style="display: none"
        ></div>

        <div class="muted" style="margin-top: 6px">
          当前保存为 HTML 字符串（发布时写入 Nacos）。
        </div>
      </div>

      <div class="preview">
        <div class="preview-header">
          <strong>预览</strong>
          <span class="muted">（按当前输入渲染）</span>
        </div>
        <div class="preview-box" id="nacos-msg-preview"></div>
      </div>

      <div class="tips">
        <div class="tip-title">说明</div>
        <ul>
          <li>
            点击“发布到 Nacos”会把当前语言对应的整个公告数组写入
            Nacos（覆盖式更新）。
          </li>
          <li>
            建议每条公告的
            <code>created</code> 使用时间戳（毫秒），用于排序与追踪。
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="nacos-msg-toast" id="nacos-msg-toast" style="display: none"></div>
</div>

<!-- 轻量流行 CDN 富文本：Quill（按需加载，避免影响其他 tab） -->
<link rel="stylesheet" href="/static/css/quill.snow.css" />
<script src="/static/js/quill.min.js"></script>

