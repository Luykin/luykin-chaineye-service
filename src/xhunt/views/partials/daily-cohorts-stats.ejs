<div class="section" style="padding: 20px">
  <div class="header-section" style="margin-bottom: 30px">
    <h2>📈 天级留存分析</h2>
    <p style="color: #666; margin-top: 10px">
      基于用户首次活跃日期，追踪用户在第2、3、4、5、6、7、8、9、10天的活跃情况（最大跨度：3个月）
    </p>

    <!-- 日期选择器 -->
    <div
      style="
        margin-top: 20px;
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
      "
    >
      <div style="display: flex; align-items: center; gap: 8px">
        <label for="start-date" style="font-weight: 500; color: #333"
          >开始日期：</label
        >
        <input
          type="date"
          id="start-date"
          style="
            padding: 8px 12px;
            border: 1px solid #ddd;
            border-radius: 5px;
            font-size: 14px;
            cursor: pointer;
          "
        />
      </div>
      <div style="display: flex; align-items: center; gap: 8px">
        <label for="end-date" style="font-weight: 500; color: #333"
          >结束日期：</label
        >
        <input
          type="date"
          id="end-date"
          style="
            padding: 8px 12px;
            border: 1px solid #ddd;
            border-radius: 5px;
            font-size: 14px;
            cursor: pointer;
          "
        />
      </div>
      <button
        id="query-cohorts-btn"
        style="
          padding: 8px 20px;
          background: #3498db;
          color: white;
          border: none;
          border-radius: 5px;
          cursor: pointer;
          font-weight: 500;
          transition: background 0.3s;
        "
        onmouseover="this.style.background='#2980b9'"
        onmouseout="this.style.background='#3498db'"
      >
        查询
      </button>
      <button
        id="reset-cohorts-btn"
        style="
          padding: 8px 20px;
          background: #95a5a6;
          color: white;
          border: none;
          border-radius: 5px;
          cursor: pointer;
          font-weight: 500;
          transition: background 0.3s;
        "
        onmouseover="this.style.background='#7f8c8d'"
        onmouseout="this.style.background='#95a5a6'"
      >
        重置为最近7天
      </button>
      <span id="date-range-info" style="color: #666; font-size: 14px"></span>
      <span id="daily-date-error" style="color: #e74c3c; font-size: 14px; display: none; margin-left: 10px;"></span>
    </div>
  </div>

  <!-- 加载状态 -->
  <div id="daily-cohorts-loading" style="text-align: center; padding: 40px">
    <div class="loading-spinner"></div>
    <p style="margin-top: 15px; color: #666">正在加载天级留存数据...</p>
  </div>

  <!-- 错误状态 -->
  <div
    id="daily-cohorts-error"
    style="display: none; text-align: center; padding: 40px"
  >
    <p style="color: #e74c3c; font-size: 16px">❌ 加载天级留存数据失败</p>
    <button
      id="retry-cohorts-btn"
      style="
        margin-top: 15px;
        padding: 10px 20px;
        background: #3498db;
        color: white;
        border: none;
        border-radius: 5px;
        cursor: pointer;
      "
    >
      重试
    </button>
  </div>

  <!-- 数据表格 -->
  <div id="daily-cohorts-table" style="display: none">
    <table
      style="
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      "
    >
      <thead>
        <tr
          style="
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
          "
        >
          <th style="padding: 15px; text-align: left; font-weight: 600">
            首次活跃日期
          </th>
          <th style="padding: 15px; text-align: center; font-weight: 600">
            新用户数
          </th>
          <th style="padding: 15px; text-align: center; font-weight: 600">
            第2天
          </th>
          <th style="padding: 15px; text-align: center; font-weight: 600">
            第3天
          </th>
          <th style="padding: 15px; text-align: center; font-weight: 600">
            第4天
          </th>
          <th style="padding: 15px; text-align: center; font-weight: 600">
            第5天
          </th>
          <th style="padding: 15px; text-align: center; font-weight: 600">
            第6天
          </th>
          <th style="padding: 15px; text-align: center; font-weight: 600">
            第7天
          </th>
          <th style="padding: 15px; text-align: center; font-weight: 600">
            第8天
          </th>
          <th style="padding: 15px; text-align: center; font-weight: 600">
            第9天
          </th>
          <th style="padding: 15px; text-align: center; font-weight: 600">
            第10天
          </th>
        </tr>
      </thead>
      <tbody id="daily-cohorts-tbody">
        <!-- 数据将通过JavaScript填充 -->
      </tbody>
    </table>
  </div>

  <!-- 空状态 -->
  <div
    id="daily-cohorts-empty"
    style="display: none; text-align: center; padding: 40px"
  >
    <p style="color: #999; font-size: 16px">暂无天级留存数据</p>
  </div>
</div>

<script>
  // 根据百分比计算背景颜色（浅蓝色渐变）
  function getRetentionColor(percentage) {
    const p = parseFloat(percentage) || 0;
    // 使用蓝色渐变：0% = 白色，100% = 深蓝色
    const opacity = Math.min(p / 100, 1); // 限制在0-1之间
    const r = Math.round(255 - (255 - 173) * opacity); // 从白色渐变到 rgb(173, 216, 230)
    const g = Math.round(255 - (255 - 216) * opacity);
    const b = Math.round(255 - (255 - 230) * opacity);
    return `rgb(${r}, ${g}, ${b})`;
  }

  // 页面加载时初始化日期选择器和获取数据
  document.addEventListener("DOMContentLoaded", function () {
    console.log("📌 DOMContentLoaded - 初始化天级留存分析");

    // 初始化日期范围
    initializeDateRange();

    // 绑定按钮事件
    const queryBtn = document.getElementById("query-cohorts-btn");
    const resetBtn = document.getElementById("reset-cohorts-btn");
    const retryBtn = document.getElementById("retry-cohorts-btn");

    if (queryBtn) {
      queryBtn.addEventListener("click", function() {
        const startDate = document.getElementById("start-date").value;
        const endDate = document.getElementById("end-date").value;
        if (validateDateRange(startDate, endDate)) {
          loadDailyCohorts();
        }
      });
      console.log("✅ 查询按钮事件已绑定");
    } else {
      console.error("❌ 找不到查询按钮");
    }

    if (resetBtn) {
      resetBtn.addEventListener("click", resetDateRange);
      console.log("✅ 重置按钮事件已绑定");
    } else {
      console.error("❌ 找不到重置按钮");
    }

    if (retryBtn) {
      retryBtn.addEventListener("click", function() {
        const startDate = document.getElementById("start-date").value;
        const endDate = document.getElementById("end-date").value;
        if (validateDateRange(startDate, endDate)) {
          loadDailyCohorts();
        }
      });
      console.log("✅ 重试按钮事件已绑定");
    } else {
      console.warn("⚠️  重试按钮未找到（正常，只在出错时显示）");
    }

    // 日期输入框支持回车键查询
    const startDateInput = document.getElementById("start-date");
    const endDateInput = document.getElementById("end-date");

    if (startDateInput) {
      startDateInput.addEventListener("keypress", function (e) {
        if (e.key === "Enter") {
          loadDailyCohorts();
        }
      });
    }

    if (endDateInput) {
      endDateInput.addEventListener("keypress", function (e) {
        if (e.key === "Enter") {
          loadDailyCohorts();
        }
      });
    }

    // 初始加载数据
    loadDailyCohorts();
  });

  // 验证日期跨度（最大3个月 = 90天）
  function validateDateRange(startDate, endDate) {
    const errorEl = document.getElementById('daily-date-error');
    errorEl.style.display = 'none';
    
    if (!startDate || !endDate) {
      errorEl.textContent = '请选择开始和结束日期';
      errorEl.style.display = 'inline';
      return false;
    }

    const start = new Date(startDate);
    const end = new Date(endDate);
    
    if (start > end) {
      errorEl.textContent = '开始日期不能晚于结束日期';
      errorEl.style.display = 'inline';
      return false;
    }

    const diffDays = Math.ceil((end - start) / (1000 * 60 * 60 * 24));
    if (diffDays > 90) {
      errorEl.textContent = '日期跨度不能超过3个月（90天）';
      errorEl.style.display = 'inline';
      return false;
    }

    return true;
  }

  // 初始化日期范围为最近7天
  function initializeDateRange() {
    const endDate = new Date();
    const startDate = new Date();
    startDate.setDate(endDate.getDate() - 7);

    document.getElementById("end-date").value = endDate
      .toISOString()
      .split("T")[0];
    document.getElementById("start-date").value = startDate
      .toISOString()
      .split("T")[0];
  }

  // 重置日期范围为最近7天
  function resetDateRange() {
    initializeDateRange();
    const startDate = document.getElementById("start-date").value;
    const endDate = document.getElementById("end-date").value;
    if (validateDateRange(startDate, endDate)) {
      loadDailyCohorts();
    }
  }

  async function loadDailyCohorts() {
    console.log("🔍 loadDailyCohorts 被调用");

    const loadingEl = document.getElementById("daily-cohorts-loading");
    const errorEl = document.getElementById("daily-cohorts-error");
    const tableEl = document.getElementById("daily-cohorts-table");
    const emptyEl = document.getElementById("daily-cohorts-empty");
    const tbodyEl = document.getElementById("daily-cohorts-tbody");

    // 显示加载状态
    loadingEl.style.display = "block";
    errorEl.style.display = "none";
    tableEl.style.display = "none";
    emptyEl.style.display = "none";

    try {
      // 获取日期范围
      const startDate = document.getElementById("start-date").value;
      const endDate = document.getElementById("end-date").value;

      console.log(`📅 查询日期范围: ${startDate} 至 ${endDate}`);

      // 构建查询URL
      const url = new URL(
        "/api/xhunt/stats/daily-cohorts",
        window.location.origin
      );
      if (startDate) url.searchParams.append("startDate", startDate);
      if (endDate) url.searchParams.append("endDate", endDate);

      console.log(`🌐 请求URL: ${url.toString()}`);

      const response = await fetch(url.toString(), {
        credentials: "include",
      });

      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }

      const result = await response.json();
      console.log(`✅ 接收到数据:`, result);

      // 显示日期范围信息
      if (result.data && result.data.dateRange) {
        const dateInfo = document.getElementById("date-range-info");
        dateInfo.textContent = `显示范围: ${result.data.dateRange.startDate} 至 ${result.data.dateRange.endDate}`;
      }

      if (result.success && result.data && result.data.cohorts.length > 0) {
        console.log(`📊 成功加载 ${result.data.cohorts.length} 个cohorts`);

        // 显示表格
        loadingEl.style.display = "none";
        tableEl.style.display = "block";
        errorEl.style.display = "none";

        // 填充数据
        tbodyEl.innerHTML = result.data.cohorts
          .map((cohort) => {
            // 格式化日期
            const dateFormatted = new Date(
              cohort.cohortDate
            ).toLocaleDateString("zh-CN", {
              year: "numeric",
              month: "short",
              day: "numeric",
            });

            return `
              <tr style="border-bottom: 1px solid #eee">
                <td style="padding: 15px; font-weight: 500; color: #333">
                  <div style="display: flex; align-items: center; gap: 10px">
                    <span>${dateFormatted}</span>
                    <span style="font-size: 12px; color: #95a5a6; font-weight: normal">
                      (日活: ${cohort.dailyActiveUsers.toLocaleString()})
                    </span>
                  </div>
                </td>
                <td style="padding: 15px; text-align: center; font-weight: 600; color: #3498db">
                  ${cohort.newUsers.toLocaleString()}
                </td>
                <td style="padding: 15px; text-align: center; font-weight: 600; background-color: ${getRetentionColor(
                  cohort.day2Retention
                )};">
                  ${parseFloat(cohort.day2Retention).toFixed(1)}%
                  <br>
                  <span style="font-size: 12px; opacity: 0.7">
                    ${cohort.day2Active}人
                  </span>
                </td>
                <td style="padding: 15px; text-align: center; font-weight: 600; background-color: ${getRetentionColor(
                  cohort.day3Retention
                )};">
                  ${parseFloat(cohort.day3Retention).toFixed(1)}%
                  <br>
                  <span style="font-size: 12px; opacity: 0.7">
                    ${cohort.day3Active}人
                  </span>
                </td>
                <td style="padding: 15px; text-align: center; font-weight: 600; background-color: ${getRetentionColor(
                  cohort.day4Retention
                )};">
                  ${parseFloat(cohort.day4Retention).toFixed(1)}%
                  <br>
                  <span style="font-size: 12px; opacity: 0.7">
                    ${cohort.day4Active}人
                  </span>
                </td>
                <td style="padding: 15px; text-align: center; font-weight: 600; background-color: ${getRetentionColor(
                  cohort.day5Retention
                )};">
                  ${parseFloat(cohort.day5Retention).toFixed(1)}%
                  <br>
                  <span style="font-size: 12px; opacity: 0.7">
                    ${cohort.day5Active}人
                  </span>
                </td>
                <td style="padding: 15px; text-align: center; font-weight: 600; background-color: ${getRetentionColor(
                  cohort.day6Retention
                )};">
                  ${parseFloat(cohort.day6Retention).toFixed(1)}%
                  <br>
                  <span style="font-size: 12px; opacity: 0.7">
                    ${cohort.day6Active}人
                  </span>
                </td>
                <td style="padding: 15px; text-align: center; font-weight: 600; background-color: ${getRetentionColor(
                  cohort.day7Retention
                )};">
                  ${parseFloat(cohort.day7Retention).toFixed(1)}%
                  <br>
                  <span style="font-size: 12px; opacity: 0.7">
                    ${cohort.day7Active}人
                  </span>
                </td>
                <td style="padding: 15px; text-align: center; font-weight: 600; background-color: ${getRetentionColor(
                  cohort.day8Retention
                )};">
                  ${parseFloat(cohort.day8Retention).toFixed(1)}%
                  <br>
                  <span style="font-size: 12px; opacity: 0.7">
                    ${cohort.day8Active}人
                  </span>
                </td>
                <td style="padding: 15px; text-align: center; font-weight: 600; background-color: ${getRetentionColor(
                  cohort.day9Retention
                )};">
                  ${parseFloat(cohort.day9Retention).toFixed(1)}%
                  <br>
                  <span style="font-size: 12px; opacity: 0.7">
                    ${cohort.day9Active}人
                  </span>
                </td>
                <td style="padding: 15px; text-align: center; font-weight: 600; background-color: ${getRetentionColor(
                  cohort.day10Retention
                )};">
                  ${parseFloat(cohort.day10Retention).toFixed(1)}%
                  <br>
                  <span style="font-size: 12px; opacity: 0.7">
                    ${cohort.day10Active}人
                  </span>
                </td>
              </tr>
            `;
          })
          .join("");

        // 背景颜色会根据单元格内容自动变化，不需要斑马纹
      } else {
        console.log(`⚠️  没有数据或数据为空`);
        // 显示空状态
        loadingEl.style.display = "none";
        emptyEl.style.display = "block";
        tableEl.style.display = "none";
      }
    } catch (error) {
      console.error("❌ Error loading daily cohorts:", error);
      loadingEl.style.display = "none";
      errorEl.style.display = "block";
      tableEl.style.display = "none";
    }
  }
</script>

<!-- 分隔线 -->
<hr style="border: none; border-top: 2px solid #e5e7eb; margin: 40px 20px;" />

<!-- 周级留存部分 -->
<div class="section" style="padding: 20px">
  <div class="header-section" style="margin-bottom: 30px">
    <h2>📊 周级留存分析</h2>
    <p style="color: #666; margin-top: 10px">
      基于用户首次活跃周，追踪用户在第2、3、4周的活跃情况（最大跨度：3个月）
    </p>

    <!-- 日期选择器 -->
    <div style="margin-top: 20px; display: flex; align-items: center; gap: 15px; flex-wrap: wrap;">
