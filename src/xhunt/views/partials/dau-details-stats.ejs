<!-- 日活详情统计 -->
<div class="stats-section">
    <div class="section">
        <h2 class="section-title">日活用户详情</h2>
        <p class="section-desc">查看指定日期的活跃用户详情</p>

        <!-- 日期选择器 -->
        <div class="date-selector">
            <label for="dau-date-selector">选择日期</label>
            <input type="date" id="dau-date-selector">
            <button id="load-dau-details" class="btn-primary">加载数据</button>
            <span id="dau-loading" class="loading-indicator">
                <span class="spinner"></span>
                加载中...
            </span>
        </div>

        <!-- 统计信息 -->
        <div id="dau-summary" class="summary-section">
            <div class="stats-grid stats-grid-3">
                <div class="stat-card">
                    <div class="stat-title" id="dau-date-title">今日日活</div>
                    <div class="stat-value stat-value-lg" id="dau-total-count">0</div>
                    <div class="stat-subtitle">总活跃记录数</div>
                </div>
                <div class="stat-card">
                    <div class="stat-title">今日去重日活</div>
                    <div class="stat-value stat-value-lg" id="dau-unique-users">0</div>
                    <div class="stat-subtitle">唯一活跃用户数</div>
                </div>
                <div class="stat-card">
                    <div class="stat-title">未知用户</div>
                    <div class="stat-value stat-value-lg" id="dau-unknown-users">0</div>
                    <div class="stat-subtitle">无用户ID的记录数</div>
                </div>
            </div>
        </div>

        <!-- 用户列表 -->
        <div id="dau-details-container" class="details-container">
            <div class="list-header">
                <h3 class="list-title">用户列表</h3>
                <input type="text" id="dau-search" class="search-input" placeholder="搜索用户ID...">
            </div>

            <div class="table-container">
                <table id="dau-details-table" class="data-table compact">
                    <thead>
                        <tr>
                            <th class="col-narrow">序号</th>
                            <th>用户ID</th>
                            <th>设备指纹</th>
                        </tr>
                    </thead>
                    <tbody id="dau-details-tbody">
                        <!-- 数据将通过JavaScript动态填充 -->
                    </tbody>
                </table>
            </div>

            <!-- 分页信息 -->
            <div id="dau-pagination" class="pagination-info">
                <!-- 分页信息将通过JavaScript动态填充 -->
            </div>
        </div>

        <!-- 无数据提示 -->
        <div id="dau-no-data" class="empty-state">
            <div class="empty-icon">-</div>
            <h3>暂无数据</h3>
            <p>所选日期没有日活数据，请选择其他日期</p>
        </div>
    </div>
</div>

<style>
/* 区域描述 */
.section-desc {
    color: #6b7280;
    margin-bottom: 20px;
    font-size: 14px;
}

/* 日期选择器 */
.date-selector {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    flex-wrap: wrap;
}

.date-selector label {
    font-weight: 500;
    color: #374151;
    font-size: 14px;
}

.date-selector input[type="date"] {
    padding: 6px 10px;
    border: 1px solid #d1d5db;
    border-radius: 4px;
    font-size: 14px;
    background: white;
}

.date-selector .btn-primary {
    padding: 6px 14px;
    background: #3b82f6 !important;
    color: white !important;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
}

.date-selector .btn-primary:hover {
    background: #2563eb !important;
}

.date-selector .btn-primary:disabled {
    opacity: 0.6;
    cursor: not-allowed;
}

/* 加载指示器 */
.loading-indicator {
    display: none;
    align-items: center;
    gap: 6px;
    color: #6b7280;
    font-size: 14px;
}

.spinner {
    display: inline-block;
    width: 14px;
    height: 14px;
    border: 2px solid #3b82f6;
    border-top-color: transparent;
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* 摘要区域 */
.summary-section {
    display: none;
    margin-bottom: 24px;
}

/* 统计网格 */
.stats-grid-3 {
    grid-template-columns: repeat(3, 1fr);
}

@media (max-width: 768px) {
    .stats-grid-3 {
        grid-template-columns: 1fr;
    }
}

/* 统计卡片 - 静态无动画 */
.stat-card {
    background: white;
    padding: 16px;
    border-radius: 6px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    border: 1px solid #e5e7eb;
}

.stat-value-lg {
    font-size: 28px;
    font-weight: 600;
    color: #111827;
    margin: 8px 0;
}

.stat-subtitle {
    font-size: 12px;
    color: #9ca3af;
    font-weight: 400;
}

/* 详情容器 */
.details-container {
    display: none;
}

/* 列表头部 */
.list-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    flex-wrap: wrap;
    gap: 12px;
}

.list-title {
    font-size: 16px;
    font-weight: 600;
    color: #374151;
    margin: 0;
}

/* 搜索输入 */
.search-input {
    padding: 5px 10px;
    border: 1px solid #d1d5db;
    border-radius: 4px;
    font-size: 13px;
    width: 180px;
}

.search-input:focus {
    outline: none;
    border-color: #3b82f6;
}

/* 数据表格 - 紧凑样式 */
.data-table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    font-size: 13px;
}

.data-table.compact thead {
    background: #f9fafb;
}

.data-table.compact th {
    padding: 10px 12px;
    text-align: left;
    border-bottom: 1px solid #e5e7eb;
    font-weight: 600;
    color: #374151;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
}

.data-table.compact td {
    padding: 8px 12px;
    border-bottom: 1px solid #f3f4f6;
    color: #4b5563;
}

.data-table.compact tbody tr:hover {
    background-color: #f9fafb;
}

.col-narrow {
    width: 60px;
}

/* 用户相关样式 */
.dau-user-id {
    font-weight: 500;
    color: #374151;
}

.dau-unknown-user {
    color: #9ca3af;
    font-style: italic;
}

.dau-fingerprint-full {
    font-family: ui-monospace, SFMono-Regular, monospace;
    color: #6b7280;
    font-size: 11px;
    word-break: break-all;
}

/* 分页信息 */
.pagination-info {
    margin-top: 16px;
    text-align: center;
    color: #6b7280;
    font-size: 13px;
}

/* 空状态 */
.empty-state {
    display: none;
    text-align: center;
    padding: 48px 20px;
    color: #6b7280;
}

.empty-icon {
    font-size: 32px;
    color: #d1d5db;
    margin-bottom: 12px;
    line-height: 1;
}

.empty-state h3 {
    font-size: 14px;
    font-weight: 500;
    color: #374151;
    margin: 0 0 4px 0;
}

.empty-state p {
    font-size: 13px;
    margin: 0;
}
</style>

<script>
// 日活详情相关JavaScript
document.addEventListener('DOMContentLoaded', function() {
    const dateSelector = document.getElementById('dau-date-selector');
    const loadButton = document.getElementById('load-dau-details');
    const loadingSpan = document.getElementById('dau-loading');
    const summaryDiv = document.getElementById('dau-summary');
    const containerDiv = document.getElementById('dau-details-container');
    const noDataDiv = document.getElementById('dau-no-data');
    const searchInput = document.getElementById('dau-search');
    
    let currentDauData = [];
    let filteredDauData = [];
    
    // 设置默认日期为今天（使用UTC+8方法，与后端保持一致）
    const today = new Date();
    const utcHours = today.getUTCHours();
    const beijingHours = utcHours + 8;
    
    let beijingDate = new Date(today);
    if (beijingHours >= 24) {
      beijingDate.setUTCDate(beijingDate.getUTCDate() + 1);
      beijingDate.setUTCHours(beijingHours - 24);
    } else {
      beijingDate.setUTCHours(beijingHours);
    }
    
    const todayStr = beijingDate.toISOString().split('T')[0];
    dateSelector.value = todayStr;
    
    // 加载按钮点击事件
    loadButton.addEventListener('click', loadDauDetails);
    
    // 搜索功能
    searchInput.addEventListener('input', filterDauData);
    
    // 仅在切换到「日活详情」tab 时加载数据
    document.addEventListener('stats-tab-activated', function(e) {
      if (e.detail && e.detail.tabId === 'dau-details') {
        loadDauDetails();
      }
    });
    
    async function loadDauDetails() {
        const selectedDate = dateSelector.value;
        if (!selectedDate) {
            alert('请选择日期');
            return;
        }
        
        // 显示加载状态
        loadingSpan.style.display = 'inline-flex';
        loadButton.disabled = true;
        
        try {
            const response = await fetch(`/api/xhunt/stats/dau-details?date=${selectedDate}`);
            
            const result = await response.json();
            
            if (result.success) {
                currentDauData = result.data.details;
                filteredDauData = [...currentDauData];
                
                updateSummary(result.data);
                updateTable();
                
                if (currentDauData.length > 0) {
                    summaryDiv.style.display = 'block';
                    containerDiv.style.display = 'block';
                    noDataDiv.style.display = 'none';
                } else {
                    summaryDiv.style.display = 'none';
                    containerDiv.style.display = 'none';
                    noDataDiv.style.display = 'block';
                }
            } else {
                alert('加载数据失败: ' + result.error);
            }
        } catch (error) {
            console.error('Error loading DAU details:', error);
            alert('加载数据失败，请检查网络连接');
        } finally {
            // 隐藏加载状态
            loadingSpan.style.display = 'none';
            loadButton.disabled = false;
        }
    }
    
    function updateSummary(data) {
        const totalCount = data.totalCount;
        const validUsers = data.details.filter(item => item.userId !== '未知').length;
        const unknownUsers = totalCount - validUsers;
        
        // 计算去重日活（按用户ID去重）
        const uniqueUserIds = new Set();
        data.details.forEach(item => {
            if (item.userId !== '未知') {
                uniqueUserIds.add(item.userId);
            }
        });
        const uniqueUsersCount = uniqueUserIds.size;
        
        // 更新日期标题（使用中国时区）
        const dateTitle = document.getElementById('dau-date-title');
        const selectedDate = new Date(data.date + 'T00:00:00+08:00'); // 使用中国时区
        const month = selectedDate.getMonth() + 1;
        const day = selectedDate.getDate();
        dateTitle.textContent = `${month}月${day}号日活`;
        
        document.getElementById('dau-total-count').textContent = totalCount.toLocaleString();
        document.getElementById('dau-unique-users').textContent = uniqueUsersCount.toLocaleString();
        document.getElementById('dau-unknown-users').textContent = unknownUsers.toLocaleString();
    }
    
    function filterDauData() {
        const searchTerm = searchInput.value.toLowerCase();
        
        if (!searchTerm) {
            filteredDauData = [...currentDauData];
        } else {
            filteredDauData = currentDauData.filter(item => 
                item.userId.toLowerCase().includes(searchTerm)
            );
        }
        
        updateTable();
    }
    
    function updateTable() {
        const tbody = document.getElementById('dau-details-tbody');
        const paginationDiv = document.getElementById('dau-pagination');
        
        // 清空现有内容
        tbody.innerHTML = '';
        
        if (filteredDauData.length === 0) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="3" style="text-align: center; padding: 32px; color: #6b7280;">
                        没有找到匹配的数据
                    </td>
                </tr>
            `;
            paginationDiv.innerHTML = '';
            return;
        }
        
        // 填充表格数据
        filteredDauData.forEach((item, index) => {
            const row = document.createElement('tr');
            
            const isUnknown = item.userId === '未知';
            
            row.innerHTML = `
                <td>${index + 1}</td>
                <td>
                    <span class="dau-user-id ${isUnknown ? 'dau-unknown-user' : ''}">${item.userId}</span>
                </td>
                <td>
                    <span class="dau-fingerprint-full" title="${item.fingerprint}">${item.fingerprint}</span>
                </td>
            `;
            
            tbody.appendChild(row);
        });
        
        // 更新分页信息
        paginationDiv.innerHTML = `共 ${filteredDauData.length} 条记录`;
    }
});
</script>
