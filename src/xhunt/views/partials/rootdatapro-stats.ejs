<style>
  .rdp-card {
    background-color: #1e293b;
    padding: 24px;
    border-radius: 12px;
    border: 1px solid #334155;
  }
  .rdp-header h2 {
    margin: 0 0 8px 0;
    font-size: 20px;
    color: #f1f5f9;
  }
  .rdp-header p {
    color: #94a3b8;
    font-size: 14px;
    margin: 0;
  }
  .rdp-form-group {
    margin-top: 24px;
    display: flex;
    gap: 12px;
    align-items: flex-end;
  }
  .rdp-input-wrapper {
    flex: 1;
  }
  .rdp-label {
    font-size: 12px;
    color: #94a3b8;
    margin-bottom: 6px;
    display: block;
  }
  .rdp-input {
    width: 100%;
    padding: 10px 12px;
    background-color: #0f172a;
    border: 1px solid #475569;
    border-radius: 8px;
    color: #e2e8f0;
    font-size: 14px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .rdp-input:focus {
    outline: none;
    border-color: #38bdf8;
    box-shadow: 0 0 0 2px rgba(56, 189, 248, 0.3);
  }
  .rdp-btn {
    padding: 10px 16px;
    background-color: #0ea5e9;
    color: white;
    border: none;
    border-radius: 8px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s;
    white-space: nowrap;
  }
  .rdp-btn:hover { background-color: #0284c7; }
  .rdp-btn:disabled { background-color: #334155; cursor: not-allowed; }
  .rdp-result-pre {
    margin-top: 16px; background-color: #0f172a; color: #e2e8f0; padding: 16px;
    border-radius: 8px; overflow: auto; max-height: 400px; border: 1px solid #334155;
    font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace; font-size: 13px; line-height: 1.6;
  }
  .rdp-query-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 24px; }

  /* Task Section Styles */
  .rdp-topbar { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; }
  .rdp-task-controls { display: flex; gap: 10px; margin-top: 0; flex-wrap: wrap; }

  .rdp-btn { box-shadow: 0 1px 0 rgba(255,255,255,0.06) inset; }
  .rdp-btn:active { transform: translateY(1px); }

  .rdp-btn-start { background-color: #10b981; }
  .rdp-btn-start:hover { background-color: #059669; }
  .rdp-btn-pause { background-color: #f59e0b; }
  .rdp-btn-pause:hover { background-color: #d97706; }
  .rdp-btn-reset { background-color: #ef4444; }
  .rdp-btn-reset:hover { background-color: #dc2626; }

  .rdp-btn-ghost {
    background: transparent;
    border: 1px solid #334155;
    color: #e2e8f0;
    padding: 8px 12px;
  }
  .rdp-btn-ghost:hover { background: rgba(148,163,184,0.08); }

  .rdp-status-row {
    margin-top: 14px;
    padding: 12px;
    background: linear-gradient(180deg, rgba(15,23,42,0.65), rgba(15,23,42,0.35));
    border: 1px solid rgba(51,65,85,0.8);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .rdp-task-status { margin: 0; color: #cbd5e1; font-size: 14px; }
  .rdp-task-status-value { font-weight: 700; padding: 4px 10px; border-radius: 999px; letter-spacing: 0.3px; }
  .status-idle { background-color: rgba(55,65,81,0.9); color: #e5e7eb; }
  .status-running { background-color: rgba(30,64,175,0.9); color: #dbeafe; }
  .status-paused { background-color: rgba(180,83,9,0.9); color: #fffbeb; }
  .status-finished { background-color: rgba(6,78,59,0.9); color: #d1fae5; }
  .status-error { background-color: rgba(153,27,27,0.9); color: #fee2e2; }

  .rdp-status-meta { display: flex; align-items: center; gap: 10px; color: #94a3b8; font-size: 12px; }
  .rdp-dot { width: 8px; height: 8px; border-radius: 50%; background: #475569; box-shadow: 0 0 0 3px rgba(71,85,105,0.2); }
  .rdp-dot.running { background: #22c55e; box-shadow: 0 0 0 3px rgba(34,197,94,0.25); }
  .rdp-dot.paused { background: #f59e0b; box-shadow: 0 0 0 3px rgba(245,158,11,0.25); }
  .rdp-dot.idle { background: #64748b; box-shadow: 0 0 0 3px rgba(100,116,139,0.25); }
  .rdp-dot.error { background: #ef4444; box-shadow: 0 0 0 3px rgba(239,68,68,0.25); }

  .rdp-progress-container { margin-top: 14px; display: grid; grid-template-columns: 1fr; gap: 12px; }
  .rdp-progress-tile {
    padding: 12px;
    border: 1px solid rgba(51,65,85,0.8);
    border-radius: 12px;
    background: rgba(15,23,42,0.45);
  }
  .rdp-progress-head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin-bottom: 10px; }
  .rdp-progress-sub-label { font-size: 13px; color: #cbd5e1; margin: 0; font-weight: 600; }
  .rdp-progress-mini { font-size: 12px; color: #94a3b8; font-variant-numeric: tabular-nums; }

  .rdp-progress-bar-bg {
    background-color: rgba(51,65,85,0.7);
    border-radius: 999px;
    height: 12px;
    width: 100%;
    overflow: hidden;
    position: relative;
  }
  .rdp-progress-bar-fill { background-color: #38bdf8; height: 100%; transition: width 0.35s ease-in-out; }
  .rdp-progress-label { display: none; }

  @media (max-width: 768px) { .rdp-form-group { flex-direction: column; align-items: stretch; } }
  .rdp-result-pre .string { color: #a5d6ff; } .rdp-result-pre .number { color: #d8b4fe; }
  .rdp-result-pre .boolean { color: #fca5a5; } .rdp-result-pre .null { color: #9ca3af; } .rdp-result-pre .key { color: #67e8f9; }
</style>

<div class="rdp-card">
  <div class="rdp-topbar">
    <div class="rdp-header">
      <h2>批量爬取任务</h2>
      <p>启动、暂停和监控所有 typemap 中实体的爬取进度。</p>
    </div>
    <div class="rdp-task-controls">
      <button id="rdp-task-start" class="rdp-btn rdp-btn-start">启动</button>
      <button id="rdp-task-pause" class="rdp-btn rdp-btn-pause">暂停</button>
      <button id="rdp-task-reset" class="rdp-btn rdp-btn-reset">重置</button>
    </div>
  </div>

  <div class="rdp-status-row">
    <div class="rdp-task-status">当前状态: <span id="rdp-task-status-value" class="rdp-task-status-value status-idle">-</span></div>
    <div class="rdp-status-meta">
      <span class="rdp-dot" id="rdp-live-dot"></span>
      <span id="rdp-live-text">未自动刷新</span>
      <button id="rdp-refresh-now" class="rdp-btn rdp-btn-ghost" type="button">立即刷新</button>
    </div>
  </div>

  <!-- Task Management Section -->

  <div class="rdp-progress-container">
    <div class="rdp-progress-tile">
      <div class="rdp-progress-head">
        <p class="rdp-progress-sub-label">总进度</p>
        <span id="rdp-progress-total-mini" class="rdp-progress-mini">0 / 0 (0%)</span>
      </div>
      <div class="rdp-progress-bar-bg" aria-label="total-progress">
        <div id="rdp-progress-total-fill" class="rdp-progress-bar-fill"></div>
      </div>
    </div>

    <div class="rdp-progress-tile">
      <div class="rdp-progress-head">
        <p class="rdp-progress-sub-label">项目 (Projects)</p>
        <span id="rdp-progress-project-mini" class="rdp-progress-mini">0 / 0 (0%)</span>
      </div>
      <div class="rdp-progress-bar-bg" aria-label="project-progress">
        <div id="rdp-progress-project-fill" class="rdp-progress-bar-fill" style="background-color: #34d399;"></div>
      </div>
    </div>

    <div class="rdp-progress-tile">
      <div class="rdp-progress-head">
        <p class="rdp-progress-sub-label">机构 (Organizations)</p>
        <span id="rdp-progress-org-mini" class="rdp-progress-mini">0 / 0 (0%)</span>
      </div>
      <div class="rdp-progress-bar-bg" aria-label="org-progress">
        <div id="rdp-progress-org-fill" class="rdp-progress-bar-fill" style="background-color: #fbbf24;"></div>
      </div>
    </div>

    <div class="rdp-progress-tile">
      <div class="rdp-progress-head">
        <p class="rdp-progress-sub-label">人物 (People)</p>
        <span id="rdp-progress-person-mini" class="rdp-progress-mini">0 / 0 (0%)</span>
      </div>
      <div class="rdp-progress-bar-bg" aria-label="person-progress">
        <div id="rdp-progress-person-fill" class="rdp-progress-bar-fill" style="background-color: #60a5fa;"></div>
      </div>
    </div>
  </div>

  <hr style="margin: 32px 0; border-color: #334155;" />

  <!-- DB Query By ID Section -->
  <div class="rdp-header">
    <h2>按 ID 查询（仅数据库）</h2>
    <p>通过不同类型的 ID 直接查询数据库，不会触发爬取。</p>
  </div>
  <div class="rdp-form-group" style="margin-top: 16px;">
    <div class="rdp-input-wrapper" style="flex: 0.6; min-width: 160px;">
      <label for="rdp-id-type" class="rdp-label">类型</label>
      <select id="rdp-id-type" class="rdp-input">
        <option value="Project">项目 (Project)</option>
        <option value="Organization">机构 (Organization)</option>
        <option value="Person">人物 (Person)</option>
      </select>
    </div>
    <div class="rdp-input-wrapper">
      <label for="rdp-id-value" class="rdp-label">ID</label>
      <input id="rdp-id-value" type="text" inputmode="numeric" placeholder="输入 project_id / org_id / people_id" class="rdp-input" />
    </div>
    <button id="rdp-id-query-btn" class="rdp-btn">查询</button>
  </div>
  <pre id="rdp-id-query-result" class="rdp-result-pre">{"message": "等待查询..."}</pre>

  <hr style="margin: 32px 0; border-color: #334155;" />

  <!-- Manual Scrape Section -->
  <div class="rdp-header">
    <h2>手动单次抓取</h2>
    <p>触发单个 URL 抓取并立即查看结果。</p>
  </div>
  <div class="rdp-form-group">
    <div class="rdp-input-wrapper">
      <label for="rdp-scrape-url" class="rdp-label">RootData URL</label>
      <input id="rdp-scrape-url" type="text" placeholder="粘贴 Projects/Investors/member 链接" class="rdp-input" />
    </div>
    <button id="rdp-scrape-btn" class="rdp-btn">触发抓取</button>
  </div>
  <pre id="rdp-scrape-result" class="rdp-result-pre">{"message": "等待操作..."}</pre>
</div>

<script>
(function() {
  function $(id) { return document.getElementById(id); }

  let statusInterval = null;

  async function jsonFetch(url, options) {
    const res = await fetch(url, {
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      ...options,
    });
    const text = await res.text();
    let data;
    try { data = JSON.parse(text); } catch { data = { raw: text }; }
    if (!res.ok) {
      const msg = data && (data.message || data.error) ? (data.message || data.error) : ('HTTP ' + res.status);
      throw new Error(msg);
    }
    return data;
  }

  function syntaxHighlight(json) {
    if (typeof json != 'string') json = JSON.stringify(json, undefined, 2);
    json = json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d+)?(?:[eE][+\-]?\d+)?)/g, function (match) {
        let cls = 'number';
        if (/^"/.test(match)) cls = /:$/.test(match) ? 'key' : 'string';
        else if (/true|false/.test(match)) cls = 'boolean';
        else if (/null/.test(match)) cls = 'null';
        return '<span class="' + cls + '">' + match + '</span>';
    });
  }

  function prettyPrint(el, obj) { el.innerHTML = syntaxHighlight(obj); }

  async function handleApiCall(button, resultEl, action) {
    const originalText = button.textContent;
    try {
      button.disabled = true;
      button.textContent = 'Loading...';
      if(resultEl) prettyPrint(resultEl, { status: 'loading...' });
      const data = await action();
      if(resultEl) prettyPrint(resultEl, data);
    } catch (e) {
      if(resultEl) prettyPrint(resultEl, { success: false, error: String(e.message || e) });
    } finally {
      button.disabled = false;
      button.textContent = originalText;
    }
  }

  function updateProgress(p) {
    const safeP = p || { total: 0, completed: 0, project: {}, organization: {}, person: {} };
    const { total, completed, project, organization, person } = safeP;

    const updateBar = (type, data) => {
      const c = data.completed || 0;
      const t = data.total || 0;
      const percent = t > 0 ? (c / t * 100) : 0;
      const percentText = Number.isFinite(percent) ? percent.toFixed(1) : '0.0';
      const fillEl = $(`rdp-progress-${type}-fill`);
      if (fillEl) fillEl.style.width = `${percent}%`;

      const miniEl = $(`rdp-progress-${type}-mini`);
      if (miniEl) miniEl.textContent = `${c} / ${t} (${percentText}%)`;
    };

    updateBar('total', { completed, total });
    updateBar('project', project);
    updateBar('org', organization);
    updateBar('person', person);
  }

  async function updateCrawlStatus() {
    try {
        const res = await jsonFetch('/api/rootdatapro/internal/crawl/status');
        const { status, progress } = res.data;

        const statusEl = $('rdp-task-status-value');
        statusEl.textContent = String(status || '-').toUpperCase();
        statusEl.className = `rdp-task-status-value status-${status}`;

        const dotEl = $('rdp-live-dot');
        const liveTextEl = $('rdp-live-text');
        if (dotEl) {
          dotEl.className = `rdp-dot ${status}`;
        }

        updateProgress(progress);

        const now = new Date();
        if (liveTextEl) {
          liveTextEl.textContent = `上次刷新 ${now.toLocaleTimeString()}`;
        }

        if (status === 'running') {
          if (!statusInterval) {
            statusInterval = setInterval(updateCrawlStatus, 2000);
          }
          $('rdp-task-start').disabled = true;
          $('rdp-task-pause').disabled = false;
        } else {
          if (statusInterval) {
            clearInterval(statusInterval);
            statusInterval = null;
          }
          $('rdp-task-start').disabled = status === 'finished';
          $('rdp-task-pause').disabled = true;
        }
    } catch (error) {
        console.error("Failed to fetch crawl status:", error);
        const dotEl = $('rdp-live-dot');
        const liveTextEl = $('rdp-live-text');
        if (dotEl) dotEl.className = 'rdp-dot error';
        if (liveTextEl) liveTextEl.textContent = '刷新失败';

        if (statusInterval) {
            clearInterval(statusInterval);
            statusInterval = null;
        }
    }
  }

  // Task controls
  $('rdp-task-start').addEventListener('click', () => {
    handleApiCall($('rdp-task-start'), null, async () => {
        await jsonFetch('/api/rootdatapro/internal/crawl/start', { method: 'POST' });
        updateCrawlStatus();
    });
  });

  $('rdp-task-pause').addEventListener('click', () => {
    handleApiCall($('rdp-task-pause'), null, async () => {
        await jsonFetch('/api/rootdatapro/internal/crawl/pause', { method: 'POST' });
        updateCrawlStatus();
    });
  });

  $('rdp-task-reset').addEventListener('click', () => {
    if (!confirm('确定要重置所有爬取进度吗？这将从头开始重新爬取未完成的项目。')) return;
    handleApiCall($('rdp-task-reset'), null, async () => {
        await jsonFetch('/api/rootdatapro/internal/crawl/reset', { method: 'POST' });
        updateCrawlStatus();
    });
  });

  // Query by ID (DB only)
  $('rdp-id-query-btn').addEventListener('click', () => {
    handleApiCall($('rdp-id-query-btn'), $('rdp-id-query-result'), async () => {
      const type = $('rdp-id-type').value;
      const rawId = String($('rdp-id-value').value || '').trim();
      const idNum = Number(rawId);
      if (!rawId || !Number.isFinite(idNum)) {
        throw new Error('请输入有效的数字 ID');
      }

      if (type === 'Project') {
        const url = `/api/rootdatapro/open/get_item?project_id=${encodeURIComponent(String(idNum))}`;
        return jsonFetch(url);
      }

      if (type === 'Organization') {
        const url = `/api/rootdatapro/open/get_org?org_id=${encodeURIComponent(String(idNum))}`;
        return jsonFetch(url);
      }

      if (type === 'Person') {
        const url = `/api/rootdatapro/open/get_people?people_id=${encodeURIComponent(String(idNum))}`;
        return jsonFetch(url);
      }

      throw new Error('不支持的类型');
    });
  });

  $('rdp-id-value').addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      $('rdp-id-query-btn').click();
    }
  });

  // Manual scrape
  $('rdp-scrape-btn').addEventListener('click', () => {
    handleApiCall($('rdp-scrape-btn'), $('rdp-scrape-result'), () => {
      return jsonFetch('/api/rootdatapro/internal/scrape', {
        method: 'POST',
        body: JSON.stringify({ url: $('rdp-scrape-url').value }),
      });
    });
  });
  
  $('rdp-refresh-now').addEventListener('click', () => {
    updateCrawlStatus();
  });

  // Initial status load
  updateCrawlStatus();
})();
</script>