        <div class="rdp-progress-bar-fill" style="background-color: #34d399; width: 0%"></div>
      </div>
    </div>

    <div class="rdp-progress-tile">
      <div class="rdp-progress-head">
        <p class="rdp-progress-sub-label">机构 (Organizations)</p>
        <span class="rdp-progress-mini">- / - (-%)</span>
      </div>
      <div class="rdp-progress-bar-bg" aria-label="org-progress">
        <div class="rdp-progress-bar-fill" style="background-color: #fbbf24; width: 0%"></div>
      </div>
