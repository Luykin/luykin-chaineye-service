<style>
  .rdp-card {
    background-color: #1e293b;
    padding: 24px;
    border-radius: 12px;
    border: 1px solid #334155;
  }
  .rdp-header h2 {
    margin: 0 0 8px 0;
    font-size: 20px;
    color: #f1f5f9;
  }
  .rdp-header p {
    color: #94a3b8;
    font-size: 14px;
    margin: 0;
  }
  .rdp-form-group {
    margin-top: 24px;
    display: flex;
    gap: 12px;
    align-items: flex-end;
  }
  .rdp-input-wrapper {
    flex: 1;
  }
  .rdp-label {
    font-size: 12px;
    color: #94a3b8;
    margin-bottom: 6px;
    display: block;
  }
  .rdp-input {
    width: 100%;
    padding: 10px 12px;
    background-color: #0f172a;
    border: 1px solid #475569;
    border-radius: 8px;
    color: #e2e8f0;
    font-size: 14px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .rdp-input:focus {
    outline: none;
    border-color: #38bdf8;
    box-shadow: 0 0 0 2px rgba(56, 189, 248, 0.3);
  }
  .rdp-btn {
    padding: 10px 16px;
    background-color: #0ea5e9;
    color: white;
    border: none;
    border-radius: 8px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s;
    white-space: nowrap;
  }
  .rdp-btn:hover {
    background-color: #0284c7;
  }
  .rdp-btn:disabled {
    background-color: #334155;
    cursor: not-allowed;
  }
  .rdp-result-pre {
    margin-top: 16px;
    background-color: #0f172a;
    color: #e2e8f0;
    padding: 16px;
    border-radius: 8px;
    overflow: auto;
    max-height: 400px;
    border: 1px solid #334155;
    font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
    font-size: 13px;
    line-height: 1.6;
  }
  .rdp-query-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-top: 24px;
  }

  @media (max-width: 768px) {
    .rdp-form-group {
      flex-direction: column;
      align-items: stretch;
    }
  }

  /* Syntax Highlighting for JSON */
  .rdp-result-pre .string { color: #a5d6ff; }
  .rdp-result-pre .number { color: #d8b4fe; }
  .rdp-result-pre .boolean { color: #fca5a5; }
  .rdp-result-pre .null { color: #9ca3af; }
  .rdp-result-pre .key { color: #67e8f9; }
</style>

<div class="rdp-card">
  <div class="rdp-header">
    <h2>RootdataPro 控制台</h2>
    <p>触发爬虫抓取并查询数据库中的实体详情。</p>
  </div>

  <!-- Scrape Section -->
  <div class="rdp-form-group">
    <div class="rdp-input-wrapper">
      <label for="rdp-scrape-url" class="rdp-label">RootData URL</label>
      <input id="rdp-scrape-url" type="text" placeholder="粘贴 Projects/Investors/member 链接" class="rdp-input" />
    </div>
    <button id="rdp-scrape-btn" class="rdp-btn">触发抓取</button>
  </div>
  <pre id="rdp-scrape-result" class="rdp-result-pre">{"message": "等待操作..."}</pre>

  <hr style="margin: 32px 0; border-color: #334155;" />

  <!-- Query Section -->
  <div class="rdp-header">
    <h3 style="font-size: 18px; margin: 0 0 8px 0; color: #f1f5f9;">数据库查询</h3>
  </div>
  <div class="rdp-query-grid">
    <div class="rdp-form-group" style="margin-top: 0;">
      <div class="rdp-input-wrapper">
        <label for="rdp-project-id" class="rdp-label">Project ID</label>
        <input id="rdp-project-id" type="text" placeholder="输入 project_id" class="rdp-input" />
      </div>
      <button id="rdp-project-btn" class="rdp-btn">查询</button>
    </div>
    <div class="rdp-form-group" style="margin-top: 0;">
      <div class="rdp-input-wrapper">
        <label for="rdp-org-id" class="rdp-label">Organization ID</label>
        <input id="rdp-org-id" type="text" placeholder="输入 org_id" class="rdp-input" />
      </div>
      <button id="rdp-org-btn" class="rdp-btn">查询</button>
    </div>
    <div class="rdp-form-group" style="margin-top: 0;">
      <div class="rdp-input-wrapper">
        <label for="rdp-people-id" class="rdp-label">People ID</label>
        <input id="rdp-people-id" type="text" placeholder="输入 people_id" class="rdp-input" />
      </div>
      <button id="rdp-people-btn" class="rdp-btn">查询</button>
    </div>
  </div>
  <pre id="rdp-query-result" class="rdp-result-pre">{"message": "等待查询..."}</pre>
</div>

<script>
(function() {
  function $(id) { return document.getElementById(id); }

  async function jsonFetch(url, options) {
    const res = await fetch(url, {
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      ...options,
    });
    const text = await res.text();
    let data;
    try { data = JSON.parse(text); } catch { data = { raw: text }; }
    if (!res.ok) {
      const msg = data && (data.message || data.error) ? (data.message || data.error) : ('HTTP ' + res.status);
      throw new Error(msg);
    }
    return data;
  }

  function syntaxHighlight(json) {
    if (typeof json != 'string') {
         json = JSON.stringify(json, undefined, 2);
    }
    json = json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d+)?(?:[eE][+\-]?\d+)?)/g, function (match) {
        let cls = 'number';
        if (/^"/.test(match)) {
            if (/:$/.test(match)) {
                cls = 'key';
            } else {
                cls = 'string';
            }
        } else if (/true|false/.test(match)) {
            cls = 'boolean';
        } else if (/null/.test(match)) {
            cls = 'null';
        }
        return '<span class="' + cls + '">' + match + '</span>';
    });
  }

  function prettyPrint(el, obj) {
    el.innerHTML = syntaxHighlight(obj);
  }

  async function handleApiCall(button, resultEl, action) {
    const originalText = button.textContent;
    try {
      button.disabled = true;
      button.textContent = 'Loading...';
      prettyPrint(resultEl, { status: 'loading...' });
      const data = await action();
      prettyPrint(resultEl, data);
    } catch (e) {
      prettyPrint(resultEl, { success: false, error: String(e.message || e) });
    } finally {
      button.disabled = false;
      button.textContent = originalText;
    }
  }

  $('rdp-scrape-btn').addEventListener('click', () => {
    handleApiCall($('rdp-scrape-btn'), $('rdp-scrape-result'), () => {
      return jsonFetch('/api/rootdatapro/internal/scrape', {
        method: 'POST',
        body: JSON.stringify({ url: $('rdp-scrape-url').value }),
      });
    });
  });

  $('rdp-project-btn').addEventListener('click', () => {
    handleApiCall($('rdp-project-btn'), $('rdp-query-result'), () => {
      const id = $('rdp-project-id').value;
      return jsonFetch('/api/rootdatapro/open/get_item?project_id=' + encodeURIComponent(id));
    });
  });

  $('rdp-org-btn').addEventListener('click', () => {
    handleApiCall($('rdp-org-btn'), $('rdp-query-result'), () => {
      const id = $('rdp-org-id').value;
      return jsonFetch('/api/rootdatapro/open/get_org?org_id=' + encodeURIComponent(id));
    });
  });

  $('rdp-people-btn').addEventListener('click', () => {
    handleApiCall($('rdp-people-btn'), $('rdp-query-result'), () => {
      const id = $('rdp-people-id').value;
      return jsonFetch('/api/rootdatapro/open/get_people?people_id=' + encodeURIComponent(id));
    });
  });
})();
</script>