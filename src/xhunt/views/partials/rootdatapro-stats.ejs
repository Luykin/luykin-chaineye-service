<script>
(function() {
  function $(id) { return document.getElementById(id); }

  let statusInterval = null;

  async function jsonFetch(url, options = {}, reqId) {
    const mergedHeaders = { ...(options.headers || {}), 'x-request-id': reqId || `req_${Date.now()}` };
    const finalOpts = { ...options, headers: mergedHeaders };
    const res = await fetch(url, {
      headers: { 'Content-Type': 'application/json', ...finalOpts.headers },
      credentials: 'include',
      ...finalOpts,
    });
    const text = await res.text();
    let data;
    try { data = JSON.parse(text); } catch { data = { raw: text }; }
    if (!res.ok) {
      const msg = data && (data.message || data.error) ? (data.message || data.error) : ('HTTP ' + res.status);
      throw new Error(msg);
    }
    return data;
  }

  function syntaxHighlight(json) {
    if (typeof json != 'string') json = JSON.stringify(json, undefined, 2);
    json = json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d+)?(?:[eE][+\-]?\d+)?)/g, function (match) {
        let cls = 'number';
        if (/^"/.test(match)) cls = /:$/.test(match) ? 'key' : 'string';
        else if (/true|false/.test(match)) cls = 'boolean';
        else if (/null/.test(match)) cls = 'null';
        return '<span class="' + cls + '">' + match + '</span>';
    });
  }

  function prettyPrint(el, obj) { el.innerHTML = syntaxHighlight(obj); }

  async function handleApiCall(button, resultEl, reqIdEl, action) {
    const originalText = button.textContent;
    const reqId = `req_${Date.now()}_${Math.random().toString(36).substring(2, 9)}`;
    try {
      button.disabled = true;
      button.textContent = 'Loading...';

      if (reqIdEl) {
        reqIdEl.textContent = `Request ID: ${reqId}`;
        reqIdEl.style.display = 'block';
      }
      if (resultEl) prettyPrint(resultEl, { status: 'loading...' });

      const data = await action(reqId);
      if (resultEl) prettyPrint(resultEl, data);
    } catch (e) {
      if (resultEl) prettyPrint(resultEl, { success: false, error: String(e.message || e) });
    } finally {
      button.disabled = false;
      button.textContent = originalText;
    }
  }

  function updateProgress(p) {
    const safeP = p || { total: 0, completed: 0, project: {}, organization: {}, person: {} };
    const { total, completed, project, organization, person } = safeP;

    const updateBar = (type, data) => {
      const c = data.completed || 0;
      const t = data.total || 0;
      const percent = t > 0 ? (c / t * 100) : 0;
      const percentText = Number.isFinite(percent) ? percent.toFixed(1) : '0.0';
      const fillEl = $(`rdp-progress-${type}-fill`);
      if (fillEl) fillEl.style.width = `${percent}%`;

      const miniEl = $(`rdp-progress-${type}-mini`);
      if (miniEl) miniEl.textContent = `${c} / ${t} (${percentText}%)`;
    };

    updateBar('total', { completed, total });
    updateBar('project', project);
    updateBar('org', organization);
    updateBar('person', person);
  }

  // 计算到下一个 UTC 03:00 的倒计时
  function updateMaintenanceCountdown() {
    const now = new Date();
    const utcHours = now.getUTCHours();
    const utcMinutes = now.getUTCMinutes();
    const utcSeconds = now.getUTCSeconds();

    // 计算到下一个 UTC 03:00 的毫秒数
    let hoursUntil3am = 3 - utcHours;
    let minutesUntil3am = -utcMinutes;
    let secondsUntil3am = -utcSeconds;

    if (secondsUntil3am < 0) {
      minutesUntil3am--;
      secondsUntil3am += 60;
    }
    if (minutesUntil3am < 0) {
      hoursUntil3am--;
      minutesUntil3am += 60;
    }
    if (hoursUntil3am < 0) {
      hoursUntil3am += 24;
    }

    const countdownEl = $('rdp-maintenance-countdown');
    if (countdownEl) {
      countdownEl.textContent = `${hoursUntil3am}小时 ${minutesUntil3am}分 ${secondsUntil3am}秒`;
    }

    setTimeout(updateMaintenanceCountdown, 1000);
  }

  async function updateCrawlStatus() {
    try {
        const res = await jsonFetch('/api/rootdatapro/internal/crawl/status');
        const { status, progress, failedUrlsCounts, phase, currentTasks, maintenance } = res.data;

        if (failedUrlsCounts) {
          $('rdp-failed-project-mini').textContent = failedUrlsCounts.Project || 0;
          $('rdp-failed-org-mini').textContent = failedUrlsCounts.Organization || 0;
          $('rdp-failed-person-mini').textContent = failedUrlsCounts.Person || 0;
        }

        const statusEl = $('rdp-task-status-value');
        statusEl.textContent = String(status || '-').toUpperCase();
        statusEl.className = `rdp-task-status-value status-${status}`;

        // 显示当前执行阶段
        const phaseEl = $('rdp-task-phase');
        if (phaseEl) {
          const phaseMap = {
            'idle': '空闲',
            'crawling_new': '正在爬取新任务',
            'retrying_failures': '正在重试失败任务',
            'discovering_new_ids': '正在增量发现新 ID',
            'finished': '已完成',
            'paused': '已暂停',
            'unknown': '未知状态',
          };
          const phaseText = phaseMap[phase] || phase || '';
          phaseEl.textContent = phaseText ? `(${phaseText})` : '';
          phaseEl.className = `rdp-task-phase phase-${phase || ''}`;
        }

        const dotEl = $('rdp-live-dot');
        const liveTextEl = $('rdp-live-text');
        if (dotEl) {
          dotEl.className = `rdp-dot ${status}`;
        }

        updateProgress(progress);

        // 当前正在爬取的任务（只展示第一个 worker 的任务）
        const currentTaskEl = $('rdp-current-task');
        if (currentTaskEl) {
          if (Array.isArray(currentTasks) && currentTasks.length > 0) {
            const t = currentTasks[0];
            const typeLabelMap = {
              Project: '项目',
              Organization: '机构',
              Person: '人物',
            };
            const typeLabel = typeLabelMap[t.typeName] || t.typeName || t.type;
            currentTaskEl.textContent = `ID ${t.id}（${typeLabel}，Worker #${t.workerId}）`;
          } else {
            currentTaskEl.textContent = '-';
          }
        }

        const now = new Date();
        if (liveTextEl) {
          liveTextEl.textContent = `上次刷新 ${now.toLocaleTimeString()}`;
        }

        // 更新每日维护任务状态
        const maintenanceStatusEl = $('rdp-maintenance-status');
        const maintenanceStageEl = $('rdp-maintenance-stage');
        const isMaintenanceRunning = status === 'maintenance_running';
        
        if (maintenanceStatusEl) {
          if (isMaintenanceRunning) {
            maintenanceStatusEl.textContent = '执行中';
            maintenanceStatusEl.style.color = '#38bdf8';
          } else {
            maintenanceStatusEl.textContent = '空闲';
            maintenanceStatusEl.style.color = '#94a3b8';
          }
        }

        // 显示当前执行阶段
        if (maintenanceStageEl) {
          if (isMaintenanceRunning && maintenance && maintenance.stage) {
            const stage = maintenance.stage;
            let displayText = stage.message || '执行中...';
            
            // 如果有进度信息，可以显示更详细的信息
            if (stage.step === 'processing_queue' && stage.totalTasks && stage.totalTasks > 0) {
              const progress = ((stage.processedTasks || 0) / stage.totalTasks * 100).toFixed(1);
              displayText = `${stage.message} (进度: ${progress}%)`;
            }
            
            maintenanceStageEl.textContent = displayText;
            maintenanceStageEl.style.display = 'block';
            maintenanceStageEl.style.color = '#38bdf8';
            maintenanceStageEl.style.fontSize = '12px';
            maintenanceStageEl.style.marginTop = '4px';
          } else {
            maintenanceStageEl.style.display = 'none';
          }
        }

        // 禁用/启用手动操作按钮（当 maintenance 运行时）
        $('rdp-task-start').disabled = isMaintenanceRunning;
        $('rdp-task-pause').disabled = isMaintenanceRunning;
        $('rdp-task-reset').disabled = isMaintenanceRunning;
        $('rdp-maintenance-run-now').disabled = isMaintenanceRunning;

        // 显示执行报告（只在非运行状态时显示上次报告）
        if (maintenance && !isMaintenanceRunning && maintenance.lastReport) {
          const reportEl = $('rdp-maintenance-report');
          const reportContentEl = $('rdp-maintenance-report-content');
          if (reportEl && reportContentEl) {
            reportEl.style.display = 'block';
            prettyPrint(reportContentEl, maintenance.lastReport);
          }
        } else if (isMaintenanceRunning) {
          // 运行中时隐藏报告
          const reportEl = $('rdp-maintenance-report');
          if (reportEl) {
            reportEl.style.display = 'none';
          }
        }

        if (status === 'running' || status === 'maintenance_running') {
          if (!statusInterval) {
            statusInterval = setInterval(updateCrawlStatus, 8000);
          }
          if (status === 'running') {
            $('rdp-task-start').disabled = false;
            $('rdp-task-start').textContent = '接管/启动';
            $('rdp-task-pause').disabled = false;
          }
        } else {
          if (statusInterval) {
            clearInterval(statusInterval);
            statusInterval = null;
          }
          $('rdp-task-start').disabled = status === 'finished';
          $('rdp-task-start').textContent = '启动';
          $('rdp-task-pause').disabled = true;
        }
    } catch (error) {
        console.error("Failed to fetch crawl status:", error);
        const dotEl = $('rdp-live-dot');
        const liveTextEl = $('rdp-live-text');
        if (dotEl) dotEl.className = 'rdp-dot error';
        if (liveTextEl) liveTextEl.textContent = '刷新失败';

        if (statusInterval) {
            clearInterval(statusInterval);
            statusInterval = null;
        }
    }
  }

  // Task controls
  // Task controls
  $('rdp-task-start').addEventListener('click', () => {
    handleApiCall($('rdp-task-start'), null, null, async () => {
        await jsonFetch('/api/rootdatapro/internal/crawl/start', { method: 'POST' });
        updateCrawlStatus();
    });
  });

  $('rdp-task-pause').addEventListener('click', () => {
    handleApiCall($('rdp-task-pause'), null, null, async () => {
        await jsonFetch('/api/rootdatapro/internal/crawl/pause', { method: 'POST' });
        updateCrawlStatus();
    });
  });

  $('rdp-task-reset').addEventListener('click', () => {
    if (!confirm('确定要重置所有爬取进度吗？这将从头开始重新爬取未完成的项目。')) return;
    handleApiCall($('rdp-task-reset'), null, null, async () => {
        await jsonFetch('/api/rootdatapro/internal/crawl/reset', { method: 'POST' });
        updateCrawlStatus();
    });
  });

  // Query by ID (DB only)
  $('rdp-id-query-btn').addEventListener('click', () => {
    handleApiCall($('rdp-id-query-btn'), $('rdp-id-query-result'), $('rdp-id-query-reqid'), async (reqId) => {
      const type = $('rdp-id-type').value;
      const rawId = String($('rdp-id-value').value || '').trim();
      const idNum = Number(rawId);
      if (!rawId || !Number.isFinite(idNum)) {
        throw new Error('请输入有效的数字 ID');
      }

      const proApiKey = "rk_d480491638fc914a8ae53c161ac4e2a9c36be02b5b349ce2";

      const commonHeaders = {
        'pro-api-key': proApiKey,
      };

      if (type === 'Project') {
        const url = `/api/rootdatapro/open/get_item?project_id=${encodeURIComponent(String(idNum))}`;
        return jsonFetch(url, { headers: commonHeaders }, reqId);
      }

      if (type === 'Organization') {
        const url = `/api/rootdatapro/open/get_org?org_id=${encodeURIComponent(String(idNum))}`;
        return jsonFetch(url, { headers: commonHeaders }, reqId);
      }

      if (type === 'Person') {
        const url = `/api/rootdatapro/open/get_people?people_id=${encodeURIComponent(String(idNum))}`;
        return jsonFetch(url, { headers: commonHeaders }, reqId);
      }

      throw new Error('不支持的类型');
    });
  });

  $('rdp-id-value').addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      $('rdp-id-query-btn').click();
    }
  });

  $('rdp-apikey-create').addEventListener('click', () => {
    handleApiCall($('rdp-apikey-create'), $('rdp-apikey-result'), $('rdp-apikey-reqid'), async (reqId) => {
      const remark = prompt('备注（可选）', '');
      return jsonFetch('/api/rootdatapro/internal/apikey/create', {
        method: 'POST',
        body: JSON.stringify({ remark: remark || null }),
      }, reqId);
    });
  });

  $('rdp-apikey-topup').addEventListener('click', () => {
    handleApiCall($('rdp-apikey-topup'), $('rdp-apikey-topup-result'), $('rdp-apikey-topup-reqid'), async (reqId) => {
      const key = String($('rdp-apikey-topup-key').value || '').trim();
      const amountRaw = $('rdp-apikey-topup-amount').value;
      const amount = Number(amountRaw);

      if (!key) throw new Error('请输入要充值的 API Key');
      if (!Number.isFinite(amount) || amount <= 0) throw new Error('请输入正确的充值额度');

      return jsonFetch('/api/rootdatapro/internal/apikey/topup', {
        method: 'POST',
        body: JSON.stringify({ key, amount }),
      }, reqId);
    });
  });

  // Manual scrape
  $('rdp-scrape-btn').addEventListener('click', () => {
    handleApiCall($('rdp-scrape-btn'), $('rdp-scrape-result'), $('rdp-scrape-reqid'), (reqId) => {
      return jsonFetch('/api/rootdatapro/internal/scrape', {
        method: 'POST',
        body: JSON.stringify({ url: $('rdp-scrape-url').value }),
      }, reqId);
    });
  });
  
  $('rdp-refresh-now').addEventListener('click', () => {
    updateCrawlStatus();
  });

  // 立即执行每日维护任务
  $('rdp-maintenance-run-now').addEventListener('click', async () => {
    const btn = $('rdp-maintenance-run-now');
    const originalText = btn.textContent;
    try {
      btn.disabled = true;
      btn.textContent = '执行中...';
      
      const result = await jsonFetch('/api/rootdatapro/internal/crawl/maintenance/run_now', {
        method: 'POST',
      });

      if (!result.success) {
        alert(`执行失败: ${result.error || result.message || '未知错误'}`);
      } else {
        alert('每日维护任务已开始执行');
        updateCrawlStatus();
      }
    } catch (e) {
      console.error('执行失败:', e);
      alert('请求失败: ' + (e.message || String(e)));
    } finally {
      setTimeout(() => {
        btn.disabled = false;
        btn.textContent = originalText;
      }, 2000);
    }
  });

  // 强制重置状态
  $('rdp-maintenance-force-reset').addEventListener('click', async () => {
    if (!confirm('确定要强制重置状态吗？\n\n只有在您确信后台没有任务在运行时才应使用此功能，否则可能导致状态不一致。')) {
      return;
    }

    const btn = $('rdp-maintenance-force-reset');
    const originalText = btn.textContent;
    try {
      btn.disabled = true;
      btn.textContent = '重置中...';
      
      const result = await jsonFetch('/api/rootdatapro/internal/crawl/force_reset_status', {
        method: 'POST',
      });

      if (result.success) {
        alert('状态已成功重置为 idle');
        updateCrawlStatus();
      } else {
        alert(`重置失败: ${result.error || '未知错误'}`);
      }
    } catch (e) {
      console.error('重置失败:', e);
      alert('请求失败: ' + (e.message || String(e)));
    } finally {
      setTimeout(() => {
        btn.disabled = false;
        btn.textContent = originalText;
      }, 2000);
    }
  });

  // Initial status load
  updateCrawlStatus();
  updateMaintenanceCountdown();
})();
</script>
