<div class="card">
  <h2>RootdataPro 控制台</h2>
  <p style="color:#6b7280;font-size:13px;">仅 super 可见。用于触发抓取并查询入库结果。</p>

  <div style="margin-top:12px; display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
    <input id="rdp-scrape-url" type="text" placeholder="粘贴 RootData 链接（Projects/Investors/member）" style="flex:1; min-width:420px; padding:8px 10px; border:1px solid #e5e7eb; border-radius:8px;" />
    <button id="rdp-scrape-btn" class="btn" style="padding:8px 12px;">触发抓取并入库</button>
  </div>

  <pre id="rdp-scrape-result" style="margin-top:10px; background:#0b1220; color:#e2e8f0; padding:12px; border-radius:10px; overflow:auto; max-height:320px;"></pre>

  <hr style="margin:18px 0;" />

  <h3 style="margin:0 0 8px;">查询</h3>

  <div style="display:grid; grid-template-columns: 1fr auto; gap:10px; max-width:720px;">
    <div>
      <div style="font-size:12px; color:#6b7280; margin-bottom:4px;">Project ID</div>
      <input id="rdp-project-id" type="text" placeholder="project_id" style="width:100%; padding:8px 10px; border:1px solid #e5e7eb; border-radius:8px;" />
    </div>
    <div style="display:flex; align-items:flex-end;">
      <button id="rdp-project-btn" class="btn" style="padding:8px 12px;">查询项目</button>
    </div>

    <div>
      <div style="font-size:12px; color:#6b7280; margin-bottom:4px;">Organization ID</div>
      <input id="rdp-org-id" type="text" placeholder="org_id" style="width:100%; padding:8px 10px; border:1px solid #e5e7eb; border-radius:8px;" />
    </div>
    <div style="display:flex; align-items:flex-end;">
      <button id="rdp-org-btn" class="btn" style="padding:8px 12px;">查询机构</button>
    </div>

    <div>
      <div style="font-size:12px; color:#6b7280; margin-bottom:4px;">People ID</div>
      <input id="rdp-people-id" type="text" placeholder="people_id" style="width:100%; padding:8px 10px; border:1px solid #e5e7eb; border-radius:8px;" />
    </div>
    <div style="display:flex; align-items:flex-end;">
      <button id="rdp-people-btn" class="btn" style="padding:8px 12px;">查询人物</button>
    </div>
  </div>

  <pre id="rdp-query-result" style="margin-top:10px; background:#0b1220; color:#e2e8f0; padding:12px; border-radius:10px; overflow:auto; max-height:420px;"></pre>
</div>

<script>
(function() {
  function $(id) { return document.getElementById(id); }

  async function jsonFetch(url, options) {
    const res = await fetch(url, {
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      ...options,
    });
    const text = await res.text();
    let data;
    try { data = JSON.parse(text); } catch { data = { raw: text }; }
    if (!res.ok) {
      const msg = data && (data.message || data.error) ? (data.message || data.error) : ('HTTP_' + res.status);
      throw new Error(msg);
    }
    return data;
  }

  function prettyPrint(el, obj) {
    el.textContent = JSON.stringify(obj, null, 2);
  }

  const scrapeBtn = $('rdp-scrape-btn');
  const scrapeUrl = $('rdp-scrape-url');
  const scrapeResult = $('rdp-scrape-result');

  const qResult = $('rdp-query-result');

  scrapeBtn.addEventListener('click', async () => {
    try {
      scrapeBtn.disabled = true;
      prettyPrint(scrapeResult, { loading: true });
      const data = await jsonFetch('/api/rootdatapro/internal/scrape', {
        method: 'POST',
        body: JSON.stringify({ url: scrapeUrl.value }),
      });
      prettyPrint(scrapeResult, data);
    } catch (e) {
      prettyPrint(scrapeResult, { success: false, error: String(e.message || e) });
    } finally {
      scrapeBtn.disabled = false;
    }
  });

  $('rdp-project-btn').addEventListener('click', async () => {
    try {
      prettyPrint(qResult, { loading: true });
      const id = $('rdp-project-id').value;
      const data = await jsonFetch('/api/rootdatapro/open/get_item?project_id=' + encodeURIComponent(id), { method: 'GET' });
      prettyPrint(qResult, data);
    } catch (e) {
      prettyPrint(qResult, { success: false, error: String(e.message || e) });
    }
  });

  $('rdp-org-btn').addEventListener('click', async () => {
    try {
      prettyPrint(qResult, { loading: true });
      const id = $('rdp-org-id').value;
      const data = await jsonFetch('/api/rootdatapro/open/get_org?org_id=' + encodeURIComponent(id), { method: 'GET' });
      prettyPrint(qResult, data);
    } catch (e) {
      prettyPrint(qResult, { success: false, error: String(e.message || e) });
    }
  });

  $('rdp-people-btn').addEventListener('click', async () => {
    try {
      prettyPrint(qResult, { loading: true });
      const id = $('rdp-people-id').value;
      const data = await jsonFetch('/api/rootdatapro/open/get_people?people_id=' + encodeURIComponent(id), { method: 'GET' });
      prettyPrint(qResult, data);
    } catch (e) {
      prettyPrint(qResult, { success: false, error: String(e.message || e) });
    }
  });
})();
</script>

