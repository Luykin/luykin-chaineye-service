    function deleteCampaign() {
      const c = getCurrentCampaign();
      if (!c) return;
      const okFirst = window.confirm(
        `确认删除该活动？\n\nid=${c.id || ""}\n\n提示：删除后需要点击“发布到 Nacos”才会生效。`
