<div class="campaigns-container">
  <div class="campaigns-header">
    <h2>🎯 Earn 活动配置（Nacos）</h2>
    <p>
      可视化编辑 Nacos 配置：<code>xhunt_campaigns</code>（结构：<code>{ version, campaigns: [] }</code>）
    </p>
  </div>

  <div class="campaigns-toolbar">
    <div class="left">
      <span class="muted"
        >当前 dataId：<code id="campaigns-dataid">xhunt_campaigns</code></span
      >
      <span class="muted">group：<code>DEFAULT_GROUP</code></span>
    </div>

    <div class="right">
      <div class="campaigns-search">
        <span class="icon">🔍</span>
        <input
          id="campaigns-search"
          type="text"
          placeholder="搜索活动（id / campaignKey / 标题）"
        />
      </div>
      <button class="btn primary" id="campaigns-refresh">🔄 从 Nacos 重新加载</button>
      <button class="btn" id="campaigns-new">➕ 新增活动</button>
      <button class="btn" id="campaigns-duplicate" disabled>🧬 复制活动</button>
      <button class="btn btn-sm danger" id="campaigns-delete" disabled>🗑️ 删除当前</button>
      <button class="btn success" id="campaigns-publish" disabled>
        🚀 发布到 Nacos
      </button>
    </div>
  </div>

  <div class="campaigns-body">
    <div class="list">
      <div class="list-header">
        <strong>活动列表</strong>
        <span class="muted" id="campaigns-count">0 个</span>
      </div>
      <div class="list-items" id="campaigns-list"></div>
    </div>

    <div class="editor">
      <div class="editor-header">
        <div>
          <strong>编辑</strong>
          <span class="muted" id="campaigns-editor-hint">选择左侧一条活动开始编辑</span>
        </div>
      </div>

      <div id="campaigns-editor-empty" class="editor-empty">
        <div class="empty-title">请选择左侧一条活动</div>
        <div class="empty-desc">
          从左侧列表点击任一活动即可开始编辑；你也可以点击上方
          <strong>「新增活动」</strong> 来创建新的 Earn 活动。
        </div>
      </div>

      <div id="campaigns-editor-body" style="display: none">
        <div class="field-row field-row-toggle">
          <div class="field">
            <label>活动启用（enabled）</label>
            <label class="switch">
              <input id="campaigns-enabled" type="checkbox" disabled />
              <span class="slider"></span>
            </label>
          </div>
          <div class="field">
            <label>测试期（testingPhase）</label>
            <label class="switch">
              <input id="campaigns-testingPhase" type="checkbox" disabled />
              <span class="slider"></span>
            </label>
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label>id（唯一）</label>
            <input id="campaigns-id" type="text" placeholder="例如：bybit-hunter" />
          </div>
          <div class="field">
            <label>campaignKey</label>
            <input id="campaigns-campaignKey" type="text" placeholder="例如：bybit" />
          </div>
          <div class="field">
            <label>hotTweetsKey</label>
            <input
              id="campaigns-hotTweetsKey"
              type="text"
              placeholder="例如：bybit"
            />
          </div>
        </div>

        <div class="section">
          <div class="section-title">展示名称（DisplayName）</div>
          <div class="field-row field-row-2">
            <div class="field">
              <label>中文</label>
              <input id="campaigns-displayName-zh" type="text" />
            </div>
            <div class="field">
              <label>English</label>
              <input id="campaigns-displayName-en" type="text" />
            </div>
          </div>
        </div>

        <div class="section">
          <div class="section-title">报名窗口（Enrollment Window）</div>
          <div class="field-row field-row-2">
            <div class="field">
              <label>startAt（本地时间）</label>
              <input id="campaigns-startAt" type="datetime-local" />
            </div>
            <div class="field">
              <label>endAt（本地时间）</label>
              <input id="campaigns-endAt" type="datetime-local" />
            </div>
          </div>
          <div class="muted" style="margin-top: 6px">
            保存时会转换为 UTC ISO 字符串（例如 <code>2025-12-10T00:00:00Z</code>）。
          </div>
        </div>

        <div class="section">
          <div class="section-title">文案（Copy）</div>
          <div class="field-row field-row-3">
            <div class="field">
              <label>emoji</label>
              <input id="campaigns-copy-emoji" type="text" placeholder="例如：🎉" />
            </div>
            <div class="field">
              <label>ctaText（zh）</label>
              <input id="campaigns-copy-ctaText-zh" type="text" />
            </div>
            <div class="field">
              <label>ctaText（en）</label>
              <input id="campaigns-copy-ctaText-en" type="text" />
            </div>
          </div>

          <div class="field-row field-row-2">
            <div class="field">
              <label>title（zh）</label>
              <input id="campaigns-copy-title-zh" type="text" />
            </div>
            <div class="field">
              <label>title（en）</label>
              <input id="campaigns-copy-title-en" type="text" />
            </div>
          </div>

          <div class="field-row field-row-2">
            <div class="field">
              <label>shortTitle（zh）</label>
              <input id="campaigns-copy-shortTitle-zh" type="text" />
            </div>
            <div class="field">
              <label>shortTitle（en）</label>
              <input id="campaigns-copy-shortTitle-en" type="text" />
            </div>
          </div>

          <div class="field-row field-row-2">
            <div class="field">
              <label>goToOfficialText（zh）</label>
              <input id="campaigns-copy-goToOfficialText-zh" type="text" />
            </div>
            <div class="field">
              <label>goToOfficialText（en）</label>
              <input id="campaigns-copy-goToOfficialText-en" type="text" />
            </div>
          </div>

          <div class="field-row field-row-2">
            <div class="field">
              <label>viewGuideText（zh）</label>
              <input id="campaigns-copy-viewGuideText-zh" type="text" />
            </div>
            <div class="field">
              <label>viewGuideText（en）</label>
              <input id="campaigns-copy-viewGuideText-en" type="text" />
            </div>
          </div>
        </div>

        <div class="section">
          <div class="section-title">链接（Links）</div>
          <div class="field-row field-row-2">
            <div class="field">
              <label>guideUrl</label>
              <input
                id="campaigns-links-guideUrl"
                type="text"
                placeholder="https://..."
              />
            </div>
            <div class="field">
              <label>activeUrl</label>
              <input
                id="campaigns-links-activeUrl"
                type="text"
                placeholder="https://..."
              />
            </div>
          </div>
        </div>

        <div class="section">
          <div class="section-title">名单（每行一个）</div>
          <div class="field-row field-row-2">
            <div class="field">
              <label>testList</label>
              <textarea
                id="campaigns-testList"
                rows="3"
                placeholder="luoyukun4"
              ></textarea>
            </div>
            <div class="field">
              <label>targetUserIds</label>
              <textarea
                id="campaigns-targetUserIds"
                rows="3"
                placeholder="bybit_web3&#10;Bybit__Alpha"
              ></textarea>
            </div>
          </div>
        </div>

        <div class="section">
          <div class="section-title">
            Logos
            <button class="btn" id="campaigns-logos-add" type="button" disabled>
              ➕ 添加 Logo
            </button>
          </div>
          <div class="repeaters" id="campaigns-logos"></div>
        </div>

        <div class="section">
          <div class="section-title">
            Tasks
            <button class="btn" id="campaigns-tasks-add" type="button" disabled>
              ➕ 添加 Task
            </button>
          </div>
          <div class="repeaters" id="campaigns-tasks"></div>
        </div>

        <div class="preview">
          <div class="preview-header">
            <strong>预览</strong>
            <span class="muted">（用于快速确认核心信息）</span>
          </div>
          <div class="preview-box" id="campaigns-preview"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="campaigns-toast" id="campaigns-toast" style="display: none"></div>

  <!-- JSON 源码编辑模态框 -->
  <div class="json-modal-overlay" id="campaigns-json-modal" style="display: none">
    <div class="json-modal-panel">
      <div class="json-modal-header">
        <h3 id="campaigns-json-modal-title">编辑 JSON</h3>
