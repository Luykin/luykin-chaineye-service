<div class="quick-links">
    <h3>🚀 快捷入口</h3>
    <div class="links-grid">
        <div class="link-item">
            <a href="#" id="open-supabase" target="_blank">
                <span class="link-icon">🗄️</span>
                <div class="link-text">
                    <div class="link-title">Supabase</div>
                    <div class="link-desc">数据库管理平台</div>
                </div>
            </a>
        </div>
        <script>
        (function(){
          const a = document.getElementById('open-supabase');
          if(!a) return;
          a.addEventListener('click', async function(ev){
            ev.preventDefault();
            try{
              const r = await fetch('/admin/supabase/link-token', { method:'POST', headers:{ 'Accept':'application/json' } });
              const j = await r.json();
              if(r.status === 403 && j && j.error === '需要先录入生物识别'){
                alert('请先在“账号安全”中录入生物识别（指纹/面容），再使用 Supabase 入口。');
                return;
              }
              if(!j.success || !j.url){ throw new Error(j.error || '生成票据失败'); }
              window.open(j.url, '_blank', 'noopener');
            }catch(ex){ alert('打开失败：' + (ex.message || ex)); }
          });
        })();
        </script>

