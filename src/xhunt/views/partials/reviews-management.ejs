<!-- 评论管理 -->
<div class="section">
  <h2 class="section-title">评论管理</h2>
  <p class="section-desc">通过被评论人的 Twitter Handle 搜索评论，支持软删除</p>

  <!-- 搜索区域 -->
  <div class="search-box">
    <input
      type="text"
      id="reviews-handle-input"
      placeholder="输入被评论人 Handle（如: elonmusk）"
      onkeypress="if(event.key==='Enter') searchReviews()"
    />
    <button id="reviews-search-btn" class="btn-primary">搜索</button>
  </div>

  <!-- 加载状态 -->
  <div id="reviews-loading" class="loading-state">
    <div class="spinner"></div>
    <span>正在搜索...</span>
  </div>

  <!-- 搜索结果 -->
  <div id="reviews-content" style="display: none">
    <!-- 账号信息 -->
    <div id="reviews-target-info" class="target-info">
      <img id="reviews-target-avatar" src="" alt="avatar" />
      <div class="target-meta">
        <div id="reviews-target-displayname" class="target-name"></div>
        <div id="reviews-target-handle" class="target-handle"></div>
      </div>
      <div class="target-count">
        <div class="count-label">收到评论</div>
        <div id="reviews-total-count" class="count-value"></div>
      </div>
    </div>

    <!-- 评论列表表格 -->
    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            <th class="col-reviewer">评论人</th>
            <th class="col-rating">评分</th>
            <th class="col-tags">标签</th>
            <th class="col-content">评论内容</th>
            <th class="col-time">时间</th>
            <th class="col-action">操作</th>
          </tr>
        </thead>
        <tbody id="reviews-table-body">
          <!-- 动态内容 -->
        </tbody>
      </table>
    </div>
  </div>

  <!-- 空状态 -->
  <div id="reviews-empty" class="empty-state">
    <div class="empty-icon">-</div>
    <h3>未找到评论</h3>
    <p>该账号暂无收到的评论，或账号不存在</p>
  </div>

  <!-- 错误提示 -->
  <div id="reviews-error" class="error-state">
    <div class="error-icon">!</div>
    <h3>搜索失败</h3>
    <p id="reviews-error-message">请稍后重试</p>
  </div>
</div>

<style>
  /* 搜索区域 */
  .section-desc {
    color: #6b7280;
    margin-bottom: 20px;
    font-size: 14px;
  }

  .search-box {
    margin-bottom: 24px;
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .search-box input {
    flex: 1;
    padding: 10px 14px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 14px;
    background: white;
    min-width: 250px;
  }

  .search-box input:focus {
    outline: none;
    border-color: #3b82f6;
  }

  .btn-primary {
    padding: 10px 20px;
    background: #3b82f6;
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
  }

  .btn-primary:hover {
    background: #2563eb;
  }

  /* 加载状态 */
  .loading-state {
    display: none;
    text-align: center;
    padding: 30px;
    color: #6b7280;
  }

  .spinner {
    display: inline-block;
    width: 20px;
    height: 20px;
    border: 2px solid #e5e7eb;
    border-top-color: #3b82f6;
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-right: 8px;
    vertical-align: middle;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* 目标账号信息 */
  .target-info {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    padding: 16px;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .target-info img {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
  }

  .target-meta {
    flex: 1;
  }

  .target-name {
    font-weight: 600;
    font-size: 16px;
    color: #1f2937;
  }

  .target-handle {
    font-size: 14px;
    color: #6b7280;
  }

  .target-count {
    text-align: right;
  }

  .count-label {
    font-size: 12px;
    color: #6b7280;
  }

  .count-value {
    font-size: 24px;
    font-weight: 700;
    color: #3b82f6;
  }

  /* 表格 */
  .table-container {
    overflow-x: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    min-width: 800px;
    font-size: 14px;
  }

  .data-table thead {
    background: #f9fafb;
  }

  .data-table th {
    padding: 10px 12px;
    text-align: left;
    border-bottom: 1px solid #e5e7eb;
    font-weight: 600;
    color: #374151;
    font-size: 13px;
  }

  .data-table td {
    padding: 10px 12px;
    border-bottom: 1px solid #f3f4f6;
  }

  .data-table th.col-reviewer { width: 18%; }
  .data-table th.col-rating { width: 8%; text-align: center; }
  .data-table th.col-tags { width: 20%; }
  .data-table th.col-content { width: 38%; }
  .data-table th.col-time { width: 12%; }
  .data-table th.col-action { width: 8%; text-align: center; }

  /* 空状态和错误状态 */
  .empty-state,
  .error-state {
    display: none;
    text-align: center;
    padding: 50px 20px;
    color: #6b7280;
  }

  .error-state {
    color: #dc2626;
  }

  .empty-icon,
  .error-icon {
    font-size: 48px;
    margin-bottom: 16px;
    color: #d1d5db;
  }

  .error-icon {
    color: #dc2626;
  }

  .empty-state h3,
  .error-state h3 {
    margin-bottom: 8px;
    color: #374151;
    font-size: 16px;
  }

  /* 评论人信息 */
  .reviews-reviewer-info {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .reviews-reviewer-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .reviews-reviewer-details {
    display: flex;
    flex-direction: column;
    gap: 2px;
    overflow: hidden;
  }

  .reviews-reviewer-name {
    font-weight: 600;
    color: #374151;
    font-size: 14px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .reviews-reviewer-username {
    font-size: 12px;
    color: #6b7280;
  }

  .reviews-rating {
    font-weight: 700;
    font-size: 16px;
  }

  .reviews-rating-high {
    color: #10b981;
  }

  .reviews-rating-medium {
    color: #f59e0b;
  }

  .reviews-rating-low {
    color: #ef4444;
  }

  .reviews-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .reviews-tag {
    display: inline-block;
    padding: 2px 8px;
    background: #f3f4f6;
    border-radius: 12px;
    font-size: 12px;
    color: #4b5563;
    border: 1px solid #e5e7eb;
  }

  .reviews-comment {
    font-size: 14px;
    color: #374151;
    line-height: 1.5;
    word-wrap: break-word;
    max-width: 400px;
  }

  .reviews-time {
    font-size: 12px;
    color: #6b7280;
  }

  .reviews-delete-btn {
    padding: 6px 12px;
    background: #ef4444;
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .reviews-delete-btn:hover {
    background: #dc2626;
  }

  .reviews-delete-btn:disabled {
    background: #9ca3af;
    cursor: not-allowed;
  }

  .reviews-row-deleted {
    opacity: 0.5;
    background: #f3f4f6 !important;
  }

  .reviews-row-deleted td {
    text-decoration: line-through;
    color: #9ca3af;
  }
</style>

<script>
  // 绑定搜索按钮点击事件
  document.addEventListener('DOMContentLoaded', function() {
    const searchBtn = document.getElementById('reviews-search-btn');
    if (searchBtn) {
      searchBtn.addEventListener('click', searchReviews);
    }
  });

  // 搜索评论
  function searchReviews() {
    const handleInput = document.getElementById("reviews-handle-input");
    const handle = handleInput.value.trim();

    if (!handle) {
      alert("请输入被评论人 Handle");
      return;
    }

    // 显示加载状态
    document.getElementById("reviews-loading").style.display = "block";
    document.getElementById("reviews-content").style.display = "none";
    document.getElementById("reviews-empty").style.display = "none";
    document.getElementById("reviews-error").style.display = "none";

    // 发送请求
    fetch(`/api/admin/reviews?handle=${encodeURIComponent(handle)}`)
      .then((response) => {
        if (!response.ok) {
          return response.json().then((data) => {
            throw new Error(data.error || `HTTP ${response.status}`);
          });
        }
        return response.json();
      })
      .then((data) => {
        document.getElementById("reviews-loading").style.display = "none";

        if (data.success && data.data.reviews.length > 0) {
          displayReviewsList(data.data);
          document.getElementById("reviews-content").style.display = "block";
        } else {
          document.getElementById("reviews-empty").style.display = "block";
        }
      })
      .catch((error) => {
        console.error("[reviews-management] 搜索失败:", error);
        document.getElementById("reviews-loading").style.display = "none";
        document.getElementById("reviews-error-message").textContent =
          error.message || "请稍后重试";
        document.getElementById("reviews-error").style.display = "block";
      });
  }

  // 显示评论列表
  function displayReviewsList(data) {
    const { targetAccount, reviews, total } = data;

    // 更新目标账号信息
    document.getElementById("reviews-target-avatar").src =
      getProxiedImageUrl(targetAccount.avatar) || "/static/images/default-avatar.png";
    document.getElementById("reviews-target-displayname").textContent =
      targetAccount.displayName || targetAccount.handle;
    document.getElementById("reviews-target-handle").textContent =
      "@" + targetAccount.handle;
    document.getElementById("reviews-total-count").textContent = total;

    // 渲染表格
    const tbody = document.getElementById("reviews-table-body");
    tbody.innerHTML = "";

    reviews.forEach((review) => {
      const row = document.createElement("tr");
      row.style.borderBottom = "1px solid #f3f4f6";
      row.dataset.reviewId = review.id;

      // 评分颜色
      let ratingClass = "reviews-rating-low";
      if (review.rating >= 4) ratingClass = "reviews-rating-high";
      else if (review.rating >= 2.5) ratingClass = "reviews-rating-medium";

      // 标签 HTML
      const tagsHtml =
        review.tags && review.tags.length > 0
          ? review.tags
              .map((tag) => `<span class="reviews-tag">${escapeHtmlReviews(tag)}</span>`)
              .join("")
          : '<span style="color: #9ca3af; font-size: 12px;">无标签</span>';

      row.innerHTML = `
        <td style="padding: 12px;">
          <div class="reviews-reviewer-info">
            <img src="${escapeHtmlReviews(getProxiedImageUrl(review.reviewer.avatar) || "/static/images/default-avatar.png")}"
                 alt="" class="reviews-reviewer-avatar">
            <div class="reviews-reviewer-details">
              <div class="reviews-reviewer-name">${escapeHtmlReviews(review.reviewer.displayName || "未知用户")}</div>
              <div class="reviews-reviewer-username">@${escapeHtmlReviews(review.reviewer.username || "unknown")}</div>
            </div>
          </div>
        </td>
        <td style="padding: 12px; text-align: center;">
          <span class="reviews-rating ${ratingClass}">${review.rating.toFixed(1)}</span>
        </td>
        <td style="padding: 12px;">
          <div class="reviews-tags">${tagsHtml}</div>
        </td>
        <td style="padding: 12px;">
          <div class="reviews-comment">${escapeHtmlReviews(review.comment || "无评论内容")}</div>
        </td>
        <td style="padding: 12px;">
          <div class="reviews-time">${escapeHtmlReviews(review.createdAt)}</div>
        </td>
        <td style="padding: 12px; text-align: center;">
          <button class="reviews-delete-btn" data-review-id="${review.id}">
            删除
          </button>
        </td>
      `;

      tbody.appendChild(row);
    });
  }

  // 绑定删除按钮事件（使用事件委托）
  document.addEventListener('click', function(e) {
    if (e.target && e.target.classList.contains('reviews-delete-btn')) {
      const reviewId = e.target.dataset.reviewId;
      if (reviewId) {
        deleteReviewItem(reviewId, e.target);
      }
    }
  });

  // 删除评论
  function deleteReviewItem(reviewId, btnElement) {
    const confirmed = confirm(
      "确定要删除这条评论吗？\n\n删除后：\n- 评论将归属于虚拟账号\n- 被评论人将不再看到这条评论\n- 此操作不可恢复"
    );

    if (!confirmed) return;

    // 禁用按钮
    btnElement.disabled = true;
    btnElement.textContent = "删除中...";

    fetch("/api/admin/reviews/delete", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({ reviewId }),
    })
      .then((response) => {
        if (!response.ok) {
          return response.json().then((data) => {
            throw new Error(data.error || `HTTP ${response.status}`);
          });
        }
        return response.json();
      })
      .then((data) => {
        if (data.success) {
          // 标记行为已删除
          const row = btnElement.closest("tr");
          row.classList.add("reviews-row-deleted");
          btnElement.textContent = "已删除";
          btnElement.disabled = true;

          // 更新计数
          const countEl = document.getElementById("reviews-total-count");
          const currentCount = parseInt(countEl.textContent, 10);
          countEl.textContent = Math.max(0, currentCount - 1);

          alert("评论已删除");
        } else {
          throw new Error(data.error || "删除失败");
        }
      })
      .catch((error) => {
        console.error("[reviews-management] 删除失败:", error);
        alert("删除失败: " + error.message);
        btnElement.disabled = false;
        btnElement.textContent = "删除";
      });
  }

  // HTML 转义
  function escapeHtmlReviews(text) {
    if (!text) return "";
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }

  // 图片代理（解决跨域问题）
  function getProxiedImageUrl(url) {
    if (!url) return null;
    // 如果是相对路径或已代理的URL，直接返回
    if (url.startsWith('/') || url.includes('wsrv.nl')) return url;
    // 使用 wsrv.nl 代理
    return `https://wsrv.nl/?url=${encodeURIComponent(url)}&w=100&h=100&fit=cover`;
  }

  // 将函数挂载到全局，供 stats.js 调用
  window.searchReviews = searchReviews;
</script>
