        />
      </div>
      <div style="display:flex;gap:10px;">
        <button id="rootdata-force-btn" style="flex:1;padding:10px 20px;background:#10b981;color:#fff;border:none;border-radius:6px;cursor:pointer;font-size:14px;font-weight:600;">⚡ 强制更新</button>
