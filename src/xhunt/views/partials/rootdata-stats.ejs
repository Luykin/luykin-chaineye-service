          style="width:100%;padding:10px;border:1px solid #d1d5db;border-radius:6px;font-size:14px;background:#f3f4f6;"
        />
      </div>
      <div style="display:flex;gap:10px;">
        <button id="rootdata-force-btn" disabled style="flex:1;padding:10px 20px;background:#9ca3af;color:#fff;border:none;border-radius:6px;cursor:not-allowed;font-size:14px;font-weight:600;">🚫 已禁用</button>
      </div>
      <div id="rootdata-force-status" style="display:none;margin-top:12px;padding:12px;background:#f3f4f6;border-radius:6px;color:#374151;font-size:14px"></div>
    </div>
  </div>
    <h2 class="section-title">📊 按天新增数据统计</h2>

    <!-- 日期选择器 -->
