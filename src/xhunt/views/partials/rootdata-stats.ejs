    <!-- 统计概览 -->
    <div id="rootdata-daily-summary" style="display: none; margin-bottom: 30px">
      <div class="stats-grid" style="grid-template-columns: repeat(3, 1fr)">
        <div class="stat-card">
          <div class="stat-title">新增项目数</div>
          <div class="stat-value" id="rootdata-new-projects-count">0</div>
        </div>
        <div class="stat-card">
