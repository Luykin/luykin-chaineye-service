<style>
  .rootdata-tab-btn.active {
    color: #3b82f6 !important;
    border-bottom-color: #3b82f6 !important;
  }

  .rootdata-tab-btn:hover {
    color: #3b82f6;
  }
</style>

<script>
  (function(){
    // --- 通用函数 ---
    function generateUUID() {
      return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
        const r = (Math.random() * 16) | 0;
        const v = c === 'x' ? r : (r & 0x3) | 0x8;
        return v.toString(16);
      });
    }

    function showReqId(wrapId, textId, reqId) {
      const wrap = document.getElementById(wrapId);
      const text = document.getElementById(textId);
      if (wrap && text) {
        text.textContent = reqId;
        wrap.style.display = 'block';
      }
    }

    function hideReqId(wrapId) {
      const wrap = document.getElementById(wrapId);
      if (wrap) wrap.style.display = 'none';
    }

    // --- 强制 API 更新 ---
    const forceBtn = document.getElementById('rootdata-force-btn');
    const forceInput = document.getElementById('rootdata-force-input');
    const forceStatusEl = document.getElementById('rootdata-force-status');
    let forceBusy = false;

    function setForceStatus(text, ok) {
      forceStatusEl.style.display = 'block';
      forceStatusEl.style.background = ok ? '#ecfdf5' : '#fef2f2';
      forceStatusEl.style.color = ok ? '#065f46' : '#991b1b';
      forceStatusEl.textContent = text;
    }

    function buildForceParams(v) {
      const params = new URLSearchParams();
      if (/rootdata\.com\//i.test(v)) {
        if (!/\/Projects\/detail\//i.test(v) && !/\/Investors\/detail\//i.test(v) && !/\/member\//i.test(v)) {
          return { error: 'RootData 链接格式不正确，应包含 /Projects/detail 或 /Investors/detail 或 /member' };
        }
        if (!/[?&]k=/.test(v)) return { error: 'RootData 链接缺少 k= 参数' };
        params.set('projectLink', v);
        return { params };
      }
      if (/^https?:\/\/x\.com\//i.test(v)) {
        if (!/^https?:\/\/x\.com\/[^/]+\/?$/i.test(v)) return { error: 'Twitter 链接应为 https://x.com/<handle>' };
        params.set('twitterUrl', v);
        return { params };
      }
      if (v.length < 2) return { error: '关键词长度至少为 2 个字符' };
      params.set('keyword', v.toLowerCase());
      return { params };
    }

    async function submitForceUpdate() {
      if (forceBusy) return;
      const v = (forceInput.value || '').trim();
      if (!v) return setForceStatus('请输入内容', false);

      const { params, error } = buildForceParams(v);
      if (error) return setForceStatus(error, false);

      const url = '/api/rootdata/force-verify';
      try {
        forceBusy = true;
        forceBtn.disabled = true;
        const oldText = forceBtn.textContent;
        forceBtn.textContent = '处理中...';
        
        const reqId = generateUUID();
        setForceStatus(`请求中...`, true);
        showReqId('rootdata-force-reqid-wrap', 'rootdata-force-reqid-text', reqId);

        const resp = await fetch(url + '?' + params.toString(), {
          method: 'GET',
          headers: { 'x-request-id': reqId },
          credentials: 'include'
        });
        const data = await resp.json().catch(() => ({}));
        const echoedReqId = data?.requestId || reqId;
        showReqId('rootdata-force-reqid-wrap', 'rootdata-force-reqid-text', echoedReqId);

        if (resp.ok) {
          setForceStatus('已触发成功：' + (data?.message || 'OK'), true);
        } else {
          setForceStatus('触发失败：' + (data?.message || resp.statusText), false);
        }

        forceBtn.textContent = oldText;
        forceBtn.disabled = false;
        forceBusy = false;
      } catch (e) {
        setForceStatus('请求异常：' + (e?.message || e), false);
        forceBtn.disabled = false;
        forceBusy = false;
      }
    }

    forceBtn && forceBtn.addEventListener('click', () => {
      let debounceTimer = null;
      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = setTimeout(submitForceUpdate, 400);
    });

    // --- 其他功能的脚本可以放在这里 ---

  })();
</script>
