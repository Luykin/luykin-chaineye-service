<!-- Rootdata 统计页面 -->
<div class="stats-section">
  <!-- 🔑 Rootdata API 配额状态 -->
  <div class="section" id="rootdata-quota-section">
    <h2 class="section-title">🔑 Rootdata API 配额</h2>
    <div class="stat-card" style="max-width: 800px; margin: 0 auto">
      <div
        style="
          display: flex;
          justify-content: space-between;
          align-items: center;
          margin-bottom: 20px;
        "
      >
        <div>
          <div class="stat-title">API 额度使用情况</div>
          <div style="font-size: 14px; color: #6b7280; margin-top: 4px">
            <span id="rootdata-level" style="font-weight: 600; color: #3b82f6"
              >-</span
            >
            级别
          </div>
        </div>
        <div style="text-align: right">
          <div
            style="font-size: 24px; font-weight: 700; color: #10b981"
            id="rootdata-remaining"
          >
            -
          </div>
          <div style="font-size: 14px; color: #6b7280">
            剩余 / <span id="rootdata-total">-</span> 总额
          </div>
        </div>
      </div>

      <!-- 进度条 -->
      <div
        style="
          width: 100%;
          height: 30px;
          background: #e5e7eb;
          border-radius: 15px;
          overflow: hidden;
          position: relative;
          margin-bottom: 15px;
        "
      >
        <div
          id="rootdata-progress-bar"
          style="
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #10b981, #3b82f6);
            transition: width 0.5s ease, background 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding-right: 10px;
          "
        >
          <span
            id="rootdata-progress-text"
            style="color: white; font-weight: 600; font-size: 14px"
          ></span>
        </div>
      </div>

      <!-- 详细信息 -->
      <div
        style="
          display: grid;
          grid-template-columns: repeat(2, 1fr);
          gap: 15px;
          font-size: 14px;
        "
      >
        <div style="display: flex; justify-content: space-between">
          <span style="color: #6b7280">已使用：</span>
          <span id="rootdata-used" style="font-weight: 600; color: #374151"
            >-</span
          >
        </div>
        <div style="display: flex; justify-content: space-between">
          <span style="color: #6b7280">使用率：</span>
          <span
            id="rootdata-usage-percent"
            style="font-weight: 600; color: #374151"
            >-</span
          >
        </div>
        <div style="display: flex; justify-content: space-between">
          <span style="color: #6b7280">周期开始：</span>
          <span
            id="rootdata-period-start"
            style="font-weight: 600; color: #374151"
            >-</span
          >
        </div>
        <div style="display: flex; justify-content: space-between">
          <span style="color: #6b7280">周期结束：</span>
          <span
            id="rootdata-period-end"
            style="font-weight: 600; color: #374151"
            >-</span
          >
        </div>
      </div>

      <!-- 加载状态 -->
      <div
        id="rootdata-loading"
        style="text-align: center; padding: 20px; display: none"
      >
        <div style="color: #6b7280">正在加载配额信息...</div>
        <div id="rootdata-quota-reqid-wrap" style="display:none;margin-top:8px;color:#6b7280;font-size:13px;">
          请求ID：<code id="rootdata-quota-reqid-text" style="color:#374151;background:#eef2ff;padding:2px 6px;border-radius:4px"></code>
        </div>
      </div>

      <!-- 错误提示 -->
      <div
        id="rootdata-error"
        style="
          display: none;
          padding: 15px;
          background: #fef2f2;
          border-left: 4px solid #ef4444;
          border-radius: 4px;
          margin-top: 15px;
        "
      >
        <div style="color: #dc2626; font-weight: 600; margin-bottom: 4px">
          ⚠️ 加载失败
        </div>
        <div
          style="color: #991b1b; font-size: 13px"
          id="rootdata-error-message"
        ></div>
      </div>
    </div>

    <!-- 刷新按钮 -->
    <div style="text-align: center; margin-top: 15px">
      <button
        id="rootdata-quota-refresh-btn"
        style="
          padding: 8px 20px;
          background: #3b82f6;
          color: white;
          border: none;
          border-radius: 6px;
          cursor: pointer;
          font-size: 14px;
          font-weight: 600;
        "
      >
        🔄 刷新配额
      </button>
    </div>
  </div>

  <!-- 🚀 手动触发爬虫（已禁用） -->
  <div
    class="section"
    id="rootdata-manual-crawl-section"
    style="margin-top: 30px; opacity: 0.5; pointer-events: none;"
  >
    <h2 class="section-title">🚀 手动触发爬虫（已禁用）</h2>
    <div class="stat-card" style="max-width: 900px; margin: 0 auto">
      <div style="margin-bottom: 15px">
        <label
          style="
            display: block;
            font-weight: 600;
            color: #374151;
