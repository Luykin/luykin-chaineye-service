      <div id="rootdata-daily-reqid-wrap" style="display:none;margin-top:8px;color:#6b7280;font-size:13px;">
        请求ID：<code id="rootdata-daily-reqid-text" style="color:#374151;background:#eef2ff;padding:2px 6px;border-radius:4px"></code>
