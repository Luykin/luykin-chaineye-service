<script>
(function(){
  function generateUUID() {
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
      const r = (Math.random() * 16) | 0;
      const v = c === 'x' ? r : (r & 0x3) | 0x8;
      return v.toString(16);
    });
  }

  // --- 配额加载 ---
  async function loadQuota() {
    const loadingEl = document.getElementById('rootdata-loading');
    const errorEl = document.getElementById('rootdata-error');

    loadingEl.style.display = 'flex';
    errorEl.style.display = 'none';

    try {
      const resp = await fetch('/api/xhunt/stats/rootdata-quota');
      const data = await resp.json();

      if (data.success) {
        const { level, remaining, total, used, periodStart, periodEnd } = data.data;
        const percent = total > 0 ? Math.round((used / total) * 100) : 0;

        document.getElementById('rootdata-level').textContent = level || '-';
        document.getElementById('rootdata-remaining').textContent = remaining?.toLocaleString() || '-';
        document.getElementById('rootdata-total').textContent = total?.toLocaleString() || '-';
        document.getElementById('rootdata-used').textContent = used?.toLocaleString() || '-';
        document.getElementById('rootdata-usage-percent').textContent = percent + '%';
        document.getElementById('rootdata-period-start').textContent = periodStart || '-';
        document.getElementById('rootdata-period-end').textContent = periodEnd || '-';

        const progressBar = document.getElementById('rootdata-progress-bar');
        progressBar.style.width = percent + '%';

        const statusEl = document.getElementById('rootdata-status');
        if (percent >= 90) {
          progressBar.style.background = 'linear-gradient(90deg, #ef4444, #dc2626)';
          statusEl.textContent = '警告';
          statusEl.className = 'rd-status-badge danger';
        } else if (percent >= 70) {
          progressBar.style.background = 'linear-gradient(90deg, #f59e0b, #d97706)';
          statusEl.textContent = '注意';
          statusEl.className = 'rd-status-badge warning';
        } else {
          progressBar.style.background = 'linear-gradient(90deg, #10b981, #3b82f6)';
          statusEl.textContent = '正常';
          statusEl.className = 'rd-status-badge';
        }
      } else {
        throw new Error(data.error || '加载失败');
      }
    } catch (err) {
      errorEl.style.display = 'block';
      document.getElementById('rootdata-error-message').textContent = err.message;
    } finally {
      loadingEl.style.display = 'none';
    }
  }

  // --- Tab 切换 ---
  document.querySelectorAll('.rd-tab').forEach(tab => {
    tab.addEventListener('click', function() {
      const targetTab = this.dataset.rootdataTab;
      document.querySelectorAll('.rd-tab').forEach(t => t.classList.remove('active'));
      this.classList.add('active');
      document.querySelectorAll('.rd-tab-content').forEach(content => {
        content.style.display = 'none';
      });
      document.getElementById('rootdata-' + targetTab + '-list').style.display = 'block';
    });
  });

  // --- 日期查询 ---
  document.getElementById('rootdata-query-btn')?.addEventListener('click', async function() {
    const date = document.getElementById('rootdata-date-picker').value;
    if (!date) { alert('请选择日期'); return; }

    const loadingEl = document.getElementById('rootdata-daily-loading');
    const errorEl = document.getElementById('rootdata-daily-error');
    const summaryEl = document.getElementById('rootdata-daily-summary');
    const tabsEl = document.getElementById('rootdata-daily-tabs');
    const emptyEl = document.getElementById('rootdata-daily-empty');

    loadingEl.style.display = 'flex';
    errorEl.style.display = 'none';
    summaryEl.style.display = 'none';
    tabsEl.style.display = 'none';
    emptyEl.style.display = 'none';

    try {
      const resp = await fetch('/api/xhunt/stats/rootdata-daily?date=' + date);
      const data = await resp.json();

      if (data.success) {
        const { projects = [], relationships = [] } = data.data || {};

        document.getElementById('rootdata-new-projects-count').textContent = projects.length;
        document.getElementById('rootdata-new-relationships-count').textContent = relationships.length;

        renderProjectsTable(projects);
        renderRelationshipsTable(relationships);

        summaryEl.style.display = 'flex';

        if (projects.length === 0 && relationships.length === 0) {
          emptyEl.style.display = 'block';
        } else {
          tabsEl.style.display = 'block';
          document.querySelector('.rd-tab[data-rootdata-tab="projects"]')?.click();
        }
      } else {
        throw new Error(data.error || '查询失败');
      }
    } catch (err) {
      errorEl.style.display = 'block';
      document.getElementById('rootdata-daily-error-message').textContent = err.message;
    } finally {
      loadingEl.style.display = 'none';
    }
  });

  function renderProjectsTable(projects) {
    const tableEl = document.getElementById('rootdata-projects-table');
    if (!projects || projects.length === 0) {
      tableEl.innerHTML = '<div class="rd-mini-empty">暂无新增项目</div>';
      return;
    }
    const rows = projects.map(p => `
      <tr>
        <td>${p.id || '-'}</td>
        <td><a href="${p.projectLink || '#'}" target="_blank" class="rd-link">${p.projectName || '-'}</a></td>
        <td>${p.isInitial ? '初始' : '普通'}</td>
        <td>${p.createdAt ? new Date(p.createdAt).toLocaleDateString() : '-'}</td>
      </tr>
    `).join('');
    tableEl.innerHTML = `
      <table class="rd-table">
        <thead><tr><th>ID</th><th>名称</th><th>类型</th><th>日期</th></tr></thead>
        <tbody>${rows}</tbody>
      </table>`;
  }

  function renderRelationshipsTable(relationships) {
    const tableEl = document.getElementById('rootdata-relationships-table');
    if (!relationships || relationships.length === 0) {
      tableEl.innerHTML = '<div class="rd-mini-empty">暂无新增关系</div>';
      return;
    }
    const rows = relationships.map(r => `
      <tr>
        <td>${r.id || '-'}</td>
        <td>${r.investorProject?.projectName || '-'}</td>
        <td>${r.fundedProject?.projectName || '-'}</td>
        <td>${r.round || '-'}</td>
      </tr>
    `).join('');
    tableEl.innerHTML = `
      <table class="rd-table">
        <thead><tr><th>ID</th><th>投资方</th><th>被投资方</th><th>轮次</th></tr></thead>
        <tbody>${rows}</tbody>
      </table>`;
  }

  // --- 强制 API 更新 ---
  const forceBtn = document.getElementById('rootdata-force-btn');
  const forceInput = document.getElementById('rootdata-force-input');
  const forceStatus = document.getElementById('rootdata-force-status');
  const forceResult = document.getElementById('rootdata-force-result');
  const forceResultText = document.getElementById('rootdata-force-result-text');
  const forceError = document.getElementById('rootdata-force-error');
  const forceErrorMessage = document.getElementById('rootdata-force-error-message');

  forceBtn?.addEventListener('click', async function() {
    const input = forceInput.value.trim();
    if (!input) { alert('请输入内容'); return; }

    let queryParam = '';
    if (input.includes('rootdata.com')) {
      queryParam = 'projectLink=' + encodeURIComponent(input);
    } else if (input.includes('x.com') || input.includes('twitter.com')) {
      queryParam = 'twitterUrl=' + encodeURIComponent(input);
    } else {
      queryParam = 'keyword=' + encodeURIComponent(input);
    }

    forceStatus.style.display = 'flex';
    forceResult.style.display = 'none';
    forceError.style.display = 'none';
    forceBtn.disabled = true;

    try {
      const resp = await fetch('/api/xhunt/rootdata/force-verify?' + queryParam);
      const data = await resp.json();
      forceStatus.style.display = 'none';

      if (data.success) {
        forceResult.style.display = 'block';
        forceResultText.textContent = `更新成功！项目ID: ${data.projectId}`;
      } else {
        forceError.style.display = 'block';
        forceErrorMessage.textContent = data.message || '更新失败';
      }
    } catch (err) {
      forceStatus.style.display = 'none';
      forceError.style.display = 'block';
      forceErrorMessage.textContent = err.message || '请求失败';
    } finally {
      forceBtn.disabled = false;
    }
  });

  // --- 手动触发爬虫 ---
  const manualBtn = document.getElementById('rootdata-manual-crawl-btn');
  const manualUrl = document.getElementById('rootdata-manual-url');
  const manualForce = document.getElementById('rootdata-manual-force');
  const manualStatus = document.getElementById('rootdata-manual-status');
  const manualResult = document.getElementById('rootdata-manual-result');
  const manualResultSummary = document.getElementById('rootdata-manual-result-summary');
  const manualReqId = document.getElementById('rootdata-manual-reqid');
  const manualResultDetail = document.getElementById('rootdata-manual-result-detail');
  const manualError = document.getElementById('rootdata-manual-error');
  const manualErrorMessage = document.getElementById('rootdata-manual-error-message');

  manualBtn?.addEventListener('click', async function() {
    const url = manualUrl.value.trim();
    const force = manualForce?.checked || false;
    const reqId = 'mc-' + Date.now() + '-' + Math.random().toString(36).substr(2, 9);
    
    if (!url) { alert('请输入 URL'); return; }
    if (!url.includes('rootdata.com')) { alert('请输入有效的 RootData 链接'); return; }
    
    if (force && !confirm('确定要强制重新爬取吗？这将删除该项目的所有旧数据和投资关系！')) {
      return;
    }

    manualStatus.style.display = 'flex';
    manualResult.style.display = 'none';
    manualError.style.display = 'none';
    manualBtn.disabled = true;

    try {
      const resp = await fetch('/api/rootdata/manual-crawl', {
        method: 'POST',
        headers: { 
          'Content-Type': 'application/json',
          'x-request-id': reqId
        },
        body: JSON.stringify({ url, force })
      });
      const data = await resp.json();
      manualStatus.style.display = 'none';

      if (data.success) {
        manualResult.style.display = 'block';
        const project = data.data?.project || {};
        const asInvestor = data.data?.asInvestor || [];
        const asInvestee = data.data?.asInvestee || [];
        
        manualResultSummary.innerHTML = `<strong>${project.projectName || ''}</strong> (${data.data?.duration || '-'}秒)`;
        manualReqId.textContent = `Request ID: ${reqId}`;
        
        let detailHtml = '<div class="rd-crawl-result">';
        
        // 投资的项目
        detailHtml += '<div class="rd-crawl-section">';
        detailHtml += '<div class="rd-crawl-section-title">';
        detailHtml += '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17l9.2-9.2M17 8V2H7v20h10v-6"/></svg>';
        detailHtml += `投资的项目 <span class="rd-crawl-count">(${asInvestor.length})</span>`;
        detailHtml += '</div>';
        if (asInvestor.length > 0) {
          detailHtml += '<div class="rd-crawl-list">';
          asInvestor.slice(0, 5).forEach(item => {
            detailHtml += '<div class="rd-crawl-item">';
            detailHtml += `<img src="${item.project?.logo || '/admin/logo'}" onerror="this.src='/admin/logo'" />`;
            detailHtml += `<span class="rd-crawl-item-name">${item.project?.projectName || '-'}</span>`;
            if (item.round) detailHtml += `<span class="rd-crawl-item-round">${item.round}</span>`;
            detailHtml += '</div>';
          });
          if (asInvestor.length > 5) {
            detailHtml += `<div class="rd-crawl-empty">还有 ${asInvestor.length - 5} 个...</div>`;
          }
          detailHtml += '</div>';
        } else {
          detailHtml += '<div class="rd-crawl-empty">暂无投资记录</div>';
        }
        detailHtml += '</div>';
        
        // 被谁投资
        detailHtml += '<div class="rd-crawl-section">';
        detailHtml += '<div class="rd-crawl-section-title">';
        detailHtml += '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 7l-9.2 9.2M7 16v6h10V4H7v6"/></svg>';
        detailHtml += `被投资机构 <span class="rd-crawl-count">(${asInvestee.length})</span>`;
        detailHtml += '</div>';
        if (asInvestee.length > 0) {
          detailHtml += '<div class="rd-crawl-list">';
          asInvestee.slice(0, 5).forEach(item => {
            detailHtml += '<div class="rd-crawl-item">';
            detailHtml += `<img src="${item.investor?.logo || '/admin/logo'}" onerror="this.src='/admin/logo'" />`;
            detailHtml += `<span class="rd-crawl-item-name">${item.investor?.projectName || '-'}</span>`;
            if (item.round) detailHtml += `<span class="rd-crawl-item-round">${item.round}</span>`;
            detailHtml += '</div>';
          });
          if (asInvestee.length > 5) {
            detailHtml += `<div class="rd-crawl-empty">还有 ${asInvestee.length - 5} 个...</div>`;
          }
          detailHtml += '</div>';
        } else {
          detailHtml += '<div class="rd-crawl-empty">暂无融资记录</div>';
        }
        detailHtml += '</div>';
        
        detailHtml += '</div>';
        manualResultDetail.innerHTML = detailHtml;
      } else {
        manualError.style.display = 'block';
        manualErrorMessage.innerHTML = `${data.error || data.message || '抓取失败'}<br><span style="font-size:11px;color:#6b7280;margin-top:4px;display:block;">Request ID: ${reqId}</span>`;
      }
    } catch (err) {
      manualStatus.style.display = 'none';
      manualError.style.display = 'block';
      manualErrorMessage.innerHTML = `${err.message || '请求失败'}<br><span style="font-size:11px;color:#6b7280;margin-top:4px;display:block;">Request ID: ${reqId}</span>`;
    } finally {
      manualBtn.disabled = false;
    }
  });

  // 初始化
  document.getElementById('rootdata-quota-refresh-btn')?.addEventListener('click', loadQuota);

  const datePicker = document.getElementById('rootdata-date-picker');
  if (datePicker) {
    datePicker.value = new Date().toISOString().split('T')[0];
  }

  document.addEventListener('stats-tab-activated', function(e) {
    if (e.detail && e.detail.tabId === 'rootdata') {
      loadQuota();
    }
  });
})();
</script>
