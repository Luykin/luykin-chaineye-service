            padding: 10px;
            border: 1px solid #d1d5db;
            border-radius: 6px;
            font-size: 14px;
            background: #f3f4f6;
          "
        />
      </div>

      <div style="display: flex; gap: 10px; margin-bottom: 15px">
        <button
          id="rootdata-manual-crawl-btn"
          disabled
          style="
            flex: 1;
            padding: 10px 20px;
            background: #9ca3af;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: not-allowed;
            font-size: 14px;
            font-weight: 600;
          "
        >
          🚫 已禁用
        </button>
      </div>
    </div>
  </div>
  <!-- 🔧 强制 API 更新数据（已禁用） -->
  <div class="section" id="rootdata-force-verify-section" style="margin-top: 30px; opacity: 0.5; pointer-events: none;">
    <h2 class="section-title">🔧 强制api更新数据（已禁用）</h2>
    <div class="stat-card" style="max-width: 900px; margin: 0 auto">
      <div style="margin-bottom: 15px">
        <label style="display:block;font-weight:600;color:#374151;margin-bottom:8px;">输入 Keyword / Twitter 链接 / RootData 链接：</label>
        <input
          type="text"
          id="rootdata-force-input"
