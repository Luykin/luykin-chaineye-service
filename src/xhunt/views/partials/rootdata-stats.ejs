<!-- Rootdata 统计页面 -->
<div class="rd-container">
  <!-- 头部 -->
  <div class="rd-header">
    <h2>Rootdata 数据统计</h2>
    <p class="rd-header-desc">API 配额监控与每日新增数据查询</p>
  </div>

  <!-- 第一行：API 配额 + 强制更新 -->
  <div class="rd-row rd-row-2">
    <!-- API 配额卡片 -->
    <div class="rd-card" id="rootdata-quota-section">
      <div class="rd-card-header">
        <div class="rd-card-title">
          <svg class="rd-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>
          </svg>
          API 配额
          <span class="rd-badge" id="rootdata-level">-</span>
        </div>
        <button class="rd-btn-icon" id="rootdata-quota-refresh-btn" title="刷新">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
            <path d="M3 3v5h5"/>
            <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/>
            <path d="M16 21h5v-5"/>
          </svg>
        </button>
      </div>

      <div class="rd-quota-main">
        <div class="rd-quota-numbers">
          <div class="rd-quota-remaining" id="rootdata-remaining">-</div>
          <div class="rd-quota-total">剩余 / <span id="rootdata-total">-</span></div>
        </div>
        <div class="rd-quota-percent" id="rootdata-usage-percent">-</div>
      </div>

      <div class="rd-progress-wrap">
        <div class="rd-progress-bar" id="rootdata-progress-bar" style="width: 0%"></div>
      </div>

      <div class="rd-info-row">
        <span class="rd-info-label">已用：<span id="rootdata-used">-</span></span>
        <span class="rd-info-label">周期：<span id="rootdata-period-start">-</span> 至 <span id="rootdata-period-end">-</span></span>
        <span class="rd-status-badge" id="rootdata-status">正常</span>
      </div>

      <div id="rootdata-loading" class="rd-mini-loading" style="display: none">
        <div class="rd-spinner-sm"></div>
        <span>加载中...</span>
      </div>

      <div id="rootdata-error" class="rd-mini-error" style="display: none">
        <span id="rootdata-error-message"></span>
      </div>
    </div>

    <!-- 强制 API 更新 -->
    <div class="rd-card" id="rootdata-force-verify-section">
      <div class="rd-card-header">
        <div class="rd-card-title">
          <svg class="rd-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
          </svg>
          强制 API 更新
        </div>
      </div>

      <div class="rd-compact-form">
        <input type="text" id="rootdata-force-input" class="rd-input" placeholder="Keyword / Twitter / RootData 链接" />
        <button class="rd-btn rd-btn-primary rd-btn-sm" id="rootdata-force-btn">更新</button>
      </div>
      <div class="rd-field-hint">清除缓存后通过 Rootdata API 重新验证修复数据</div>

      <div id="rootdata-force-status" class="rd-mini-loading" style="display: none">
        <div class="rd-spinner-sm"></div>
        <span>处理中...</span>
      </div>

      <div id="rootdata-force-result" class="rd-mini-success" style="display: none">
        <span id="rootdata-force-result-text"></span>
      </div>

      <div id="rootdata-force-error" class="rd-mini-error" style="display: none">
        <span id="rootdata-force-error-message"></span>
      </div>
    </div>
  </div>

  <!-- 第二行：手动爬虫 + 每日统计 -->
  <div class="rd-row rd-row-2">
    <!-- 手动触发爬虫 -->
    <div class="rd-card" id="rootdata-manual-crawl-section">
      <div class="rd-card-header">
        <div class="rd-card-title">
          <svg class="rd-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
          </svg>
          手动触发爬虫
        </div>
      </div>

      <div class="rd-compact-form">
        <input type="text" id="rootdata-manual-url" class="rd-input" placeholder="RootData 项目/机构/成员 URL" />
        <button class="rd-btn rd-btn-primary rd-btn-sm" id="rootdata-manual-crawl-btn">抓取</button>
      </div>
      <div class="rd-checkbox-wrap">
        <label class="rd-checkbox-label">
          <input type="checkbox" id="rootdata-manual-force" />
          <span>强制重新爬取（先删除旧数据和投资关系）</span>
        </label>
      </div>

      <div id="rootdata-manual-status" class="rd-mini-loading" style="display: none">
        <div class="rd-spinner-sm"></div>
        <span>抓取中（1-3分钟）...</span>
      </div>

      <div id="rootdata-manual-result" class="rd-mini-success" style="display: none">
        <div id="rootdata-manual-result-summary"></div>
        <div id="rootdata-manual-reqid" class="rd-reqid-display"></div>
        <div id="rootdata-manual-result-detail" class="rd-crawl-result"></div>
      </div>

      <div id="rootdata-manual-error" class="rd-mini-error" style="display: none">
        <span id="rootdata-manual-error-message"></span>
      </div>
    </div>

    <!-- 每日新增数据查询 -->
    <div class="rd-card" id="rootdata-daily-section">
      <div class="rd-card-header">
        <div class="rd-card-title">
          <svg class="rd-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          每日新增数据
        </div>
      </div>

      <div class="rd-compact-form">
        <input type="date" id="rootdata-date-picker" class="rd-input rd-input-date" />
        <button class="rd-btn rd-btn-primary rd-btn-sm" id="rootdata-query-btn">查询</button>
      </div>

      <!-- 统计概览 -->
      <div id="rootdata-daily-summary" class="rd-mini-stats" style="display: none">
        <div class="rd-mini-stat">
          <span class="rd-mini-stat-value" id="rootdata-new-projects-count">0</span>
          <span class="rd-mini-stat-label">新增项目</span>
        </div>
        <div class="rd-mini-stat">
          <span class="rd-mini-stat-value" id="rootdata-new-relationships-count">0</span>
          <span class="rd-mini-stat-label">新增关系</span>
        </div>
      </div>

      <!-- Tab 切换 -->
      <div id="rootdata-daily-tabs" style="display: none">
        <div class="rd-tabs rd-tabs-sm">
          <button class="rd-tab active" data-rootdata-tab="projects">项目</button>
          <button class="rd-tab" data-rootdata-tab="relationships">关系</button>
        </div>

        <div id="rootdata-projects-list" class="rd-tab-content">
          <div id="rootdata-projects-table" class="rd-table-wrap rd-table-sm"></div>
        </div>

        <div id="rootdata-relationships-list" class="rd-tab-content" style="display: none">
          <div id="rootdata-relationships-table" class="rd-table-wrap rd-table-sm"></div>
        </div>
      </div>

      <div id="rootdata-daily-empty" class="rd-mini-empty" style="display: none">该日期暂无数据</div>

      <div id="rootdata-daily-loading" class="rd-mini-loading" style="display: none">
        <div class="rd-spinner-sm"></div>
        <span>加载中...</span>
      </div>

      <div id="rootdata-daily-error" class="rd-mini-error" style="display: none">
        <span id="rootdata-daily-error-message"></span>
      </div>
    </div>
  </div>
</div>

