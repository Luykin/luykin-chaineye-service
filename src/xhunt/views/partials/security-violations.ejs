<style>
  #security-violations-section {
    --border-color: #e5e7eb;
    --bg-muted: #f9fafb;
    --text-muted: #6b7280;
    --badge-danger: #fee2e2;
    --badge-danger-text: #b91c1c;
    --badge-warning: #fef3c7;
    --badge-warning-text: #92400e;
    --badge-info: #dbeafe;
    --badge-info-text: #1d4ed8;
    --badge-default: #e5e7eb;
    --badge-default-text: #374151;
  }

  .security-violations-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    padding: 12px 0 4px;
  }

  .security-violations-toolbar .title-block {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .security-violations-toolbar .title-block h3 {
    margin: 0;
    font-size: 18px;
    font-weight: 600;
    color: #111827;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .security-violations-toolbar .title-block span {
    font-size: 13px;
    color: var(--text-muted);
  }

  .security-violations-toolbar.glass {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(229, 231, 235, 0.8);
    border-radius: 14px;
    padding: 12px 14px;
  }

  .controls {
    display: flex;
    gap: 10px;
    align-items: flex-end;
  }

  .control {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .control-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    padding-left: 4px;
  }

  .control-input,
  .control-select {
    height: 38px;
    padding: 0 12px;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: white;
    font-size: 13px;
    min-width: 200px;
  }

  .control-input:focus,
  .control-select:focus {
    outline: none;
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  .security-violations-toolbar .actions.controls {
    display: flex;
    gap: 10px;
    align-items: flex-end;
  }

  .btn-primary {
    height: 38px;
    padding: 0 16px;
    border-radius: 10px;
    border: 1px solid rgba(37, 99, 235, 0.8);
    background: linear-gradient(180deg, #3b82f6 0%, #2563eb 100%);
    color: white;
    font-weight: 700;
    cursor: pointer;
    transition: 0.2s ease;
    box-shadow: 0 8px 18px rgba(37, 99, 235, 0.18);
  }

  .btn-primary:hover {
    filter: brightness(0.98);
  }

  .btn-primary:active {
    transform: translateY(1px);
  }

  #security-violation-loading {
    background: var(--bg-muted);
    border-radius: 10px;
    padding: 14px;
    font-weight: 600;
    color: #374151;
    display: none;
    margin-bottom: 14px;
  }

  #security-violation-error {
    display: none;
    padding: 14px;
    border-radius: 10px;
    background: #fee2e2;
    color: #991b1b;
    font-weight: 600;
    margin-bottom: 14px;
    white-space: pre-line;
  }

  .security-violation-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .violation-card {
    border: 1px solid rgba(229, 231, 235, 0.9);
    border-radius: 16px;
    padding: 16px 18px;
    background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
  }

  .top-ips-card {
    border: 1px solid rgba(229, 231, 235, 0.9);
    border-radius: 16px;
    padding: 12px 14px;
    background: linear-gradient(180deg, #ffffff 0%, #fbfbff 100%);
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
  }

  .top-ips-card h4 {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin: 0 0 10px;
    font-size: 13px;
    font-weight: 800;
    color: #111827;
  }

  .top-ips-card h4::after {
    content: "Last 7 days";
    font-size: 12px;
    font-weight: 600;
    color: #6b7280;
  }

  .violation-card__header {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 12px;
    margin-bottom: 12px;
  }

  .violation-card__time {
    font-size: 14px;
    font-weight: 600;
    color: #111827;
  }

  .violation-card__chip-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .violation-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    background: rgba(249, 250, 251, 0.9);
    border-radius: 999px;
    font-size: 12px;
    color: #111827;
    border: 1px solid rgba(229, 231, 235, 0.9);
    box-shadow: 0 1px 2px rgba(16, 24, 40, 0.05);
  }

  .violation-chip .chip-label {
    font-weight: 700;
    color: #374151;
  }

  .violation-chip .chip-value {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
      "Liberation Mono", "Courier New", monospace;
    color: #111827;
  }

  .violation-card__body {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
  }

  .violation-field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .violation-field .label {
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .violation-field .value {
    font-size: 13px;
    color: #111827;
    line-height: 1.5;
    word-break: break-all;
  }

  .violation-field .method-pill {
    display: inline-flex;
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    background: #e0f2fe;
    color: #0369a1;
  }

  .violation-details {
    margin-top: 12px;
    border-top: 1px dashed var(--border-color);
    padding-top: 12px;
  }

  .violation-details summary {
    cursor: pointer;
    color: #2563eb;
    font-weight: 600;
    font-size: 13px;
  }

  .violation-details pre {
    background: #0f172a;
    color: #e2e8f0;
    padding: 10px;
    border-radius: 10px;
    font-size: 11px;
    overflow-x: auto;
    margin-top: 8px;
    max-height: 200px;
  }

  .violation-empty {
    padding: 40px;
    text-align: center;
    border: 2px dashed var(--border-color);
    border-radius: 14px;
    color: var(--text-muted);
    background: var(--bg-muted);
    font-weight: 600;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border-radius: 999px;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 600;
    border: 1px solid transparent;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .badge.badge-danger {
    background: var(--badge-danger);
    color: var(--badge-danger-text);
    border-color: #fecaca;
  }

  .badge.badge-warning {
    background: var(--badge-warning);
    color: var(--badge-warning-text);
    border-color: #fcd34d;
  }

  .badge.badge-info {
    background: var(--badge-info);
    color: var(--badge-info-text);
    border-color: #bfdbfe;
  }

  .badge.badge-default {
    background: var(--badge-default);
    color: var(--badge-default-text);
    border-color: var(--border-color);
  }

  .security-violations-pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 18px;
  }

  .security-violations-pagination button {
    padding: 8px 14px;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: white;
    cursor: pointer;
    font-size: 13px;
    min-width: 110px;
    transition: 0.2s ease;
  }

  .security-violations-pagination button:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .security-violations-pagination button:not(:disabled):hover {
    background: var(--bg-muted);
  }

  @media (max-width: 768px) {
    .violation-card__body {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="stats-section">
  <div class="section" id="security-violations-section">
    <div class="security-violations-toolbar glass">
      <div class="title-block">
        <h3>🛡️ 安全拦截日志</h3>
        <span id="security-violation-summary">自动加载最新 50 条记录</span>
      </div>
      <div class="actions controls">
        <div class="control">
          <label class="control-label" for="security-violation-ip-filter"
            >IP</label
          >
          <input
            type="text"
            id="security-violation-ip-filter"
            class="control-input"
            placeholder="Search IP (fuzzy)"
          />
        </div>
        <div class="control">
          <label class="control-label" for="security-violation-reason-filter"
            >Reason</label
          >
          <select id="security-violation-reason-filter" class="control-select">
            <option value="">全部原因</option>
            <option value="missing_headers">
              缺少必需的参数 (missing_headers)
            </option>
            <option value="invalid_fingerprint">
              指纹不合法 (invalid_fingerprint)
            </option>
            <option value="invalid_request_id">
              请求ID不合法 (invalid_request_id)
            </option>
            <option value="invalid_timestamp">
              时间戳异常 (invalid_timestamp)
            </option>
            <option value="invalid_signature">
              签名不匹配 (invalid_signature)
            </option>
          </select>
        </div>

        <button id="security-violation-refresh" class="btn-primary">
          Refresh
        </button>
      </div>

      <div id="security-violation-loading">⏳ 正在加载安全日志...</div>
      <div id="security-violation-error"></div>

      <div
        id="top-ips-section"
        class="top-ips-card"
        style="margin-bottom: 16px; display: none"
      >
        <h4 style="font-size: 14px; font-weight: 600; margin-bottom: 8px">
          Top 10 风险IP (最近7天)
        </h4>
        <div
          id="top-ips-list"
          style="display: flex; flex-wrap: wrap; gap: 8px"
        ></div>
      </div>

      <div class="security-violation-list" id="security-violation-list">
        <div class="violation-empty">暂无安全校验失败记录</div>
      </div>

      <div class="security-violations-pagination">
        <div
          id="security-violation-pagination-info"
          style="color: #6b7280; font-size: 13px"
        >
          第 1 / 1 页，共 0 条
        </div>
        <div style="display: flex; gap: 8px">
          <button id="security-violation-prev" disabled>⬅️ 上一页</button>
          <button id="security-violation-next" disabled>下一页 ➡️</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function () {
      const PAGE_SIZE = 50;
      let currentPage = 1;
      let totalPages = 1;
      let isLoading = false;
      let currentReasonFilter = "";
      let currentIpFilter = "";

      const listContainer = document.getElementById("security-violation-list");
      const topIpsSection = document.getElementById("top-ips-section");
      const topIpsList = document.getElementById("top-ips-list");
      const loadingEl = document.getElementById("security-violation-loading");
      const errorEl = document.getElementById("security-violation-error");
      const summaryEl = document.getElementById("security-violation-summary");
      const paginationInfo = document.getElementById(
        "security-violation-pagination-info"
      );
      const prevBtn = document.getElementById("security-violation-prev");
      const nextBtn = document.getElementById("security-violation-next");
      const refreshBtn = document.getElementById("security-violation-refresh");
      const reasonFilterSelect = document.getElementById(
        "security-violation-reason-filter"
      );
      const ipFilterInput = document.getElementById(
        "security-violation-ip-filter"
      );

      refreshBtn.addEventListener("click", () => {
        loadSecurityViolations(1);
      });

      if (reasonFilterSelect) {
        reasonFilterSelect.addEventListener("change", () => {
          currentReasonFilter = reasonFilterSelect.value || "";
          loadSecurityViolations(1);
        });
      }

      if (ipFilterInput) {
        // 刷新按钮触发搜索
        refreshBtn.addEventListener("click", () => {
          currentIpFilter = ipFilterInput.value || "";
          loadSecurityViolations(1);
        });
        // 回车触发搜索
        ipFilterInput.addEventListener("keypress", (e) => {
          if (e.key === "Enter") {
            currentIpFilter = ipFilterInput.value || "";
            loadSecurityViolations(1);
          }
        });
      }

      prevBtn.addEventListener("click", () => {
        if (currentPage > 1) {
          loadSecurityViolations(currentPage - 1);
        }
      });

      nextBtn.addEventListener("click", () => {
        if (currentPage < totalPages) {
          loadSecurityViolations(currentPage + 1);
        }
      });

      async function loadSecurityViolations(page = 1) {
        if (isLoading) return;
        isLoading = true;
        loadingEl.style.display = "block";
        errorEl.style.display = "none";
        listContainer.innerHTML =
          '<div class="violation-empty">正在加载...</div>';

        try {
          const params = new URLSearchParams();
          params.set("page", page);
          params.set("limit", PAGE_SIZE);
          if (currentReasonFilter) {
            params.set("reasonCode", currentReasonFilter);
          }
          if (currentIpFilter) {
            params.set("ip", currentIpFilter);
          }

          const response = await fetch(
            `/api/xhunt/stats/security-violations?${params.toString()}`
          );
          const result = await response.json();

          if (!response.ok || !result.success) {
            throw new Error(result.error || "加载安全日志失败");
          }

          const records = result.data || [];
          const pagination = result.pagination || {
            page: 1,
            totalPages: 1,
            total: 0,
          };

          renderTopIps(result.topIps || []);

          currentPage = pagination.page;
          totalPages = pagination.totalPages;

          renderList(records);
          updateSummary(pagination.total);
          updatePagination(pagination);
        } catch (error) {
          console.error("加载安全日志失败:", error);
          errorEl.textContent = "❌ " + error.message;
          errorEl.style.display = "block";
          listContainer.innerHTML =
            '<div class="violation-empty">加载失败</div>';
        } finally {
          isLoading = false;
          loadingEl.style.display = "none";
        }
      }

      function renderList(records) {
        if (!records || records.length === 0) {
          listContainer.innerHTML =
            '<div class="violation-empty">暂无安全校验失败记录</div>';
          return;
        }

        listContainer.innerHTML = records
          .map((item) => {
            const createdAt = formatDateTime(item.createdAt);
            const reason = escapeHtml(item.reasonCode || "-");
            const errorDetail = escapeHtml(item.errorDetail || "-");
            const requestPath = escapeHtml(item.requestPath || "-");
            const method = escapeHtml(item.requestMethod || "-");
            const queryString = item.queryString
              ? escapeHtml(item.queryString)
              : "";
            const fingerprint = escapeHtml(item.fingerprint || "-");
            const version = escapeHtml(item.extensionVersion || "-");
            const clientIp = escapeHtml(item.clientIp || "-");
            const windowLocation = escapeHtml(item.windowLocationHref || "-");
            const requestId = escapeHtml(item.requestId || "-");
            const requestTimestamp = item.requestTimestamp
              ? escapeHtml(String(item.requestTimestamp))
              : "-";
            const headers = formatJson(item.headers);
            const requestBody = escapeHtml(item.requestBody || "-");
            const reasonBadge = getReasonBadge(item.reasonCode || "");

            return `
            <div class="violation-card">
              <div class="violation-card__header">
                <div>
                  <div class="violation-card__time">${createdAt}</div>
                  <div style="margin-top: 6px">${reasonBadge}</div>
                </div>
                <div class="violation-card__chip-row">
                  <span class="violation-chip">
                    <span class="chip-label">IP</span>
                    <span class="chip-value">${clientIp}</span>
                  </span>
                  <span class="violation-chip">
                    <span class="chip-label">Fingerprint</span>
                    <span class="chip-value">${fingerprint}</span>
                  </span>
                  <span class="violation-chip">
                    <span class="chip-label">Version</span>
                    <span class="chip-value">${version}</span>
                  </span>
                </div>
              </div>
              <div class="violation-card__body">
                <div class="violation-field" style="grid-column: span 2;">
                  <span class="label">失败详情</span>
                  <span class="value">${errorDetail}</span>
                </div>
                <div class="violation-field">
                  <span class="label">请求</span>
                  <span class="value">
                    <span class="method-pill">${method}</span>
                    &nbsp;${requestPath}
                  </span>
                </div>
                ${
                  queryString
                    ? `<div class="violation-field">
                         <span class="label">Query</span>
                         <span class="value">${queryString}</span>
                       </div>`
                    : ""
                }
                <div class="violation-field">
                  <span class="label">Request ID</span>
                  <span class="value">${requestId}</span>
                </div>
                <div class="violation-field">
                  <span class="label">Timestamp</span>
                  <span class="value">${requestTimestamp}</span>
                </div>
                <div class="violation-field">
                  <span class="label">来源</span>
                  <span class="value">${windowLocation}</span>
                </div>
              </div>
              <details class="violation-details">
                <summary>展开 Headers / Body 详情</summary>
                <div style="margin-top: 10px">
                  <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px">Headers</div>
                  <pre>${headers}</pre>
                </div>
                <div style="margin-top: 12px">
                  <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px">Body</div>
                  <pre>${requestBody}</pre>
                </div>
              </details>
            </div>
          `;
          })
          .join("");
      }

      function renderTopIps(topIps) {
        if (!topIps || topIps.length === 0) {
          if (topIpsSection) topIpsSection.style.display = "none";
          return;
        }

        if (topIpsSection) topIpsSection.style.display = "block";
        if (topIpsList) {
          topIpsList.innerHTML = topIps
            .map((item) => {
              const ip = escapeHtml(item.ip);
              const count = formatNumber(item.count);
              return `
            <span class="violation-chip" style="cursor: pointer; background: var(--badge-danger);" title="点击筛选此 IP">
              <span class="chip-label" style="color: var(--badge-danger-text); font-weight: 700;">${ip}</span>
              <span class="chip-value" style="color: var(--badge-danger-text);">${count} 次</span>
            </span>
          `;
            })
            .join("");

          // Add click listeners
          topIpsList
            .querySelectorAll(".violation-chip")
            .forEach((chip, index) => {
              chip.addEventListener("click", () => {
                const ip = topIps[index].ip;
                if (ipFilterInput) {
                  ipFilterInput.value = ip;
                  currentIpFilter = ip;
                  loadSecurityViolations(1);
                }
              });
            });
        }
      }

      function updateSummary(total) {
        summaryEl.textContent = `共 ${formatNumber(
          total || 0
        )} 条告警，单页展示 ${PAGE_SIZE} 条`;
      }

      function updatePagination(pagination) {
        paginationInfo.textContent = `第 ${pagination.page} / ${
          pagination.totalPages
        } 页，共 ${formatNumber(pagination.total)} 条`;
        prevBtn.disabled = pagination.page <= 1;
        nextBtn.disabled = pagination.page >= pagination.totalPages;
      }

      function formatDateTime(value) {
        if (!value) return "-";
        try {
          const date = new Date(value);
          return date.toLocaleString("zh-CN", {
            hour12: false,
            year: "numeric",
            month: "2-digit",
            day: "2-digit",
            hour: "2-digit",
            minute: "2-digit",
            second: "2-digit",
          });
        } catch (error) {
          return value;
        }
      }

      function escapeHtml(text) {
        if (text === null || text === undefined) return "";
        return text
          .toString()
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;");
      }

      function formatJson(obj) {
        if (!obj) return "-";
        try {
          return escapeHtml(JSON.stringify(obj, null, 2));
        } catch (error) {
          return "-";
        }
      }

      function formatNumber(num) {
        if (typeof num !== "number") {
          num = Number(num) || 0;
        }
        return num.toLocaleString("zh-CN");
      }

      function getReasonBadge(reasonCode) {
        const code = (reasonCode || "").toLowerCase();
        let className = "badge-default";
        if (code.includes("signature") || code.includes("missing")) {
          className = "badge-danger";
        } else if (code.includes("timestamp")) {
          className = "badge-warning";
        } else if (code.includes("fingerprint")) {
          className = "badge-info";
        }
        const label = escapeHtml(reasonCode || "UNKNOWN");
        return `<span class="badge ${className}">${label}</span>`;
      }

      // 首次进入自动加载
      loadSecurityViolations(1);
    })();
  </script>
</div>
