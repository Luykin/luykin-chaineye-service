<style>
  #security-violations-section {
    --border-color: #e5e7eb;
    --bg-muted: #f9fafb;
    --text-muted: #6b7280;
    --badge-danger: #fee2e2;
    --badge-danger-text: #b91c1c;
    --badge-warning: #fef3c7;
    --badge-warning-text: #92400e;
    --badge-info: #dbeafe;
    --badge-info-text: #1d4ed8;
    --badge-default: #e5e7eb;
    --badge-default-text: #374151;
  }

  .security-violations-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    padding: 12px 0 4px;
  }

  .security-violations-toolbar .title-block {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .security-violations-toolbar .title-block h3 {
    margin: 0;
    font-size: 18px;
    font-weight: 600;
    color: #111827;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .security-violations-toolbar .title-block span {
    font-size: 13px;
    color: var(--text-muted);
  }

  .security-violations-toolbar .actions {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .security-violations-toolbar button {
    padding: 9px 18px;
    border-radius: 8px;
    border: 1px solid transparent;
    font-weight: 600;
    cursor: pointer;
    transition: 0.2s ease;
  }

  #security-violation-refresh {
    background: #2563eb;
    color: white;
    border-color: #1d4ed8;
  }

  #security-violation-refresh:hover {
    background: #1d4ed8;
  }

  #security-violation-loading {
    background: var(--bg-muted);
    border-radius: 10px;
    padding: 14px;
    font-weight: 600;
    color: #374151;
    display: none;
    margin-bottom: 14px;
  }

  #security-violation-error {
    display: none;
    padding: 14px;
    border-radius: 10px;
    background: #fee2e2;
    color: #991b1b;
    font-weight: 600;
    margin-bottom: 14px;
    white-space: pre-line;
  }

  .security-violation-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .violation-card {
    border: 1px solid var(--border-color);
    border-radius: 14px;
    padding: 16px 18px;
    background: white;
    box-shadow: 0 4px 20px rgba(15, 23, 42, 0.04);
  }

  .violation-card__header {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 12px;
    margin-bottom: 12px;
  }

  .violation-card__time {
    font-size: 14px;
    font-weight: 600;
    color: #111827;
  }

  .violation-card__chip-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .violation-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    background: var(--bg-muted);
    border-radius: 999px;
    font-size: 12px;
    color: #374151;
    border: 1px solid var(--border-color);
  }

  .violation-chip .chip-label {
    font-weight: 600;
    color: #1f2937;
  }

  .violation-card__body {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
  }

  .violation-field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .violation-field .label {
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .violation-field .value {
    font-size: 13px;
    color: #111827;
    line-height: 1.5;
    word-break: break-all;
  }

  .violation-field .method-pill {
    display: inline-flex;
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    background: #e0f2fe;
    color: #0369a1;
  }

  .violation-details {
    margin-top: 12px;
    border-top: 1px dashed var(--border-color);
    padding-top: 12px;
  }

  .violation-details summary {
    cursor: pointer;
    color: #2563eb;
    font-weight: 600;
    font-size: 13px;
  }

  .violation-details pre {
    background: #0f172a;
    color: #e2e8f0;
    padding: 10px;
    border-radius: 10px;
    font-size: 11px;
    overflow-x: auto;
    margin-top: 8px;
    max-height: 200px;
  }

  .violation-empty {
    padding: 40px;
    text-align: center;
    border: 2px dashed var(--border-color);
    border-radius: 14px;
    color: var(--text-muted);
    background: var(--bg-muted);
    font-weight: 600;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border-radius: 999px;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 600;
    border: 1px solid transparent;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .badge.badge-danger {
    background: var(--badge-danger);
    color: var(--badge-danger-text);
    border-color: #fecaca;
  }

  .badge.badge-warning {
    background: var(--badge-warning);
    color: var(--badge-warning-text);
    border-color: #fcd34d;
  }

  .badge.badge-info {
    background: var(--badge-info);
    color: var(--badge-info-text);
    border-color: #bfdbfe;
  }

  .badge.badge-default {
    background: var(--badge-default);
    color: var(--badge-default-text);
    border-color: var(--border-color);
  }

  .security-violations-pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 18px;
  }

  .security-violations-pagination button {
    padding: 8px 14px;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: white;
    cursor: pointer;
    font-size: 13px;
    min-width: 110px;
    transition: 0.2s ease;
  }

  .security-violations-pagination button:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .security-violations-pagination button:not(:disabled):hover {
    background: var(--bg-muted);
  }

  @media (max-width: 768px) {
    .violation-card__body {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="stats-section">
  <div class="section" id="security-violations-section">
    <div class="security-violations-toolbar">
      <div class="title-block">
        <h3>🛡️ 安全拦截日志</h3>
        <span id="security-violation-summary">自动加载最新 50 条记录</span>
      </div>
      <div class="actions">
        <select id="security-violation-reason-filter">
          <option value="">全部原因</option>
          <option value="missing_headers">缺少必需的参数 (missing_headers)</option>
          <option value="invalid_fingerprint">指纹不合法 (invalid_fingerprint)</option>
          <option value="invalid_request_id">请求ID不合法 (invalid_request_id)</option>
          <option value="invalid_timestamp">时间戳异常 (invalid_timestamp)</option>
          <option value="invalid_signature">签名不匹配 (invalid_signature)</option>
        </select>
        <button id="security-violation-refresh">🔄 刷新</button>
      </div>
    </div>

    <div id="security-violation-loading">⏳ 正在加载安全日志...</div>
    <div id="security-violation-error"></div>

    <div class="security-violation-list" id="security-violation-list">
      <div class="violation-empty">暂无安全校验失败记录</div>
    </div>

    <div class="security-violations-pagination">
      <div id="security-violation-pagination-info" style="color: #6b7280; font-size: 13px">
        第 1 / 1 页，共 0 条
      </div>
      <div style="display: flex; gap: 8px">
        <button id="security-violation-prev" disabled>⬅️ 上一页</button>
        <button id="security-violation-next" disabled>下一页 ➡️</button>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const PAGE_SIZE = 50;
    let currentPage = 1;
    let totalPages = 1;
    let isLoading = false;
    let currentReasonFilter = "";

    const listContainer = document.getElementById("security-violation-list");
    const loadingEl = document.getElementById("security-violation-loading");
    const errorEl = document.getElementById("security-violation-error");
    const summaryEl = document.getElementById("security-violation-summary");
    const paginationInfo = document.getElementById(
      "security-violation-pagination-info"
    );
    const prevBtn = document.getElementById("security-violation-prev");
    const nextBtn = document.getElementById("security-violation-next");
    const refreshBtn = document.getElementById("security-violation-refresh");
    const reasonFilterSelect = document.getElementById(
      "security-violation-reason-filter"
    );

    refreshBtn.addEventListener("click", () => {
      loadSecurityViolations(1);
    });

    if (reasonFilterSelect) {
      reasonFilterSelect.addEventListener("change", () => {
        currentReasonFilter = reasonFilterSelect.value || "";
        loadSecurityViolations(1);
      });
    }

    prevBtn.addEventListener("click", () => {
      if (currentPage > 1) {
        loadSecurityViolations(currentPage - 1);
      }
    });

    nextBtn.addEventListener("click", () => {
      if (currentPage < totalPages) {
        loadSecurityViolations(currentPage + 1);
      }
    });

    async function loadSecurityViolations(page = 1) {
      if (isLoading) return;
      isLoading = true;
      loadingEl.style.display = "block";
      errorEl.style.display = "none";
      listContainer.innerHTML =
        '<div class="violation-empty">正在加载...</div>';

      try {
        const params = new URLSearchParams();
        params.set("page", page);
        params.set("limit", PAGE_SIZE);
        if (currentReasonFilter) {
          params.set("reasonCode", currentReasonFilter);
        }

        const response = await fetch(
          `/api/xhunt/stats/security-violations?${params.toString()}`
        );
        const result = await response.json();

        if (!response.ok || !result.success) {
          throw new Error(result.error || "加载安全日志失败");
        }

        const records = result.data || [];
        const pagination = result.pagination || {
          page: 1,
          totalPages: 1,
          total: 0,
        };

        currentPage = pagination.page;
        totalPages = pagination.totalPages;

        renderList(records);
        updateSummary(pagination.total);
        updatePagination(pagination);
      } catch (error) {
        console.error("加载安全日志失败:", error);
        errorEl.textContent = "❌ " + error.message;
        errorEl.style.display = "block";
        listContainer.innerHTML =
          '<div class="violation-empty">加载失败</div>';
      } finally {
        isLoading = false;
        loadingEl.style.display = "none";
      }
    }

    function renderList(records) {
      if (!records || records.length === 0) {
        listContainer.innerHTML =
          '<div class="violation-empty">暂无安全校验失败记录</div>';
        return;
      }

      listContainer.innerHTML = records
        .map((item) => {
          const createdAt = formatDateTime(item.createdAt);
          const reason = escapeHtml(item.reasonCode || "-");
          const errorDetail = escapeHtml(item.errorDetail || "-");
          const requestPath = escapeHtml(item.requestPath || "-");
          const method = escapeHtml(item.requestMethod || "-");
          const queryString = item.queryString
            ? escapeHtml(item.queryString)
            : "";
          const fingerprint = escapeHtml(item.fingerprint || "-");
          const version = escapeHtml(item.extensionVersion || "-");
          const clientIp = escapeHtml(item.clientIp || "-");
          const windowLocation = escapeHtml(item.windowLocationHref || "-");
          const requestId = escapeHtml(item.requestId || "-");
          const requestTimestamp = item.requestTimestamp
            ? escapeHtml(String(item.requestTimestamp))
            : "-";
          const headers = formatJson(item.headers);
          const requestBody = escapeHtml(item.requestBody || "-");
          const reasonBadge = getReasonBadge(item.reasonCode || "");

          return `
            <div class="violation-card">
              <div class="violation-card__header">
                <div>
                  <div class="violation-card__time">${createdAt}</div>
                  <div style="margin-top: 6px">${reasonBadge}</div>
                </div>
                <div class="violation-card__chip-row">
                  <span class="violation-chip">
                    <span class="chip-label">IP</span>
                    <span class="chip-value">${clientIp}</span>
                  </span>
                  <span class="violation-chip">
                    <span class="chip-label">Fingerprint</span>
                    <span class="chip-value">${fingerprint}</span>
                  </span>
                  <span class="violation-chip">
                    <span class="chip-label">Version</span>
                    <span class="chip-value">${version}</span>
                  </span>
                </div>
              </div>
              <div class="violation-card__body">
                <div class="violation-field" style="grid-column: span 2;">
                  <span class="label">失败详情</span>
                  <span class="value">${errorDetail}</span>
                </div>
                <div class="violation-field">
                  <span class="label">请求</span>
                  <span class="value">
                    <span class="method-pill">${method}</span>
                    &nbsp;${requestPath}
                  </span>
                </div>
                ${
                  queryString
                    ? `<div class="violation-field">
                         <span class="label">Query</span>
                         <span class="value">${queryString}</span>
                       </div>`
                    : ""
                }
                <div class="violation-field">
                  <span class="label">Request ID</span>
                  <span class="value">${requestId}</span>
                </div>
                <div class="violation-field">
                  <span class="label">Timestamp</span>
                  <span class="value">${requestTimestamp}</span>
                </div>
                <div class="violation-field">
                  <span class="label">来源</span>
                  <span class="value">${windowLocation}</span>
                </div>
              </div>
              <details class="violation-details">
                <summary>展开 Headers / Body 详情</summary>
                <div style="margin-top: 10px">
                  <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px">Headers</div>
                  <pre>${headers}</pre>
                </div>
                <div style="margin-top: 12px">
                  <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px">Body</div>
                  <pre>${requestBody}</pre>
                </div>
              </details>
            </div>
          `;
        })
        .join("");
    }

    function updateSummary(total) {
      summaryEl.textContent = `共 ${formatNumber(total || 0)} 条告警，单页展示 ${PAGE_SIZE} 条`;
    }

    function updatePagination(pagination) {
      paginationInfo.textContent = `第 ${pagination.page} / ${
        pagination.totalPages
      } 页，共 ${formatNumber(pagination.total)} 条`;
      prevBtn.disabled = pagination.page <= 1;
      nextBtn.disabled = pagination.page >= pagination.totalPages;
    }

    function formatDateTime(value) {
      if (!value) return "-";
      try {
        const date = new Date(value);
        return date.toLocaleString("zh-CN", {
          hour12: false,
          year: "numeric",
          month: "2-digit",
          day: "2-digit",
          hour: "2-digit",
          minute: "2-digit",
          second: "2-digit",
        });
      } catch (error) {
        return value;
      }
    }

    function escapeHtml(text) {
      if (text === null || text === undefined) return "";
      return text
        .toString()
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function formatJson(obj) {
      if (!obj) return "-";
      try {
        return escapeHtml(JSON.stringify(obj, null, 2));
      } catch (error) {
        return "-";
      }
    }

    function formatNumber(num) {
      if (typeof num !== "number") {
        num = Number(num) || 0;
      }
      return num.toLocaleString("zh-CN");
    }

    function getReasonBadge(reasonCode) {
      const code = (reasonCode || "").toLowerCase();
      let className = "badge-default";
      if (code.includes("signature") || code.includes("missing")) {
        className = "badge-danger";
      } else if (code.includes("timestamp")) {
        className = "badge-warning";
      } else if (code.includes("fingerprint")) {
        className = "badge-info";
      }
      const label = escapeHtml(reasonCode || "UNKNOWN");
      return `<span class="badge ${className}">${label}</span>`;
    }

    // 首次进入自动加载
    loadSecurityViolations(1);
  })();
</script>

