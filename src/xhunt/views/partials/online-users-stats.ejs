<!-- 在线用户统计 -->
<div class="stats-section">
  <div class="section">
    <h2 class="section-title">在线用户</h2>
    <p class="section-desc">最近10分钟内有活动的已登录用户</p>

    <!-- 统计卡片 -->
    <div id="online-summary" class="summary-section">
      <div class="stats-grid stats-grid-3">
        <div class="stat-card">
          <div class="stat-title">在线用户</div>
          <div class="stat-value stat-value-lg" id="online-total-count">0</div>
        </div>
        <div class="stat-card">
          <div class="stat-title">当前页</div>
          <div class="stat-value stat-value-lg" id="online-current-page">1</div>
        </div>
        <div class="stat-card">
          <div class="stat-title">总页数</div>
          <div class="stat-value stat-value-lg" id="online-total-pages">1</div>
        </div>
      </div>
    </div>

    <!-- 用户列表 -->
    <div id="online-users-container" class="details-container">
      <div class="list-header">
        <h3 class="list-title">用户列表</h3>
        <div class="list-actions">
          <input type="text" id="online-search" class="search-input" placeholder="搜索用户名..." />
          <button id="refresh-online-users" class="btn-primary">刷新</button>
        </div>
      </div>

      <!-- 表格 -->
      <div class="table-container">
        <table id="online-users-table" class="data-table">
          <thead>
            <tr>
              <th>用户名</th>
              <th>显示名称</th>
              <th>推特ID</th>
              <th>最后使用</th>
            </tr>
          </thead>
          <tbody id="online-users-tbody"></tbody>
        </table>
      </div>

      <!-- 分页 -->
      <div id="online-pagination" class="pagination"></div>
    </div>

    <!-- 无数据提示 -->
    <div id="online-no-data" class="empty-state">
      <div class="empty-icon">●</div>
      <h3>暂无在线用户</h3>
      <p>最近10分钟内没有用户活动</p>
    </div>

    <!-- 加载状态 -->
    <div id="online-loading" class="loading-state">
      <div class="spinner"></div>
      <p>加载中...</p>
    </div>
  </div>
</div>

<style>
  /* 区域描述 */
  .section-desc {
    color: #6b7280;
    margin-bottom: 20px;
    font-size: 14px;
  }

  /* 统计区域 */
  .summary-section {
    display: none;
    margin-bottom: 24px;
  }

  /* 统计网格 */
  .stats-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  @media (max-width: 768px) {
    .stats-grid-3 {
      grid-template-columns: 1fr;
    }
  }

  /* 统计卡片 */
  .stat-card {
    background: white;
    padding: 16px;
    border-radius: 6px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    border: 1px solid #e5e7eb;
  }

  .stat-value-lg {
    font-size: 28px;
    font-weight: 600;
    color: #111827;
    margin: 8px 0;
  }

  /* 详情容器 */
  .details-container {
    display: none;
  }

  /* 列表头部 */
  .list-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    flex-wrap: wrap;
    gap: 12px;
  }

  .list-title {
    font-size: 16px;
    font-weight: 600;
    color: #374151;
    margin: 0;
  }

  .list-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* 搜索框 */
  .search-input {
    padding: 6px 10px;
    border: 1px solid #d1d5db;
    border-radius: 4px;
    font-size: 14px;
    background: white;
    width: 200px;
  }

  .search-input:focus {
    outline: none;
    border-color: #3b82f6;
  }

  /* 主按钮 */
  .list-actions .btn-primary {
    padding: 6px 14px;
    background: #3b82f6 !important;
    color: white !important;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
  }

  .list-actions .btn-primary:hover {
    background: #2563eb !important;
  }

  .list-actions .btn-primary:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* 表格 */
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .data-table th {
    padding: 10px 12px;
    text-align: left;
    font-weight: 600;
    color: #374151;
    border-bottom: 1px solid #e5e7eb;
    background: #f9fafb;
    font-size: 13px;
  }

  .data-table td {
    padding: 10px 12px;
    border-bottom: 1px solid #f3f4f6;
  }

  .data-table tr:hover {
    background: #f9fafb;
  }

  .user-name {
    font-weight: 500;
    color: #111827;
  }

  .user-handle {
    color: #6b7280;
    font-size: 13px;
  }

  .user-time {
    color: #6b7280;
    font-size: 13px;
  }

  /* 分页 */
  .pagination {
    margin-top: 16px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
  }

  .page-btn {
    padding: 4px 10px;
    border: none;
    background: transparent;
    color: #6b7280;
    cursor: pointer;
    font-size: 13px;
  }

  .page-btn:hover:not(:disabled) {
    color: #111827;
  }

  .page-btn:disabled {
    color: #d1d5db;
    cursor: not-allowed;
  }

  .page-info {
    color: #6b7280;
    font-size: 13px;
    padding: 0 8px;
  }

  /* 空状态 */
  .empty-state {
    display: none;
    text-align: center;
    padding: 48px 20px;
    color: #6b7280;
  }

  .empty-icon {
    font-size: 32px;
    color: #d1d5db;
    margin-bottom: 12px;
    line-height: 1;
  }

  .empty-state h3 {
    font-size: 14px;
    font-weight: 500;
    color: #374151;
    margin: 0 0 4px 0;
  }

  .empty-state p {
    font-size: 13px;
    margin: 0;
  }

  /* 加载状态 */
  .loading-state {
    display: none;
    text-align: center;
    padding: 40px 20px;
    color: #6b7280;
  }

  .spinner {
    display: inline-block;
    width: 20px;
    height: 20px;
    border: 2px solid #e5e7eb;
    border-top-color: #3b82f6;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin-bottom: 8px;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  // 在线用户相关JavaScript
  document.addEventListener("DOMContentLoaded", function () {
    const summaryDiv = document.getElementById("online-summary");
    const containerDiv = document.getElementById("online-users-container");
    const noDataDiv = document.getElementById("online-no-data");
    const loadingDiv = document.getElementById("online-loading");
    const searchInput = document.getElementById("online-search");
    const refreshButton = document.getElementById("refresh-online-users");

    let currentOnlineData = [];
    let filteredOnlineData = [];
    let currentPage = 1;
    let totalPages = 1;
    let totalCount = 0;

    // 搜索功能
    searchInput.addEventListener("input", filterOnlineData);

    // 刷新功能
    refreshButton.addEventListener("click", loadOnlineUsers);

    // 仅在切换到「在线用户」tab 时加载数据
    document.addEventListener("stats-tab-activated", function (e) {
      if (e.detail && e.detail.tabId === "online-users") {
        loadOnlineUsers();
      }
    });

    async function loadOnlineUsers(page = 1) {
      // 显示加载状态
      loadingDiv.style.display = "block";
      summaryDiv.style.display = "none";
      containerDiv.style.display = "none";
      noDataDiv.style.display = "none";

      try {
        const response = await fetch(
          `/api/xhunt/stats/online-users?page=${page}&limit=100`
        );
        const result = await response.json();

        if (result.success) {
          currentOnlineData = result.data.users;
          filteredOnlineData = [...currentOnlineData];
          currentPage = result.data.pagination.currentPage;
          totalPages = result.data.pagination.totalPages;
          totalCount = result.data.pagination.totalCount;

          updateOnlineSummary();
          updateOnlineTable();
          updatePagination();

          if (totalCount > 0) {
            summaryDiv.style.display = "block";
            containerDiv.style.display = "block";
            noDataDiv.style.display = "none";
          } else {
            summaryDiv.style.display = "none";
            containerDiv.style.display = "none";
            noDataDiv.style.display = "block";
          }
        } else {
          alert("加载数据失败: " + result.error);
        }
      } catch (error) {
        console.error("Error loading online users:", error);
        alert("加载数据失败，请检查网络连接");
      } finally {
        // 隐藏加载状态
        loadingDiv.style.display = "none";
      }
    }

    function updateOnlineSummary() {
      document.getElementById("online-total-count").textContent =
        totalCount.toLocaleString();
      document.getElementById("online-current-page").textContent = currentPage;
      document.getElementById("online-total-pages").textContent = totalPages;
    }

    function filterOnlineData() {
      const searchTerm = searchInput.value.toLowerCase();

      if (!searchTerm) {
        filteredOnlineData = [...currentOnlineData];
      } else {
        filteredOnlineData = currentOnlineData.filter(
          (user) =>
            user.username.toLowerCase().includes(searchTerm) ||
            user.displayName.toLowerCase().includes(searchTerm) ||
            user.twitterId.toLowerCase().includes(searchTerm)
        );
      }

      updateOnlineTable();
    }

    function updateOnlineTable() {
      const tbody = document.getElementById("online-users-tbody");

      // 清空现有内容
      tbody.innerHTML = "";

      if (filteredOnlineData.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="4" class="no-results">没有找到匹配的数据</td>
          </tr>
        `;
        return;
      }

      // 填充表格数据
      filteredOnlineData.forEach((user) => {
        const row = document.createElement("tr");

        // 格式化时间
        const lastUsed = new Date(user.lastUsed);
        const timeAgo = getTimeAgo(lastUsed);
        const chinaTime = lastUsed.toLocaleString("zh-CN", {
          timeZone: "Asia/Shanghai",
        });

        row.innerHTML = `
          <td><span class="user-name">${user.username}</span></td>
          <td><span class="user-name">${user.displayName}</span></td>
          <td><span class="user-handle">@${user.twitterId}</span></td>
          <td><span class="user-time" title="${chinaTime}">${timeAgo}</span></td>
        `;

        tbody.appendChild(row);
      });
    }

    function updatePagination() {
      const paginationDiv = document.getElementById("online-pagination");

      if (totalPages <= 1) {
        paginationDiv.innerHTML = "";
        return;
      }

      paginationDiv.innerHTML = `
        <button id="online-prev-btn" class="page-btn" ${currentPage === 1 ? "disabled" : ""}>上一页</button>
        <span class="page-info">${currentPage} / ${totalPages}</span>
        <button id="online-next-btn" class="page-btn" ${currentPage === totalPages ? "disabled" : ""}>下一页</button>
      `;

      // 绑定事件监听器
      const prevBtn = document.getElementById("online-prev-btn");
      const nextBtn = document.getElementById("online-next-btn");

      if (prevBtn && !prevBtn.disabled) {
        prevBtn.addEventListener("click", () => loadOnlineUsers(currentPage - 1));
      }

      if (nextBtn && !nextBtn.disabled) {
        nextBtn.addEventListener("click", () => loadOnlineUsers(currentPage + 1));
      }
    }

    function getTimeAgo(date) {
      // 确保使用中国时区
      const now = new Date();
      const chinaNow = new Date(
        now.toLocaleString("en-US", { timeZone: "Asia/Shanghai" })
      );
      const chinaDate = new Date(
        date.toLocaleString("en-US", { timeZone: "Asia/Shanghai" })
      );

      const diffMs = chinaNow - chinaDate;
      const diffMins = Math.floor(diffMs / (1000 * 60));

      if (diffMins < 1) {
        return "刚刚";
      } else if (diffMins < 60) {
        return `${diffMins}分钟前`;
      } else {
        const diffHours = Math.floor(diffMins / 60);
        return `${diffHours}小时前`;
      }
    }
  });
</script>
