  function $(id) {
    return document.getElementById(id);
  }

  function toast(msg, type) {
    const el = $("ff-toast");
    if (!el) return;
    el.textContent = msg;
    el.style.display = "block";
    el.style.background =
      type === "error" ? "#991b1b" : type === "success" ? "#065f46" : "#111827";
    setTimeout(() => {
      el.style.display = "none";
    }, 2400);
  }

  // --- Tag Input Component ---
  function createTagInput(
    container,
    initialTags = [],
    onChange,
    showTranslation = false
  ) {
    let tags = [...initialTags];
    const input = document.createElement("input");
    input.type = "text";
    input.className = "tag-input";
    input.placeholder = "Add users or features...";

    function render() {
      container.innerHTML = "";
      tags.forEach((tag, index) => {
        const tagEl = document.createElement("span");
        tagEl.className = "tag-item";
        if (showTranslation) {
          const translation = FEATURE_KEYS[tag] || "";
          tagEl.textContent = translation ? `${tag} (${translation})` : tag;
        } else {
          tagEl.textContent = tag;
        }
        const removeEl = document.createElement("span");
        removeEl.className = "tag-remove";
        removeEl.textContent = "×";
        removeEl.onclick = () => {
          tags.splice(index, 1);
          render();
          onChange(tags);
        };
        tagEl.appendChild(removeEl);
        container.appendChild(tagEl);
      });
      container.appendChild(input);
      input.focus();
    }

    function addTags(newTags) {
      const toAdd = newTags
        .split(/[,\s]+/)
        .map((t) => t.trim())
        .filter(Boolean);
      if (toAdd.length > 0) {
        tags.push(...toAdd);
        tags = [...new Set(tags)]; // remove duplicates
        render();
        onChange(tags);
      }
    }

    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === ",") {
        e.preventDefault();
        addTags(input.value);
        input.value = "";
      }
    });
    input.addEventListener("blur", () => {
      addTags(input.value);
      input.value = "";
    });
    render();
    return { getTags: () => tags };
  }

  // --- API Calls ---
  async function loadConfig(isForDiff = false) {
    if (!isForDiff) toast("Loading config...", "info");
    const resp = await fetch("/api/xhunt/stats/feature-flags", {
      credentials: "include",
    });
    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
    const json = await resp.json();
    if (!json.success) throw new Error(json.error || "Failed to load");
    const parsed = JSON.parse(json.data.content || "{}");
    if (isForDiff) return parsed;

    configData = parsed;
    originalConfigData = JSON.parse(JSON.stringify(parsed)); // Deep copy for diffing
    dirty = false;
    if (!isForDiff) toast("Config loaded successfully!", "success");
  }

  async function loadTranslations() {
    try {
      const resp = await fetch(
        "https://kb.cryptohunt.ai/nacos-configs?dataId=xhunt_i18n&group=DEFAULT_GROUP"
      );
      if (!resp.ok) {
        throw new Error(`HTTP error ${resp.status}`);
      }
      const data = await resp.json();

      if (data && data.zh) {
        FEATURE_KEYS = {
          ...FEATURE_KEYS,
          ...data.zh,
        };
      } else {
        throw new Error("Translations format is invalid or missing 'zh' key");
      }
    } catch (e) {
      console.error("Failed to load feature key translations:", e);
      toast(`Translations Error: ${e.message}`, "error");
    }
  }

  async function publishConfig() {
    toast("Publishing...", "info");
    const content = JSON.stringify(configData, null, 2);
    const resp = await fetch("/api/xhunt/stats/feature-flags", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      credentials: "include",
      body: JSON.stringify({ content }),
    });
    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
    const json = await resp.json();
    if (!json.success) throw new Error(json.error || "Failed to publish");
    dirty = false;
    toast("Published successfully!", "success");
    closeDiffModal();
    await loadConfig(); // Reload to get fresh state
  }

  // --- UI Rendering ---
  function renderSummary() {
    const flexibleSummaryList = $("ff-summary-flexible-list");
    const testSummaryList = $("ff-summary-test-list");
    const canarySummaryList = $("ff-summary-canary-list");

    // Flexible Testing Summary
    const flexibleConfig = configData.flexibleTesting || {};
    const flexibleFeatures = Object.entries(flexibleConfig).filter(
      ([key]) => !key.startsWith("_")
    );

    if (flexibleFeatures.length > 0) {
      flexibleSummaryList.innerHTML = flexibleFeatures
        .map(([key, users]) => {
          const translation = FEATURE_KEYS[key] || "";
          const displayName = translation ? `${key} (${translation})` : key;
          return `
                <li>
                    <span class="feature-name">${displayName}</span>
                    <span class="user-count-badge">${users.length} user(s)</span>
                </li>
            `;
        })
        .join("");
    } else {
      flexibleSummaryList.innerHTML =
        '<li class="no-features">No active flexible rules.</li>';
    }

    // Test Group Summary
    const testFeatures = (configData.testConfig?.features || []).filter(
      (key) => !key.startsWith("_")
    );

    if (testFeatures.length > 0) {
      testSummaryList.innerHTML = testFeatures
        .map((key) => {
          const translation = FEATURE_KEYS[key] || "";
          const displayName = translation ? `${key} (${translation})` : key;
          return `
                <li>
                    <span class="feature-name">${displayName}</span>
                </li>
            `;
        })
        .join("");
    } else {
      testSummaryList.innerHTML =
        '<li class="no-features">No features in test group.</li>';
    }

    // Canary Group Summary
    const canaryFeatures = (configData.canaryConfig?.features || []).filter(
      (key) => !key.startsWith("_")
    );

    if (canaryFeatures.length > 0) {
      canarySummaryList.innerHTML = canaryFeatures
        .map((key) => {
          const translation = FEATURE_KEYS[key] || "";
          const displayName = translation ? `${key} (${translation})` : key;
          return `
                <li>
                    <span class="feature-name">${displayName}</span>
                </li>
            `;
        })
        .join("");
    } else {
      canarySummaryList.innerHTML =
        '<li class="no-features">No features in canary group.</li>';
    }
  }

  function renderUI() {
    renderSummary();
    renderFlexibleTesting();
    renderTestConfig();
    renderCanaryConfig();
    renderFeatureKeys(); // Ensure keys are rendered with the rest of the UI
  }

  function renderFlexibleTesting() {
    const container = $("ff-flexible-list");
    container.innerHTML = "";
    const flexibleConfig = configData.flexibleTesting || {};
    for (const key in flexibleConfig) {
      const card = createFlexibleRuleCard(key, flexibleConfig[key]);
      container.appendChild(card);
    }
  }

  function createFlexibleRuleCard(key, users) {
    const card = document.createElement("div");
    card.className = "flexible-rule-card";
    card.dataset.featureKey = key;
    card.innerHTML = `
            <button class="delete-rule-btn" title="Delete this rule">×</button>
            <div class="ff-field">
                <label>Feature Name</label>
                <input type="text" class="control-input feature-name-input" value="${key}">
                <div class="feature-key-translation" style="color: red;">${
                  FEATURE_KEYS[key] || FEATURE_KEYS[key.replace("_", "")] || ""
                }</div>
            </div>
            <div class="ff-field">
                <label>User Handles</label>
                <div class="tag-input-container"></div>
                <div class="quick-add-btns">
                  <button class="btn quick-add-btn" data-target="flexible" data-feature="${key}" data-list="vip">+ VIP 名单</button>
                  <button class="btn quick-add-btn" data-target="flexible" data-feature="${key}" data-list="internal">+ 内测名单</button>
                </div>
            </div>
        `;
    const tagInputContainer = card.querySelector(".tag-input-container");
    createTagInput(tagInputContainer, users, (newUsers) => {
      if (!configData.flexibleTesting) configData.flexibleTesting = {};
      configData.flexibleTesting[key] = newUsers;
      dirty = true;
    });

    card.querySelector(".delete-rule-btn").onclick = () => {
      delete configData.flexibleTesting[key];
      dirty = true;
      renderFlexibleTesting();
    };

    const nameInput = card.querySelector(".feature-name-input");
    const translationDiv = card.querySelector(".feature-key-translation");

    nameInput.addEventListener("input", (e) => {
      let inputValue = e.target.value.trim();
      const hasUnderscore = inputValue.startsWith("_");
      if (hasUnderscore) {
        inputValue = inputValue.substring(1);
      }

      let translation = "";
      if (inputValue) {
        const matchedKey = Object.keys(FEATURE_KEYS).find((key) =>
          key.startsWith(inputValue)
        );
        if (matchedKey) {
          translation = FEATURE_KEYS[matchedKey];
        }
      }

      translationDiv.textContent = hasUnderscore
        ? `_${translation}`
        : translation;
    });

    nameInput.addEventListener("change", (e) => {
      const newKey = e.target.value.trim();
      if (newKey && newKey !== key) {
        if (!configData.flexibleTesting) configData.flexibleTesting = {};
        configData.flexibleTesting[newKey] = configData.flexibleTesting[key];
        delete configData.flexibleTesting[key];
        dirty = true;
        // No full re-render needed, just update the key for future operations
        // But a re-render is safer to keep everything in sync
        renderFlexibleTesting();
      }
    });
    return card;
  }

