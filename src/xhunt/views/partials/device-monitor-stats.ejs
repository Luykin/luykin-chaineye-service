<div class="stats-section">
  <div class="section" id="device-monitor-section">
    <h2 class="section-title">🖥️ 设备监控</h2>

    <div class="stat-card" style="max-width: 900px; margin: 0 auto 20px">
      <button
        id="refreshDeviceStatus"
        style="
          width: 100%;
          padding: 12px 20px;
          background: #3b82f6;
          color: white;
          border: none;
          border-radius: 6px;
          cursor: pointer;
          font-size: 14px;
          font-weight: 600;
        "
      >
        🔄 获取当前设备状态
      </button>

      <!-- 加载状态 -->
      <div
        id="deviceLoadingStatus"
        style="
          display: none;
          padding: 15px;
          background: #f3f4f6;
          border-radius: 6px;
          margin-top: 15px;
          color: #374151;
          font-weight: 600;
        "
      >
        ⏳ 正在获取设备状态...
      </div>

      <!-- 错误提示 -->
      <div
        id="deviceErrorMessage"
        style="
          display: none;
          padding: 15px;
          background: #fee2e2;
          border-radius: 6px;
          margin-top: 15px;
          color: #991b1b;
          font-weight: 600;
        "
      ></div>
    </div>

    <!-- 设备状态展示区域 -->
    <div id="deviceStatusContainer" style="display: none">
      <!-- 系统信息 -->
      <div class="stat-card" style="max-width: 900px; margin: 0 auto 20px">
        <div class="stat-title" style="margin-bottom: 15px">📋 系统信息</div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >操作系统:</span
          >
          <span
            class="stat-value"
            id="systemOS"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >主机名:</span
          >
          <span
            class="stat-value"
            id="systemHostname"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >运行时间:</span
          >
          <span
            class="stat-value"
            id="systemUptime"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >更新时间:</span
          >
          <span
            class="stat-value"
            id="updateTime"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
      </div>

      <!-- CPU 信息 -->
      <div class="stat-card" style="max-width: 900px; margin: 0 auto 20px">
        <div class="stat-title" style="margin-bottom: 15px">
          💻 CPU 使用情况
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >CPU 核心数:</span
          >
          <span
            class="stat-value"
            id="cpuCores"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >CPU 使用率:</span
          >
          <span
            class="stat-value"
            id="cpuUsage"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >负载平均值 (1/5/15分钟):</span
          >
          <span
            class="stat-value"
            id="loadAverage"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
      </div>

      <!-- 内存信息 -->
      <div class="stat-card" style="max-width: 900px; margin: 0 auto 20px">
        <div class="stat-title" style="margin-bottom: 15px">
          💾 内存使用情况
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >总内存:</span
          >
          <span
            class="stat-value"
            id="memTotal"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >已使用:</span
          >
          <span
            class="stat-value"
            id="memUsed"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >可用内存:</span
          >
          <span
            class="stat-value"
            id="memFree"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >使用率:</span
          >
          <span
            class="stat-value"
            id="memUsagePercent"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
      </div>

      <!-- PM2 状态 -->
      <div class="stat-card" style="max-width: 900px; margin: 0 auto 20px">
        <div class="stat-title" style="margin-bottom: 15px">
          🔄 PM2 进程状态
        </div>
        <div id="pm2Status">
          <div style="color: #6b7280; font-size: 14px">暂无数据</div>
        </div>
      </div>

      <!-- Redis 状态 -->
      <div class="stat-card" style="max-width: 900px; margin: 0 auto 20px">
        <div class="stat-title" style="margin-bottom: 15px">📦 Redis 状态</div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >连接状态:</span
          >
          <span
            class="stat-value"
            id="redisStatus"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >已用内存:</span
          >
          <span
            class="stat-value"
            id="redisMemory"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >内存限制:</span
          >
          <span
            class="stat-value"
            id="redisMaxMemory"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >内存使用率:</span
          >
          <span
            class="stat-value"
            id="redisMemoryUsagePercent"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >Key 数量:</span
          >
          <span
            class="stat-value"
            id="redisKeys"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >运行天数:</span
          >
          <span
            class="stat-value"
            id="redisUptime"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>

        <!-- 缓存清除功能 -->
        <div
          style="
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #e5e7eb;
          "
        >
          <div
            style="
              margin-bottom: 10px;
              color: #374151;
              font-weight: 600;
              font-size: 14px;
            "
          >
            🗑️ 清除缓存
          </div>
          <div
            style="
              display: flex;
              gap: 10px;
              align-items: center;
              margin-bottom: 10px;
            "
          >
            <input
              type="text"
              id="cacheKeyPrefix"
              placeholder="输入缓存 key 前缀"
              style="
                flex: 1;
                padding: 8px 12px;
                border: 1px solid #d1d5db;
                border-radius: 6px;
                font-size: 14px;
                outline: none;
              "
            />
            <button
              id="clearCacheBtn"
              style="
                padding: 8px 16px;
                background: #ef4444;
                color: white;
                border: none;
                border-radius: 6px;
                cursor: pointer;
                font-size: 14px;
                font-weight: 600;
                white-space: nowrap;
              "
            >
              清除
            </button>
          </div>
          <div
            id="clearCacheResult"
            style="
              display: none;
              padding: 10px;
              border-radius: 6px;
              font-size: 13px;
              margin-bottom: 10px;
            "
          ></div>
          <details style="margin-top: 10px">
            <summary
              style="
                cursor: pointer;
                color: #6b7280;
                font-size: 13px;
                user-select: none;
              "
            >
              💡 常用缓存 Key 前缀示例（点击展开）
            </summary>
            <div
              style="
                margin-top: 10px;
                padding: 10px;
                background: #f9fafb;
                border-radius: 6px;
                font-size: 12px;
                line-height: 1.8;
              "
            >
              <div>
                <code
                  style="
                    background: #e5e7eb;
                    padding: 2px 6px;
                    border-radius: 3px;
                  "
                  >rootdata_verified:</code
                >
                - Rootdata 数据验证状态（20天缓存）
              </div>
              <div>
                <code
                  style="
                    background: #e5e7eb;
                    padding: 2px 6px;
                    border-radius: 3px;
                  "
                  >rootdata_search_</code
                >
                - Rootdata 搜索结果（10分钟）
              </div>
              <div>
                <code
                  style="
                    background: #e5e7eb;
                    padding: 2px 6px;
                    border-radius: 3px;
                  "
                  >dau:</code
                >
                - 每日活跃用户数据（8天）
              </div>
              <div>
                <code
                  style="
                    background: #e5e7eb;
                    padding: 2px 6px;
                    border-radius: 3px;
                  "
                  >projects_</code
                >
                - 项目列表缓存（5分钟）
              </div>
              <div>
                <code
                  style="
                    background: #e5e7eb;
                    padding: 2px 6px;
                    border-radius: 3px;
                  "
                  >project_search_</code
                >
                - 项目搜索结果（5分钟）
              </div>
              <div>
                <code
                  style="
                    background: #e5e7eb;
                    padding: 2px 6px;
                    border-radius: 3px;
                  "
                  >vc_listed_projects_</code
                >
                - VC 投资项目列表（5分钟）
              </div>
              <div>
                <code
                  style="
                    background: #e5e7eb;
                    padding: 2px 6px;
                    border-radius: 3px;
                  "
                  >mantle:register:cd:</code
                >
                - Mantle 注册冷却（10秒）
              </div>
              <div>
                <code
                  style="
                    background: #e5e7eb;
                    padding: 2px 6px;
                    border-radius: 3px;
                  "
                  >mantle:invites:count:</code
                >
                - Mantle 邀请数量（10分钟）
              </div>
              <div>
                <code
                  style="
                    background: #e5e7eb;
                    padding: 2px 6px;
                    border-radius: 3px;
                  "
                  >twitter_oauth_state:</code
                >
                - Twitter OAuth 状态（8分钟）
              </div>
              <div>
                <code
                  style="
                    background: #e5e7eb;
                    padding: 2px 6px;
                    border-radius: 3px;
                  "
                  >user:points:</code
                >
                - 用户积分缓存
              </div>
              <div>
                <code
                  style="
                    background: #e5e7eb;
                    padding: 2px 6px;
                    border-radius: 3px;
                  "
                  >user:review:limit:</code
                >
                - 用户评论限制（6分钟）
              </div>
              <div>
                <code
                  style="
                    background: #e5e7eb;
                    padding: 2px 6px;
                    border-radius: 3px;
                  "
                  >high_delay_report:</code
                >
                - 高延迟报告防重（10分钟）
              </div>
              <div style="margin-top: 8px; color: #ef4444; font-weight: 600">
                ⚠️ 注意：清除缓存可能影响系统性能，请谨慎操作！
              </div>
            </div>
          </details>
        </div>
      </div>

      <!-- PostgreSQL 状态 -->
      <div class="stat-card" style="max-width: 900px; margin: 0 auto 20px">
        <div class="stat-title" style="margin-bottom: 15px">
          🐘 PostgreSQL 状态
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >连接状态:</span
          >
          <span
            class="stat-value"
            id="pgStatus"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >版本:</span
          >
          <span
            class="stat-value"
            id="pgVersion"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >数据库大小:</span
          >
          <span
            class="stat-value"
            id="pgSize"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px"
            >活跃连接数:</span
          >
          <span
            class="stat-value"
            id="pgConnections"
            style="color: #111827; font-size: 14px; font-weight: 600"
            >-</span
          >
        </div>
      </div>

      <!-- 磁盘信息 -->
      <div class="stat-card" style="max-width: 900px; margin: 0 auto 20px">
        <div class="stat-title" style="margin-bottom: 15px">
          💿 磁盘使用情况
        </div>
        <div id="diskStatus">
          <div style="color: #6b7280; font-size: 14px">暂无数据</div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // 设备监控相关逻辑
  (function () {
    const refreshBtn = document.getElementById("refreshDeviceStatus");
    const loadingStatus = document.getElementById("deviceLoadingStatus");
    const errorMessage = document.getElementById("deviceErrorMessage");
    const statusContainer = document.getElementById("deviceStatusContainer");

    refreshBtn.addEventListener("click", async () => {
      try {
        // 显示加载状态
        loadingStatus.style.display = "block";
        errorMessage.style.display = "none";
        statusContainer.style.display = "none";
        refreshBtn.disabled = true;

        // 调用API获取设备状态
        const response = await fetch("/api/xhunt/stats/device-status");
        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.error || "获取设备状态失败");
        }

        // 更新界面
        updateDeviceStatus(data);

        // 显示数据
        loadingStatus.style.display = "none";
        statusContainer.style.display = "block";
      } catch (error) {
        console.error("获取设备状态失败:", error);
        errorMessage.textContent = "❌ " + error.message;
        errorMessage.style.display = "block";
        loadingStatus.style.display = "none";
      } finally {
        refreshBtn.disabled = false;
      }
    });

    function updateDeviceStatus(data) {
      // 更新系统信息
      document.getElementById("systemOS").textContent =
        data.system.platform || "-";
      document.getElementById("systemHostname").textContent =
        data.system.hostname || "-";
      document.getElementById("systemUptime").textContent =
        data.system.uptime || "-";
      document.getElementById("updateTime").textContent = data.timestamp || "-";

      // 更新CPU信息
      document.getElementById("cpuCores").textContent = data.cpu.cores || "-";
      document.getElementById("cpuUsage").textContent = data.cpu.usage || "-";
      document.getElementById("loadAverage").textContent =
        data.cpu.loadAverage || "-";

      // 更新内存信息
      document.getElementById("memTotal").textContent =
        data.memory.total || "-";
      document.getElementById("memUsed").textContent = data.memory.used || "-";
      document.getElementById("memFree").textContent = data.memory.free || "-";
      document.getElementById("memUsagePercent").textContent =
        data.memory.usagePercent || "-";

      // 更新PM2状态
      const pm2Container = document.getElementById("pm2Status");
      if (data.pm2 && data.pm2.length > 0) {
        pm2Container.innerHTML = data.pm2
          .map(
            (app) => `
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px;">${
            app.name
          }:</span>
          <span class="stat-value" style="color: ${
            app.status === "online" ? "#10b981" : "#ef4444"
          }; font-size: 14px; font-weight: 600;">
            ${app.status} | CPU: ${app.cpu} | Mem: ${app.memory} | 重启: ${
              app.restarts
            }次
          </span>
        </div>
      `
          )
          .join("");
      } else {
        pm2Container.innerHTML =
          '<div style="color: #6b7280; font-size: 14px;">PM2 未运行或无进程</div>';
      }

      // 更新Redis状态
      const redisStatusEl = document.getElementById("redisStatus");
      if (data.redis.connected) {
        redisStatusEl.textContent = "✅ 已连接";
        redisStatusEl.style.color = "#10b981";
        document.getElementById("redisMemory").textContent =
          data.redis.memory || "-";
        document.getElementById("redisMaxMemory").textContent =
          data.redis.maxMemory || "-";
        document.getElementById("redisMemoryUsagePercent").textContent =
          data.redis.memoryUsagePercent || "-";
        document.getElementById("redisKeys").textContent =
          data.redis.keys || "-";
        document.getElementById("redisUptime").textContent =
          data.redis.uptime || "-";
      } else {
        redisStatusEl.textContent = "❌ 未连接";
        redisStatusEl.style.color = "#ef4444";
        document.getElementById("redisMemory").textContent = "-";
        document.getElementById("redisMaxMemory").textContent = "-";
        document.getElementById("redisMemoryUsagePercent").textContent = "-";
        document.getElementById("redisKeys").textContent = "-";
        document.getElementById("redisUptime").textContent = "-";
      }

      // 更新PostgreSQL状态
      const pgStatusEl = document.getElementById("pgStatus");
      if (data.postgresql.connected) {
        pgStatusEl.textContent = "✅ 已连接";
        pgStatusEl.style.color = "#10b981";
        document.getElementById("pgVersion").textContent =
          data.postgresql.version || "-";
        document.getElementById("pgSize").textContent =
          data.postgresql.size || "-";
        document.getElementById("pgConnections").textContent =
          data.postgresql.connections || "-";
      } else {
        pgStatusEl.textContent = "❌ 未连接";
        pgStatusEl.style.color = "#ef4444";
        document.getElementById("pgVersion").textContent = "-";
        document.getElementById("pgSize").textContent = "-";
        document.getElementById("pgConnections").textContent = "-";
      }

      // 更新磁盘信息
      const diskContainer = document.getElementById("diskStatus");
      if (data.disk && data.disk.length > 0) {
        diskContainer.innerHTML = data.disk
          .map(
            (disk) => `
        <div class="stat-row">
          <span class="stat-label" style="color: #6b7280; font-size: 14px;">${disk.filesystem} (${disk.mounted}):</span>
          <span class="stat-value" style="color: #111827; font-size: 14px; font-weight: 600;">
            已用: ${disk.used} / 总计: ${disk.size} (${disk.usePercent})
          </span>
        </div>
      `
          )
          .join("");
      } else {
        diskContainer.innerHTML =
          '<div style="color: #6b7280; font-size: 14px;">暂无磁盘数据</div>';
      }
    }

    // 清除缓存功能
    const clearCacheBtn = document.getElementById("clearCacheBtn");
    const cacheKeyPrefixInput = document.getElementById("cacheKeyPrefix");
    const clearCacheResult = document.getElementById("clearCacheResult");

    clearCacheBtn.addEventListener("click", async () => {
      const prefix = cacheKeyPrefixInput.value.trim();

      if (!prefix) {
        clearCacheResult.textContent = "⚠️ 请输入缓存 key 前缀";
        clearCacheResult.style.display = "block";
        clearCacheResult.style.background = "#fef3c7";
        clearCacheResult.style.color = "#92400e";
        return;
      }

      if (
        !confirm(
          `确定要清除所有以 "${prefix}" 开头的缓存吗？\n\n此操作不可撤销！`
        )
      ) {
        return;
      }

      try {
        clearCacheBtn.disabled = true;
        clearCacheBtn.textContent = "处理中...";

        const response = await fetch("/api/xhunt/stats/clear-cache", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ prefix }),
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.error || "清除缓存失败");
        }

        // 判断是同步还是异步处理
        if (data.sync) {
          // 同步处理完成，显示详细结果
          let resultText =
            data.message || `✅ 成功清除 ${data.deletedCount} 个缓存键`;

          // 处理超时情况
          if (data.timeout) {
            if (data.deletedCount === 0) {
              resultText = `⚠️ ${data.message || "未找到匹配的缓存键"}`;
              if (data.scanCount) {
                resultText += `\n提示: Redis 中键太多，扫描 ${data.scanCount} 次后超时`;
              }
              clearCacheResult.style.background = "#fef3c7";
              clearCacheResult.style.color = "#92400e";
            } else {
              resultText = `⚠️ ${data.message || "部分清除完成"}`;
              clearCacheResult.style.background = "#fed7aa";
              clearCacheResult.style.color = "#9a3412";
            }
          } else {
            if (data.samples && data.samples.length > 0) {
              resultText += `\n示例: ${data.samples.slice(0, 3).join(", ")}${
                data.samples.length > 3 ? "..." : ""
              }`;
            }
            clearCacheResult.style.background = "#d1fae5";
            clearCacheResult.style.color = "#065f46";
          }

          clearCacheResult.textContent = resultText;
          clearCacheResult.style.display = "block";
          clearCacheResult.style.whiteSpace = "pre-line";

          console.log(`✅ 清除缓存完成: ${data.deletedCount} 个键`);
          if (data.samples) {
            console.log("删除的键:", data.samples);
          }
          if (data.timeout) {
            console.warn(`⚠️ 扫描提前终止（扫描了 ${data.scanCount} 次）`);
          }
        } else {
          // 异步处理，显示进度提示
          clearCacheResult.textContent = `🔄 ${
            data.message || "正在后台处理..."
          }`;
          clearCacheResult.style.display = "block";
          clearCacheResult.style.background = "#dbeafe";
          clearCacheResult.style.color = "#1e40af";
          clearCacheResult.style.whiteSpace = "normal";

          console.log(`📝 缓存清除任务已提交: "${prefix}"`);
          console.log(
            `💡 已删除 ${data.deletedCount} 个精确键，约 ${data.estimatedTotal} 个键正在后台删除`
          );
          console.log("请查看服务器日志以了解详细进度");
        }

        // 5秒后隐藏提示
        setTimeout(() => {
          clearCacheResult.style.display = "none";
        }, 5000);
      } catch (error) {
        console.error("清除缓存失败:", error);
        clearCacheResult.textContent = "❌ " + error.message;
        clearCacheResult.style.display = "block";
        clearCacheResult.style.background = "#fee2e2";
        clearCacheResult.style.color = "#991b1b";
        clearCacheResult.style.whiteSpace = "normal";
      } finally {
        clearCacheBtn.disabled = false;
        clearCacheBtn.textContent = "清除";
      }
    });
  })();
</script>
