<!-- Redis 数据管理 -->
<div class="redis-section">
  
  <!-- 头部 -->
  <div class="redis-header">
    <div class="redis-header-title">
      <h2>Redis 数据管理</h2>
      <p>查询、修改和删除 Redis 缓存数据</p>
    </div>
    <button id="redis-refresh-info" class="redis-btn redis-btn-secondary">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
        <path d="M3 3v5h5"/>
        <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/>
        <path d="M16 21h5v-5"/>
      </svg>
      刷新
    </button>
  </div>

  <!-- 服务器信息 -->
  <div class="redis-info-bar" id="redis-info-cards">
    <div class="info-item">
      <span class="info-label">版本</span>
      <span class="info-value" id="redis-version">-</span>
    </div>
    <div class="info-divider"></div>
    <div class="info-item">
      <span class="info-label">模式</span>
      <span class="info-value" id="redis-mode">-</span>
    </div>
    <div class="info-divider"></div>
    <div class="info-item info-item-large">
      <span class="info-label">总 Keys</span>
      <span class="info-value info-value-mono" id="redis-keys" title="-">-</span>
    </div>
    <div class="info-divider"></div>
    <div class="info-item">
      <span class="info-label">内存</span>
      <span class="info-value" id="redis-memory">-</span>
    </div>
    <div class="info-divider"></div>
    <div class="info-item">
      <span class="info-label">连接</span>
      <span class="info-value" id="redis-clients">-</span>
    </div>
    <div class="info-divider"></div>
    <div class="info-item">
      <span class="info-label">命中率</span>
      <span class="info-value" id="redis-hitrate">-</span>
    </div>
  </div>

  <!-- 主操作区 -->
  <div class="redis-main">
    <!-- 左侧：查询 -->
    <div class="redis-panel redis-panel-query">
      <div class="panel-header">
        <h3>查询 Key</h3>
      </div>
      
      <div class="query-form">
        <div class="input-group">
          <input 
            type="text" 
            id="redis-key-input" 
            class="redis-input" 
            placeholder="输入 Key，如: user:session:xxx" 
          />
          <button id="redis-query-btn" class="redis-btn redis-btn-primary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.3-4.3"/>
            </svg>
            查询
          </button>
        </div>
        
        <div class="scan-section">
          <div class="input-group input-group-sm">
            <input 
              type="text" 
              id="redis-pattern-input" 
              class="redis-input redis-input-sm" 
              placeholder="扫描模式，如: user:*" 
            />
            <button id="redis-scan-btn" class="redis-btn redis-btn-secondary">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 7V4h3"/>
                <path d="M4 17v3h3"/>
                <path d="M20 7V4h-3"/>
                <path d="M20 17v3h-3"/>
                <path d="M9 9h6v6H9z"/>
              </svg>
              扫描
            </button>
          </div>
          <span class="input-hint">最多返回 100 个匹配项</span>
        </div>
      </div>

      <!-- Keys 列表 -->
      <div id="redis-keys-list" class="keys-list" style="display: none;">
        <table class="redis-table redis-table-compact">
          <thead>
            <tr>
              <th>Key</th>
              <th class="col-action">操作</th>
            </tr>
          </thead>
          <tbody id="redis-keys-tbody">
          </tbody>
        </table>
      </div>

      <!-- 最近查询 -->
      <div class="history-section">
        <div class="section-subheader">
          <span>最近查询</span>
          <button id="redis-clear-history" class="btn-text">清空</button>
        </div>
        <div id="redis-history-list" class="history-list">
          <span class="empty-text">暂无记录</span>
        </div>
      </div>
    </div>

    <!-- 右侧：结果 -->
    <div class="redis-panel redis-panel-result" id="redis-result-area" style="display: none;">
      <div class="panel-header">
        <h3>查询结果</h3>
        <div id="redis-warning-badge" class="badge badge-warning" style="display: none;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/>
            <line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
          敏感 Key
        </div>
      </div>

      <!-- Key 元信息 -->
      <div class="meta-grid">
        <div class="meta-item">
          <span class="meta-label">Key</span>
          <span id="redis-result-key" class="meta-value meta-value-mono"></span>
        </div>
        <div class="meta-item">
          <span class="meta-label">类型</span>
          <span id="redis-result-type" class="meta-value">
            <span class="badge badge-type">-</span>
          </span>
        </div>
        <div class="meta-item">
          <span class="meta-label">TTL</span>
          <span id="redis-result-ttl" class="meta-value">-</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">大小</span>
          <span id="redis-result-size" class="meta-value">-</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">元素数</span>
          <span id="redis-result-length" class="meta-value">-</span>
        </div>
      </div>

      <!-- Value -->
      <div class="value-section">
        <div class="value-header">
          <span class="value-label">Value</span>
          <span id="redis-value-type-badge" class="badge badge-json" style="display: none;">JSON</span>
        </div>
        <textarea 
          id="redis-result-value" 
          class="redis-textarea" 
          rows="12" 
          readonly
        ></textarea>
      </div>

      <!-- 操作按钮 -->
      <div class="panel-actions" id="redis-actions">
        <button id="redis-edit-btn" class="redis-btn redis-btn-primary" style="display: none;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
          编辑
        </button>
        <button id="redis-copy-btn" class="redis-btn redis-btn-secondary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
            <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
          </svg>
          复制
        </button>
        <button id="redis-delete-btn" class="redis-btn redis-btn-danger">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M3 6h18"/>
            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/>
            <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
          </svg>
          删除
        </button>
      </div>
    </div>

    <!-- 空状态 -->
    <div class="redis-panel redis-panel-empty" id="redis-empty-state">
      <div class="empty-state-content">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
          <ellipse cx="12" cy="5" rx="9" ry="3"/>
          <path d="M3 5V19A9 3 0 0 0 21 19V5"/>
          <path d="M3 12A9 3 0 0 0 21 12"/>
        </svg>
        <p>在左侧查询或扫描 Key</p>
        <span>输入 Key 名称或模式来查看数据</span>
      </div>
    </div>
  </div>
</div>

<!-- 编辑对话框 -->
<div id="redis-edit-modal" class="redis-modal" style="display: none;">
  <div class="modal-backdrop"></div>
  <div class="modal-container">
    <div class="modal-header">
      <h3>编辑 Value</h3>
      <button class="modal-close" id="redis-edit-modal-close">&times;</button>
    </div>
    <div class="modal-body">
      <div class="form-row">
        <label>Key</label>
        <div id="redis-edit-key" class="form-static"></div>
      </div>
      <div class="form-row">
        <label>Value</label>
        <textarea id="redis-edit-value" class="redis-textarea" rows="8"></textarea>
      </div>
      <div class="form-row">
        <label>TTL (秒，可选)</label>
        <input type="number" id="redis-edit-ttl" class="redis-input" placeholder="留空保持原 TTL，-1 表示永不过期" />
        <span class="form-hint">当前 TTL: <span id="redis-edit-current-ttl">-</span></span>
      </div>
    </div>
    <div class="modal-footer">
      <button id="redis-edit-cancel" class="redis-btn redis-btn-secondary">取消</button>
      <button id="redis-edit-save" class="redis-btn redis-btn-primary">保存</button>
    </div>
  </div>
</div>

<!-- 删除确认对话框 -->
<div id="redis-delete-modal" class="redis-modal" style="display: none;">
  <div class="modal-backdrop"></div>
  <div class="modal-container modal-container-sm">
    <div class="modal-header">
      <h3>确认删除</h3>
      <button class="modal-close" id="redis-delete-modal-close">&times;</button>
    </div>
    <div class="modal-body">
      <p class="text-danger">此操作不可恢复，请确认是否删除：</p>
      <div id="redis-delete-key" class="delete-key-box"></div>
    </div>
    <div class="modal-footer">
      <button id="redis-delete-cancel" class="redis-btn redis-btn-secondary">取消</button>
      <button id="redis-delete-confirm" class="redis-btn redis-btn-danger">确认删除</button>
    </div>
  </div>
</div>
