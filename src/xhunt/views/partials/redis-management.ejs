<!-- Redis 管理 -->
<div class="stats-container">
  <div class="stats-header">
    <div class="stats-title-wrapper">
      <h2 class="stats-title">Redis 数据管理</h2>
      <p class="stats-subtitle">查询、修改和删除 Redis 缓存数据</p>
    </div>
    <div class="stats-actions">
      <button id="redis-refresh-info" class="btn btn-secondary" title="刷新服务器信息">
        <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
          <path d="M3 3v5h5"/>
          <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/>
          <path d="M16 21h5v-5"/>
        </svg>
        刷新
      </button>
    </div>
  </div>

  <!-- Redis 服务器信息卡片 -->
  <div class="stats-grid" id="redis-info-cards">
    <div class="stat-card">
      <div class="stat-label">Redis 版本</div>
      <div class="stat-value" id="redis-version">-</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">运行模式</div>
      <div class="stat-value" id="redis-mode">-</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">总 Key 数</div>
      <div class="stat-value" id="redis-keys">-</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">内存使用</div>
      <div class="stat-value" id="redis-memory">-</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">连接数</div>
      <div class="stat-value" id="redis-clients">-</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">命中率</div>
      <div class="stat-value" id="redis-hitrate">-</div>
    </div>
  </div>

  <!-- Key 查询区域 -->
  <div class="section-card" style="margin-top: 24px;">
    <div class="section-header">
      <h3 class="section-title">Key 查询</h3>
    </div>
    <div class="form-group" style="display: flex; gap: 12px; flex-wrap: wrap;">
      <input 
        type="text" 
        id="redis-key-input" 
        class="form-control" 
        placeholder="输入 Redis Key，如: user:session:xxx" 
        style="flex: 1; min-width: 300px;"
      />
      <button id="redis-query-btn" class="btn btn-primary">
        <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.3-4.3"/>
        </svg>
        查询
      </button>
      <button id="redis-reset-btn" class="btn btn-secondary">重置</button>
    </div>
    
    <!-- 扫描 Keys -->
    <div style="margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border-color);">
      <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
        <input 
          type="text" 
          id="redis-pattern-input" 
          class="form-control" 
          placeholder="输入匹配模式，如: user:*" 
          style="width: 250px;"
        />
        <button id="redis-scan-btn" class="btn btn-secondary">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 7V4h3"/>
            <path d="M4 17v3h3"/>
            <path d="M20 7V4h-3"/>
            <path d="M20 17v3h-3"/>
            <path d="M9 9h6v6H9z"/>
          </svg>
          扫描 Keys
        </button>
        <span class="text-muted" style="font-size: 12px;">最多返回 100 个</span>
      </div>
      <div id="redis-keys-list" style="margin-top: 12px; display: none;">
        <div style="max-height: 200px; overflow-y: auto; border: 1px solid var(--border-color); border-radius: 6px;">
          <table class="data-table" style="margin: 0;">
            <thead>
              <tr>
                <th>Key</th>
                <th style="width: 80px;">操作</th>
              </tr>
            </thead>
            <tbody id="redis-keys-tbody">
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- 查询结果区域 -->
  <div id="redis-result-area" class="section-card" style="margin-top: 24px; display: none;">
    <div class="section-header" style="display: flex; justify-content: space-between; align-items: center;">
      <h3 class="section-title">查询结果</h3>
      <div id="redis-warning-badge" style="display: none;">
        <span style="background: #fef3c7; color: #92400e; padding: 4px 12px; border-radius: 4px; font-size: 12px; font-weight: 500;">
          ⚠️ 敏感 Key，请谨慎操作
        </span>
      </div>
    </div>
    
    <div class="key-info-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 20px;">
      <div class="info-item">
        <span class="info-label">Key:</span>
        <span id="redis-result-key" class="info-value" style="font-family: monospace; word-break: break-all;"></span>
      </div>
      <div class="info-item">
        <span class="info-label">类型:</span>
        <span id="redis-result-type" class="info-value"></span>
      </div>
      <div class="info-item">
        <span class="info-label">TTL:</span>
        <span id="redis-result-ttl" class="info-value"></span>
      </div>
      <div class="info-item">
        <span class="info-label">大小:</span>
        <span id="redis-result-size" class="info-value"></span>
      </div>
      <div class="info-item">
        <span class="info-label">元素数:</span>
        <span id="redis-result-length" class="info-value"></span>
      </div>
    </div>

    <div style="margin-bottom: 16px;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
        <span class="info-label">Value:</span>
        <span id="redis-value-type-badge" style="display: none; font-size: 11px; background: #dbeafe; color: #1e40af; padding: 2px 8px; border-radius: 4px;">JSON</span>
      </div>
      <textarea 
        id="redis-result-value" 
        class="form-control" 
        rows="10" 
        readonly
        style="font-family: monospace; font-size: 13px; background: #f8fafc;"
      ></textarea>
    </div>

    <div id="redis-actions" style="display: flex; gap: 12px; flex-wrap: wrap;">
      <button id="redis-edit-btn" class="btn btn-primary" style="display: none;">
        <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
        </svg>
        编辑值
      </button>
      <button id="redis-delete-btn" class="btn btn-danger">
        <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 6h18"/>
          <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/>
          <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
        </svg>
        删除 Key
      </button>
      <button id="redis-copy-btn" class="btn btn-secondary">
        <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
          <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
        </svg>
        复制 Value
      </button>
    </div>
  </div>

  <!-- 最近查询历史 -->
  <div class="section-card" style="margin-top: 24px;">
    <div class="section-header">
      <h3 class="section-title">最近查询</h3>
      <button id="redis-clear-history" class="btn btn-text" style="font-size: 12px;">清空历史</button>
    </div>
    <div id="redis-history-list" style="max-height: 200px; overflow-y: auto;">
      <p class="text-muted" style="text-align: center; padding: 20px;">暂无查询记录</p>
    </div>
  </div>
</div>

<!-- 编辑对话框 -->
<div id="redis-edit-modal" class="modal" style="display: none;">
  <div class="modal-overlay"></div>
  <div class="modal-content" style="max-width: 600px;">
    <div class="modal-header">
      <h3 class="modal-title">编辑 Redis Value</h3>
      <button class="modal-close" id="redis-edit-modal-close">&times;</button>
    </div>
    <div class="modal-body">
      <div style="margin-bottom: 16px;">
        <label class="form-label">Key:</label>
        <div id="redis-edit-key" style="font-family: monospace; padding: 8px 12px; background: #f1f5f9; border-radius: 6px; word-break: break-all;"></div>
      </div>
      <div style="margin-bottom: 16px;">
        <label class="form-label">Value:</label>
        <textarea 
          id="redis-edit-value" 
          class="form-control" 
          rows="8" 
          style="font-family: monospace; font-size: 13px;"
        ></textarea>
      </div>
      <div style="margin-bottom: 16px;">
        <label class="form-label">TTL (秒，可选):</label>
        <input 
          type="number" 
          id="redis-edit-ttl" 
          class="form-control" 
          placeholder="留空保持原 TTL，-1 表示永不过期"
          style="width: 100%;"
        />
        <span class="form-hint">当前 TTL: <span id="redis-edit-current-ttl">-</span></span>
      </div>
    </div>
    <div class="modal-footer">
      <button id="redis-edit-cancel" class="btn btn-secondary">取消</button>
      <button id="redis-edit-save" class="btn btn-primary">确认保存</button>
    </div>
  </div>
</div>

<!-- 删除确认对话框 -->
<div id="redis-delete-modal" class="modal" style="display: none;">
  <div class="modal-overlay"></div>
  <div class="modal-content" style="max-width: 400px;">
    <div class="modal-header">
      <h3 class="modal-title">确认删除</h3>
      <button class="modal-close" id="redis-delete-modal-close">&times;</button>
    </div>
    <div class="modal-body">
      <p style="color: #dc2626; margin-bottom: 16px;">⚠️ 此操作不可恢复，请确认是否删除以下 Key：</p>
      <div id="redis-delete-key" style="font-family: monospace; padding: 12px; background: #fef2f2; border: 1px solid #fecaca; border-radius: 6px; word-break: break-all; color: #991b1b;"></div>
    </div>
    <div class="modal-footer">
      <button id="redis-delete-cancel" class="btn btn-secondary">取消</button>
      <button id="redis-delete-confirm" class="btn btn-danger">确认删除</button>
    </div>
  </div>
</div>

<style>
/* Redis 管理专用样式 */
.key-info-grid .info-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.key-info-grid .info-label {
  font-size: 12px;
  color: var(--text-muted);
  font-weight: 500;
}
.key-info-grid .info-value {
  font-size: 14px;
  color: var(--text-color);
}
</style>
