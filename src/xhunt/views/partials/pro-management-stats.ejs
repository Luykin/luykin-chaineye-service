<div class="pro-management-container">
  <div class="pro-management-header">
    <h2>👑 Pro 用户管理</h2>
    <p>手动开通和管理 Pro 用户权限</p>
  </div>

  <!-- 手动开通 Pro -->
  <div class="pro-grant-section">
    <div class="section-card">
      <div class="section-card-header">
        <h3>✨ 手动开通 Pro</h3>
        <p>为指定用户开通 Pro 权限</p>
      </div>
      <div class="section-card-content">
        <form id="grant-pro-form" class="grant-form">
          <div class="form-group">
            <label for="pro-username">用户名 (username)</label>
            <input
              type="text"
              id="pro-username"
              name="username"
              placeholder="请输入用户的 username"
              required
            />
            <small>输入要开通 Pro 的用户 username</small>
          </div>

          <div class="form-group">
            <label for="pro-duration">开通时长</label>
            <select id="pro-duration" name="duration" required>
              <option value="">请选择开通时长</option>
              <option value="1">1 天</option>
              <option value="15">15 天</option>
              <option value="30">1 个月 (30天)</option>
              <option value="90">3 个月 (90天)</option>
              <option value="365">1 年 (365天)</option>
            </select>
          </div>

          <div class="form-group">
            <label for="pro-reason">开通原因 (可选)</label>
            <input
              type="text"
              id="pro-reason"
              name="reason"
              placeholder="例如：活动奖励、测试账号等"
            />
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary">
              <span class="btn-icon">✨</span>
              开通 Pro
            </button>
            <button type="reset" class="btn btn-secondary">重置</button>
          </div>
        </form>

        <div id="grant-result" class="result-message" style="display: none">
          <div class="result-content"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Pro 用户列表 -->
  <div class="pro-list-section">
    <div class="section-card">
      <div class="section-card-header">
        <h3>📋 Pro 用户列表</h3>
        <p>当前已开通 Pro 的用户</p>
      </div>
      <div class="section-card-content">
        <div class="list-controls">
          <button id="refresh-pro-list" class="btn btn-secondary">
            <span class="btn-icon">🔄</span>
            刷新列表
          </button>
          <div class="list-stats">
            <span id="pro-user-count">加载中...</span>
          </div>
        </div>

        <div id="pro-users-table-container">
          <table id="pro-users-table" class="data-table">
            <thead>
              <tr>
                <th>序号</th>
                <th>用户名</th>
                <th>显示名称</th>
                <th>套餐类型</th>
                <th>开通时间</th>
                <th>过期时间</th>
                <th>状态</th>
                <th>开通原因</th>
              </tr>
            </thead>
            <tbody id="pro-users-tbody">
              <tr>
                <td colspan="8" style="text-align: center; padding: 40px">
                  <div class="loading">加载中...</div>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <div id="pro-list-pagination" class="pagination">
          <!-- 分页控件将动态生成 -->
        </div>
      </div>
    </div>
  </div>
</div>

