          <%= formatNumber(stats.periodMetrics.monthly.reviews) %>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-title">本月新用户</div>
        <div class="stat-value">
          <%= formatNumber(stats.periodMetrics.monthly.newUsers) %>
        </div>
      </div>
    </div>
  </div>
