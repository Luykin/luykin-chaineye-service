<!-- 统计数据区域 -->
<div class="stats-section">
  <!-- 🆕 基于设备指纹的日活统计 -->
  <div class="section">
    <h2 class="section-title">📱 设备指纹日活统计（最近7天）</h2>
    <p style="color: #6b7280; margin-bottom: 20px; font-size: 14px">
      基于设备指纹统计，包含所有访问用户（已登录 + 未登录）
    </p>

    <div class="stats-grid">
      <% if (stats.dailyActiveUsersData && stats.dailyActiveUsersData.length >
      0) { %> <% stats.dailyActiveUsersData.forEach(function(dayData) { %>
      <div class="stat-card">
        <div class="stat-title"><%= dayData.displayDate %></div>
        <div class="stat-value" style="font-size: 1.8rem">
          <%= formatNumber(dayData.activeUsers) %>
        </div>
        <div style="font-size: 12px; color: #9ca3af; margin-top: 4px">
          <%= dayData.date %>
        </div>
      </div>
      <% }); %> <% } else { %>
      <div class="stat-card">
        <div class="stat-title">暂无数据</div>
        <div class="stat-value">0</div>
      </div>
      <% } %>
    </div>

    <!-- 🆕 趋势图表区域 -->
    <div
      style="
        margin-top: 20px;
        padding: 20px;
        background: #f9fafb;
        border-radius: 8px;
      "
    >
      <h4 style="margin-bottom: 15px; color: #374151">📈 7天趋势</h4>
      <div style="display: flex; align-items: end; gap: 8px; height: 100px">
        <% if (stats.dailyActiveUsersData && stats.dailyActiveUsersData.length >
        0) { %> <% // 计算最大值 let maxValue = 0; for (let i = 0; i <
        stats.dailyActiveUsersData.length; i++) { if
        (stats.dailyActiveUsersData[i].activeUsers > maxValue) { maxValue =
        stats.dailyActiveUsersData[i].activeUsers; } } const minHeight = 10;
        const maxHeight = 80; %> <%
        stats.dailyActiveUsersData.forEach(function(dayData, index) { %> <% let
        height = minHeight; if (maxValue > 0) { height = Math.max(minHeight,
        (dayData.activeUsers / maxValue) * maxHeight); } const isToday = index
        === stats.dailyActiveUsersData.length - 1; %>
        <div
          style="flex: 1; background: <%= isToday ? '#3b82f6' : '#94a3b8' %>; height: <%= height %>px; border-radius: 4px 4px 0 0; position: relative; display: flex; align-items: end; justify-content: center; color: white; font-size: 10px; font-weight: 600; padding: 2px;"
        >
          <span style="transform: rotate(-90deg); white-space: nowrap">
            <%= dayData.activeUsers %>
          </span>
        </div>
        <% }); %> <% } %>
      </div>
      <div
        style="
          display: flex;
          gap: 8px;
          margin-top: 8px;
          font-size: 11px;
          color: #6b7280;
        "
      >
        <% if (stats.dailyActiveUsersData && stats.dailyActiveUsersData.length >
        0) { %> <% stats.dailyActiveUsersData.forEach(function(dayData, index) {
        %>
        <div style="flex: 1; text-align: center">
          <%= dayData.displayDate.split(' ')[0] %>
        </div>
        <% }); %> <% } %>
      </div>
    </div>
  </div>

