<!-- 统计数据区域 -->
<div class="stats-section">
    <!-- 核心指标 -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">📱 日活用户(已登录X)</span>
            </div>
            <div class="stat-value"><%= formatNumber(stats.coreMetrics.dailyActiveUsers.value) %></div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">💬 今日评论</span>
            </div>
            <div class="stat-value"><%= formatNumber(stats.coreMetrics.dailyReviews.value) %></div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">👥 评论用户</span>
            </div>
            <div class="stat-value"><%= formatNumber(stats.coreMetrics.dailyReviewUsers.value) %></div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">🆕 新注册用户(已登录X)</span>
            </div>
            <div class="stat-value"><%= formatNumber(stats.coreMetrics.dailyNewUsers.value) %></div>
        </div>
    </div>

    <!-- 累计数据 -->
    <div class="section">
        <h2 class="section-title">📈 累计数据</h2>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-title">总用户数</div>
                <div class="stat-value"><%= formatNumber(stats.totalMetrics.totalUsers) %></div>
            </div>
            <div class="stat-card">
                <div class="stat-title">总账号数</div>
                <div class="stat-value"><%= formatNumber(stats.totalMetrics.totalAccounts) %></div>
            </div>
            <div class="stat-card">
                <div class="stat-title">KOL 用户数</div>
                <div class="stat-value"><%= formatNumber(stats.totalMetrics.totalKOLUsers) %></div>
            </div>
            <div class="stat-card">
                <div class="stat-title">累计积分</div>
                <div class="stat-value"><%= formatNumber(stats.totalMetrics.totalPointsAwarded) %></div>
            </div>
            <div class="stat-card">
                <div class="stat-title">平均评分</div>
                <div class="stat-value"><%= stats.totalMetrics.averageRating %> ⭐</div>
            </div>
            <div class="stat-card">
                <div class="stat-title">今日积分</div>
                <div class="stat-value"><%= formatNumber(stats.todayDetails.pointsAwarded) %></div>
            </div>
        </div>
    </div>

    <!-- 🆕 基于设备指纹的日活统计 -->
    <div class="section">
        <h2 class="section-title">📱 设备指纹日活统计（最近7天）</h2>
        <p style="color: #6b7280; margin-bottom: 20px; font-size: 14px;">
            基于设备指纹统计，包含所有访问用户（已登录 + 未登录）
        </p>
        
        <div class="stats-grid">
            <% if (stats.dailyActiveUsersData && stats.dailyActiveUsersData.length > 0) { %>
                <% stats.dailyActiveUsersData.forEach(dayData => { %>
                    <div class="stat-card">
                        <div class="stat-title"><%= dayData.displayDate %></div>
                        <div class="stat-value" style="font-size: 1.8rem;"><%= formatNumber(dayData.activeUsers) %></div>
                        <div style="font-size: 12px; color: #9ca3af; margin-top: 4px;"><%= dayData.date %></div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="stat-card">
                    <div class="stat-title">暂无数据</div>
                    <div class="stat-value">0</div>
                </div>
            <% } %>
        </div>
        
        <!-- 🆕 趋势图表区域（可选，未来可以添加图表库） -->
        <div style="margin-top: 20px; padding: 20px; background: #f9fafb; border-radius: 8px;">
            <h4 style="margin-bottom: 15px; color: #374151;">📈 7天趋势</h4>
            <div style="display: flex; align-items: end; gap: 8px; height: 100px;">
                <% if (stats.dailyActiveUsersData && stats.dailyActiveUsersData.length > 0) { %>
                    <% 
                        const maxValue = Math.max(...stats.dailyActiveUsersData.map(d => d.activeUsers));
                        const minHeight = 10; // 最小高度
                        const maxHeight = 80; // 最大高度
                    %>
                    <% stats.dailyActiveUsersData.forEach((dayData, index) => { %>
                        <% 
                            const height = maxValue > 0 
                                ? Math.max(minHeight, (dayData.activeUsers / maxValue) * maxHeight)
                                : minHeight;
                            const isToday = index === stats.dailyActiveUsersData.length - 1;
                        %>
                        <div style="
                            flex: 1; 
                            background: <%= isToday ? '#3b82f6' : '#94a3b8' %>; 
                            height: <%= height %>px; 
                            border-radius: 4px 4px 0 0;
                            position: relative;
                            display: flex;
                            align-items: end;
                            justify-content: center;
                            color: white;
                            font-size: 10px;
                            font-weight: 600;
                            padding: 2px;
                        ">
                            <span style="transform: rotate(-90deg); white-space: nowrap;">
                                <%= dayData.activeUsers %>
                            </span>
                        </div>
                    <% }); %>
                <% } %>
            </div>
            <div style="display: flex; gap: 8px; margin-top: 8px; font-size: 11px; color: #6b7280;">
                <% if (stats.dailyActiveUsersData && stats.dailyActiveUsersData.length > 0) { %>
                    <% stats.dailyActiveUsersData.forEach((dayData, index) => { %>
                        <div style="flex: 1; text-align: center;">
                            <%= dayData.displayDate.split(' ')[0] %>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </div>

    <!-- 周期统计 -->
    <div class="section">
        <h2 class="section-title">📅 周期统计</h2>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-title">本周评论</div>
                <div class="stat-value"><%= formatNumber(stats.periodMetrics.weekly.reviews) %></div>
            </div>
            <div class="stat-card">
                <div class="stat-title">本周新用户</div>
                <div class="stat-value"><%= formatNumber(stats.periodMetrics.weekly.newUsers) %></div>
            </div>
            <div class="stat-card">
                <div class="stat-title">本月评论</div>
                <div class="stat-value"><%= formatNumber(stats.periodMetrics.monthly.reviews) %></div>
            </div>
            <div class="stat-card">
                <div class="stat-title">本月新用户</div>
                <div class="stat-value"><%= formatNumber(stats.periodMetrics.monthly.newUsers) %></div>
            </div>
        </div>
    </div>
</div>