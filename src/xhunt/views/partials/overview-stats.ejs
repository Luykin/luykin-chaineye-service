<!-- 统计数据区域 -->
<div class="stats-section">
  
  <!-- 设备指纹日活统计 -->
  <div class="section">
    <div class="section-header">
      <div class="section-title-wrapper">
        <div class="section-icon icon-blue">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        </div>
        <h2 class="section-title">设备指纹日活统计</h2>
      </div>
      <span class="section-badge">最近7天</span>
    </div>
    <p class="section-desc">
      基于设备指纹统计，包含所有访问用户（已登录 + 未登录）
    </p>

    <!-- 7天数据卡片 -->
    <div class="stats-grid daily-stats-grid">
      <% if (stats.dailyActiveUsersData && stats.dailyActiveUsersData.length > 0) { %>
        <% stats.dailyActiveUsersData.forEach(function(dayData, index) { 
          var isToday = index === stats.dailyActiveUsersData.length - 1;
          var cardClass = isToday ? 'stat-card-highlight' : '';
        %>
        <div class="stat-card <%= cardClass %>">
          <div class="stat-card-header">
            <span class="stat-date"><%= dayData.displayDate %></span>
            <% if (isToday) { %>
              <span class="today-badge">今日</span>
            <% } %>
          </div>
          <div class="stat-value-large">
            <%= formatNumber(dayData.activeUsers) %>
          </div>
          <div class="stat-meta">
            <span class="stat-full-date"><%= dayData.date %></span>
          </div>
          <% if (!isToday && index > 0) { 
            var prevDay = stats.dailyActiveUsersData[index - 1];
            var change = prevDay.activeUsers > 0 ? ((dayData.activeUsers - prevDay.activeUsers) / prevDay.activeUsers * 100) : 0;
            var isPositive = change >= 0;
          %>
          <div class="stat-trend <%= isPositive ? 'trend-up' : 'trend-down' %>">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="<% if (isPositive) { %>23 6 13.5 15.5 8.5 10.5 1 18<% } else { %>23 18 13.5 8.5 8.5 13.5 1 6<% } %>"/>
            </svg>
            <span><%= Math.abs(change).toFixed(1) %>%</span>
          </div>
          <% } %>
        </div>
        <% }); %>
      <% } else { %>
        <div class="stat-card stat-card-empty">
          <div class="empty-state">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span>暂无数据</span>
          </div>
        </div>
      <% } %>
    </div>

    <!-- 趋势图表 -->
    <div class="trend-chart-container">
      <div class="trend-chart-header">
        <div class="trend-chart-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 3v18h18"/>
            <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/>
          </svg>
          <span>7天趋势</span>
        </div>
        <% if (stats.dailyActiveUsersData && stats.dailyActiveUsersData.length > 0) { 
          var totalUsers = stats.dailyActiveUsersData.reduce(function(sum, day) { return sum + day.activeUsers; }, 0);
          var avgUsers = Math.round(totalUsers / stats.dailyActiveUsersData.length);
        %>
        <div class="trend-chart-avg">
          平均: <strong><%= formatNumber(avgUsers) %></strong>
        </div>
        <% } %>
      </div>
      <div class="trend-chart">
        <% if (stats.dailyActiveUsersData && stats.dailyActiveUsersData.length > 0) { 
          var maxValue = 0;
          for (var i = 0; i < stats.dailyActiveUsersData.length; i++) {
            if (stats.dailyActiveUsersData[i].activeUsers > maxValue) {
              maxValue = stats.dailyActiveUsersData[i].activeUsers;
            }
          }
          var minHeight = 20;
          var maxHeight = 140;
          stats.dailyActiveUsersData.forEach(function(dayData, index) {
            var height = minHeight;
            if (maxValue > 0) {
              height = Math.max(minHeight, (dayData.activeUsers / maxValue) * maxHeight);
            }
            var isToday = index === stats.dailyActiveUsersData.length - 1;
        %>
        <div class="trend-bar-wrapper">
          <div class="trend-bar <%= isToday ? 'trend-bar-today' : '' %>" style="height: <%= height %>px;">
            <span class="trend-bar-value"><%= formatNumber(dayData.activeUsers) %></span>
          </div>
          <span class="trend-bar-label"><%= dayData.displayDate.split(' ')[0] %></span>
        </div>
        <% }); } %>
      </div>
    </div>
  </div>

  <!-- 核心指标 -->
  <div class="section">
    <div class="section-header">
      <div class="section-title-wrapper">
        <div class="section-icon icon-purple">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </div>
        <h2 class="section-title">核心指标</h2>
      </div>
      <span class="section-badge badge-live">
        <span class="live-pulse"></span>
        实时
      </span>
    </div>
    
    <div class="stats-grid core-metrics-grid">
      <div class="stat-card stat-card-blue">
        <div class="stat-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <div class="stat-card-content">
          <div class="stat-title">日活用户 (已登录X)</div>
          <div class="stat-value">
            <%= formatNumber(stats.coreMetrics.dailyActiveUsers.value) %>
          </div>
        </div>
      </div>

      <div class="stat-card stat-card-green">
        <div class="stat-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
          </svg>
        </div>
        <div class="stat-card-content">
          <div class="stat-title">今日评论</div>
          <div class="stat-value">
            <%= formatNumber(stats.coreMetrics.dailyReviews.value) %>
          </div>
        </div>
      </div>

      <div class="stat-card stat-card-orange">
        <div class="stat-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </div>
        <div class="stat-card-content">
          <div class="stat-title">评论用户</div>
          <div class="stat-value">
            <%= formatNumber(stats.coreMetrics.dailyReviewUsers.value) %>
          </div>
        </div>
      </div>

      <div class="stat-card stat-card-pink">
        <div class="stat-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="8.5" cy="7" r="4"/>
            <line x1="20" y1="8" x2="20" y2="14"/>
            <line x1="23" y1="11" x2="17" y2="11"/>
          </svg>
        </div>
        <div class="stat-card-content">
          <div class="stat-title">新注册用户 (已登录X)</div>
          <div class="stat-value">
            <%= formatNumber(stats.coreMetrics.dailyNewUsers.value) %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 累计数据 -->
  <div class="section">
    <div class="section-header">
      <div class="section-title-wrapper">
        <div class="section-icon icon-teal">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="20" x2="12" y2="10"/>
            <line x1="18" y1="20" x2="18" y2="4"/>
            <line x1="6" y1="20" x2="6" y2="16"/>
          </svg>
        </div>
        <h2 class="section-title">累计数据</h2>
      </div>
    </div>
    
    <div class="stats-grid total-metrics-grid">
      <div class="stat-card stat-card-minimal">
        <div class="stat-title">总用户数</div>
        <div class="stat-value">
          <%= formatNumber(stats.totalMetrics.totalUsers) %>
        </div>
      </div>
      
      <div class="stat-card stat-card-minimal">
        <div class="stat-title">总账号数</div>
        <div class="stat-value">
          <%= formatNumber(stats.totalMetrics.totalAccounts) %>
        </div>
      </div>
      
      <div class="stat-card stat-card-minimal stat-card-kol">
        <div class="stat-title">KOL 用户数</div>
        <div class="stat-value">
          <%= formatNumber(stats.totalMetrics.totalKOLUsers) %>
        </div>
      </div>
      
      <div class="stat-card stat-card-minimal stat-card-kol-tier">
        <div class="stat-title">KOL ≤ 20万</div>
        <div class="stat-value">
          <%= formatNumber(stats.totalMetrics.kolBuckets?.within200k || 0) %>
        </div>
      </div>
      
      <div class="stat-card stat-card-minimal stat-card-kol-tier">
        <div class="stat-title">KOL ≤ 5万</div>
        <div class="stat-value">
          <%= formatNumber(stats.totalMetrics.kolBuckets?.within50k || 0) %>
        </div>
      </div>
      
      <div class="stat-card stat-card-minimal stat-card-kol-tier">
        <div class="stat-title">KOL ≤ 2万</div>
        <div class="stat-value">
          <%= formatNumber(stats.totalMetrics.kolBuckets?.within20k || 0) %>
        </div>
      </div>
      
      <div class="stat-card stat-card-minimal stat-card-kol-tier">
        <div class="stat-title">KOL ≤ 5千</div>
        <div class="stat-value">
          <%= formatNumber(stats.totalMetrics.kolBuckets?.within5k || 0) %>
        </div>
      </div>
      
      <div class="stat-card stat-card-minimal stat-card-points">
        <div class="stat-title">累计积分</div>
        <div class="stat-value">
          <%= formatNumber(stats.totalMetrics.totalPointsAwarded) %>
        </div>
      </div>
      
      <div class="stat-card stat-card-minimal stat-card-rating">
        <div class="stat-title">平均评分</div>
        <div class="stat-value rating-value">
          <%= stats.totalMetrics.averageRating %>
          <span class="star-icon">★</span>
        </div>
      </div>
      
      <div class="stat-card stat-card-minimal stat-card-points-today">
        <div class="stat-title">今日积分</div>
        <div class="stat-value">
          <%= formatNumber(stats.todayDetails.pointsAwarded) %>
        </div>
      </div>
    </div>
  </div>

  <!-- 周期统计 -->
  <div class="section section-period">
    <div class="section-header">
      <div class="section-title-wrapper">
        <div class="section-icon icon-indigo">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <h2 class="section-title">周期统计</h2>
      </div>
    </div>
    
    <div class="period-stats-grid">
      <div class="period-card period-card-weekly">
        <div class="period-card-header">
          <div class="period-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M2 12h20"/>
              <path d="M20 12v6a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-6"/>
              <path d="m12 12 4-4"/>
              <path d="m12 12-4-4"/>
            </svg>
          </div>
          <span class="period-label">本周</span>
        </div>
        <div class="period-metrics">
          <div class="period-metric">
            <span class="period-metric-value"><%= formatNumber(stats.periodMetrics.weekly.reviews) %></span>
            <span class="period-metric-label">评论</span>
          </div>
          <div class="period-metric-divider"></div>
          <div class="period-metric">
            <span class="period-metric-value"><%= formatNumber(stats.periodMetrics.weekly.newUsers) %></span>
            <span class="period-metric-label">新用户</span>
          </div>
        </div>
      </div>

      <div class="period-card period-card-monthly">
        <div class="period-card-header">
          <div class="period-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
              <path d="M8 14h.01"/>
              <path d="M12 14h.01"/>
              <path d="M16 14h.01"/>
              <path d="M8 18h.01"/>
              <path d="M12 18h.01"/>
              <path d="M16 18h.01"/>
            </svg>
          </div>
          <span class="period-label">本月</span>
        </div>
        <div class="period-metrics">
          <div class="period-metric">
            <span class="period-metric-value"><%= formatNumber(stats.periodMetrics.monthly.reviews) %></span>
            <span class="period-metric-label">评论</span>
          </div>
          <div class="period-metric-divider"></div>
          <div class="period-metric">
            <span class="period-metric-value"><%= formatNumber(stats.periodMetrics.monthly.newUsers) %></span>
            <span class="period-metric-label">新用户</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
