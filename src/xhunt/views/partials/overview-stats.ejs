<!-- 统计数据区域 -->
<div class="stats-section">
    <!-- 🆕 基于设备指纹的日活统计 -->
    <div class="section">
        <h2 class="section-title">📱 设备指纹日活统计（最近7天）</h2>
        <p style="color: #6b7280; margin-bottom: 20px; font-size: 14px;">
            基于设备指纹统计，包含所有访问用户（已登录 + 未登录）
        </p>

        <div class="stats-grid">
            <% if (stats.dailyActiveUsersData && stats.dailyActiveUsersData.length > 0) { %>
                <% stats.dailyActiveUsersData.forEach(dayData => { %>
                    <div class="stat-card">
                        <div class="stat-title"><%= dayData.displayDate %></div>
                        <div class="stat-value" style="font-size: 1.8rem;"><%= formatNumber(dayData.activeUsers) %></div>
                        <div style="font-size: 12px; color: #9ca3af; margin-top: 4px;"><%= dayData.date %></div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="stat-card">
                    <div class="stat-title">暂无数据</div>
                    <div class="stat-value">0</div>
                </div>
            <% } %>
        </div>

        <!-- 🆕 趋势图表区域（可选，未来可以添加图表库） -->
        <div style="margin-top: 20px; padding: 20px; background: #f9fafb; border-radius: 8px;">
            <h4 style="margin-bottom: 15px; color: #374151;">📈 7天趋势</h4>
            <div style="display: flex; align-items: end; gap: 8px; height: 100px;">
                <% if (stats.dailyActiveUsersData && stats.dailyActiveUsersData.length > 0) { %>
                    <%
                        const maxValue = Math.max(...stats.dailyActiveUsersData.map(d => d.activeUsers));
                        const minHeight = 10; // 最小高度
                        const maxHeight = 80; // 最大高度
                    %>
                    <% stats.dailyActiveUsersData.forEach((dayData, index) => { %>
                        <%
                            const height = maxValue > 0
                                    ? Math.max(minHeight, (dayData.activeUsers / maxValue) * maxHeight)
                                    : minHeight;
                            const isToday = index === stats.dailyActiveUsersData.length - 1;
                        %>
                        <div style="
                                flex: 1;
                                background: <%= isToday ? '#3b82f6' : '#94a3b8' %>;
                                height: <%= height %>px;
                                border-radius: 4px 4px 0 0;
                                position: relative;
                                display: flex;
                                align-items: end;
                                justify-content: center;
                                color: white;
                                font-size: 10px;
                                font-weight: 600;
                                padding: 2px;
                                ">
                            <span style="transform: rotate(-90deg); white-space: nowrap;">
                                <%= dayData.activeUsers %>
                            </span>
                        </div>
                    <% }); %>
                <% } %>
            </div>
            <div style="display: flex; gap: 8px; margin-top: 8px; font-size: 11px; color: #6b7280;">
                <% if (stats.dailyActiveUsersData && stats.dailyActiveUsersData.length > 0) { %>
                    <% stats.dailyActiveUsersData.forEach((dayData, index) => { %>
                        <div style="flex: 1; text-align: center;">
                            <%= dayData.displayDate.split(' ')[0] %>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </div>

    <!-- 核心指标 -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">📱 日活用户(已登录X)</span>
            </div>
            <div class="stat-value"><%= formatNumber(stats.coreMetrics.dailyActiveUsers.value) %></div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">💬 今日评论</span>
            </div>
            <div class="stat-value"><%= formatNumber(stats.coreMetrics.dailyReviews.value) %></div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">👥 评论用户</span>
            </div>
            <div class="stat-value"><%= formatNumber(stats.coreMetrics.dailyReviewUsers.value) %></div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">🆕 新注册用户(已登录X)</span>
            </div>
            <div class="stat-value"><%= formatNumber(stats.coreMetrics.dailyNewUsers.value) %></div>
        </div>
    </div>

    <!-- 累计数据 -->
    <div class="section">
        <h2 class="section-title">📈 累计数据</h2>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-title">总用户数</div>
                <div class="stat-value"><%= formatNumber(stats.totalMetrics.totalUsers) %></div>
            </div>
            <div class="stat-card">
                <div class="stat-title">总账号数</div>
                <div class="stat-value"><%= formatNumber(stats.totalMetrics.totalAccounts) %></div>
            </div>
            <div class="stat-card">
                <div class="stat-title">KOL 用户数</div>
                <div class="stat-value"><%= formatNumber(stats.totalMetrics.totalKOLUsers) %></div>
            </div>
            <div class="stat-card">
                <div class="stat-title">累计积分</div>
                <div class="stat-value"><%= formatNumber(stats.totalMetrics.totalPointsAwarded) %></div>
            </div>
            <div class="stat-card">
                <div class="stat-title">平均评分</div>
                <div class="stat-value"><%= stats.totalMetrics.averageRating %> ⭐</div>
            </div>
            <div class="stat-card">
                <div class="stat-title">今日积分</div>
                <div class="stat-value"><%= formatNumber(stats.todayDetails.pointsAwarded) %></div>
            </div>
        </div>
    </div>

    <!-- 🆕 设备指纹重复分析 -->
    <div class="section">
        <h2 class="section-title">🔍 设备指纹重复分析</h2>
        <p style="color: #6b7280; margin-bottom: 20px; font-size: 14px;">
            分析 XHuntUserTokens 表中指纹重复情况，评估日活统计的准确性
        </p>
        
        <!-- 重复统计概览 -->
        <div class="stats-grid" style="margin-bottom: 30px;">
            <div class="stat-card">
                <div class="stat-title">总指纹数</div>
                <div class="stat-value"><%= formatNumber(stats.fingerprintDuplicateAnalysis.summary.totalFingerprints) %></div>
                <div style="font-size: 12px; color: #9ca3af; margin-top: 4px;">有效Token的指纹总数</div>
            </div>
            <div class="stat-card">
                <div class="stat-title">重复指纹数</div>
                <div class="stat-value" style="color: #f59e0b;"><%= formatNumber(stats.fingerprintDuplicateAnalysis.summary.duplicateCount) %></div>
                <div style="font-size: 12px; color: #9ca3af; margin-top: 4px;">被多个Token使用的指纹</div>
            </div>
            <div class="stat-card">
                <div class="stat-title">重复概率</div>
                <div class="stat-value" style="color: #f59e0b;"><%= stats.fingerprintDuplicateAnalysis.summary.duplicateRate %>%</div>
                <div style="font-size: 12px; color: #9ca3af; margin-top: 4px;">指纹重复的概率</div>
            </div>
            <div class="stat-card">
                <div class="stat-title">可能少统计</div>
                <div class="stat-value" style="color: #ef4444;"><%= formatNumber(stats.fingerprintDuplicateAnalysis.summary.potentialUndercount) %></div>
                <div style="font-size: 12px; color: #9ca3af; margin-top: 4px;">因重复指纹可能少计的用户</div>
            </div>
            <div class="stat-card">
                <div class="stat-title">少统计概率</div>
                <div class="stat-value" style="color: #ef4444;"><%= stats.fingerprintDuplicateAnalysis.summary.undercountRate %>%</div>
                <div style="font-size: 12px; color: #9ca3af; margin-top: 4px;">日活可能被低估的比例</div>
            </div>
            <div class="stat-card">
                <div class="stat-title">实际用户数</div>
                <div class="stat-value" style="color: #10b981;"><%= formatNumber(stats.fingerprintDuplicateAnalysis.summary.totalUniqueUsers) %></div>
                <div style="font-size: 12px; color: #9ca3af; margin-top: 4px;">去重后的真实用户数</div>
            </div>
        </div>
        
        <!-- 重复指纹详情表格 -->
        <% if (stats.fingerprintDuplicateAnalysis.topDuplicates && stats.fingerprintDuplicateAnalysis.topDuplicates.length > 0) { %>
            <div>
                <h3 style="font-size: 1.3rem; color: #374151; border-left: 4px solid #f59e0b; padding-left: 12px; margin-bottom: 20px;">
                    🔥 重复最多的指纹 TOP 10
                </h3>
                
                <div class="table-container">
                    <table style="width: 100%; border-collapse: collapse; background: white;">
                        <thead style="background: #f9fafb;">
                            <tr>
                                <th style="padding: 12px; text-align: left; border-bottom: 1px solid #e5e7eb; font-weight: 600;">排名</th>
                                <th style="padding: 12px; text-align: left; border-bottom: 1px solid #e5e7eb; font-weight: 600;">指纹（前8位）</th>
                                <th style="padding: 12px; text-align: left; border-bottom: 1px solid #e5e7eb; font-weight: 600;">Token数量</th>
                                <th style="padding: 12px; text-align: left; border-bottom: 1px solid #e5e7eb; font-weight: 600;">实际用户数</th>
                                <th style="padding: 12px; text-align: left; border-bottom: 1px solid #e5e7eb; font-weight: 600;">重复程度</th>
                                <th style="padding: 12px; text-align: left; border-bottom: 1px solid #e5e7eb; font-weight: 600;">影响评估</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% stats.fingerprintDuplicateAnalysis.topDuplicates.forEach((duplicate, index) => { %>
                                <tr style="border-bottom: 1px solid #f3f4f6;">
                                    <td style="padding: 12px; color: #374151;"><%= index + 1 %></td>
                                    <td style="padding: 12px; font-family: monospace; color: #6b7280;"><%= duplicate.fingerprint %></td>
                                    <td style="padding: 12px; color: #f59e0b; font-weight: 600;"><%= duplicate.tokenCount %></td>
                                    <td style="padding: 12px; color: #10b981; font-weight: 600;"><%= duplicate.uniqueUsers %></td>
                                    <td style="padding: 12px; color: #ef4444; font-weight: 600;">+<%= duplicate.duplicateLevel %></td>
                                    <td style="padding: 12px;">
                                        <% if (duplicate.duplicateLevel === 0) { %>
                                            <span style="color: #10b981; font-size: 12px;">✅ 无影响</span>
                                        <% } else if (duplicate.duplicateLevel <= 2) { %>
                                            <span style="color: #f59e0b; font-size: 12px;">⚠️ 轻微</span>
                                        <% } else { %>
                                            <span style="color: #ef4444; font-size: 12px;">🚨 严重</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>
        
        <!-- 分析说明 -->
        <div style="margin-top: 20px; padding: 16px; background: #fef3c7; border-left: 4px solid #f59e0b; border-radius: 6px;">
            <h4 style="color: #92400e; margin-bottom: 8px;">📊 统计准确性分析</h4>
            <ul style="color: #92400e; font-size: 14px; margin: 0; padding-left: 20px;">
                <li><strong>理论最大误差</strong>：日活可能被低估 <%= stats.fingerprintDuplicateAnalysis.summary.undercountRate %>%</li>
                <li><strong>重复原因</strong>：同一设备多次登录、浏览器重装、隐私模式等</li>
                <li><strong>实际影响</strong>：由于指纹算法稳定性，实际误差通常远小于理论值</li>
                <li><strong>建议</strong>：当重复率 > 10% 时，考虑结合其他指标进行校正</li>
            </ul>
        </div>
    </div>

    <!-- 周期统计 -->
    <div class="section">
        <h2 class="section-title">📅 周期统计</h2>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-title">本周评论</div>
                <div class="stat-value"><%= formatNumber(stats.periodMetrics.weekly.reviews) %></div>
            </div>
            <div class="stat-card">
                <div class="stat-title">本周新用户</div>
                <div class="stat-value"><%= formatNumber(stats.periodMetrics.weekly.newUsers) %></div>
            </div>
            <div class="stat-card">
                <div class="stat-title">本月评论</div>
                <div class="stat-value"><%= formatNumber(stats.periodMetrics.monthly.reviews) %></div>
            </div>
            <div class="stat-card">
                <div class="stat-title">本月新用户</div>
                <div class="stat-value"><%= formatNumber(stats.periodMetrics.monthly.newUsers) %></div>
            </div>
        </div>
    </div>
</div>
