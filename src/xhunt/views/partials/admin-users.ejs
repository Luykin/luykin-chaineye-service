<div class="admin-users-card">
  <div class="admin-users-header">
    <h3 class="admin-users-title">管理员列表</h3>
  </div>

  <!-- 新增管理员（默认折叠） -->
  <div class="admin-section">
    <div class="section-toggle">
      <span class="section-label">新增管理员</span>
      <button id="ca-toggle" class="btn btn-sm">展开</button>
    </div>
    <div id="ca-body" class="section-body" style="display: none">
      <div class="form-grid">
        <div class="form-item">
          <label for="ca-email">邮箱</label>
          <input id="ca-email" type="email" placeholder="you@example.com" autocomplete="off" />
        </div>
        <div class="form-item">
          <label for="ca-password">初始密码（≥8位）</label>
          <input id="ca-password" type="password" placeholder="至少8位" autocomplete="new-password" />
        </div>
        <div class="form-item">
          <label for="ca-role">角色</label>
          <select id="ca-role">
            <option value="admin">admin</option>
            <option value="super">super</option>
          </select>
        </div>
        <div class="form-item">
          <label for="ca-daily-report">接收日报</label>
          <div class="switch-wrap">
            <label class="switch">
              <input id="ca-daily-report" type="checkbox" />
              <span class="switch-slider"></span>
            </label>
            <span class="switch-hint">默认关闭</span>
          </div>
        </div>
      </div>
      <div class="perm-section">
        <div class="perm-hint">权限选择（可多选） · <span class="perm-muted">[Tab] 页面权限 / [API] 接口操作</span></div>
        <div id="ca-preset" class="perm-presets">
          <button id="ca-preset-all" class="btn btn-sm">全部权限</button>
          <button id="ca-preset-basic" class="btn btn-sm">基础权限</button>
          <button id="ca-preset-clear" class="btn btn-sm">清空</button>
        </div>
        <div id="ca-perm-grid" class="perm-grid"></div>
      </div>
      <div class="form-actions">
        <button id="ca-submit" class="btn btn-primary btn-sm">创建</button>
      </div>
    </div>
  </div>

  <!-- 管理员列表 -->
  <div class="admin-table-wrap">
    <table class="admin-table">
      <thead>
        <tr>
          <th class="col-id">ID</th>
          <th>邮箱</th>
          <th class="col-role">角色</th>
          <th class="col-status">状态</th>
          <th class="col-bio">生物识别</th>
          <th class="col-report">接收日报</th>
          <th>权限</th>
          <th class="col-actions">操作</th>
        </tr>
      </thead>
      <tbody id="dr-tbody"></tbody>
    </table>
  </div>
  <div id="dr-status" class="status-msg"></div>
</div>

<style>
  .admin-users-card {
    padding: 16px;
  }
  .admin-users-header {
    margin-bottom: 16px;
  }
  .admin-users-title {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    color: #111827;
  }
  .admin-section {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 12px;
    margin-bottom: 16px;
  }
  .section-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .section-label {
    font-weight: 500;
    font-size: 14px;
    color: #374151;
  }
  .section-body {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid #e5e7eb;
  }
  .form-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
  }
  .form-item label {
    display: block;
    font-size: 12px;
    color: #6b7280;
    margin-bottom: 4px;
  }
  .form-item input,
  .form-item select {
    width: 100%;
    padding: 6px 10px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    background: #fff;
    font-size: 13px;
    box-sizing: border-box;
  }
  .form-item input:focus,
  .form-item select:focus {
    outline: none;
    border-color: #3b82f6;
  }
  .switch-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 0;
  }
  .switch {
    position: relative;
    display: inline-block;
    width: 40px;
    height: 22px;
  }
  .switch input {
    display: none;
  }
  .switch-slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: #d1d5db;
    border-radius: 22px;
    transition: 0.2s;
  }
  .switch-slider:before {
    content: "";
    position: absolute;
    left: 2px;
    top: 2px;
    width: 18px;
    height: 18px;
    background: #fff;
    border-radius: 50%;
    transition: 0.2s;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
  }
  .switch input:checked + .switch-slider {
    background: #10b981;
  }
  .switch input:checked + .switch-slider:before {
    transform: translateX(18px);
  }
  .switch-hint {
    font-size: 12px;
    color: #9ca3af;
  }
  .perm-section {
    margin-top: 12px;
  }
  .perm-hint {
    margin-bottom: 8px;
    font-size: 12px;
    color: #6b7280;
  }
  .perm-muted {
    color: #9ca3af;
  }
  .perm-presets {
    margin-bottom: 10px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .perm-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 10px;
  }
  .form-actions {
    margin-top: 12px;
    display: flex;
    gap: 8px;
  }
  .admin-table-wrap {
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    overflow: hidden;
  }
  .admin-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .admin-table th,
  .admin-table td {
    padding: 8px 12px;
    text-align: left;
    border-bottom: 1px solid #e5e7eb;
  }
  .admin-table th {
    background: #f9fafb;
    font-weight: 500;
    color: #6b7280;
    font-size: 12px;
  }
  .admin-table tbody tr:last-child td {
    border-bottom: none;
  }
  .admin-table tbody tr:hover {
    background: #f9fafb;
  }
  .col-id { width: 50px; }
  .col-role { width: 90px; }
  .col-status { width: 90px; }
  .col-bio { width: 90px; }
  .col-report { width: 100px; }
  .col-actions { width: 100px; }
  .status-msg {
    margin-top: 12px;
    padding: 8px 12px;
    border-radius: 6px;
    font-size: 13px;
    display: none;
  }
  .status-msg.success {
    background: #d1fae5;
    color: #065f46;
    border: 1px solid #a7f3d0;
  }
  .status-msg.error {
    background: #fee2e2;
    color: #991b1b;
    border: 1px solid #fecaca;
  }
  .btn {
    padding: 6px 12px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    background: #fff;
    font-size: 13px;
    cursor: pointer;
    color: #374151;
  }
  .btn:hover {
    background: #f3f4f6;
  }
  .btn-sm {
    padding: 4px 10px;
    font-size: 12px;
  }
  .btn-primary {
    background: #3b82f6;
    border-color: #3b82f6;
    color: #fff;
  }
  .btn-primary:hover {
    background: #2563eb;
  }
  .perm-editor-row td {
    background: #f9fafb;
    padding: 12px;
  }
  .perm-group {
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 10px 12px;
    background: #fff;
  }
  .perm-group-header {
    font-weight: 500;
    margin-bottom: 8px;
    color: #111827;
    font-size: 13px;
  }
  .perm-group-items {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .perm-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 8px;
    border: 1px solid #e5e7eb;
    border-radius: 4px;
    background: #f9fafb;
    font-size: 12px;
    cursor: pointer;
  }
  .perm-chip input {
    margin: 0;
  }
  .perm-chip.disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>

<script>
  (async function () {
    const tbody = document.getElementById("dr-tbody");
    const statusEl = document.getElementById("dr-status");
    const isSuper = window.user && window.user.role === "super";
    const RESTRICTED = new Set([
      "admin-users",
      "admin-audit-logs",
      "daily-report:send",
      "admin:manage-permissions",
      "audit-logs:read",
    ]);

    // 接收日报（创建表单）开关 UI 同步
    const caDrCb = document.getElementById("ca-daily-report");
    function updateDailyReportToggleUI(checked) {
      // 纯 CSS 实现，无需 JS 控制样式
    }
    if (caDrCb) {
      caDrCb.addEventListener("change", () => {});
    }

    function setStatus(msg, ok = true) {
      statusEl.textContent = msg;
      statusEl.style.display = "block";
      statusEl.className = "status-msg " + (ok ? "success" : "error");
      if (ok) {
        setTimeout(() => {
          statusEl.style.display = "none";
        }, 3000);
      }
    }

    // 完整权限清单（Tab + API）
    const ALL_PERMISSIONS = [
      "overview",
      "dau-details",
      "online-users",
      "cohorts",
      "rootdata",
      "notes",
      "log-search",
      "device-monitor",
      "version-stats",
      "url-stats",
      "perf-monitor",
      "security-violations",
      "messages",
      "data-export",
      "pro-management",
      "reviews-management",
      "backup",
      "server-command",
      "admin-users",
      "admin-audit-logs",
      "nacos-messages",
      "nacos-campaigns",
      "feature-flags",
      "notes:read",
      "rootdata:read",
      "log-search:read",
      "error-logs:read",
      "device-status:read",
      "export:users",
      "server:execute",
      "backup:operate",
      "messages:send",
      "pro:manage",
      "daily-report:send",
      "audit-logs:read",
      "admin:manage-permissions",
      "nacos_config",
      "feature_flags_config",
      "supabase",
    ];

    // 权限说明（用于展示友好名称与归属 Tab）
    const PERM_META = {
      // Tabs
      overview: { type: "Tab", label: "数据概览" },
      "dau-details": { type: "Tab", label: "日活详情" },
      "online-users": { type: "Tab", label: "在线用户" },
      cohorts: { type: "Tab", label: "用户留存" },
      rootdata: { type: "Tab", label: "Rootdata" },
      notes: { type: "Tab", label: "备注查看" },
      "log-search": { type: "Tab", label: "日志搜索" },
      "device-monitor": { type: "Tab", label: "设备监控" },
      "version-stats": { type: "Tab", label: "版本统计" },
      "url-stats": { type: "Tab", label: "接口统计" },
      "perf-monitor": { type: "Tab", label: "性能监控" },
      "security-violations": { type: "Tab", label: "安全拦截" },
      messages: { type: "Tab", label: "发送私信" },
      "data-export": { type: "Tab", label: "数据导出" },
      "pro-management": { type: "Tab", label: "Pro 用户管理" },
      "reviews-management": { type: "Tab", label: "评论管理" },
      backup: { type: "Tab", label: "数据库备份" },
      "server-command": { type: "Tab", label: "服务器命令" },
      "admin-users": { type: "Tab", label: "管理员列表" },
      "admin-audit-logs": { type: "Tab", label: "管理员操作记录" },
      "nacos-messages": { type: "Tab", label: "公告配置（Nacos）" },
      "nacos-campaigns": { type: "Tab", label: "Earn 活动配置（Nacos）" },
      "feature-flags": { type: "Tab", label: "功能开关" },
      // APIs
      "notes:read": { type: "API", label: "备注数据读取", tab: "notes" },
      "rootdata:read": { type: "API", label: "Rootdata 读取", tab: "rootdata" },
      "log-search:read": {
        type: "API",
        label: "日志搜索读取",
        tab: "log-search",
      },
      "error-logs:read": {
        type: "API",
        label: "错误日志读取",
        tab: "log-search",
      },
      "device-status:read": {
        type: "API",
        label: "设备状态读取",
        tab: "device-monitor",
      },
      "export:users": {
        type: "API",
        label: "导出用户数据",
        tab: "data-export",
      },
      "server:execute": {
        type: "API",
        label: "执行服务器命令",
        tab: "server-command",
      },
      "backup:operate": { type: "API", label: "备份/恢复操作", tab: "backup" },
      "messages:send": { type: "API", label: "发送私信操作", tab: "messages" },
      "pro:manage": {
        type: "API",
        label: "Pro 用户管理操作",
        tab: "pro-management",
      },
      "daily-report:send": {
        type: "API",
        label: "发送每日报告",
        tab: "admin-users",
      },
      "audit-logs:read": {
        type: "API",
        label: "审计日志读取",
        tab: "admin-audit-logs",
      },
      "admin:manage-permissions": {
        type: "API",
        label: "管理管理员权限",
        tab: "admin-users",
      },
      "nacos_config": { type: "API", label: "Nacos 配置管理", tab: "nacos-campaigns" },
      "feature_flags_config": { type: "API", label: "功能开关配置", tab: "feature-flags" },
      supabase: { type: "API", label: "Supabase 访问票据" },
      "*": { type: "API", label: "全部权限" },
    };

    // 快速预设
    const PRESETS = {
      ALL: ["*"],
      BASIC: ["overview", "dau-details", "online-users"],
    };

    // 新增管理员：权限编辑器初始化
    const caGrid = document.getElementById("ca-perm-grid");
    let caSelected = new Set();
    const caChecks = [];
    function permLabelText(p) {
      const meta = PERM_META[p];
      if (!meta) return p;
      if (meta.type === "Tab") return `[Tab] ${meta.label} (${p})`;
      if (meta.type === "API") return `[API] ${meta.label} (${p})`;
      return `${meta.label || p} (${p})`;
    }

    function buildGroups() {
      const tabs = ALL_PERMISSIONS.filter((p) => PERM_META[p]?.type === "Tab");
      const groups = [];
      const used = new Set();
      tabs.forEach((tabKey) => {
        const tabMeta = PERM_META[tabKey];
        const items = [tabKey];
        ALL_PERMISSIONS.forEach((p) => {
          const m = PERM_META[p];
          if (m && m.type === "API" && m.tab === tabKey) {
            items.push(p);
            used.add(p);
          }
        });

        groups.push({ key: tabKey, label: tabMeta?.label || tabKey, items });
      });
      // 其余未归属的 API 放在"全局/其他"
      const others = ALL_PERMISSIONS.filter(
        (p) => !tabs.includes(p) && !used.has(p)
      );
      if (others.length)
        groups.push({ key: "__others__", label: "全局/其他", items: others });
      return groups;
    }

    function renderGroup(container, g, selectedSet, checksArr) {
      const card = document.createElement("div");
      card.className = "perm-group";
      const header = document.createElement("div");
      header.className = "perm-group-header";
      header.textContent = `[${g.label}]`;
      card.appendChild(header);
      const row = document.createElement("div");
      row.className = "perm-group-items";
      g.items.forEach((p) => {
        const chip = document.createElement("label");
        chip.className = "perm-chip";
        const cb = document.createElement("input");
        cb.type = "checkbox";
        cb.value = p;
        cb.checked = selectedSet.has(p);
        if (!isSuper && RESTRICTED.has(p)) {
          cb.disabled = true;
          chip.classList.add("disabled");
        }
        cb.addEventListener("change", () => {
          if (cb.checked) {
            selectedSet.add(p);
          } else {
            selectedSet.delete(p);
          }
        });
        chip.appendChild(cb);
        const span = document.createElement("span");
        span.textContent = permLabelText(p);
        chip.appendChild(span);
        row.appendChild(chip);
        if (checksArr) checksArr.push(cb);
      });
      card.appendChild(row);
      container.appendChild(card);
    }

    function renderCreatePerms() {
      caGrid.innerHTML = "";
      const groups = buildGroups();
      groups.forEach((g) => renderGroup(caGrid, g, caSelected, caChecks));
    }
    function caSync() {
      caChecks.forEach((cb) => {
        cb.checked = caSelected.has(cb.value);
      });
    }
    renderCreatePerms();

    // 预设按钮绑定
    document.getElementById("ca-preset-all").addEventListener("click", (e) => {
      e.preventDefault();
      caSelected = new Set(
        PRESETS.ALL.filter((p) => isSuper || !RESTRICTED.has(p))
      );
      caSync();
    });
    document
      .getElementById("ca-preset-basic")
      .addEventListener("click", (e) => {
        e.preventDefault();
        caSelected = new Set(
          PRESETS.BASIC.filter((p) => isSuper || !RESTRICTED.has(p))
        );
        caSync();
      });
    document
      .getElementById("ca-preset-clear")
      .addEventListener("click", (e) => {
        e.preventDefault();
        caSelected = new Set();
        caSync();
      });

    // 新增管理员 折叠/展开
    const caToggle = document.getElementById("ca-toggle");
    const caBody = document.getElementById("ca-body");
    if (caToggle && caBody) {
      caToggle.addEventListener("click", (e) => {
        e.preventDefault();
        const isHidden =
          caBody.style.display === "none" || caBody.style.display === "";
        if (isHidden) {
          caBody.style.display = "block";
          caToggle.textContent = "收起";
        } else {
          caBody.style.display = "none";
          caToggle.textContent = "展开";
        }
      });
    }

    // 创建提交
    document.getElementById("ca-submit").addEventListener("click", async () => {
      try {
        const email = (document.getElementById("ca-email").value || "").trim();
        const password = document.getElementById("ca-password").value || "";
        const role = document.getElementById("ca-role").value || "admin";
        const receivesDailyReport =
          !!document.getElementById("ca-daily-report").checked;
        if (!email || !password) {
          setStatus("请填写邮箱与密码", false);
          return;
        }
        setStatus("创建中...");
        const res = await fetch("/admin/users", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({
            email,
            password,
            role,
            receivesDailyReport,
            permissions: Array.from(caSelected),
          }),
        });
        const data = await res.json();
        if (!data.success) {
          throw new Error(data.error || "创建失败");
        }
        setStatus("创建成功");
        // 清空表单
        document.getElementById("ca-email").value = "";
        document.getElementById("ca-password").value = "";
        document.getElementById("ca-role").value = "admin";
        // reset toggle
        const drCb = document.getElementById("ca-daily-report");
        if (drCb) {
          drCb.checked = false;
        }
        caSelected = new Set();
        caSync();
        // 重新加载列表
        loadList();
      } catch (e) {
        setStatus(e.message || "创建失败", false);
      }
    });

    async function loadList() {
      tbody.innerHTML =
        '<tr><td colspan="8" style="padding:10px;text-align:center;color:#6b7280;">加载中...</td></tr>';
      try {
        const res = await fetch("/admin/users", { credentials: "include" });
        const data = await res.json();
        if (!data.success) {
          throw new Error(data.error || "加载失败");
        }
        const list = data.data || [];
        if (list.length === 0) {
          tbody.innerHTML =
            '<tr><td colspan="8" style="padding:10px;text-align:center;color:#6b7280;">暂无管理员</td></tr>';
          return;
        }
        tbody.innerHTML = "";
        list.forEach((item) => {
          const tr = document.createElement("tr");
          tr.innerHTML = `
          <td>${item.id}</td>
          <td>${item.email}</td>
          <td>${item.role}</td>
          <td>${item.isActive && item.canLogin ? "可登录" : "禁用"}</td>
          <td>${Number(item.webauthnCount || 0)}</td>`;
          tbody.appendChild(tr);

          // 接收日报 toggle
          const tdReport = document.createElement("td");
          tdReport.innerHTML = `<input type="checkbox" ${
            item.receivesDailyReport ? "checked" : ""
          } data-id="${item.id}" class="dr-toggle" style="cursor:pointer;" />`;
          tr.appendChild(tdReport);

          // 权限展示
          const tdPerm = document.createElement("td");
          const perms = Array.isArray(item.permissions) ? item.permissions : [];
          tdPerm.textContent = perms.length ? perms.join(", ") : "(空)";
          tr.appendChild(tdPerm);

          // 操作区
          const tdActions = document.createElement("td");
          const editBtn = document.createElement("button");
          editBtn.textContent = "编辑";
          editBtn.className = "btn btn-sm";
          editBtn.addEventListener("click", () => openEditor(item, tr, tdPerm));
          tdActions.appendChild(editBtn);
          tr.appendChild(tdActions);
        });
      } catch (e) {
        console.error("[admin-users] 加载失败:", e);
        tbody.innerHTML =
          '<tr><td colspan="8" style="padding:10px;text-align:center;color:#dc2626;">加载失败: ' +
          (e.message || "未知错误") +
          "</td></tr>";
      }
    }

    tbody.addEventListener("change", async (ev) => {
      const t = ev.target;
      if (t && t.classList.contains("dr-toggle")) {
        const id = t.getAttribute("data-id");
        const enabled = !!t.checked;
        try {
          const res = await fetch(`/admin/users/${id}`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ receivesDailyReport: enabled }),
          });
          const data = await res.json();
          if (!data.success) {
            throw new Error(data.error || "更新失败");
          }
          setStatus("状态已更新");
        } catch (e) {
          setStatus(e.message || "更新失败", false);
        }
      }
    });

    // 打开权限编辑器（行下方展开一个编辑区）
    function openEditor(item, tr, tdPerm) {
      // 若已有编辑器，先移除
      const next = tr.nextElementSibling;
      if (next && next.classList.contains("perm-editor-row")) {
        next.remove();
      }

      const row = document.createElement("tr");
      row.className = "perm-editor-row";
      const td = document.createElement("td");
      td.colSpan = 8;

      // 当前权限
      const current = new Set(
        Array.isArray(item.permissions) ? item.permissions : []
      );

      // 预设按钮
      const presetBar = document.createElement("div");
      presetBar.className = "perm-presets";
      const btnAll = document.createElement("button");
      btnAll.className = "btn btn-sm";
      btnAll.textContent = "全部权限";
      btnAll.addEventListener("click", () => {
        selected = new Set(PRESETS.ALL);
        syncChecks();
      });
      const btnBasic = document.createElement("button");
      btnBasic.className = "btn btn-sm";
      btnBasic.textContent = "基础权限";
      btnBasic.addEventListener("click", () => {
        selected = new Set(PRESETS.BASIC);
        syncChecks();
      });
      presetBar.appendChild(btnAll);
      presetBar.appendChild(btnBasic);

      // 权限复选区
      let selected = new Set(current);
      const grid = document.createElement("div");
      grid.className = "perm-grid";

      const checks = [];
      const groups = buildGroups();
      groups.forEach((g) => renderGroup(grid, g, selected, checks));

      function syncChecks() {
        checks.forEach((cb) => {
          cb.checked = selected.has(cb.value);
        });
      }

      // 保存/取消
      const actions = document.createElement("div");
      actions.className = "form-actions";
      const saveBtn = document.createElement("button");
      saveBtn.className = "btn btn-primary btn-sm";
      saveBtn.textContent = "保存";
      const cancelBtn = document.createElement("button");
      cancelBtn.className = "btn btn-sm";
      cancelBtn.textContent = "取消";
      cancelBtn.addEventListener("click", () => row.remove());
      saveBtn.addEventListener("click", async () => {
        try {
          const body = Array.from(selected);
          const res = await fetch(`/admin/users/${item.id}/permissions`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            credentials: "include",
            body: JSON.stringify({ permissions: body }),
          });
          const data = await res.json();
          if (!data.success) {
            throw new Error(data.error || "保存失败");
          }
          tdPerm.textContent = (data.data.permissions || []).join(", ");
          setStatus("权限已更新");
          row.remove();
          // 刷新列表，确保展示最新数据
          if (typeof loadList === "function") {
            loadList();
          }
        } catch (e) {
          setStatus(e.message || "保存失败", false);
        }
      });

      td.appendChild(presetBar);
      td.appendChild(grid);
      td.appendChild(actions);
      actions.appendChild(saveBtn);
      actions.appendChild(cancelBtn);
      row.appendChild(td);
      tr.after(row);
    }

    loadList();
  })();
</script>
