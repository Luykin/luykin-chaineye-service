</div>

<style>
  .footer-status-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 24px;
    background: #f8fafc;
    border-top: 1px solid #e2e8f0;
    font-size: 12px;
    color: #64748b;
  }
  
  .status-group {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  
  .status-item {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  
  .status-icon {
    width: 14px;
    height: 14px;
    color: #94a3b8;
  }
  
  .status-icon.status-success {
    color: #22c55e;
  }
  
  .status-label {
    font-weight: 500;
    white-space: nowrap;
  }
  
  .status-divider {
    width: 4px;
    height: 4px;
    background: #cbd5e1;
    border-radius: 50%;
