<!-- 币安广场管理后台 -->
<div class="section" id="binance-square-section">
  <h2 class="section-title">币安广场爬虫管理</h2>
  <p class="section-desc">种子用户关注同步 → Top50目标计算 → 帖子定时抓取 → 镜像对比分析</p>

  <!-- 初始化提示（数据库未就绪时显示） -->
  <div id="bs-init-alert" class="bs-alert bs-alert-warning" style="display:none;">
    <div class="bs-alert-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></div>
    <div class="bs-alert-content">
      <strong>数据库未初始化</strong>
      <p>币安广场数据表尚未创建，请先运行迁移：<code>yarn db:migrate:pg</code></p>
    </div>
  </div>

  <!-- 统计卡片 -->
  <div class="bs-stats-grid" id="bs-stats-grid">
    <div class="bs-stat-card">
      <div class="bs-stat-meta">
        <div class="bs-stat-label">种子用户</div>
        <div class="bs-stat-value" id="bs-stat-seeds">-</div>
      </div>
      <div class="bs-stat-indicator" style="--indicator-color:#3b82f6;"></div>
    </div>
    <div class="bs-stat-card">
      <div class="bs-stat-meta">
        <div class="bs-stat-label">目标用户</div>
        <div class="bs-stat-value" id="bs-stat-targets">-</div>
      </div>
      <div class="bs-stat-indicator" style="--indicator-color:#f59e0b;"></div>
    </div>
    <div class="bs-stat-card">
      <div class="bs-stat-meta">
        <div class="bs-stat-label">帖子总数</div>
        <div class="bs-stat-value" id="bs-stat-posts">-</div>
      </div>
      <div class="bs-stat-indicator" style="--indicator-color:#10b981;"></div>
    </div>
    <div class="bs-stat-card">
      <div class="bs-stat-meta">
        <div class="bs-stat-label">镜像记录</div>
        <div class="bs-stat-value" id="bs-stat-snapshots">-</div>
      </div>
      <div class="bs-stat-indicator" style="--indicator-color:#8b5cf6;"></div>
    </div>
    <div class="bs-stat-card">
      <div class="bs-stat-meta">
        <div class="bs-stat-label">镜像存储</div>
        <div class="bs-stat-value" id="bs-stat-storage">-</div>
      </div>
      <div class="bs-stat-indicator" style="--indicator-color:#ec4899;"></div>
    </div>
    <div class="bs-stat-card">
      <div class="bs-stat-meta">
        <div class="bs-stat-label">上次抓取</div>
        <div class="bs-stat-value" id="bs-stat-last-crawl">-</div>
      </div>
      <div class="bs-stat-indicator" style="--indicator-color:#64748b;"></div>
    </div>
    <div class="bs-stat-card">
      <div class="bs-stat-meta">
        <div class="bs-stat-label">调度器状态</div>
        <div class="bs-stat-value" id="bs-stat-scheduler">-</div>
      </div>
      <div class="bs-stat-indicator" style="--indicator-color:#ef4444;"></div>
    </div>
  </div>

  <!-- 操作按钮区 -->
  <div class="bs-actions-bar">
    <button class="bs-btn bs-btn-primary" id="bs-btn-sync">同步关注列表</button>
    <button class="bs-btn bs-btn-primary" id="bs-btn-calc">计算 Top50</button>
    <button class="bs-btn bs-btn-primary" id="bs-btn-crawl">抓取帖子</button>
    <button class="bs-btn bs-btn-success" id="bs-btn-start">启动调度器</button>
    <button class="bs-btn bs-btn-danger" id="bs-btn-pause">暂停调度器</button>
    <button class="bs-btn bs-btn-refresh" id="bs-btn-refresh">刷新数据</button>
  </div>

  <!-- 全局操作状态 -->
  <div id="bs-action-status" class="bs-action-status" style="display:none;"></div>

  <!-- 子面板导航 -->
  <div class="bs-sub-tabs">
    <button class="bs-sub-tab active" data-subtab="overview">总览</button>
    <button class="bs-sub-tab" data-subtab="seeds">种子用户</button>
    <button class="bs-sub-tab" data-subtab="targets">目标用户</button>
    <button class="bs-sub-tab" data-subtab="posts">帖子列表</button>
    <button class="bs-sub-tab" data-subtab="logs">抓取日志</button>
  </div>

  <!-- ========== 总览面板 ========== -->
  <div class="bs-sub-panel active" id="bs-panel-overview">
    <div class="bs-panel-title">爬虫运行概览</div>
    <div id="bs-overview-loading" class="loading-state">
      <div class="spinner"></div>
      <span>加载概览数据...</span>
    </div>
    <div id="bs-overview-content" style="display:none;">
      <div class="bs-overview-grid">
        <div class="bs-overview-card">
          <h4>配置参数</h4>
          <div class="bs-config-list" id="bs-config-list"></div>
        </div>
        <div class="bs-overview-card">
          <h4>最近抓取统计</h4>
          <div class="bs-recent-stats" id="bs-recent-stats"></div>
        </div>
        <div class="bs-overview-card">
          <h4>最近日志</h4>
          <div class="bs-recent-logs" id="bs-recent-logs"></div>
        </div>
      </div>
    </div>
    <div id="bs-overview-empty" class="empty-state" style="display:none;">
      <div class="empty-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
      </div>
      <h3>暂无数据</h3>
      <p>请先添加种子用户并同步关注列表</p>
    </div>
  </div>

  <!-- ========== 种子用户面板 ========== -->
  <div class="bs-sub-panel" id="bs-panel-seeds">
    <div class="bs-panel-title">种子用户管理</div>
    <div class="bs-seed-add-row">
      <input type="text" id="bs-seed-username" placeholder="用户名（如 CZ）" />
      <input type="text" id="bs-seed-display" placeholder="显示名称（可选）" />
      <button class="bs-btn bs-btn-primary" id="bs-btn-add-seed">添加</button>
    </div>
    <div id="bs-seeds-loading" class="loading-state">
      <div class="spinner"></div>
      <span>加载种子用户...</span>
    </div>
    <div id="bs-seeds-content" style="display:none;">
      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th>用户名</th>
              <th>显示名</th>
              <th>关注数</th>
              <th>最后同步</th>
              <th>状态</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody id="bs-seeds-table-body"></tbody>
        </table>
      </div>
    </div>
    <div id="bs-seeds-empty" class="empty-state" style="display:none;">
      <div class="empty-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
      </div>
      <h3>暂无种子用户</h3>
      <p>请先调用「初始化种子用户」或手动添加</p>
      <button class="bs-btn bs-btn-primary" id="bs-btn-init-seeds">初始化默认种子用户</button>
    </div>
  </div>

  <!-- ========== 目标用户面板 ========== -->
  <div class="bs-sub-panel" id="bs-panel-targets">
    <div class="bs-panel-title">Top 50 目标用户</div>
    <div id="bs-targets-loading" class="loading-state">
      <div class="spinner"></div>
      <span>加载目标用户...</span>
    </div>
    <div id="bs-targets-content" style="display:none;">
      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th>排名</th>
              <th>用户名</th>
              <th>被关注次数</th>
              <th>关注者（种子）</th>
            </tr>
          </thead>
          <tbody id="bs-targets-table-body"></tbody>
        </table>
      </div>
    </div>
    <div id="bs-targets-empty" class="empty-state" style="display:none;">
      <div class="empty-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
      </div>
      <h3>尚未计算目标用户</h3>
      <p>请先同步关注列表，然后点击「计算 Top50」</p>
    </div>
  </div>

  <!-- ========== 帖子列表面板 ========== -->
  <div class="bs-sub-panel" id="bs-panel-posts">
    <div class="bs-panel-title">帖子列表</div>
    <!-- 实时抓取进度 -->
    <div id="bs-crawl-progress" class="bs-crawl-progress" style="display:none;">
      <div class="bs-progress-header">
        <span class="bs-progress-status" id="bs-progress-status">正在抓取...</span>
        <span class="bs-progress-stats" id="bs-progress-stats">0/0</span>
      </div>
      <div class="bs-progress-bar-bg">
        <div class="bs-progress-bar-fill" id="bs-progress-bar-fill" style="width:0%;"></div>
      </div>
      <div class="bs-progress-detail">
        <span id="bs-progress-success">成功: 0</span>
        <span id="bs-progress-failed" style="color:#ef4444;">失败: 0</span>
        <span id="bs-progress-error-rate">出错率: 0%</span>
        <span id="bs-progress-posts">帖子: 0</span>
      </div>
      <div id="bs-progress-errors" class="bs-progress-errors" style="display:none;">
        <div class="bs-progress-errors-title">失败详情:</div>
        <ul id="bs-progress-errors-list"></ul>
      </div>
    </div>
    <div class="bs-posts-filter">
      <select id="bs-posts-filter-type">
        <option value="">全部类型</option>
        <option value="article">文章</option>
        <option value="quote">引用</option>
        <option value="reply">回复</option>
      </select>
      <input type="text" id="bs-posts-filter-user" placeholder="筛选用户名" />
      <button class="bs-btn bs-btn-refresh" id="bs-btn-filter-posts">筛选</button>
    </div>
    <div id="bs-posts-loading" class="loading-state">
      <div class="spinner"></div>
      <span>加载帖子列表...</span>
    </div>
    <div id="bs-posts-content" style="display:none;">
      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th>类型</th>
              <th>用户名</th>
              <th>标题</th>
              <th>点赞</th>
              <th>评论</th>
              <th>分享</th>
              <th>浏览</th>
              <th>发布时间</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody id="bs-posts-table-body"></tbody>
        </table>
      </div>
      <div class="bs-pagination" id="bs-posts-pagination"></div>
    </div>
    <div id="bs-posts-empty" class="empty-state" style="display:none;">
      <div class="empty-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
      </div>
      <h3>暂无帖子数据</h3>
      <p>请先计算 Top50 目标用户，然后抓取帖子</p>
    </div>
  </div>

  <!-- ========== 日志面板 ========== -->
  <div class="bs-sub-panel" id="bs-panel-logs">
    <div class="bs-panel-title">抓取日志</div>
    <div class="bs-logs-filter">
      <select id="bs-logs-filter-type">
        <option value="">全部类型</option>
        <option value="following">关注同步</option>
        <option value="post">帖子抓取</option>
        <option value="target_calculate">Top50计算</option>
      </select>
      <select id="bs-logs-filter-status">
        <option value="">全部状态</option>
        <option value="success">成功</option>
        <option value="failed">失败</option>
        <option value="partial">部分成功</option>
      </select>
      <button class="bs-btn bs-btn-refresh" id="bs-btn-refresh-logs">刷新</button>
    </div>
    <div id="bs-logs-loading" class="loading-state">
      <div class="spinner"></div>
      <span>加载日志...</span>
    </div>
    <div id="bs-logs-content" style="display:none;">
      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th>时间</th>
              <th>任务类型</th>
              <th>状态</th>
              <th>目标</th>
              <th>数量</th>
              <th>耗时</th>
              <th>镜像批次</th>
            </tr>
          </thead>
          <tbody id="bs-logs-table-body"></tbody>
        </table>
      </div>
      <div class="bs-pagination" id="bs-logs-pagination"></div>
    </div>
    <div id="bs-logs-empty" class="empty-state" style="display:none;">
      <div class="empty-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48"><path d="M9 12h6"/><path d="M9 16h6"/><path d="M9 8h2"/><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/></svg>
      </div>
      <h3>暂无日志</h3>
      <p>执行一次抓取任务后日志将显示在这里</p>
    </div>
  </div>

  <!-- 镜像查看弹窗 -->
  <div id="bs-snapshot-modal" class="bs-modal" style="display:none;">
    <div class="bs-modal-overlay"></div>
    <div class="bs-modal-content">
      <div class="bs-modal-header">
        <h3>帖子镜像历史</h3>
        <button class="bs-modal-close" id="bs-modal-close">&times;</button>
      </div>
      <div class="bs-modal-body">
        <div id="bs-snapshot-loading" class="loading-state">
          <div class="spinner"></div>
          <span>加载镜像历史...</span>
        </div>
        <div id="bs-snapshot-empty" class="empty-state" style="display:none;">
          <p>该帖子暂无镜像记录</p>
        </div>
        <div id="bs-snapshot-list" style="display:none;"></div>
      </div>
    </div>
  </div>
</div>

<style>
/* ===== 币安广场管理后台样式 ===== */
#binance-square-section {
  padding: 0;
}

/* 统计卡片 */
.bs-stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 16px;
  margin-bottom: 24px;
}
.bs-stat-card {
  background: #fff;
  border: 1px solid #e2e8f0;
  border-radius: 10px;
  padding: 16px 16px 16px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}
.bs-stat-card:hover {
  border-color: #cbd5e1;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}
.bs-stat-indicator {
  width: 4px;
  height: 40px;
  border-radius: 2px;
  background: var(--indicator-color, #94a3b8);
  flex-shrink: 0;
  margin-left: 12px;
}
.bs-stat-meta {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.bs-stat-value {
  font-size: 24px;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.2;
  letter-spacing: -0.02em;
}
.bs-stat-label {
  font-size: 12px;
  font-weight: 500;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* 操作按钮区 */
.bs-actions-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 20px;
}
.bs-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 7px 14px;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  border: 1px solid transparent;
  transition: all 0.15s ease;
  white-space: nowrap;
  line-height: 1.4;
}
.bs-btn:hover { opacity: 0.85; }
.bs-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.bs-btn-primary {
  background: #2563eb;
  color: #fff;
}
.bs-btn-primary:hover { background: #1d4ed8; opacity: 1; }
.bs-btn-success {
  background: #059669;
  color: #fff;
}
.bs-btn-success:hover { background: #047857; opacity: 1; }
.bs-btn-danger {
  background: #dc2626;
  color: #fff;
}
.bs-btn-danger:hover { background: #b91c1c; opacity: 1; }
.bs-btn-refresh {
  background: #f8fafc;
  color: #475569;
  border-color: #e2e8f0;
}
.bs-btn-refresh:hover { background: #f1f5f9; opacity: 1; }

/* 操作状态提示 */
.bs-action-status {
  margin-bottom: 16px;
  padding: 12px 16px;
  border-radius: 8px;
  font-size: 13px;
  animation: bsFadeIn 0.3s ease;
}
.bs-action-status.success {
  background: #dcfce7;
  color: #166534;
  border: 1px solid #86efac;
}
.bs-action-status.error {
  background: #fee2e2;
  color: #991b1b;
  border: 1px solid #fca5a5;
}
.bs-action-status.info {
  background: #dbeafe;
  color: #1e40af;
  border: 1px solid #93c5fd;
}
@keyframes bsFadeIn {
  from { opacity: 0; transform: translateY(-4px); }
  to { opacity: 1; transform: translateY(0); }
}

/* 初始化警告 */
.bs-alert {
  display: flex;
  gap: 12px;
  padding: 16px;
  border-radius: 10px;
  margin-bottom: 20px;
  border: 1px solid;
}
.bs-alert-warning {
  background: #fffbeb;
  border-color: #fcd34d;
  color: #92400e;
}
.bs-alert-icon { font-size: 20px; flex-shrink: 0; }
.bs-alert-content p { margin: 4px 0 0; font-size: 13px; }
.bs-alert-content code {
  background: #fef3c7;
  padding: 2px 6px;
  border-radius: 4px;
  font-family: monospace;
}

/* 子面板导航 */
.bs-sub-tabs {
  display: flex;
  gap: 4px;
  margin-bottom: 20px;
  border-bottom: 2px solid #e2e8f0;
  padding-bottom: 0;
}
.bs-sub-tab {
  padding: 10px 20px;
  font-size: 14px;
  font-weight: 500;
  color: #64748b;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  margin-bottom: -2px;
  cursor: pointer;
  transition: all 0.15s ease;
  white-space: nowrap;
}
.bs-sub-tab:hover {
  color: #3b82f6;
  background: #f1f5f9;
  border-radius: 6px 6px 0 0;
}
.bs-sub-tab.active {
  color: #2563eb;
  border-bottom-color: #2563eb;
  background: #eff6ff;
  border-radius: 6px 6px 0 0;
}

/* 子面板 */
.bs-sub-panel { display: none; }
.bs-sub-panel.active { display: block; }

/* 实时抓取进度 */
.bs-crawl-progress {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  padding: 14px 16px;
  margin-bottom: 16px;
}
.bs-progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
  font-size: 13px;
  font-weight: 500;
}
.bs-progress-status {
  color: #2563eb;
}
.bs-progress-stats {
  color: #64748b;
}
.bs-progress-bar-bg {
  width: 100%;
  height: 8px;
  background: #e2e8f0;
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 10px;
}
.bs-progress-bar-fill {
  height: 100%;
  background: #2563eb;
  border-radius: 4px;
  transition: width 0.3s ease;
}
.bs-progress-bar-fill.is-error {
  background: #dc2626;
}
.bs-progress-detail {
  display: flex;
  gap: 16px;
  font-size: 12px;
  color: #64748b;
}
.bs-progress-errors {
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px solid #e2e8f0;
}
.bs-progress-errors-title {
  font-size: 12px;
  font-weight: 600;
  color: #dc2626;
  margin-bottom: 6px;
}
.bs-progress-errors ul {
  margin: 0;
  padding-left: 16px;
  font-size: 12px;
  color: #64748b;
}
.bs-progress-errors li {
  margin-bottom: 3px;
}

.bs-panel-title {
  font-size: 16px;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16px;
  padding-bottom: 8px;
  border-bottom: 1px solid #e2e8f0;
}

/* 总览面板 */
.bs-overview-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 16px;
}
.bs-overview-card {
  background: #fff;
  border: 1px solid #e2e8f0;
  border-radius: 10px;
  padding: 16px;
}
.bs-overview-card h4 {
  margin: 0 0 12px;
  font-size: 14px;
  color: #475569;
}
.bs-config-list {
  display: flex;
  flex-direction: column;
