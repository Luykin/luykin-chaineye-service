}

/* 表格操作按钮 */
.bs-table-actions {
  display: flex;
  gap: 6px;
}
.bs-table-btn {
  padding: 4px 10px;
  font-size: 12px;
  border-radius: 4px;
  cursor: pointer;
  border: 1px solid;
  background: #fff;
  transition: all 0.1s ease;
}
.bs-table-btn-sync {
  color: #2563eb;
  border-color: #bfdbfe;
}
.bs-table-btn-sync:hover { background: #eff6ff; }
