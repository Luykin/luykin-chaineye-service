    bsSetVisible('bs-posts-content', false);
    bsSetVisible('bs-posts-empty', false);

    try {
      const type = document.getElementById('bs-posts-filter-type')?.value || '';
      const user = document.getElementById('bs-posts-filter-user')?.value || '';
      let url = `/posts?page=${page}&pageSize=${BS_PAGE_SIZE}`;
      if (type) url += `&postType=${type}`;
      if (user) url += `&username=${encodeURIComponent(user)}`;

      const res = await bsApi('GET', url);
      const posts = res.success ? (res.data?.data || []) : [];
      const total = res.success ? (res.data?.total || 0) : 0;
      bsPostsTotal = total;
      const tbody = document.getElementById('bs-posts-table-body');

      if (!posts.length) {
        bsSetLoading('bs-posts-loading', false);
        bsSetVisible('bs-posts-empty', true);
        return;
      }

      tbody.innerHTML = posts.map(p => `
        <tr data-source-url="${p.sourceUrl || ''}" style="cursor:pointer;">
          <td><span class="bs-log-type ${p.postType === 'article' ? 'bs-log-type-post' : p.postType === 'reply' ? 'bs-log-type-following' : 'bs-log-type-target'}">${p.postType}</span></td>
          <td>${p.username}</td>
          <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${p.title || ''}">${p.title || '(无标题)'}</td>
          <td>${bsFormatNum(p.likeCount)}</td>
          <td>${bsFormatNum(p.commentCount)}</td>
          <td>${bsFormatNum(p.shareCount)}</td>
          <td>${bsFormatNum(p.viewCount)}</td>
          <td>${bsFormatDate(p.publishedAt)}</td>
          <td>
            <button class="bs-table-btn bs-table-btn-view" data-action="view-snapshots" data-post-id="${p.postId}">镜像</button>
          </td>
        </tr>
      `).join('');

      // 分页
      const totalPages = Math.ceil(total / BS_PAGE_SIZE);
      bsRenderPagination('bs-posts-pagination', totalPages, page);

      bsSetLoading('bs-posts-loading', false);
      bsSetVisible('bs-posts-content', true);
    } catch (e) {
      bsSetLoading('bs-posts-loading', false);
      bsSetVisible('bs-posts-empty', true);
    }
  };

  // ========== 日志面板 ==========
  async function bsLoadLogs(page) {
    page = page || bsLogsPage;
    bsLogsPage = page;
    bsSetLoading('bs-logs-loading', true);
    bsSetVisible('bs-logs-content', false);
    bsSetVisible('bs-logs-empty', false);

    try {
      const type = document.getElementById('bs-logs-filter-type')?.value || '';
      const status = document.getElementById('bs-logs-filter-status')?.value || '';
      let url = `/crawl/logs?page=${page}&pageSize=${BS_PAGE_SIZE}`;
      if (type) url += `&taskType=${type}`;
      if (status) url += `&status=${status}`;

      const res = await bsApi('GET', url);
      const logs = res.success ? (res.data?.data || []) : [];
      const total = res.success ? (res.data?.total || 0) : 0;
      bsLogsTotal = total;
      const tbody = document.getElementById('bs-logs-table-body');

      if (!logs.length) {
        bsSetLoading('bs-logs-loading', false);
        bsSetVisible('bs-logs-empty', true);
        return;
      }

      tbody.innerHTML = logs.map(log => {
        const statusClass = log.status === 'success' ? 'bs-log-status-success' : log.status === 'failed' ? 'bs-log-status-failed' : 'bs-log-status-partial';
        return `
          <tr>
            <td>${bsFormatDate(log.createdAt)}</td>
            <td><span class="bs-log-type ${log.taskType === 'following' ? 'bs-log-type-following' : log.taskType === 'post' ? 'bs-log-type-post' : 'bs-log-type-target'}">${log.taskType}</span></td>
            <td class="${statusClass}">${log.status}</td>
            <td>${log.targetId || '-'}</td>
            <td>${log.itemsCount !== null ? log.itemsCount : '-'}</td>
            <td>${log.durationMs ? (log.durationMs / 1000).toFixed(1) + 's' : '-'}</td>
            <td>${log.snapshotId || '-'}</td>
          </tr>
        `;
      }).join('');

      // 分页
      const totalPages = Math.ceil(total / BS_PAGE_SIZE);
      bsRenderPagination('bs-logs-pagination', totalPages, page);

      bsSetLoading('bs-logs-loading', false);
      bsSetVisible('bs-logs-content', true);
    } catch (e) {
      bsSetLoading('bs-logs-loading', false);
      bsSetVisible('bs-logs-empty', true);
    }
  };

  // ========== 分页渲染 ==========
  function bsRenderPagination(containerId, totalPages, currentPage) {
    const container = document.getElementById(containerId);
    if (!container || totalPages <= 1) {
      if (container) container.innerHTML = '';
      return;
    }
    let html = '';
    // 上一页
    html += `<button class="bs-page-btn" ${currentPage <= 1 ? 'disabled' : ''} data-page="${currentPage - 1}">上一页</button>`;
    // 页码
    const maxButtons = 7;
    let start = Math.max(1, currentPage - Math.floor(maxButtons / 2));
    let end = Math.min(totalPages, start + maxButtons - 1);
    if (end - start < maxButtons - 1) start = Math.max(1, end - maxButtons + 1);
    if (start > 1) html += `<button class="bs-page-btn" data-page="1">1</button>${start > 2 ? '<span style="padding:6px 4px;color:#94a3b8;">...</span>' : ''}`;
    for (let i = start; i <= end; i++) {
      html += `<button class="bs-page-btn ${i === currentPage ? 'active' : ''}" data-page="${i}">${i}</button>`;
    }
    if (end < totalPages) html += `${end < totalPages - 1 ? '<span style="padding:6px 4px;color:#94a3b8;">...</span>' : ''}<button class="bs-page-btn" data-page="${totalPages}">${totalPages}</button>`;
    // 下一页
    html += `<button class="bs-page-btn" ${currentPage >= totalPages ? 'disabled' : ''} data-page="${currentPage + 1}">下一页</button>`;
    container.innerHTML = html;
  }

