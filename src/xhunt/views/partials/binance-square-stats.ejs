  color: #dc2626;
  border-color: #fecaca;
}
.bs-table-btn-remove:hover { background: #fef2f2; }
.bs-table-btn-view {
  color: #059669;
  border-color: #a7f3d0;
}
.bs-table-btn-view:hover { background: #f0fdf4; }

/* 分页 */
.bs-pagination {
  display: flex;
  justify-content: center;
  gap: 6px;
