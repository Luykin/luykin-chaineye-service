.bs-modal-body {
  padding: 16px 20px;
  overflow-y: auto;
  flex: 1;
}

/* 镜像卡片 */
.bs-snapshot-card {
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  padding: 14px 16px;
  margin-bottom: 12px;
  background: #f8fafc;
}
.bs-snapshot-card:last-child { margin-bottom: 0; }
.bs-snapshot-time {
  font-size: 13px;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 8px;
}
.bs-snapshot-time .bs-snapshot-batch {
  font-weight: 400;
  color: #94a3b8;
  margin-left: 8px;
  font-size: 12px;
}
.bs-snapshot-metrics {
  display: flex;
  gap: 16px;
  font-size: 13px;
  color: #475569;
  margin-bottom: 8px;
}
.bs-snapshot-metrics span {
  display: inline-flex;
  align-items: center;
  gap: 4px;
}
.bs-snapshot-diff {
  font-size: 12px;
  padding: 8px 10px;
  background: #fff;
  border-radius: 6px;
  border-left: 3px solid #3b82f6;
}
.bs-snapshot-diff-title {
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 4px;
}
.bs-snapshot-diff-item {
  display: flex;
  gap: 8px;
  margin-bottom: 2px;
  color: #64748b;
}
.bs-snapshot-diff-item .diff-up { color: #16a34a; }
.bs-snapshot-diff-item .diff-down { color: #dc2626; }
.bs-snapshot-no-diff {
  font-size: 12px;
  color: #94a3b8;
  font-style: italic;
}

/* 响应式 */
@media (max-width: 768px) {
  .bs-stats-grid { grid-template-columns: repeat(2, 1fr); }
  .bs-overview-grid { grid-template-columns: 1fr; }
  .bs-actions-bar { justify-content: center; }
  .bs-sub-tabs { overflow-x: auto; }
  .bs-modal-content { width: 95%; max-height: 90vh; }
}
</style>

<script>
(function() {
  'use strict';

  // ========== 全局状态 ==========
  const API_BASE = '/api/admin/binance-square';
  let bsDbReady = true;
  let bsPostsPage = 1;
  let bsLogsPage = 1;
  let bsPostsTotal = 0;
  let bsLogsTotal = 0;
  const BS_PAGE_SIZE = 20;

  // ========== 初始化 ==========
  document.addEventListener('DOMContentLoaded', function() {
    // === 绑定静态按钮事件 ===
    document.getElementById('bs-btn-sync')?.addEventListener('click', bsSyncFollowing);
    document.getElementById('bs-btn-calc')?.addEventListener('click', bsCalculateTargets);
    document.getElementById('bs-btn-crawl')?.addEventListener('click', bsCrawlPosts);
    document.getElementById('bs-btn-start')?.addEventListener('click', bsStartScheduler);
    document.getElementById('bs-btn-pause')?.addEventListener('click', bsPauseScheduler);
    document.getElementById('bs-btn-refresh')?.addEventListener('click', bsRefreshAll);

    // === 绑定子 Tab 切换 ===
    document.querySelectorAll('.bs-sub-tab').forEach(tab => {
      tab.addEventListener('click', () => bsSwitchSubTab(tab.dataset.subtab));
    });

    // === 种子用户面板 ===
    document.getElementById('bs-btn-add-seed')?.addEventListener('click', bsAddSeed);
    document.getElementById('bs-btn-init-seeds')?.addEventListener('click', bsInitSeeds);

    // === 帖子筛选 ===
    document.getElementById('bs-posts-filter-type')?.addEventListener('change', () => bsLoadPosts());
    document.getElementById('bs-posts-filter-user')?.addEventListener('keypress', function(e) {
      if (e.key === 'Enter') bsLoadPosts();
    });
    document.getElementById('bs-btn-filter-posts')?.addEventListener('click', () => bsLoadPosts());

    // === 日志筛选 ===
    document.getElementById('bs-logs-filter-type')?.addEventListener('change', () => bsLoadLogs());
    document.getElementById('bs-logs-filter-status')?.addEventListener('change', () => bsLoadLogs());
    document.getElementById('bs-btn-refresh-logs')?.addEventListener('click', () => bsLoadLogs());

    // === 镜像弹窗关闭 ===
    document.getElementById('bs-modal-close')?.addEventListener('click', bsCloseSnapshotModal);
    document.getElementById('bs-snapshot-modal')?.addEventListener('click', function(e) {
      if (e.target.classList.contains('bs-modal-overlay')) bsCloseSnapshotModal();
    });

    // === 表格事件委托 ===
    // 种子用户表格
    document.getElementById('bs-seeds-table-body')?.addEventListener('click', function(e) {
      const btn = e.target.closest('[data-action]');
      if (!btn) return;
      const action = btn.dataset.action;
      const username = btn.dataset.username;
      if (action === 'sync-seed' && username) bsSyncOneSeed(username);
      else if (action === 'remove-seed' && username) bsRemoveSeed(username);
    });

    // 帖子表格
    document.getElementById('bs-posts-table-body')?.addEventListener('click', function(e) {
      const btn = e.target.closest('[data-action]');
      if (btn) {
        const action = btn.dataset.action;
        const postId = btn.dataset.postId;
        if (action === 'view-snapshots' && postId) bsViewPostSnapshots(postId);
        return;
      }
      const row = e.target.closest('tr[data-source-url]');
      if (row && row.dataset.sourceUrl) {
        window.open(row.dataset.sourceUrl, '_blank');
      }
    });

    // === 分页事件委托 ===
    document.getElementById('bs-posts-pagination')?.addEventListener('click', function(e) {
      const btn = e.target.closest('.bs-page-btn');
      if (!btn || btn.disabled) return;
      const page = parseInt(btn.dataset.page, 10);
      if (!isNaN(page)) bsLoadPosts(page);
    });
    document.getElementById('bs-logs-pagination')?.addEventListener('click', function(e) {
      const btn = e.target.closest('.bs-page-btn');
      if (!btn || btn.disabled) return;
      const page = parseInt(btn.dataset.page, 10);
      if (!isNaN(page)) bsLoadLogs(page);
    });

    // 等待 stats.js 的 tab 切换系统就绪后再加载
    const checkTab = setInterval(() => {
      if (document.getElementById('binance-square')?.classList.contains('active')) {
        clearInterval(checkTab);
        bsRefreshAll();
      }
    }, 200);
    // 兜底：3秒后无论如何都加载一次
    setTimeout(() => { clearInterval(checkTab); bsRefreshAll(); }, 3000);

    // 启动进度轮询（检查是否有正在运行的抓取任务）
    bsPollCrawlProgress();
  });

  // 监听 Tab 切换事件（stats.js 切换时会改变 class）
  const bsObserver = new MutationObserver(function(mutations) {
    mutations.forEach(function(mutation) {
      if (mutation.target.id === 'binance-square' && mutation.target.classList.contains('active')) {
        bsRefreshAll();
      }
    });
  });
  const bsTabPane = document.getElementById('binance-square');
  if (bsTabPane) {
    bsObserver.observe(bsTabPane, { attributes: true, attributeFilter: ['class'] });
  }

  // ========== 工具函数 ==========
  function bsApi(method, path, body) {
    const opts = {
      method,
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }
    };
    if (body) opts.body = JSON.stringify(body);
    return fetch(API_BASE + path, opts).then(async r => {
      const data = await r.json().catch(() => ({}));
      if (!r.ok) {
        const err = new Error(data.error || data.message || `HTTP ${r.status}`);
        err.status = r.status;
        err.data = data;
        throw err;
      }
      return data;
    });
  }

  function bsShowStatus(msg, type) {
    const el = document.getElementById('bs-action-status');
    el.textContent = msg;
    el.className = 'bs-action-status ' + (type || 'info');
    el.style.display = 'block';
    setTimeout(() => { el.style.display = 'none'; }, 5000);
  }

  function bsFormatNum(n) {
    if (n === null || n === undefined) return '-';
    if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
    if (n >= 1000) return (n / 1000).toFixed(1) + 'K';
    return String(n);
  }

  function bsFormatBytes(bytes) {
    if (!bytes || bytes === 0) return '-';
    const gb = bytes / (1024 * 1024 * 1024);
    if (gb >= 1) return gb.toFixed(2) + ' GB';
    const mb = bytes / (1024 * 1024);
    if (mb >= 1) return mb.toFixed(2) + ' MB';
    const kb = bytes / 1024;
    if (kb >= 1) return kb.toFixed(2) + ' KB';
    return bytes + ' B';
  }

  function bsFormatDate(d) {
    if (!d) return '-';
    const date = new Date(d);
    if (isNaN(date)) return '-';
    return `${date.getMonth()+1}/${date.getDate()} ${String(date.getHours()).padStart(2,'0')}:${String(date.getMinutes()).padStart(2,'0')}`;
  }

  function bsTimeAgo(d) {
    if (!d) return '-';
    const diff = Date.now() - new Date(d).getTime();
    if (diff < 60000) return '刚刚';
    if (diff < 3600000) return Math.floor(diff / 60000) + '分钟前';
    if (diff < 86400000) return Math.floor(diff / 3600000) + '小时前';
    return Math.floor(diff / 86400000) + '天前';
  }

  function bsSetLoading(id, loading) {
    const el = document.getElementById(id);
    if (el) el.style.display = loading ? 'flex' : 'none';
  }

  function bsSetVisible(id, visible) {
    const el = document.getElementById(id);
    if (el) el.style.display = visible ? 'block' : 'none';
  }

  // ========== 子 Tab 切换 ==========
  function bsSwitchSubTab(tab) {
    document.querySelectorAll('.bs-sub-tab').forEach(t => t.classList.toggle('active', t.dataset.subtab === tab));
    document.querySelectorAll('.bs-sub-panel').forEach(p => p.classList.toggle('active', p.id === 'bs-panel-' + tab));
    // 加载对应面板数据
    if (tab === 'seeds') bsLoadSeeds();
    else if (tab === 'targets') bsLoadTargets();
    else if (tab === 'posts') bsLoadPosts();
    else if (tab === 'logs') bsLoadLogs();
    else if (tab === 'overview') bsLoadOverview();
  };

  // ========== 刷新全部 ==========
  function bsRefreshAll() {
    if (!bsDbReady) return;
    bsLoadStats();
    bsLoadSchedulerStatus();
    // 根据当前子面板加载对应数据
    const activeTab = document.querySelector('.bs-sub-tab.active');
    if (activeTab) {
      bsSwitchSubTab(activeTab.dataset.subtab);
    } else {
      bsLoadOverview();
    }
  };

  // ========== 加载统计卡片 ==========
  async function bsLoadStats() {
    try {
      const statsRes = await bsApi('GET', '/stats');

      if (statsRes.success && statsRes.data) {
        const d = statsRes.data;
        document.getElementById('bs-stat-seeds').textContent = d.seedCount || 0;
        document.getElementById('bs-stat-targets').textContent = d.targetCount || 0;
        document.getElementById('bs-stat-posts').textContent = bsFormatNum(d.postCount || 0);
        document.getElementById('bs-stat-snapshots').textContent = bsFormatNum(d.snapshotCount || 0);
        document.getElementById('bs-stat-storage').textContent = bsFormatBytes(d.snapshotStorageBytes || 0);
        document.getElementById('bs-stat-last-crawl').textContent = d.lastCrawlAt ? bsTimeAgo(d.lastCrawlAt) : '-';
      }
    } catch (e) {
      if (e.status === 503 || e.message?.includes('Table') || e.message?.includes('relation') || e.message?.includes('does not exist')) {
        bsHandleDbNotReady();
      }
    }
  }

  // ========== 调度器状态 ==========
  async function bsLoadSchedulerStatus() {
    try {
      const res = await bsApi('GET', '/crawl/status');
      const status = res.success ? res.data : null;
      const el = document.getElementById('bs-stat-scheduler');
      if (!status) {
        el.textContent = '未知';
        el.style.color = '#64748b';
        return;
      }
      if (status.isCrawling && status.currentTask) {
        const t = status.currentTask;
        el.innerHTML = `运行中 <span style="font-size:12px;font-weight:400;color:#f59e0b;display:block;margin-top:2px;">正在爬取 ${t.processedUsers || 0}/${t.totalUsers || 0}</span>`;
        el.style.color = '#16a34a';
      } else if (status.isRunning) {
        el.textContent = '运行中';
        el.style.color = '#16a34a';
      } else {
        el.textContent = '已停止';
        el.style.color = '#dc2626';
      }
    } catch (e) {
      document.getElementById('bs-stat-scheduler').textContent = '未知';
    }
  }

  // ========== 数据库未初始化处理 ==========
  function bsHandleDbNotReady() {
    bsDbReady = false;
    document.getElementById('bs-init-alert').style.display = 'flex';
    document.getElementById('bs-stats-grid').style.opacity = '0.5';
    document.querySelector('.bs-actions-bar').style.display = 'none';
    document.querySelector('.bs-sub-tabs').style.display = 'none';
    document.querySelectorAll('.bs-sub-panel').forEach(p => p.style.display = 'none');
  }

  // ========== 总览面板 ==========
  async function bsLoadOverview() {
    bsSetLoading('bs-overview-loading', true);
    bsSetVisible('bs-overview-content', false);
    bsSetVisible('bs-overview-empty', false);

    try {
      // 并行获取配置、日志、统计
      const [configRes, logsRes, seedsRes] = await Promise.all([
        bsApi('GET', '/config').catch(() => ({ success: false, data: [] })),
        bsApi('GET', '/crawl/logs?page=1&pageSize=5').catch(() => ({ success: false, data: [] })),
        bsApi('GET', '/seed/list').catch(() => ({ success: false, data: [] }))
      ]);

      // 配置列表
      const configList = document.getElementById('bs-config-list');
      if (configRes.success && configRes.data?.length) {
        configList.innerHTML = configRes.data.map(c => `
          <div class="bs-config-item">
            <span class="bs-config-key">${c.configKey}</span>
            <span class="bs-config-val">${c.configValue}${c.minValue ? ` (${c.minValue}~${c.maxValue})` : ''}</span>
          </div>
        `).join('');
      } else {
        configList.innerHTML = '<div style="color:#94a3b8;font-size:13px;">暂无配置数据</div>';
      }

      // 最近统计
      const recentStats = document.getElementById('bs-recent-stats');
      const seedCount = seedsRes.success ? (seedsRes.data?.length || 0) : 0;
      recentStats.innerHTML = `
        <div class="bs-config-item"><span class="bs-config-key">活跃种子用户</span><span class="bs-config-val">${seedCount} 人</span></div>
        <div class="bs-config-item"><span class="bs-config-key">帖子抓取间隔</span><span class="bs-config-val">${configRes.data?.find(c => c.configKey === 'post_crawl_interval_hours')?.configValue || '2'} 小时</span></div>
        <div class="bs-config-item"><span class="bs-config-key">镜像保留天数</span><span class="bs-config-val">${configRes.data?.find(c => c.configKey === 'snapshot_retention_days')?.configValue || '3'} 天</span></div>
      `;

      // 最近日志
      const recentLogs = document.getElementById('bs-recent-logs');
      if (logsRes.success && logsRes.data?.length) {
        recentLogs.innerHTML = logsRes.data.map(log => {
          const typeClass = log.taskType === 'following' ? 'bs-log-type-following' : log.taskType === 'post' ? 'bs-log-type-post' : 'bs-log-type-target';
          const statusClass = log.status === 'success' ? 'bs-log-status-success' : log.status === 'failed' ? 'bs-log-status-failed' : 'bs-log-status-partial';
          return `
            <div class="bs-recent-log-item">
              <div>
                <span class="bs-log-type ${typeClass}">${log.taskType}</span>
                <span class="${statusClass}" style="margin-left:6px;">${log.status}</span>
                ${log.itemsCount !== null ? `<span style="margin-left:6px;color:#64748b;">${log.itemsCount}条</span>` : ''}
              </div>
              <div class="bs-log-time">${bsTimeAgo(log.createdAt)}</div>
            </div>
          `;
        }).join('');
      } else {
        recentLogs.innerHTML = '<div style="color:#94a3b8;font-size:13px;">暂无日志记录</div>';
      }

      bsSetLoading('bs-overview-loading', false);
      bsSetVisible('bs-overview-content', true);
    } catch (e) {
      bsSetLoading('bs-overview-loading', false);
      bsSetVisible('bs-overview-empty', true);
    }
  }

  // ========== 种子用户面板 ==========
  async function bsLoadSeeds() {
    bsSetLoading('bs-seeds-loading', true);
    bsSetVisible('bs-seeds-content', false);
    bsSetVisible('bs-seeds-empty', false);

    try {
      const res = await bsApi('GET', '/seed/list');
      const seeds = res.success ? (res.data || []) : [];
      const tbody = document.getElementById('bs-seeds-table-body');

      if (!seeds.length) {
        bsSetLoading('bs-seeds-loading', false);
        bsSetVisible('bs-seeds-empty', true);
        return;
      }

      tbody.innerHTML = seeds.map(s => `
        <tr>
          <td><strong>${s.username}</strong></td>
          <td>${s.displayName || '-'}</td>
          <td>${bsFormatNum(s.totalFollowingCount)}</td>
          <td>${bsTimeAgo(s.lastCrawledAt)}</td>
          <td><span class="bs-status-badge ${s.isActive !== false ? 'bs-status-active' : 'bs-status-inactive'}">${s.isActive !== false ? '活跃' : '停用'}</span></td>
          <td>
            <div class="bs-table-actions">
              <button class="bs-table-btn bs-table-btn-sync" data-action="sync-seed" data-username="${s.username}">同步</button>
              <button class="bs-table-btn bs-table-btn-remove" data-action="remove-seed" data-username="${s.username}">移除</button>
            </div>
          </td>
        </tr>
      `).join('');

      bsSetLoading('bs-seeds-loading', false);
      bsSetVisible('bs-seeds-content', true);
    } catch (e) {
      bsSetLoading('bs-seeds-loading', false);
      bsSetVisible('bs-seeds-empty', true);
