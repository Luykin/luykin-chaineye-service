  // 进度轮询定时器
  let bsProgressTimer = null;

  async function bsPollCrawlProgress() {
    try {
      const res = await bsApi('GET', '/crawl/progress');
      if (res.success && res.data) {
        bsRenderCrawlProgress(res.data);
        // 如果任务还在运行，继续轮询
        if (res.data.running) {
          bsProgressTimer = setTimeout(bsPollCrawlProgress, 3000);
        } else if (res.data.status) {
          // 任务已完成，再轮询一次确保状态更新
          bsProgressTimer = setTimeout(bsPollCrawlProgress, 5000);
        }
      }
    } catch (e) {
      // 轮询失败不报错
    }
  }

  function bsRenderCrawlProgress(data) {
    const container = document.getElementById('bs-crawl-progress');
    if (!container) return;

    const isRunning = data.running;
    const total = data.totalUsers || 0;
    const processed = data.processedUsers || 0;
    const success = data.successUsers || 0;
    const failed = data.failedUsers || 0;
    const errorRate = data.errorRate || '0%';
    const posts = (data.totalPostsAll || 0) + (data.totalPostsReply || 0);
    const percent = total > 0 ? Math.round((processed / total) * 100) : 0;

    container.style.display = 'block';

    document.getElementById('bs-progress-status').textContent = isRunning ? '正在抓取...' : '抓取完成';
    document.getElementById('bs-progress-stats').textContent = `${processed}/${total}`;
    document.getElementById('bs-progress-bar-fill').style.width = percent + '%';
    document.getElementById('bs-progress-bar-fill').classList.toggle('is-error', failed > 0);
    document.getElementById('bs-progress-success').textContent = `成功: ${success}`;
    document.getElementById('bs-progress-failed').textContent = `失败: ${failed}`;
    document.getElementById('bs-progress-error-rate').textContent = `出错率: ${errorRate}`;
    document.getElementById('bs-progress-posts').textContent = `帖子: ${posts}`;

    // 失败详情
    const errorsDiv = document.getElementById('bs-progress-errors');
    const errorsList = document.getElementById('bs-progress-errors-list');
    const errors = data.errors || [];
    if (errors.length > 0) {
      errorsDiv.style.display = 'block';
      errorsList.innerHTML = errors.map(err =>
        `<li><strong>${err.username}</strong>: ${err.error}</li>`
      ).join('');
    } else {
      errorsDiv.style.display = 'none';
      errorsList.innerHTML = '';
    }
  }

  function bsStopProgressPolling() {
    if (bsProgressTimer) {
      clearTimeout(bsProgressTimer);
      bsProgressTimer = null;
    }
  }

  async function bsCrawlPosts() {
    const btn = document.getElementById('bs-btn-crawl');
    btn.disabled = true;
    bsShowStatus('正在抓取帖子，这可能需要几分钟...', 'info');
    // 启动进度轮询
    bsStopProgressPolling();
    bsPollCrawlProgress();
    try {
      const res = await bsApi('POST', '/crawl/posts');
      bsShowStatus(`抓取完成：${res.data?.totalPostsAll || 0} 主帖, ${res.data?.totalPostsReply || 0} 回复`, 'success');
      bsRefreshAll();
    } catch (e) {
      bsShowStatus('抓取失败：' + (e.message || '未知错误'), 'error');
    } finally {
      btn.disabled = false;
      // 再轮询一次确保最终状态展示
      setTimeout(bsPollCrawlProgress, 2000);
    }
  };

