/* 筛选区 */
.bs-posts-filter, .bs-logs-filter {
  display: flex;
  gap: 10px;
  margin-bottom: 16px;
  flex-wrap: wrap;
  align-items: center;
}
.bs-posts-filter select, .bs-logs-filter select,
.bs-posts-filter input {
  padding: 8px 12px;
  border: 1px solid #d1d5db;
