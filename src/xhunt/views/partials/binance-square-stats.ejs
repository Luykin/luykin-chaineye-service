  // ========== 镜像弹窗 ==========
  function bsOpenSnapshotModal() {
    document.getElementById('bs-snapshot-modal').style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function bsCloseSnapshotModal() {
    document.getElementById('bs-snapshot-modal').style.display = 'none';
    document.body.style.overflow = '';
  }

  async function bsViewPostSnapshots(postId) {
    bsOpenSnapshotModal();

    const loading = document.getElementById('bs-snapshot-loading');
    const empty = document.getElementById('bs-snapshot-empty');
    const list = document.getElementById('bs-snapshot-list');

    loading.style.display = 'block';
    empty.style.display = 'none';
    list.style.display = 'none';
    list.innerHTML = '';

    try {
      const res = await bsApi('GET', `/posts/${postId}/snapshots`);
      const snapshots = res.success ? (res.data || []) : [];

      loading.style.display = 'none';

      if (!snapshots.length) {
        empty.style.display = 'block';
        return;
      }

      list.innerHTML = snapshots.map((s, index) => {
        const isFirst = index === snapshots.length - 1;
        const time = s.snapshotTime ? new Date(s.snapshotTime).toLocaleString('zh-CN') : '-';
        const diffHtml = isFirst
          ? '<div class="bs-snapshot-no-diff">首次抓取，无历史对比</div>'
          : bsRenderSnapshotDiff(s.diffFromPrev);

        return `
          <div class="bs-snapshot-card">
            <div class="bs-snapshot-time">
              ${time}
              <span class="bs-snapshot-batch">批次: ${s.snapshotId || '-'}</span>
            </div>
            <div class="bs-snapshot-metrics">
              <span>点赞 ${s.likeCount !== null ? s.likeCount : '-'}</span>
              <span>评论 ${s.commentCount !== null ? s.commentCount : '-'}</span>
              <span>分享 ${s.shareCount !== null ? s.shareCount : '-'}</span>
              <span>浏览 ${s.viewCount !== null ? s.viewCount : '-'}</span>
            </div>
            ${diffHtml}
          </div>
        `;
      }).join('');

      list.style.display = 'block';
    } catch (e) {
      loading.style.display = 'none';
      empty.style.display = 'block';
      empty.innerHTML = `<p style="color:#dc2626;">加载失败: ${e.message || '未知错误'}</p>`;
    }
  }

  function bsRenderSnapshotDiff(diff) {
    const fieldMeta = [
      { key: 'title', label: '标题', type: 'text' },
      { key: 'content', label: '内容', type: 'text' },
      { key: 'contentText', label: '正文', type: 'text' },
      { key: 'likeCount', label: '点赞', type: 'number' },
      { key: 'shareCount', label: '分享', type: 'number' },
      { key: 'commentCount', label: '评论', type: 'number' },
      { key: 'viewCount', label: '浏览', type: 'number' },
      { key: 'isDeleted', label: '删除状态', type: 'boolean' },
    ];

    const items = fieldMeta.map(({ key, label, type }) => {
      const val = diff?.[key];
      if (!val) {
        return `<div class="bs-snapshot-diff-item"><span>${label}:</span> <span class="bs-snapshot-no-diff">无变化</span></div>`;
      }
      if (type === 'number' && val.delta !== undefined) {
        const cls = val.delta > 0 ? 'diff-up' : val.delta < 0 ? 'diff-down' : '';
        const sign = val.delta > 0 ? '+' : '';
        return `<div class="bs-snapshot-diff-item"><span>${label}:</span> <span class="${cls}">${val.old || 0} → ${val.new || 0} (${sign}${val.delta})</span></div>`;
      }
      // 文本字段变化：截断展示，避免太长
      const oldText = val.old ? String(val.old).substring(0, 80) + (String(val.old).length > 80 ? '...' : '') : '-';
      const newText = val.new ? String(val.new).substring(0, 80) + (String(val.new).length > 80 ? '...' : '') : '-';
      return `<div class="bs-snapshot-diff-item"><span>${label}:</span> <span>${oldText} → ${newText}</span></div>`;
    }).join('');

    const hasAnyChange = diff && Object.keys(diff).length > 0;
    const title = hasAnyChange ? '变化:' : '无变化';
    return `<div class="bs-snapshot-diff"><div class="bs-snapshot-diff-title">${title}</div>${items}</div>`;
  };
})();
</script>
