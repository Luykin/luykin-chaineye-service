<div class="user-menu">
  <!-- 用户信息卡片 -->
  <div class="user-info">
    <div class="user-email">
      <svg class="email-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="2" y="5" width="20" height="14" rx="3"/>
        <path d="m2 8 9.5 6.5a2 2 0 0 0 2.5 0L22 8"/>
      </svg>
      <span class="email-text"><%= typeof user !== 'undefined' && user ? user.name : 'Admin' %></span>
    </div>
    <svg class="dropdown-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="m6 9 6 6 6-6"/>
    </svg>
  </div>
  
  <!-- 下拉菜单 -->
  <div class="user-dropdown">
    <div class="dropdown-header">
      <span class="dropdown-label">账号操作</span>
    </div>
    <a href="#" class="dropdown-item btn-change-pwd">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
      <span>修改密码</span>
    </a>
    <a href="#" class="dropdown-item btn-webauthn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        <path d="m9 12 2 2 4-4"/>
      </svg>
      <span>生物识别</span>
    </a>
    <div class="dropdown-divider"></div>
    <a href="#" class="dropdown-item dropdown-item-danger btn-logout">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/>
        <line x1="21" x2="9" y1="12" y2="12"/>
      </svg>
      <span>退出登录</span>
    </a>
  </div>
</div>

<style>
  /* 用户菜单容器 */
  .user-menu {
    position: relative;
  }
  
  /* 用户信息卡片 */
  .user-info {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 6px 6px 6px 6px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .user-info:hover {
    background: #f1f5f9;
    border-color: #cbd5e1;
  }
  
  /* 邮箱展示 */
  .user-email {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 4px;
  }
  
  .email-icon {
    width: 16px;
    height: 16px;
    color: #64748b;
    flex-shrink: 0;
  }
  
  .email-text {
    font-size: 13px;
    font-weight: 500;
    color: #334155;
    letter-spacing: 0.01em;
  }
  
  .user-info:hover .email-icon,
  .user-info:hover .email-text {
    color: #1e293b;
  }
  
  /* 下拉箭头 */
  .dropdown-chevron {
    width: 14px;
    height: 14px;
    color: #94a3b8;
    margin-left: 2px;
    margin-right: 2px;
    transition: transform 0.2s ease;
  }
  
  .user-menu:hover .dropdown-chevron {
    transform: rotate(180deg);
    color: #64748b;
  }
  
  /* 下拉菜单 */
  .user-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 200px;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    box-shadow: 0 10px 40px -10px rgba(0,0,0,0.15);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: all 0.2s ease;
    z-index: 1000;
    overflow: hidden;
  }
  
  .user-menu:hover .user-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  
  /* 下拉菜单头部 */
  .dropdown-header {
    padding: 12px 16px;
    background: #f8fafc;
    border-bottom: 1px solid #f1f5f9;
  }
  
  .dropdown-label {
    font-size: 11px;
    font-weight: 600;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  /* 下拉菜单项 */
  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    color: #475569;
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    transition: all 0.15s ease;
    border: none;
    background: none;
    width: 100%;
    cursor: pointer;
  }
  
  .dropdown-item:hover {
    background: #f8fafc;
    color: #1e293b;
  }
  
  .dropdown-item svg {
    width: 16px;
    height: 16px;
    color: #94a3b8;
    flex-shrink: 0;
  }
  
  .dropdown-item:hover svg {
    color: #64748b;
  }
  
  /* 危险操作 */
  .dropdown-item-danger {
    color: #ef4444;
  }
  
  .dropdown-item-danger:hover {
    background: #fef2f2;
    color: #dc2626;
  }
  
  .dropdown-item-danger svg {
    color: #f87171;
  }
  
  .dropdown-item-danger:hover svg {
    color: #ef4444;
  }
  
  /* 分隔线 */
  .dropdown-divider {
    height: 1px;
    background: #f1f5f9;
    margin: 8px 0;
  }
  
  /* 移动端适配 */
  @media (max-width: 768px) {
    .email-text {
      max-width: 120px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    
    .user-info {
      padding: 4px 8px;
    }
  }
</style>

<script src="/static/js/index.umd.min.js"></script>
<script>
  (function () {
    try {
      var logoutBtn = document.querySelector('.btn-logout');
      if (logoutBtn) logoutBtn.addEventListener('click', function (e) {
        e.preventDefault();
        fetch('/admin/logout', { method: 'POST', credentials: 'include' })
          .then(function () { window.location.href = '/admin/login'; })
          .catch(function () { window.location.reload(); });
      });

      // 创建简单的密码修改弹层
      var pwdBtn = document.querySelector('.btn-change-pwd');
      if (pwdBtn) {
        var modal = document.createElement('div');
        modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.35);display:none;align-items:center;justify-content:center;z-index:9999;';
        modal.innerHTML = '<div style="background:#fff;padding:16px 16px 12px;border-radius:10px;width:320px;box-shadow:0 10px 30px rgba(0,0,0,.2);">\
          <h3 style="margin:0 0 10px;font-size:16px;">修改管理员密码</h3>\
          <div style="font-size:12px;color:#666;margin-bottom:8px;">先发送验证码到当前登录邮箱，校验后可修改密码。</div>\
          <div style="margin-bottom:8px;display:flex;gap:8px;">\
            <button id="ap-send" style="flex:1;padding:8px 10px;background:#2563eb;color:#fff;border:none;border-radius:6px;">发送验证码</button>\
          </div>\
          <div style="margin-bottom:8px;">\
            <input id="ap-code" placeholder="验证码" style="width:100%;padding:8px 10px;border:1px solid #e5e7eb;border-radius:6px;box-sizing:border-box;" />\
          </div>\
          <div style="margin-bottom:8px;">\
            <input id="ap-password" type="password" placeholder="新密码（至少8位）" style="width:100%;padding:8px 10px;border:1px solid #e5e7eb;border-radius:6px;box-sizing:border-box;" />\
          </div>\
          <div style="display:flex;gap:8px;justify-content:flex-end;">\
            <button id="ap-cancel" style="padding:8px 10px;background:#e5e7eb;border:none;border-radius:6px;">取消</button>\
            <button id="ap-submit" style="padding:8px 10px;background:#16a34a;color:#fff;border:none;border-radius:6px;">确定修改</button>\
          </div>\
          <div id="ap-status" style="margin-top:8px;font-size:12px;color:#666;min-height:16px;"></div>\
        </div>';
        document.body.appendChild(modal);

        function setApStatus(msg, ok) {
          var el = document.getElementById('ap-status');
          if (!el) return;
          el.textContent = msg || '';
          el.style.color = ok ? '#16a34a' : '#dc2626';
        }

        pwdBtn.addEventListener('click', function(e){ e.preventDefault(); modal.style.display = 'flex'; setApStatus('', true); });
        modal.addEventListener('click', function(e){ if (e.target === modal) modal.style.display = 'none'; });
        modal.querySelector('#ap-cancel').addEventListener('click', function(){ modal.style.display = 'none'; });
        modal.querySelector('#ap-send').addEventListener('click', function(){
          var sendBtn = this;
          var submitBtn = modal.querySelector('#ap-submit');
          var originalText = sendBtn.textContent;
          
          sendBtn.disabled = true;
          sendBtn.style.opacity = '0.6';
          sendBtn.style.cursor = 'not-allowed';
          sendBtn.textContent = '发送中...';
          submitBtn.disabled = true;
          submitBtn.style.opacity = '0.6';
          submitBtn.style.cursor = 'not-allowed';
          
          setApStatus('发送中...', true);
          
          fetch('/admin/password/send-code', { method:'POST', credentials:'include' })
            .then(function(r){ return r.json(); })
            .then(function(d){
              if(!d.success) throw new Error(d.error||'发送失败');
              setApStatus('验证码已发送，请查收邮箱', true);
            })
            .catch(function(err){
              setApStatus(err.message||'发送失败', false);
            })
            .finally(function(){
              sendBtn.disabled = false;
              sendBtn.style.opacity = '1';
              sendBtn.style.cursor = 'pointer';
              sendBtn.textContent = originalText;
              submitBtn.disabled = false;
              submitBtn.style.opacity = '1';
              submitBtn.style.cursor = 'pointer';
            });
        });
        modal.querySelector('#ap-submit').addEventListener('click', function(){
          var submitBtn = this;
          var sendBtn = modal.querySelector('#ap-send');
          var code = document.getElementById('ap-code').value.trim();
          var pwd = document.getElementById('ap-password').value;
          var hasLetter = /[A-Za-z]/.test(pwd);
          var hasDigit = /\d/.test(pwd);
          
          if (!code || !pwd || pwd.length < 8 || !hasLetter || !hasDigit) { 
            setApStatus('请输入验证码，并设置至少8位且包含字母和数字的新密码', false); 
            return; 
          }
          
          var originalText = submitBtn.textContent;
          
          submitBtn.disabled = true;
          submitBtn.style.opacity = '0.6';
          submitBtn.style.cursor = 'not-allowed';
          submitBtn.textContent = '提交中...';
          sendBtn.disabled = true;
          sendBtn.style.opacity = '0.6';
          sendBtn.style.cursor = 'not-allowed';
          
          setApStatus('提交中...', true);
          
          fetch('/admin/password/reset', { method:'POST', headers:{'Content-Type':'application/json'}, credentials:'include', body: JSON.stringify({ code: code, newPassword: pwd }) })
            .then(function(r){ return r.json(); })
            .then(function(d){
              if(!d.success) throw new Error(d.error||'重置失败');
              setApStatus('密码已修改，请重新登录', true);
              setTimeout(function(){
                window.location.href = '/admin/login';
              }, 2000);
            })
            .catch(function(err){
              setApStatus(err.message||'重置失败', false);
              submitBtn.disabled = false;
              submitBtn.style.opacity = '1';
              submitBtn.style.cursor = 'pointer';
              submitBtn.textContent = originalText;
              sendBtn.disabled = false;
              sendBtn.style.opacity = '1';
              sendBtn.style.cursor = 'pointer';
            });
        });
      }

      // ========== WebAuthn 管理弹层 ==========
      var waBtn = document.querySelector('.btn-webauthn');
      if (waBtn) {
        var waModal = document.createElement('div');
        waModal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.35);display:none;align-items:center;justify-content:center;z-index:9999;';
        waModal.innerHTML = '\
        <div style="background:#fff;padding:16px;border-radius:10px;width:360px;max-width:90vw;box-shadow:0 10px 30px rgba(0,0,0,.2);">\
          <h3 style="margin:0 0 10px;font-size:16px;">生物识别登录</h3>\
          <div style="font-size:12px;color:#666;margin-bottom:10px;">在本设备添加或删除指纹/FaceID 登录凭证。</div>\
          <div style="display:flex;gap:8px;margin-bottom:10px;">\
            <input id="wa-nickname" placeholder="设备备注（可选）" style="flex:1;padding:8px 10px;border:1px solid #e5e7eb;border-radius:6px;" />\
            <button id="wa-add" style="padding:8px 10px;background:#2563eb;color:#fff;border:none;border-radius:6px;">添加</button>\
          </div>\
          <div id="wa-status" style="font-size:12px;min-height:16px;margin-bottom:6px;color:#666;"></div>\
          <div id="wa-list" style="max-height:220px;overflow:auto;border:1px solid #eee;border-radius:6px;padding:6px;">加载中...</div>\
          <div style="margin-top:10px;text-align:right;">\
            <button id="wa-close" style="padding:8px 10px;background:#e5e7eb;border:none;border-radius:6px;">关闭</button>\
          </div>\
        </div>';
        document.body.appendChild(waModal);

        function setWaStatus(msg, ok){
          var el = document.getElementById('wa-status');
          if(!el) return;
          el.textContent = msg||'';
          el.style.color = ok ? '#16a34a' : '#dc2626';
        }

        async function reloadCreds(){
          try{
            setWaStatus('加载中...', true);
            var res = await fetch('/admin/webauthn/credentials', { credentials:'include' });
            var data = await res.json();
            var list = document.getElementById('wa-list');
            if(!data.success){ list.textContent = data.error||'获取失败'; setWaStatus('', true); return; }
            if(!data.credentials || !data.credentials.length){ list.textContent = '尚未添加任何设备'; setWaStatus('', true); return; }
            list.innerHTML = '';
            data.credentials.forEach(function(c){
              var row = document.createElement('div');
              row.style.cssText = 'display:flex;align-items:center;justify-content:space-between;padding:6px;border-bottom:1px solid #f1f5f9;';
              var name = c.nickname || '设备 #' + c.id;
              var info = (c.lastUsedAt ? (' 最近使用: ' + new Date(c.lastUsedAt).toLocaleString()) : '');
              row.innerHTML = '<div style="font-size:13px;color:#334155;">'+ name +'<span style="color:#64748b;">'+ info +'</span></div>'+
                              '<button data-id="'+c.id+'" class="wa-del" style="padding:6px 8px;background:#ef4444;color:#fff;border:none;border-radius:6px;">删除</button>';
              list.appendChild(row);
            });
            Array.prototype.forEach.call(list.querySelectorAll('.wa-del'), function(btn){
              btn.addEventListener('click', async function(){
                var id = this.getAttribute('data-id');
                if (!id) return;
                if (!confirm('确认删除该设备？')) return;
                try{
                  var r = await fetch('/admin/webauthn/credentials/'+id, { method:'DELETE', credentials:'include' });
                  var d = await r.json();
                  if(!d.success) throw new Error(d.error||'删除失败');
                  setWaStatus('已删除', true);
                  reloadCreds();
                }catch(ex){ setWaStatus(ex.message||'删除失败', false); }
              });
            });
            setWaStatus('', true);
          }catch(ex){ setWaStatus(ex.message||'加载失败', false); }
        }

        waBtn.addEventListener('click', function(e){ e.preventDefault(); waModal.style.display='flex'; reloadCreds(); });
        waModal.addEventListener('click', function(e){ if(e.target===waModal) waModal.style.display='none'; });
        waModal.querySelector('#wa-close').addEventListener('click', function(){ waModal.style.display='none'; });

        waModal.querySelector('#wa-add').addEventListener('click', async function(){
          try{
            setWaStatus('准备注册...', true);
            var optRes = await fetch('/admin/webauthn/registration/options', { credentials:'include' });
            var optData = await optRes.json();
            if(!optData.success) throw new Error(optData.error||'获取注册参数失败');
            var attResp = await window.SimpleWebAuthnBrowser.startRegistration(optData.options);
            var nickname = (document.getElementById('wa-nickname').value||'').trim();
            var vRes = await fetch('/admin/webauthn/registration/verify', {
              method:'POST',
              headers:{ 'Content-Type':'application/json' },
              credentials:'include',
              body: JSON.stringify({ attResp: attResp, nickname: nickname })
            });
            var vData = await vRes.json();
            if(!vData.success) throw new Error(vData.error||'注册失败');
            setWaStatus('已添加此设备，可用于登录二次验证', true);
            document.getElementById('wa-nickname').value='';
            reloadCreds();
          }catch(ex){ setWaStatus(ex.message||'注册失败', false); }
        });
      }
    } catch (e) {
      // no-op
    }
  })();
</script>
