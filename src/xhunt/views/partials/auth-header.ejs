<div class="auth-info">
  <span>
    🔐 已认证访问 - <%= typeof user !== 'undefined' && user ? user.name : '用户' %>
  </span>
  <a href="#" class="logout-btn pwd-btn" style="margin-right:12px;">修改管理员密码</a>
  <a href="#" class="logout-btn">退出登录</a>
</div>
<script>
  (function () {
    try {
      var logoutBtn = document.querySelector('.logout-btn:not(.pwd-btn)');
      if (logoutBtn) logoutBtn.addEventListener('click', function (e) {
        e.preventDefault();
        fetch('/admin/logout', { method: 'POST', credentials: 'include' })
          .then(function () { window.location.href = '/admin/login'; })
          .catch(function () { window.location.reload(); });
      });

      // 创建简单的密码修改弹层
      var pwdBtn = document.querySelector('.pwd-btn');
      if (pwdBtn) {
        var modal = document.createElement('div');
        modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.35);display:none;align-items:center;justify-content:center;z-index:9999;';
        modal.innerHTML = '<div style="background:#fff;padding:16px 16px 12px;border-radius:10px;width:320px;box-shadow:0 10px 30px rgba(0,0,0,.2);">\
          <h3 style="margin:0 0 10px;font-size:16px;">修改管理员密码</h3>\
          <div style="font-size:12px;color:#666;margin-bottom:8px;">先发送验证码到当前登录邮箱，校验后可修改密码。</div>\
          <div style="margin-bottom:8px;display:flex;gap:8px;">\
            <button id="ap-send" style="flex:1;padding:8px 10px;background:#2563eb;color:#fff;border:none;border-radius:6px;">发送验证码</button>\
          </div>\
          <div style="margin-bottom:8px;">\
            <input id="ap-code" placeholder="验证码" style="width:100%;padding:8px 10px;border:1px solid #e5e7eb;border-radius:6px;box-sizing:border-box;" />\
          </div>\
          <div style="margin-bottom:8px;">\
            <input id="ap-password" type="password" placeholder="新密码（至少8位）" style="width:100%;padding:8px 10px;border:1px solid #e5e7eb;border-radius:6px;box-sizing:border-box;" />\
          </div>\
          <div style="display:flex;gap:8px;justify-content:flex-end;">\
            <button id="ap-cancel" style="padding:8px 10px;background:#e5e7eb;border:none;border-radius:6px;">取消</button>\
            <button id="ap-submit" style="padding:8px 10px;background:#16a34a;color:#fff;border:none;border-radius:6px;">确定修改</button>\
          </div>\
          <div id="ap-status" style="margin-top:8px;font-size:12px;color:#666;min-height:16px;"></div>\
        </div>';
        document.body.appendChild(modal);

        function setApStatus(msg, ok) {
          var el = document.getElementById('ap-status');
          if (!el) return;
          el.textContent = msg || '';
          el.style.color = ok ? '#16a34a' : '#dc2626';
        }

        pwdBtn.addEventListener('click', function(e){ e.preventDefault(); modal.style.display = 'flex'; setApStatus('', true); });
        modal.addEventListener('click', function(e){ if (e.target === modal) modal.style.display = 'none'; });
        modal.querySelector('#ap-cancel').addEventListener('click', function(){ modal.style.display = 'none'; });
        modal.querySelector('#ap-send').addEventListener('click', function(){
          setApStatus('发送中...', true);
          fetch('/admin/password/send-code', { method:'POST', credentials:'include' })
            .then(function(r){ return r.json(); })
            .then(function(d){ if(!d.success) throw new Error(d.error||'发送失败'); setApStatus('验证码已发送，请查收邮箱', true); })
            .catch(function(err){ setApStatus(err.message||'发送失败', false); });
        });
        modal.querySelector('#ap-submit').addEventListener('click', function(){
          var code = document.getElementById('ap-code').value.trim();
          var pwd = document.getElementById('ap-password').value;
          var hasLetter = /[A-Za-z]/.test(pwd);
          var hasDigit = /\d/.test(pwd);
          if (!code || !pwd || pwd.length < 8 || !hasLetter || !hasDigit) { setApStatus('请输入验证码，并设置至少8位且包含字母和数字的新密码', false); return; }
          setApStatus('提交中...', true);
          fetch('/admin/password/reset', { method:'POST', headers:{'Content-Type':'application/json'}, credentials:'include', body: JSON.stringify({ code: code, newPassword: pwd }) })
            .then(function(r){ return r.json(); })
            .then(function(d){ if(!d.success) throw new Error(d.error||'重置失败'); setApStatus('密码已修改，请重新登录', true); })
            .catch(function(err){ setApStatus(err.message||'重置失败', false); });
        });
      }
    } catch (e) {
      // no-op
    }
  })();
  </script>
