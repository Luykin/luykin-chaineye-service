<script>
  document.addEventListener("DOMContentLoaded", () => {
    let scatterChart, metricsChart, errorsScatterChart;
    let isInitialized = false;
    let queueTimer = null;
    let rawTraceData = []; // Cache for the original trace data
    
    // 延迟获取 Tab 元素（因为 Tab 是动态渲染的）
    function getPerfMonitorTab() {
      return document.querySelector('.tab-btn[data-tab="perf-monitor"]');
    }

    const filterByUserIdInput = document.getElementById("filter-by-userid");
    const filterByPathInput = document.getElementById("filter-by-path");
    const filterByIpInput = document.getElementById("filter-by-ip");
    const applyFiltersBtn = document.getElementById("apply-filters-btn");
    const clearFiltersBtn = document.getElementById("clear-filters-btn");

    const startTimePicker = document.getElementById("start-time-picker");
    const endTimePicker = document.getElementById("end-time-picker");
    const queryTimeRangeBtn = document.getElementById("query-time-range-btn");
    const resetToLatestBtn = document.getElementById("reset-to-latest-btn");
    const modal = document.getElementById("trace-detail-modal");
    const closeModalButton = modal.querySelector(".close-button");
    const traceDetailContent = document.getElementById("trace-detail-content");
    const searchInput = document.getElementById("search-request-id");
    const searchButton = document.getElementById("search-request-btn");
    const latencyRankingBody = document.getElementById("latency-ranking-body");
    const urlStatsModal = document.getElementById("url-stats-modal");
    const urlStatsModalCloseBtn = urlStatsModal.querySelector(".close-button");
    const urlStatsModalTitle = document.getElementById("url-stats-modal-title");
    const urlStatsModalContent = document.getElementById(
      "url-stats-modal-content"
    );

    // Security Scan Elements
    const securityScanSection = document.getElementById(
      "security-scan-section"
    );
    const securityScanIpInput = document.getElementById(
      "security-scan-ip-input"
    );
    const securityScanBtn = document.getElementById("security-scan-btn");
    const securityScanResults = document.getElementById(
      "security-scan-results"
    );
    const securityScanStatus = document.getElementById("security-scan-status");

    const normalizationRules = [
      {
        pattern: /^\/api\/xhunt\/notes\/([^\/]+)$/,
        replacement: "/api/xhunt/notes/*",
      },
      {
        pattern: /^\/api\/xhunt\/reviews\/([^\/]+)$/,
        replacement: "/api/xhunt/reviews/*",
      },
      {
        pattern: /^\/api\/xhunt\/reviews\/([^\/]+)\/comments$/,
        replacement: "/api/xhunt/reviews/*/comments",
      },
      {
        pattern: /^\/api\/xhunt\/rootdata\/relationship\/([^\/]+)$/,
        replacement: "/api/xhunt/rootdata/relationship/*",
      },
    ];

    function normalizeUrlPath(pathname) {
      for (const rule of normalizationRules) {
        if (rule.pattern.test(pathname)) {
          return rule.replacement;
        }
      }
      return pathname;
    }

    function escapeRegExp(string) {
      return string.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    }

    function escapeHtml(str) {
      return String(str || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function highlightText(text, query) {
      if (!query) return text;
      const escapedText = text
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");
      const regex = new RegExp(`(${escapeRegExp(query)})`, "gi");
      return escapedText.replace(
        regex,
        '<span class="log-highlight">$1</span>'
      );
    }

    function ensureEchartsReady() {
      if (typeof echarts !== "undefined") return true;
      const err = `图表库 (ECharts) 未加载。请确认 /static/js/echarts.min.js 可访问。`;
      document.getElementById(
        "scatter-chart-container"
      ).innerHTML = `<div style="padding:40px;color:#ef4444;text-align:center">${err}</div>`;
      document.getElementById(
        "metrics-chart-container"
      ).innerHTML = `<div style="padding:40px;color:#ef4444;text-align:center">${err}</div>`;
      return false;
    }

    function initResize() {
      window.addEventListener("resize", () => {
        if (scatterChart) scatterChart.resize();
        if (metricsChart) metricsChart.resize();
        if (errorsScatterChart) errorsScatterChart.resize();
      });
    }

    async function fetchQueueStatus() {
      const badge = document.getElementById("queue-status-badge");
      if (!badge) return;
      try {
        const response = await fetch("/api/stats/perf/queue-status");
        if (!response.ok) {
          badge.textContent = "队列积压: 获取失败";
          badge.style.color = "#ef4444";
          return;
        }
        const data = await response.json();
        const queueLength = data.queueLength || 0;
        badge.textContent = `队列积压: ${queueLength}`;
        if (queueLength > 10000) badge.style.color = "#ef4444";
        else if (queueLength > 1000) badge.style.color = "#f97316";
        else badge.style.color = "#16a34a";
      } catch (e) {
        badge.textContent = "队列积压: 错误";
        badge.style.color = "#ef4444";
      }
    }

    function toDatetimeLocalValue(ts) {
      const d = new Date(ts);
      const pad = (n) => String(n).padStart(2, "0");
      // datetime-local 用本地时间，不带时区
      return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(
        d.getDate()
      )}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
    }

    function formatDateTime(value) {
      if (!value) return "-";
      try {
        const date = new Date(value);
        return date.toLocaleString("zh-CN", {
          hour12: false,
          year: "numeric",
          month: "2-digit",
          day: "2-digit",
          hour: "2-digit",
          minute: "2-digit",
          second: "2-digit",
        });
      } catch (e) {
        return String(value);
      }
    }

    function parsePickerToMs(pickerEl) {
      const v = (pickerEl?.value || "").trim();
      if (!v) return NaN;
      const ms = new Date(v).getTime();
      return ms;
    }

    function validateAndGetRangeMs() {
      const startMs = parsePickerToMs(startTimePicker);
      const endMs = parsePickerToMs(endTimePicker);
      if (!Number.isFinite(startMs) || !Number.isFinite(endMs)) {
        alert("请输入有效的开始/结束时间");
        return null;
      }
      if (endMs <= startMs) {
        alert("结束时间必须大于开始时间");
        return null;
      }
      const spanMs = endMs - startMs;
      const maxSpanMs = 30 * 60 * 1000;
      if (spanMs > maxSpanMs) {
        alert("时间跨度不能超过 30 分钟");
        return null;
      }
      const now = Date.now();
      const minAllowed = now - 48 * 3600 * 1000;
      if (startMs < minAllowed || endMs < minAllowed) {
        alert("仅支持查询最近 48 小时内的数据");
        return null;
      }
      return { startMs, endMs };
    }

    function setKpiCardsLoading(isLoading) {
      const ids = [
        "kpi-total-requests",
        "kpi-rps",
        "kpi-avg-duration",
        "kpi-p95",
      ];
      ids.forEach((id) => {
        const el = document.getElementById(id);
        if (!el) return;
        el.style.opacity = isLoading ? "0.55" : "1";
      });
    }

    async function fetchKpis(startMs, endMs) {
      try {
        setKpiCardsLoading(true);
        const response = await fetch(
          `/api/stats/perf/kpis?startTime=${startMs}&endTime=${endMs}`
        );
        if (!response.ok)
          throw new Error(`HTTP ${response.status}: ${await response.text()}`);
        const data = await response.json();
        updateKpiCards(data, startMs, endMs);
      } catch (e) {
        console.error(e);
        updateKpiCards(null);
      } finally {
        setKpiCardsLoading(false);
      }
    }

    function formatNumber(n, digits = 2) {
      if (!Number.isFinite(n)) return "--";
      return n.toLocaleString(undefined, {
        minimumFractionDigits: digits,
        maximumFractionDigits: digits,
      });
    }

    function formatInt(n) {
      if (!Number.isFinite(n)) return "--";
      return Math.round(n).toLocaleString();
    }

    function formatMs(n) {
      if (!Number.isFinite(n)) return "--";
      if (n >= 1000) return `${formatNumber(n / 1000, 2)} s`;
      return `${formatNumber(n, 0)} ms`;
    }

    function updateKpiCards(kpis, startMs, endMs) {
      const elTotal = document.getElementById("kpi-total-requests");
      const elRps = document.getElementById("kpi-rps");
      const elAvg = document.getElementById("kpi-avg-duration");
      const elP95 = document.getElementById("kpi-p95");

      if (!kpis) {
        if (elTotal) elTotal.textContent = "--";
        if (elRps) elRps.textContent = "--";
        if (elAvg) elAvg.textContent = "--";
        if (elP95) elP95.textContent = "--";
        return;
      }

      const cur = kpis.current || kpis.cur || kpis.data || kpis;

      const curRequests = Number(
        cur.totalRequests ??
          cur.requestCount ??
          cur.totalCount ??
          cur.total ??
          cur.count
      );
      const curAvg = Number(
        cur.avgDurationMs ?? cur.avg_duration_ms ?? cur.avgMs ?? cur.avg
      );
      const curP95 = Number(
        cur.p95DurationMs ?? cur.p95_duration_ms ?? cur.p95Ms ?? cur.p95
      );

      const spanSec = (endMs - startMs) / 1000;
      const curRps = spanSec > 0 ? curRequests / spanSec : 0;

      if (elTotal) elTotal.textContent = formatInt(curRequests);
      if (elRps) elRps.textContent = formatNumber(curRps, 2);
      if (elAvg) elAvg.textContent = formatMs(curAvg);
      if (elP95) elP95.textContent = formatMs(curP95);
    }

    async function fetchData(startMs, endMs) {
      if (!isInitialized) return;
      showLoading(scatterChart, "正在加载追踪数据...");
      showLoading(metricsChart, "正在加载聚合指标...");
      await Promise.all([
        fetchTraces(startMs, endMs),
        fetchMetrics(startMs, endMs),
        fetchKpis(startMs, endMs),
      ]);
    }

    async function fetchTraces(startMs, endMs) {
      try {
        const response = await fetch(
          `/api/stats/perf/traces?startTime=${startMs}&endTime=${endMs}&limit=15000`
        );
        if (!response.ok)
          throw new Error(`HTTP ${response.status}: ${await response.text()}`);
        const data = await response.json();
        rawTraceData = data; // cache
        renderScatterChart(data);
      } catch (e) {
        console.error(e);
        showError(scatterChart, "加载追踪数据失败");
      }
    }

    async function fetchMetrics(startMs, endMs) {
      try {
        const spanMs = endMs - startMs;
        const spanSecs = spanMs / 1000;
        // 30分钟窗口内，60秒粒度足够
        const intervalSecs = spanSecs > 2 * 3600 ? 300 : 60;
        const response = await fetch(
          `/api/stats/perf/metrics?startTime=${startMs}&endTime=${endMs}&intervalSecs=${intervalSecs}`
        );
        if (!response.ok)
          throw new Error(`HTTP ${response.status}: ${await response.text()}`);
        const data = await response.json();
        renderMetricsChart(data, intervalSecs, startMs, endMs);
      } catch (e) {
        console.error(e);
        showError(metricsChart, "加载聚合指标失败");
      }
    }

    async function fetchTraceDetailExact(requestId) {
      const response = await fetch(
        `/api/stats/perf/trace/${encodeURIComponent(requestId)}`
      );
      if (!response.ok)
        throw new Error(`HTTP ${response.status}: ${await response.text()}`);
      return response.json();
    }

    async function fetchTraceDetailByPrefix(prefix) {
      // 在当前已加载的点中前缀匹配（最多 2000），避免依赖旧 hours 逻辑
      const points = Array.isArray(rawTraceData)
        ? rawTraceData.slice(-2000)
        : [];
      const match = points.find((p) => (p.requestId || "").startsWith(prefix));
      if (!match) return null;
      if (!match.hasDetail) {
        return {
          __noDetail: true,
          requestId: match.requestId,
          durationMs: match.durationMs,
          status: match.status,
          ts: match.ts,
        };
      }
      return fetchTraceDetailExact(match.requestId);
    }

    // legacy fetch removed

    function setSecurityScanUi({ visible, ip, statusText, html, loading }) {
      if (!securityScanSection) return;
      securityScanSection.style.display = visible ? "block" : "none";
      if (securityScanIpInput && typeof ip === "string")
        securityScanIpInput.value = ip;
      if (securityScanStatus) securityScanStatus.textContent = statusText || "";
      if (securityScanBtn) securityScanBtn.disabled = !!loading;
      if (securityScanResults && typeof html === "string") {
        securityScanResults.innerHTML = html;
      }
    }

    function renderSecurityScanResult(records, scannedIp) {
      const ip = escapeHtml(scannedIp || "");
      if (!records || records.length === 0) {
        return `<div style="color:#065f46; font-weight:800;">No risk found.</div>`;
      }

      const items = records
        .map((r) => {
          const t = escapeHtml(formatDateTime(r.createdAt));
          const reason = escapeHtml(r.reasonCode || "-");
          const path = escapeHtml((r.requestPath || "-").slice(0, 120));
          const detail = escapeHtml((r.errorDetail || "-").slice(0, 160));
          return `
            <div style="padding:8px 10px; border-bottom:1px solid #e5e7eb;">
              <div style="display:flex; justify-content:space-between; gap:10px; flex-wrap:wrap;">
                <div style="font-weight:700; color:#111827;">${reason}</div>
                <div style="color:#6b7280;">${t}</div>
              </div>
              <div style="margin-top:4px; color:#111827; font-family:monospace; font-size:12px;">${path}</div>
              <div style="margin-top:4px; color:#6b7280;">${detail}</div>
            </div>
          `;
        })
        .join("");

      return `
        <div style="display:flex; align-items:center; justify-content:space-between; gap:10px; margin-bottom:8px;">
          <div style="color:#b91c1c; font-weight:800;">Risk detected</div>
          <div style="color:#6b7280; font-size:12px;">ip=${ip} · showing ${records.length}</div>
        </div>
        <div style="border:1px solid #e5e7eb; border-radius:10px; overflow:hidden; background:#fff;">
          ${items}
        </div>
      `;
    }

    function getClientIpFromTrace(ipData) {
      if (!ipData) return "";
      // Case 1: It's already the clientIp string
      if (typeof ipData === "string" && !ipData.startsWith("{")) {
        return ipData;
      }
      // Case 2: It's an object
      if (typeof ipData === "object" && ipData !== null) {
        return ipData.clientIp || "";
      }
      // Case 3: It's a JSON string
      if (typeof ipData === "string" && ipData.startsWith("{")) {
        try {
          const parsed = JSON.parse(ipData);
          return parsed.clientIp || "";
        } catch (e) {
          // Not a valid JSON, return the string itself as a fallback
          return ipData;
        }
      }
      return "";
    }

    async function runSecurityScan(ip) {
      const trimmed = String(getClientIpFromTrace(ip) || "").trim();
      if (!trimmed) {
        setSecurityScanUi({
          visible: true,
          ip: "",
          statusText: "",
          html: `<div style="color:#92400e; font-weight:700;">Please input an IP.</div>`,
          loading: false,
        });
        return;
      }

      setSecurityScanUi({
        visible: true,
        ip: trimmed,
        statusText: "Scanning...",
        html: `<div style="color:#6b7280;">Loading...</div>`,
        loading: true,
      });

      try {
        const params = new URLSearchParams();
        params.set("ip", trimmed);
        params.set("page", "1");
        params.set("limit", "10");
        const resp = await fetch(
          `/api/xhunt/stats/security-violations?${params.toString()}`
        );
        const json = await resp.json();
        if (!resp.ok || !json.success) {
          throw new Error(json.error || `HTTP ${resp.status}`);
        }
        const records = Array.isArray(json.data) ? json.data : [];
        const html = renderSecurityScanResult(records, trimmed);
        setSecurityScanUi({
          visible: true,
          ip: trimmed,
          statusText: records.length ? `Risk: ${records.length}` : "No risk",
          html,
          loading: false,
        });
      } catch (e) {
        setSecurityScanUi({
          visible: true,
          ip: trimmed,
          statusText: "",
          html: `<div style="color:#991b1b; font-weight:700;">Scan failed: ${escapeHtml(
            e.message || "unknown"
          )}</div>`,
          loading: false,
        });
      }
    }

    if (securityScanBtn) {
      securityScanBtn.addEventListener("click", () => {
        runSecurityScan(securityScanIpInput?.value);
      });
    }
    if (securityScanIpInput) {
      securityScanIpInput.addEventListener("keypress", (e) => {
        if (e.key === "Enter") {
          runSecurityScan(securityScanIpInput.value);
        }
      });
    }

    async function openTraceDetail(requestIdOrPrefix) {
      const logSearchSection = document.getElementById("log-search-section");
      const searchLogsBtn = document.getElementById("search-logs-btn");
      const logResultsContainer = document.getElementById(
        "log-results-container"
      );

      logSearchSection.style.display = "none";
      logResultsContainer.innerHTML = "";
      traceDetailContent.textContent = "Loading...";
      modal.style.display = "block";

      let traceData = null;

      try {
        try {
          traceData = await fetchTraceDetailExact(requestIdOrPrefix);
        } catch (e) {
          traceData = await fetchTraceDetailByPrefix(requestIdOrPrefix);
        }

        if (!traceData) {
          traceDetailContent.textContent = `未找到匹配的 requestId（当前时间范围内）: ${requestIdOrPrefix}`;
          return;
        }

        // Always display the data, add a message if no detail is available.
        const displayData = traceData.__noDetail
          ? {
              message:
                "该请求点没有采样到详情（hasDetail=false），仅展示基础信息",
              ...traceData,
            }
          : traceData;
        traceDetailContent.textContent = JSON.stringify(displayData, null, 2);

        // 初始化安全扫描：默认填充本次 trace 的 ip（优先 traceData.ip）
        if (securityScanSection) {
          const ipFromTrace = getClientIpFromTrace(traceData && traceData.ip);
          setSecurityScanUi({
            visible: true,
            ip: ipFromTrace,
            statusText: "",
            html: `<div style="color:#6b7280; font-weight:700;">Not scanned yet. Click "Scan" to check.</div>`,
            loading: false,
          });
        }

        if (traceData.requestId) {
          logSearchSection.style.display = "block";
          const newSearchLogsBtn = searchLogsBtn.cloneNode(true);
          searchLogsBtn.parentNode.replaceChild(
            newSearchLogsBtn,
            searchLogsBtn
          );
          newSearchLogsBtn.addEventListener("click", () => {
            searchLogsForRequestId(traceData.requestId);
          });
        }
      } catch (err) {
        console.error(err);
        traceDetailContent.textContent = `Failed to load details.\n${err.message}`;
      }
    }

    function renderScatterChart(data) {
      const errorData5xx = [];
      const errorData4xx = [];
      const normalData = [];

      data.forEach((d) => {
        const point = {
          // Encode all necessary data into the value array
          // [0: ts, 1: duration, 2: status, 3: hasDetail, 4: requestId, 5: path, 6: userId, 7: ip]
          value: [
            d.ts,
            d.durationMs,
            d.status,
            d.hasDetail ? 1 : 0,
            d.requestId,
            d.path,
            d.userId,
            d.ip,
          ],
        };

        if (d.status >= 500) {
          errorData5xx.push(point);
        } else if (d.status >= 400) {
          errorData4xx.push(point);
        } else {
          normalData.push(point);
        }
      });

      calculateAndRenderLatencyRanking(data);
      scatterChart.hideLoading();
      const now = Date.now();
      const tenMinutesAgo = now - 10 * 60 * 1000;

      scatterChart.setOption(
        {
          legend: {
            data: ["Server Errors (5xx)", "Client Errors (4xx)", "Success"],
            right: 10,
          },
          tooltip: {
            trigger: "item",
            formatter: (params) => {
              const v = params.value;
              // [0: ts, 1: duration, 2: status, 3: hasDetail, 4: requestId, 5: path, 6: userId, 7: ip]
              const path = v[5] || "";
              const truncatedPath =
                path.length > 65 ? path.substring(0, 65) + "..." : path;
              const pathLine = `<br/><b>path:</b> <span title="${path}">${truncatedPath}</span>`;
              const userIdLine = `<br/><b>userId:</b> ${v[6] || ""}`;
              const ip = v[7] || "";
              const maxIpLen = 40;
              const ipTruncated =
                ip.length > maxIpLen ? ip.slice(0, maxIpLen) + "..." : ip;
              const ipLine = ip
                ? `<br/><b>ip:</b> <span title="${escapeHtml(ip)}">${escapeHtml(
                    ipTruncated
                  )}</span>`
                : "";
              const hasDetail = v[3] === 1;

              return `<b>requestId:</b> ${
                v[4]
              }${pathLine}${userIdLine}${ipLine}<br/><b>status:</b> ${
                v[2]
              }<br/><b>duration:</b> ${Number(v[1]).toFixed(2)} ms<br/>${
                hasDetail ? "<b>点击查看详情</b>" : "无详情（未采样）"
              }`;
            },
          },
          xAxis: { type: "time", name: "Time", scale: true },
          yAxis: { type: "value", name: "Duration (ms)", scale: true },
          visualMap: {
            type: "piecewise",
            orient: "horizontal",
            left: "center",
            top: 10,
            pieces: [
              { min: 6000, label: "> 6s", color: "#fca5a5" },
              { min: 3000, max: 6000, label: "3s - 6s", color: "#f97316" },
              { min: 500, max: 3000, label: "500ms - 3s", color: "#86efac" },
              { max: 500, label: "<= 500ms", color: "#22c55e" },
            ],
            dimension: 1, // Map to the second dimension (durationMs)
            seriesIndex: 2, // Apply only to the 'Success' series
            inRange: {
              color: ["#22c55e", "#86efac", "#f97316", "#fca5a5"],
            },
          },
          series: [
            {
              name: "Server Errors (5xx)",
              type: "effectScatter",
              symbolSize: 12,
              color: "#b91c1c",
              data: errorData5xx,
              z: 10,
            },
            {
              name: "Client Errors (4xx)",
              type: "scatter", // Changed from effectScatter
              symbolSize: 10, // Slightly larger than normal
              color: "#144e33", // 4xx
              data: errorData4xx,
              z: 9,
            },
            {
              name: "Success",
              type: "scatter",
              symbolSize: 8,
              data: normalData,
              z: 5,
            },
          ],
          dataZoom: [
            { type: "inside", disabled: true },
            {
              type: "slider",
              startValue: tenMinutesAgo,
              endValue: now,
            },
          ],
          grid: { left: 50, right: 24, top: 60, bottom: 80 },
        },
        true
      );
    }

    function renderMetricsChart(data, intervalSecs) {
      metricsChart.hideLoading();
      // 默认 dataZoom 范围：优先使用当前选择的时间窗口，否则最近10分钟
      const nowTs = Date.now();
      const range = validateAndGetRangeMs();
      const zoomStart = range ? range.startMs : nowTs - 10 * 60 * 1000;
      const zoomEnd = range ? range.endMs : nowTs;
      metricsChart.setOption(
        {
          tooltip: { trigger: "axis" },
          legend: { data: ["Avg Duration (ms)", "RPS"] },
          xAxis: { type: "time" },
          yAxis: [
            { type: "value", name: "Duration (ms)", scale: true },
            { type: "value", name: "RPS" },
          ],
          series: [
            {
              name: "Avg Duration (ms)",
              type: "line",
              showSymbol: false,
              yAxisIndex: 0,
              data: data.map((d) => [
                d.timestamp,
                Number(d.avg_duration_ms).toFixed(2),
              ]),
            },
            {
              name: "RPS",
              type: "line",
              showSymbol: false,
              yAxisIndex: 1,
              data: data.map((d) => [
                d.timestamp,
                (d.request_count / intervalSecs).toFixed(2),
              ]),
            },
          ],
          dataZoom: [
            { type: "inside", disabled: true },
            {
              type: "slider",
              startValue: zoomStart,
              endValue: zoomEnd,
            },
          ],
          grid: { left: 50, right: 24, top: 20, bottom: 60 },
        },
        true
      );
    }

    function showLoading(chartInstance, text) {
      chartInstance.showLoading("default", {
        text,
        maskColor: "rgba(255, 255, 255, 0.1)",
      });
    }

    function showError(chartInstance, message) {
      chartInstance.hideLoading();
      chartInstance.setOption(
        {
          title: {
            text: message,
            left: "center",
            top: "center",
            textStyle: { color: "#ef4444" },
          },
        },
        true
      );
    }

    let errorsScatterLoaded = false;

    async function fetchErrorTraces() {
      // 不受时间范围控制：拉取 Redis 保留窗口内所有 500+ 点
      const response = await fetch("/api/stats/perf/errors?maxScan=100000");
      if (!response.ok)
        throw new Error(`HTTP ${response.status}: ${await response.text()}`);
      return response.json();
    }

    function renderErrorsScatterChart(data) {
      if (!errorsScatterChart) {
        const container = document.getElementById(
          "errors-scatter-chart-container"
        );
        if (!container) return;
        errorsScatterChart = echarts.init(container);
      }

      const points = Array.isArray(data) ? data : [];
      const seriesData = points.map((d) => ({
        // [0: ts, 1: duration, 2: status, 3: requestId, 4: path, 5: userId]
        value: [d.ts, d.durationMs, d.status, d.requestId, d.path, d.userId],
      }));

      errorsScatterChart.setOption(
        {
          tooltip: {
            trigger: "item",
            formatter: (params) => {
              const v = params.value;
              const path = v[4] || "";
              const truncatedPath =
                path.length > 65 ? path.substring(0, 65) + "..." : path;
              return `<b>requestId:</b> ${
                v[3]
              }<br/><b>path:</b> <span title="${path}">${truncatedPath}</span><br/><b>status:</b> ${
                v[2]
              }<br/><b>duration:</b> ${Number(v[1]).toFixed(
                2
              )} ms<br/><b>点击查看详情</b>`;
            },
          },
          xAxis: { type: "time", name: "Time", scale: true },
          yAxis: { type: "value", name: "Duration (ms)", scale: true },
          series: [
            {
              name: "5xx",
              type: "scatter",
              symbolSize: 8,
              itemStyle: { color: "#ef4444" },
              data: seriesData,
            },
          ],
          grid: { left: 50, right: 24, top: 20, bottom: 60 },
        },
        true
      );

      // 绑定点击：打开详情
      errorsScatterChart.off("click");
      errorsScatterChart.on("click", (params) => {
        const requestId = params?.value?.[3];
        if (!requestId) return;
        openTraceDetail(requestId);
      });
    }

    async function reloadErrorsScatter() {
      const details = document.getElementById("error-scatter-details");
      if (!details || !details.open) return;

      try {
        renderErrorsScatterChart([]);
        showLoading(errorsScatterChart, "正在加载 500+ 错误点... (全量)");
        const data = await fetchErrorTraces();
        errorsScatterChart.hideLoading();
        renderErrorsScatterChart(data);
        errorsScatterLoaded = true;
      } catch (e) {
        console.error(e);
        if (errorsScatterChart) {
          showError(errorsScatterChart, "加载 500+ 错误点失败");
        }
        errorsScatterLoaded = false;
      }
    }

    function bindErrorsScatterExpand() {
      const details = document.getElementById("error-scatter-details");
      const refreshBtn = document.getElementById("errors-scatter-refresh-btn");
      if (!details) return;

      // 刷新按钮：不触发 summary 的折叠
      if (refreshBtn) {
        refreshBtn.addEventListener("click", async (e) => {
          e.preventDefault();
          e.stopPropagation();

          // 确保已展开再刷新
          if (!details.open) {
            details.open = true;
          }

          refreshBtn.disabled = true;
          const oldText = refreshBtn.textContent;
          refreshBtn.textContent = "刷新中...";
          await reloadErrorsScatter();
          refreshBtn.textContent = oldText;
          refreshBtn.disabled = false;
        });
      }

      details.addEventListener("toggle", async () => {
        if (!details.open) return;

        // 展开后可能需要 resize
        setTimeout(() => {
          if (errorsScatterChart) errorsScatterChart.resize();
        }, 50);

        if (errorsScatterLoaded) return;
        await reloadErrorsScatter();
      });
    }

    function calculateAndRenderLatencyRanking(data) {
      if (!data || data.length === 0) {
        latencyRankingBody.innerHTML =
          '<tr><td colspan="5" style="text-align: center;">暂无数据</td></tr>';
        return;
      }

      const urlStats = {};

      data.forEach((item) => {
        const pathOnly = (item.path || "").split("?")[0];
        const normalizedPath = normalizeUrlPath(pathOnly);

        if (!urlStats[normalizedPath]) {
          urlStats[normalizedPath] = {
            durations: [],
            path: normalizedPath,
          };
        }
        urlStats[normalizedPath].durations.push(item.durationMs);
      });

      let rankingData = Object.values(urlStats).map((stat) => {
        const count = stat.durations.length;
        const sum = stat.durations.reduce((a, b) => a + b, 0);
        const avgDuration = sum / count;

        stat.durations.sort((a, b) => a - b);
        const maxDuration = stat.durations[count - 1];

        let medianDuration;
        if (count % 2 === 0) {
          const mid1 = stat.durations[count / 2 - 1];
          const mid2 = stat.durations[count / 2];
          medianDuration = (mid1 + mid2) / 2;
        } else {
          medianDuration = stat.durations[Math.floor(count / 2)];
        }

        return {
          path: stat.path,
          count: count,
          avgDuration: avgDuration,
          medianDuration: medianDuration,
          maxDuration: maxDuration,
        };
      });

      rankingData = rankingData.filter((item) => item.count >= 10);

      rankingData.sort((a, b) => b.avgDuration - a.avgDuration);

      latencyRankingBody.innerHTML = "";
      const top20 = rankingData.slice(0, 20);
      const totalRequests = data.length;

      top20.forEach((item) => {
        const row = document.createElement("tr");
        row.innerHTML = `
            <td>${item.path}</td>
            <td>${item.avgDuration.toFixed(2)}</td>
            <td>${item.medianDuration.toFixed(2)}</td>
            <td>${item.maxDuration.toFixed(2)}</td>
            <td>${item.count}</td>
        `;
        row.addEventListener("click", () => {
          const percentage = ((item.count / totalRequests) * 100).toFixed(2);
          urlStatsModalTitle.textContent = `接口详情: ${item.path}`;
          urlStatsModalContent.innerHTML = `
                <p><strong>请求数量:</strong> ${item.count}</p>
                <p><strong>请求占比:</strong> ${percentage}%</p>
            `;
          urlStatsModal.style.display = "block";
        });
        latencyRankingBody.appendChild(row);
      });
    }

    async function searchLogsForRequestId(requestId) {
      const logResultsContainer = document.getElementById(
        "log-results-container"
      );
      logResultsContainer.innerHTML = "<p>搜索中...</p>";

      try {
        const params = new URLSearchParams({
          query: requestId,
          contextLines: 3,
          limit: 20,
        });
        const response = await fetch(`/api/xhunt/stats/log-search?${params}`);
        const data = await response.json();

        if (!data.success) {
          logResultsContainer.innerHTML = `<p style="color: #ef4444;">搜索失败: ${
            data.error || "未知错误"
          }</p>`;
          return;
        }
        if (data.data.totalMatches === 0) {
          logResultsContainer.innerHTML =
            "<p>未找到与此 requestId 相关的日志记录。</p>";
          return;
        }

        logResultsContainer.innerHTML = "";
        data.data.results.forEach((result) => {
          const fileTitle = document.createElement("div");
          fileTitle.style.fontWeight = "bold";
          fileTitle.style.marginTop = "8px";
          fileTitle.textContent = `📄 ${result.file}`;
          logResultsContainer.appendChild(fileTitle);

          result.context.forEach((line) => {
            const lineDiv = document.createElement("div");
            lineDiv.className = "log-context-line";
            const highlightedContent = highlightText(line.content, requestId);
            lineDiv.innerHTML = `<span class="log-line-number">${line.lineNumber}:</span>${highlightedContent}`;
            logResultsContainer.appendChild(lineDiv);
          });
        });
      } catch (err) {
        console.error(err);
        logResultsContainer.innerHTML = `<p style="color: #ef4444;">日志搜索失败: ${err.message}</p>`;
      }
    }

    function applyFilters() {
      const userIdFilter = filterByUserIdInput.value.trim().toLowerCase();
      const pathFilter = filterByPathInput.value.trim().toLowerCase();
      const ipFilter = (filterByIpInput?.value || "").trim().toLowerCase();

      if (!userIdFilter && !pathFilter && !ipFilter) {
        renderScatterChart(rawTraceData);
        return;
      }

      const filteredData = rawTraceData.filter((item) => {
        const userIdMatch =
          !userIdFilter ||
          (item.userId && item.userId.toLowerCase().includes(userIdFilter));
        const pathMatch =
          !pathFilter ||
          (item.path && item.path.toLowerCase().includes(pathFilter));

        // perf 事件基础字段里我们记录的是 ip: clientIp（字符串）
        const ipVal = (item.ip || "").toString().toLowerCase();
        const ipMatch = !ipFilter || ipVal.includes(ipFilter);

        return userIdMatch && pathMatch && ipMatch;
      });

      renderScatterChart(filteredData);
    }

    function clearFilters() {
      filterByUserIdInput.value = "";
      filterByPathInput.value = "";
      if (filterByIpInput) filterByIpInput.value = "";
      renderScatterChart(rawTraceData);
    }

    // events
    applyFiltersBtn.addEventListener("click", applyFilters);
    clearFiltersBtn.addEventListener("click", clearFilters);

    queryTimeRangeBtn.addEventListener("click", async () => {
      const range = validateAndGetRangeMs();
      if (!range) return;
      await fetchData(range.startMs, range.endMs);
    });

    resetToLatestBtn.addEventListener("click", async () => {
      const now = Date.now();
      const start = now - 30 * 60 * 1000;
      startTimePicker.value = toDatetimeLocalValue(start);
      endTimePicker.value = toDatetimeLocalValue(now);
      await fetchData(start, now);
    });

    urlStatsModalCloseBtn.addEventListener("click", () => {
      urlStatsModal.style.display = "none";
    });

    closeModalButton.addEventListener(
      "click",
      () => (modal.style.display = "none")
    );
    window.addEventListener("click", (event) => {
      if (event.target === modal) modal.style.display = "none";
    });

    searchButton.addEventListener("click", () => {
      const q = searchInput.value.trim();
      if (q) openTraceDetail(q);
    });
    searchInput.addEventListener("keydown", (event) => {
      if (event.key === "Enter") {
        event.preventDefault();
        const q = searchInput.value.trim();
        if (q) openTraceDetail(q);
      }
    });

    function bindPointClick() {
      scatterChart.on("click", (params) => {
        // [0: ts, 1: duration, 2: status, 3: hasDetail, 4: requestId, ...]
        const requestId = params?.value?.[4];
        if (!requestId) return;
        openTraceDetail(requestId);
      });
    }

    function initializeCharts() {
      if (!ensureEchartsReady()) return;

      const scatterContainer = document.getElementById(
        "scatter-chart-container"
      );
      const metricsContainer = document.getElementById(
        "metrics-chart-container"
      );
      if (!scatterContainer || !metricsContainer) return;

      scatterChart = echarts.init(scatterContainer);
      metricsChart = echarts.init(metricsContainer);
      isInitialized = true;

      bindPointClick();
      bindErrorsScatterExpand(); // 绑定错误散点图展开事件
      initResize();

      // 默认选择最近30分钟
      const now = Date.now();
      const start = now - 30 * 60 * 1000;
      startTimePicker.value = toDatetimeLocalValue(start);
      endTimePicker.value = toDatetimeLocalValue(now);

      // 初次加载默认时间窗口
      fetchData(start, now);

      fetchQueueStatus();
      if (queueTimer) clearInterval(queueTimer);
      queueTimer = setInterval(fetchQueueStatus, 30000);
    }

    // 方式1: 监听 stats-tab-activated 事件（最可靠）
    document.addEventListener("stats-tab-activated", function(e) {
      if (e.detail && e.detail.tabId === "perf-monitor" && !isInitialized) {
        initializeCharts();
      }
    });

    // 方式2: MutationObserver 监听 class 变化（备用）
    const perfMonitorTab = getPerfMonitorTab();
    if (perfMonitorTab) {
      const observer = new MutationObserver(() => {
        if (perfMonitorTab.classList.contains("active") && !isInitialized) {
          initializeCharts();
        }
      });
      observer.observe(perfMonitorTab, {
        attributes: true,
        attributeFilter: ["class"],
      });

      // 如果当前已经激活，直接初始化
      if (perfMonitorTab.classList.contains("active") && !isInitialized) {
        initializeCharts();
      }
    }
  });
</script>
