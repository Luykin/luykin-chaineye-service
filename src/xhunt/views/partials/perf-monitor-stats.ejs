<style>
  .perf-monitor-container {
    width: 100%;
  }
  .perf-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: flex-end;
    margin-bottom: 12px;
  }
  .perf-controls .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .perf-controls label {
    font-size: 12px;
    color: #6b7280;
  }
  .perf-controls select,
  .perf-controls input {
    height: 34px;
    padding: 6px 10px;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    outline: none;
    font-size: 13px;
    background: #fff;
    min-width: 180px;
  }
  .perf-controls input {
    min-width: 260px;
  }
  .perf-controls button {
    height: 34px;
    padding: 0 12px;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    background: #111827;
    color: #fff;
    cursor: pointer;
    font-size: 13px;
  }
  .perf-controls button.secondary {
    background: #fff;
    color: #111827;
  }
  .perf-controls .badge {
    height: 34px;
    display: inline-flex;
    align-items: center;
    padding: 0 10px;
    border-radius: 999px;
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    font-size: 12px;
    color: #111827;
  }
  .perf-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }
  .perf-card {
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    background: #fff;
    padding: 12px;
  }
  .perf-card-title {
    font-weight: 700;
    font-size: 14px;
    margin-bottom: 10px;
    color: #111827;
  }
  .chart-container {
    width: 100%;
    height: 520px;
  }
  .perf-help {
    margin-top: 12px;
    color: #6b7280;
    font-size: 12px;
    line-height: 1.6;
  }
  .perf-help code {
    background: #f3f4f6;
    padding: 2px 6px;
    border-radius: 6px;
    color: #111827;
  }

  /* Styles for log search results */
  #log-search-section button {
    height: 34px;
    padding: 0 12px;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    background: #fff;
    color: #111827;
    cursor: pointer;
    font-size: 13px;
    transition: background-color 0.2s ease;
  }
  #log-search-section button:hover {
    background-color: #f3f4f6;
  }
  .log-context-line {
    margin: 2px 0;
    padding: 2px 0;
    white-space: pre-wrap; /* Allow wrapping */
    word-break: break-all; /* Break long words */
  }
  .log-line-number {
    color: #6c757d;
    margin-right: 10px;
    user-select: none;
  }
  .log-highlight {
    background: #fff3cd;
    padding: 1px 3px;
    border-radius: 3px;
    font-weight: 600;
    color: #111827;
  }
  /* Styles for latency ranking table */
  .latency-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .latency-table th,
  .latency-table td {
    padding: 8px 12px;
    text-align: left;
    border-bottom: 1px solid #e5e7eb;
  }
  .latency-table th {
    background-color: #f9fafb;
    font-weight: 600;
  }
  .latency-table tbody tr:hover {
    background-color: #f3f4f6;
    cursor: pointer;
  }
  .latency-table th:nth-child(n + 2),
  .latency-table td:nth-child(n + 2) {
    text-align: right;
    font-family: monospace;
  }

  /* Modal styles */
  .modal {
    display: none;
    position: fixed;
    z-index: 9999;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgba(17, 24, 39, 0.45);
  }
  .modal-content {
    background: #fff;
    border-radius: 12px;
    margin: 8vh auto;
    padding: 16px;
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.25);
    position: relative;
  }
  .modal .close-button {
    position: absolute;
    right: 14px;
    top: 10px;
    font-size: 20px;
    cursor: pointer;
    color: #6b7280;
  }
  #url-stats-modal-content p {
    font-size: 14px;
    margin: 8px 0;
    color: #374151;
  }
  #url-stats-modal-content strong {
    color: #111827;
    width: 90px;
    display: inline-block;
  }
</style>

<script src="/static/js/echarts.min.js"></script>

<div class="perf-monitor-container">
  <div class="perf-controls">
    <div class="field">
      <label for="perf-time-range">时间范围</label>
      <select id="perf-time-range">
        <option value="0.5" selected>最近 30 分钟</option>
        <option value="1">最近 1 小时</option>
        <option value="2">最近 2 小时</option>
        <option value="4">最近 4 小时</option>
        <option value="8">最近 8 小时</option>
        <option value="24">最近 1 天</option>
        <option value="48">最近 2 天</option>
      </select>
    </div>

    <div class="field">
      <label>&nbsp;</label>
      <button id="refresh-perf-data" class="secondary">刷新数据</button>
    </div>

    <div class="field">
      <label for="filter-by-userid">按 userId 筛选</label>
      <input
        id="filter-by-userid"
        type="text"
        placeholder="输入 userId (模糊匹配)"
      />
    </div>
    <div class="field">
      <label for="filter-by-path">按 path 筛选</label>
      <input
        id="filter-by-path"
        type="text"
        placeholder="输入 path (模糊匹配)"
      />
    </div>
    <div class="field">
      <label>&nbsp;</label>
      <button id="apply-filters-btn">筛选</button>
    </div>
    <div class="field">
      <label>&nbsp;</label>
      <button id="clear-filters-btn" class="secondary">清除</button>
    </div>

    <div class="field" style="flex: 1; min-width: 260px">
      <label for="search-request-id">按 requestId 查询详情</label>
      <input
        id="search-request-id"
        type="text"
        placeholder="支持前缀（例如 b6550afd-9194）"
      />
    </div>

    <div class="field">
      <label>&nbsp;</label>
      <button id="search-request-btn">搜索</button>
    </div>

    <div class="field">
      <label>&nbsp;</label>
      <span id="queue-status-badge" class="badge">队列积压: --</span>
    </div>
  </div>

  <div class="perf-layout">
    <div class="perf-card">
      <div class="perf-card-title">请求耗时分布（散点图）</div>
      <div id="scatter-chart-container" class="chart-container"></div>
    </div>

    <div class="perf-card">
      <div class="perf-card-title">平均耗时与吞吐量（折线图）</div>
      <div
        id="metrics-chart-container"
        class="chart-container"
        style="height: 360px"
      ></div>
    </div>

    <div class="perf-card">
      <div class="perf-card-title">接口平均耗时排行榜 (Top 20)</div>
      <div
        id="latency-ranking-container"
        style="max-height: 400px; overflow-y: auto"
      >
        <table class="latency-table">
          <thead>
            <tr>
              <th>接口路径</th>
              <th>平均延迟 (ms)</th>
              <th>中位延迟 (ms)</th>
              <th>最大延迟 (ms)</th>
              <th>请求数</th>
            </tr>
          </thead>
          <tbody id="latency-ranking-body">
            <!-- Ranking will be injected here -->
          </tbody>
        </table>
      </div>
    </div>

    <div class="perf-card">
      <div class="perf-card-title">指标说明</div>
      <div class="perf-help">
        <div>
          <b>RPS</b>（Requests Per Second）：每秒请求数，反映系统吞吐量。
        </div>
        <div>
          <b>Avg Duration</b
          >：统计窗口内的平均耗时（毫秒）。窗口大小由后端聚合（通常 60s 或
          300s）。
        </div>
        <div>
          <b>队列积压</b>：<code>perf:events:queue</code>
          当前长度。持续升高表示后台消费速度不足。
        </div>
        <div style="margin-top: 8px">
          <b>颜色规则</b>：绿色 &lt;= 500ms；橙色 &gt; 500ms；浅红 &gt;
          5s；深红=HTTP 4xx/5xx。
        </div>
        <div style="margin-top: 8px">
          <b>为什么搜索可能有延迟？</b> requestId
          的详情写入是“采集→队列→单例处理器消费→落库”的异步流程，通常会有 1~5
          秒延迟（队列积压时可能更久）。
        </div>
      </div>
    </div>
  </div>

  <div
    id="trace-detail-modal"
    class="modal"
    style="
      display: none;
      position: fixed;
      z-index: 9999;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background: rgba(17, 24, 39, 0.45);
    "
  >
    <div
      class="modal-content"
      style="
        background: #fff;
        border-radius: 12px;
        max-width: 880px;
        width: calc(100% - 48px);
        margin: 8vh auto;
        padding: 16px 16px;
        box-shadow: 0 12px 48px rgba(0, 0, 0, 0.25);
        position: relative;
      "
    >
      <span
        class="close-button"
        style="
          position: absolute;
          right: 14px;
          top: 10px;
          font-size: 20px;
          cursor: pointer;
          color: #6b7280;
        "
        >&times;</span
      >
      <h3 style="margin: 0 0 10px; font-size: 16px">请求追踪详情</h3>
      <pre
        id="trace-detail-content"
        style="
          max-height: 60vh;
          overflow: auto;
          background: #0b1220;
          color: #e5e7eb;
          padding: 12px;
          border-radius: 10px;
          font-size: 12px;
          line-height: 1.45;
        "
      ></pre>

      <div id="log-search-section" style="display: none; margin-top: 12px">
        <button id="search-logs-btn" style="margin-bottom: 8px">
          🔍 搜索相关日志
        </button>
        <div
          id="log-results-container"
          style="
            max-height: 40vh;
            overflow: auto;
            background: #f3f4f6;
            padding: 12px;
            border-radius: 8px;
            font-family: 'Courier New', monospace;
            font-size: 12px;
            line-height: 1.5;
            color: #111827;
          "
        >
          <!-- Log results will be injected here -->
        </div>
      </div>
    </div>
  </div>

  <div id="url-stats-modal" class="modal">
    <div class="modal-content" style="max-width: 600px">
      <span class="close-button">&times;</span>
      <h3 id="url-stats-modal-title" style="margin: 0 0 10px; font-size: 16px">
        接口请求详情
      </h3>
      <div id="url-stats-modal-content"></div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const perfMonitorTab = document.querySelector(
      '.tab-btn[data-tab="perf-monitor"]'
    );
    if (!perfMonitorTab) return;

    let scatterChart, metricsChart;
    let isInitialized = false;
    let queueTimer = null;
    let rawTraceData = []; // Cache for the original trace data

    const filterByUserIdInput = document.getElementById("filter-by-userid");
    const filterByPathInput = document.getElementById("filter-by-path");
    const applyFiltersBtn = document.getElementById("apply-filters-btn");
    const clearFiltersBtn = document.getElementById("clear-filters-btn");

    const timeRangeSelector = document.getElementById("perf-time-range");
    const refreshButton = document.getElementById("refresh-perf-data");
    const modal = document.getElementById("trace-detail-modal");
    const closeModalButton = modal.querySelector(".close-button");
    const traceDetailContent = document.getElementById("trace-detail-content");
    const searchInput = document.getElementById("search-request-id");
    const searchButton = document.getElementById("search-request-btn");
    const latencyRankingBody = document.getElementById("latency-ranking-body");
    const urlStatsModal = document.getElementById("url-stats-modal");
    const urlStatsModalCloseBtn = urlStatsModal.querySelector(".close-button");
    const urlStatsModalTitle = document.getElementById("url-stats-modal-title");
    const urlStatsModalContent = document.getElementById(
      "url-stats-modal-content"
    );

    const normalizationRules = [
      {
        pattern: /^\/api\/xhunt\/notes\/([^\/]+)$/,
        replacement: "/api/xhunt/notes/*",
      },
      {
        pattern: /^\/api\/xhunt\/reviews\/([^\/]+)$/,
        replacement: "/api/xhunt/reviews/*",
      },
      {
        pattern: /^\/api\/xhunt\/reviews\/([^\/]+)\/comments$/,
        replacement: "/api/xhunt/reviews/*/comments",
      },
      {
        pattern: /^\/api\/xhunt\/rootdata\/relationship\/([^\/]+)$/,
        replacement: "/api/xhunt/rootdata/relationship/*",
      },
    ];

    function normalizeUrlPath(pathname) {
      for (const rule of normalizationRules) {
        if (rule.pattern.test(pathname)) {
          return rule.replacement;
        }
      }
      return pathname;
    }

    function escapeRegExp(string) {
      return string.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    }

    function highlightText(text, query) {
      if (!query) return text;
      const escapedText = text
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");
      const regex = new RegExp(`(${escapeRegExp(query)})`, "gi");
      return escapedText.replace(
        regex,
        '<span class="log-highlight">$1</span>'
      );
    }

    function ensureEchartsReady() {
      if (typeof echarts !== "undefined") return true;
      const err = `图表库 (ECharts) 未加载。请确认 /static/js/echarts.min.js 可访问。`;
      document.getElementById(
        "scatter-chart-container"
      ).innerHTML = `<div style="padding:40px;color:#ef4444;text-align:center">${err}</div>`;
      document.getElementById(
        "metrics-chart-container"
      ).innerHTML = `<div style="padding:40px;color:#ef4444;text-align:center">${err}</div>`;
      return false;
    }

    function initResize() {
      window.addEventListener("resize", () => {
        if (scatterChart) scatterChart.resize();
        if (metricsChart) metricsChart.resize();
      });
    }

    async function fetchQueueStatus() {
      const badge = document.getElementById("queue-status-badge");
      if (!badge) return;
      try {
        const response = await fetch("/api/stats/perf/queue-status");
        if (!response.ok) {
          badge.textContent = "队列积压: 获取失败";
          badge.style.color = "#ef4444";
          return;
        }
        const data = await response.json();
        const queueLength = data.queueLength || 0;
        badge.textContent = `队列积压: ${queueLength}`;
        if (queueLength > 10000) badge.style.color = "#ef4444";
        else if (queueLength > 1000) badge.style.color = "#f97316";
        else badge.style.color = "#16a34a";
      } catch (e) {
        badge.textContent = "队列积压: 错误";
        badge.style.color = "#ef4444";
      }
    }

    async function fetchData() {
      if (!isInitialized) return;
      showLoading(scatterChart, "正在加载追踪数据...");
      showLoading(metricsChart, "正在加载聚合指标...");
      const hours = parseFloat(timeRangeSelector.value);
      await Promise.all([fetchTraces(hours), fetchMetrics(hours)]);
    }

    async function fetchTraces(hours) {
      try {
        const response = await fetch(
          `/api/stats/perf/traces?hours=${hours}&limit=10000`
        );
        if (!response.ok)
          throw new Error(`HTTP ${response.status}: ${await response.text()}`);
        const data = await response.json();
        rawTraceData = data; // cache
        renderScatterChart(data);
      } catch (e) {
        console.error(e);
        showError(scatterChart, "加载追踪数据失败");
      }
    }

    async function fetchMetrics(hours) {
      try {
        const intervalSecs = hours > 2 ? 300 : 60;
        const response = await fetch(
          `/api/stats/perf/metrics?rangeHours=${hours}&intervalSecs=${intervalSecs}`
        );
        if (!response.ok)
          throw new Error(`HTTP ${response.status}: ${await response.text()}`);
        const data = await response.json();
        renderMetricsChart(data, intervalSecs);
      } catch (e) {
        console.error(e);
        showError(metricsChart, "加载聚合指标失败");
      }
    }

    async function fetchTraceDetailExact(requestId) {
      const response = await fetch(
        `/api/stats/perf/trace/${encodeURIComponent(requestId)}`
      );
      if (!response.ok)
        throw new Error(`HTTP ${response.status}: ${await response.text()}`);
      return response.json();
    }

    async function fetchTraceDetailByPrefix(prefix) {
      const hours = parseFloat(timeRangeSelector.value);
      const response = await fetch(
        `/api/stats/perf/traces?hours=${hours}&limit=2000`
      );
      if (!response.ok)
        throw new Error(`HTTP ${response.status}: ${await response.text()}`);
      const points = await response.json();
      const match = points.find((p) => (p.requestId || "").startsWith(prefix));
      if (!match) return null;
      if (!match.hasDetail) {
        return {
          __noDetail: true,
          requestId: match.requestId,
          durationMs: match.durationMs,
          status: match.status,
          ts: match.ts,
        };
      }
      return fetchTraceDetailExact(match.requestId);
    }

    async function openTraceDetail(requestIdOrPrefix) {
      const logSearchSection = document.getElementById("log-search-section");
      const searchLogsBtn = document.getElementById("search-logs-btn");
      const logResultsContainer = document.getElementById(
        "log-results-container"
      );

      logSearchSection.style.display = "none";
      logResultsContainer.innerHTML = "";
      traceDetailContent.textContent = "Loading...";
      modal.style.display = "block";

      let traceData = null;

      try {
        try {
          traceData = await fetchTraceDetailExact(requestIdOrPrefix);
        } catch (e) {
          traceData = await fetchTraceDetailByPrefix(requestIdOrPrefix);
        }

        if (!traceData) {
          traceDetailContent.textContent = `未找到匹配的 requestId（当前时间范围内）: ${requestIdOrPrefix}`;
          return;
        }

        if (traceData.__noDetail) {
          traceDetailContent.textContent = JSON.stringify(
            {
              message:
                "该请求点没有采样到详情（hasDetail=false），仅展示基础信息",
              ...traceData,
            },
            null,
            2
          );
        } else {
          traceDetailContent.textContent = JSON.stringify(traceData, null, 2);
        }

        if (traceData.requestId) {
          logSearchSection.style.display = "block";
          const newSearchLogsBtn = searchLogsBtn.cloneNode(true);
          searchLogsBtn.parentNode.replaceChild(
            newSearchLogsBtn,
            searchLogsBtn
          );
          newSearchLogsBtn.addEventListener("click", () => {
            searchLogsForRequestId(traceData.requestId);
          });
        }
      } catch (err) {
        console.error(err);
        traceDetailContent.textContent = `Failed to load details.\n${err.message}`;
      }
    }

    function renderScatterChart(data) {
      const getColor = (item) => {
        if (item.durationMs > 5000) return "#fca5a5"; // light red
        if (item.durationMs > 500) return "#f97316"; // orange
        return "#22c55e"; // green
      };

      const errorData = [];
      const normalData = [];

      data.forEach((d) => {
        const point = {
          ...d,
          value: [d.ts, d.durationMs],
        };
        if (d.status >= 500) {
          errorData.push(point);
        } else {
          point.itemStyle = { color: getColor(d) };
          normalData.push(point);
        }
      });

      calculateAndRenderLatencyRanking(data);
      scatterChart.hideLoading();
      const now = Date.now();
      const tenMinutesAgo = now - 10 * 60 * 1000;

      scatterChart.setOption(
        {
          tooltip: {
            trigger: "item",
            formatter: (params) => {
              const d = params.data;
              const path = d?.path || "";
              const truncatedPath =
                path.length > 60 ? path.substring(0, 60) + "..." : path;
              const pathLine = `<br/><b>path:</b> <span title="${path}">${truncatedPath}</span>`;
              const userIdLine = `<br/><b>userId:</b> ${d?.userId || ""}`;
              return `<b>requestId:</b> ${
                d.requestId
              }${pathLine}${userIdLine}<br/><b>status:</b> ${
                d.status
              }<br/><b>duration:</b> ${Number(d.durationMs).toFixed(
                2
              )} ms<br/>${
                d.hasDetail ? "<b>点击查看详情</b>" : "无详情（未采样）"
              }`;
            },
          },
          xAxis: { type: "time", name: "Time", scale: true },
          yAxis: { type: "value", name: "Duration (ms)", scale: true },
          series: [
            {
              name: "Errors",
              type: "effectScatter",
              symbolSize: 12,
              color: "#b91c1c",
              data: errorData,
              z: 10,
            },
            {
              name: "Success",
              type: "scatter",
              symbolSize: 8,
              data: normalData,
              z: 5,
            },
          ],
          dataZoom: [
            { type: "inside", disabled: true },
            {
              type: "slider",
              startValue: tenMinutesAgo,
              endValue: now,
            },
          ],
          grid: { left: 50, right: 24, top: 20, bottom: 80 },
        },
        true
      );
    }

    function renderMetricsChart(data, intervalSecs) {
      metricsChart.hideLoading();
      metricsChart.setOption(
        {
          tooltip: { trigger: "axis" },
          legend: { data: ["Avg Duration (ms)", "RPS"] },
          xAxis: { type: "time" },
          yAxis: [
            { type: "value", name: "Duration (ms)", scale: true },
            { type: "value", name: "RPS" },
          ],
          series: [
            {
              name: "Avg Duration (ms)",
              type: "line",
              showSymbol: false,
              yAxisIndex: 0,
              data: data.map((d) => [
                d.timestamp,
                Number(d.avg_duration_ms).toFixed(2),
              ]),
            },
            {
              name: "RPS",
              type: "line",
              showSymbol: false,
              yAxisIndex: 1,
              data: data.map((d) => [
                d.timestamp,
                (d.request_count / intervalSecs).toFixed(2),
              ]),
            },
          ],
          dataZoom: [{ type: "inside", disabled: true }, { type: "slider" }],
          grid: { left: 50, right: 24, top: 20, bottom: 60 },
        },
        true
      );
    }

    function showLoading(chartInstance, text) {
      chartInstance.showLoading("default", {
        text,
        maskColor: "rgba(255, 255, 255, 0.1)",
      });
    }

    function showError(chartInstance, message) {
      chartInstance.hideLoading();
      chartInstance.setOption(
        {
          title: {
            text: message,
            left: "center",
            top: "center",
            textStyle: { color: "#ef4444" },
          },
        },
        true
      );
    }

    function calculateAndRenderLatencyRanking(data) {
      if (!data || data.length === 0) {
        latencyRankingBody.innerHTML =
          '<tr><td colspan="5" style="text-align: center;">暂无数据</td></tr>';
        return;
      }

      const urlStats = {};

      data.forEach((item) => {
        const pathOnly = (item.path || "").split("?")[0];
        const normalizedPath = normalizeUrlPath(pathOnly);

        if (!urlStats[normalizedPath]) {
          urlStats[normalizedPath] = {
            durations: [],
            path: normalizedPath,
          };
        }
        urlStats[normalizedPath].durations.push(item.durationMs);
      });

      const rankingData = Object.values(urlStats).map((stat) => {
        const count = stat.durations.length;
        const sum = stat.durations.reduce((a, b) => a + b, 0);
        const avgDuration = sum / count;

        stat.durations.sort((a, b) => a - b);
        const maxDuration = stat.durations[count - 1];

        let medianDuration;
        if (count % 2 === 0) {
          const mid1 = stat.durations[count / 2 - 1];
          const mid2 = stat.durations[count / 2];
          medianDuration = (mid1 + mid2) / 2;
        } else {
          medianDuration = stat.durations[Math.floor(count / 2)];
        }

        return {
          path: stat.path,
          count: count,
          avgDuration: avgDuration,
          medianDuration: medianDuration,
          maxDuration: maxDuration,
        };
      });

      rankingData.sort((a, b) => b.avgDuration - a.avgDuration);

      latencyRankingBody.innerHTML = "";
      const top20 = rankingData.slice(0, 20);
      const totalRequests = data.length;

      top20.forEach((item) => {
        const row = document.createElement("tr");
        row.innerHTML = `
            <td>${item.path}</td>
            <td>${item.avgDuration.toFixed(2)}</td>
            <td>${item.medianDuration.toFixed(2)}</td>
            <td>${item.maxDuration.toFixed(2)}</td>
            <td>${item.count}</td>
        `;
        row.addEventListener("click", () => {
          const percentage = ((item.count / totalRequests) * 100).toFixed(2);
          urlStatsModalTitle.textContent = `接口详情: ${item.path}`;
          urlStatsModalContent.innerHTML = `
                <p><strong>请求数量:</strong> ${item.count}</p>
                <p><strong>请求占比:</strong> ${percentage}%</p>
            `;
          urlStatsModal.style.display = "block";
        });
        latencyRankingBody.appendChild(row);
      });
    }

    async function searchLogsForRequestId(requestId) {
      const logResultsContainer = document.getElementById(
        "log-results-container"
      );
      logResultsContainer.innerHTML = "<p>搜索中...</p>";

      try {
        const params = new URLSearchParams({
          query: requestId,
          contextLines: 3,
          limit: 20,
        });
        const response = await fetch(`/api/xhunt/stats/log-search?${params}`);
        const data = await response.json();

        if (!data.success) {
          logResultsContainer.innerHTML = `<p style="color: #ef4444;">搜索失败: ${
            data.error || "未知错误"
          }</p>`;
          return;
        }
        if (data.data.totalMatches === 0) {
          logResultsContainer.innerHTML =
            "<p>未找到与此 requestId 相关的日志记录。</p>";
          return;
        }

        logResultsContainer.innerHTML = "";
        data.data.results.forEach((result) => {
          const fileTitle = document.createElement("div");
          fileTitle.style.fontWeight = "bold";
          fileTitle.style.marginTop = "8px";
          fileTitle.textContent = `📄 ${result.file}`;
          logResultsContainer.appendChild(fileTitle);

          result.context.forEach((line) => {
            const lineDiv = document.createElement("div");
            lineDiv.className = "log-context-line";
            const highlightedContent = highlightText(line.content, requestId);
            lineDiv.innerHTML = `<span class="log-line-number">${line.lineNumber}:</span>${highlightedContent}`;
            logResultsContainer.appendChild(lineDiv);
          });
        });
      } catch (err) {
        console.error(err);
        logResultsContainer.innerHTML = `<p style="color: #ef4444;">日志搜索失败: ${err.message}</p>`;
      }
    }

    function applyFilters() {
      const userIdFilter = filterByUserIdInput.value.trim().toLowerCase();
      const pathFilter = filterByPathInput.value.trim().toLowerCase();

      if (!userIdFilter && !pathFilter) {
        renderScatterChart(rawTraceData);
        return;
      }

      const filteredData = rawTraceData.filter((item) => {
        const userIdMatch =
          !userIdFilter ||
          (item.userId && item.userId.toLowerCase().includes(userIdFilter));
        const pathMatch =
          !pathFilter ||
          (item.path && item.path.toLowerCase().includes(pathFilter));
        return userIdMatch && pathMatch;
      });

      renderScatterChart(filteredData);
    }

    function clearFilters() {
      filterByUserIdInput.value = "";
      filterByPathInput.value = "";
      renderScatterChart(rawTraceData);
    }

    // events
    timeRangeSelector.addEventListener("change", fetchData);
    refreshButton.addEventListener("click", fetchData);
    applyFiltersBtn.addEventListener("click", applyFilters);
    clearFiltersBtn.addEventListener("click", clearFilters);

    urlStatsModalCloseBtn.addEventListener("click", () => {
      urlStatsModal.style.display = "none";
    });

    closeModalButton.addEventListener(
      "click",
      () => (modal.style.display = "none")
    );
    window.addEventListener("click", (event) => {
      if (event.target === modal) modal.style.display = "none";
    });

    searchButton.addEventListener("click", () => {
      const q = searchInput.value.trim();
      if (q) openTraceDetail(q);
    });
    searchInput.addEventListener("keydown", (event) => {
      if (event.key === "Enter") {
        event.preventDefault();
        const q = searchInput.value.trim();
        if (q) openTraceDetail(q);
      }
    });

    function bindPointClick() {
      scatterChart.on("click", (params) => {
        if (!params?.data?.requestId) return;
        openTraceDetail(params.data.requestId);
      });
    }

    function initializeCharts() {
      if (!ensureEchartsReady()) return;

      const scatterContainer = document.getElementById(
        "scatter-chart-container"
      );
      const metricsContainer = document.getElementById(
        "metrics-chart-container"
      );
      if (!scatterContainer || !metricsContainer) return;

      scatterChart = echarts.init(scatterContainer);
      metricsChart = echarts.init(metricsContainer);
      isInitialized = true;

      bindPointClick();
      initResize();

      fetchData();

      fetchQueueStatus();
      if (queueTimer) clearInterval(queueTimer);
      queueTimer = setInterval(fetchQueueStatus, 30000);
    }

    const observer = new MutationObserver(() => {
      if (perfMonitorTab.classList.contains("active") && !isInitialized) {
        initializeCharts();
      }
    });
    observer.observe(perfMonitorTab, {
      attributes: true,
      attributeFilter: ["class"],
    });

    if (perfMonitorTab.classList.contains("active") && !isInitialized) {
      initializeCharts();
    }
  });
</script>
