<style>
  .perf-monitor-container {
    width: 100%;
  }
  .perf-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: flex-end;
    margin-bottom: 12px;
  }
  .perf-controls .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .perf-controls label {
    font-size: 12px;
    color: #6b7280;
  }
  .perf-controls select,
  .perf-controls input {
    height: 34px;
    padding: 6px 10px;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    outline: none;
    font-size: 13px;
    background: #fff;
    min-width: 180px;
  }
  .perf-controls input {
    min-width: 260px;
  }
  .perf-controls button {
    height: 34px;
    padding: 0 12px;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    background: #111827;
    color: #fff;
    cursor: pointer;
    font-size: 13px;
  }
  .perf-controls button.secondary {
    background: #fff;
    color: #111827;
  }
  .perf-controls .badge {
    height: 34px;
    display: inline-flex;
    align-items: center;
    padding: 0 10px;
    border-radius: 999px;
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    font-size: 12px;
    color: #111827;
  }
  .perf-kpis {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin: 12px 0 14px;
  }
  @media (max-width: 1100px) {
    .perf-kpis {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 640px) {
    .perf-kpis {
      grid-template-columns: 1fr;
    }
  }

  .kpi-card {
    border: 1px solid rgba(229, 231, 235, 0.9);
    border-radius: 14px;
    background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
    padding: 12px;
    box-shadow: 0 1px 2px rgba(16, 24, 40, 0.06);
    position: relative;
    overflow: hidden;
  }
  .kpi-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      120px 90px at 20% 0%,
      rgba(59, 130, 246, 0.1),
      transparent 60%
    );
    pointer-events: none;
  }
  .kpi-label {
    font-size: 12px;
    color: #6b7280;
    letter-spacing: 0.2px;
  }
  .kpi-value {
    margin-top: 8px;
    font-size: 22px;
    font-weight: 800;
    color: #111827;
    line-height: 1.2;
  }

  .perf-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }
  .perf-card {
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    background: #fff;
    padding: 12px;
  }
  .perf-card-title {
    font-weight: 700;
    font-size: 14px;
    margin-bottom: 10px;
    color: #111827;
  }
  .chart-container {
    width: 100%;
    height: 520px;
  }
  .perf-help {
    margin-top: 12px;
    color: #6b7280;
    font-size: 12px;
    line-height: 1.6;
  }
  .perf-help code {
    background: #f3f4f6;
    padding: 2px 6px;
    border-radius: 6px;
    color: #111827;
  }

  /* Styles for log search results */
  #log-search-section button {
    height: 34px;
    padding: 0 12px;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    background: #fff;
    color: #111827;
    cursor: pointer;
    font-size: 13px;
    transition: background-color 0.2s ease;
  }
  #log-search-section button:hover {
    background-color: #f3f4f6;
  }
  .log-context-line {
    margin: 2px 0;
    padding: 2px 0;
    white-space: pre-wrap; /* Allow wrapping */
    word-break: break-all; /* Break long words */
  }
  .log-line-number {
    color: #6c757d;
    margin-right: 10px;
    user-select: none;
  }
  .log-highlight {
    background: #fff3cd;
    padding: 1px 3px;
    border-radius: 3px;
    font-weight: 600;
    color: #111827;
  }
  /* Styles for latency ranking table */
  .latency-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .latency-table th,
  .latency-table td {
    padding: 8px 12px;
    text-align: left;
    border-bottom: 1px solid #e5e7eb;
  }
  .latency-table th {
    background-color: #f9fafb;
    font-weight: 600;
  }
  .latency-table tbody tr:hover {
    background-color: #f3f4f6;
    cursor: pointer;
  }
  .latency-table th:nth-child(n + 2),
  .latency-table td:nth-child(n + 2) {
    text-align: right;
    font-family: monospace;
  }

  /* Modal styles */
  .modal {
    display: none;
    position: fixed;
    z-index: 9999;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgba(17, 24, 39, 0.45);
  }
  .modal-content {
    background: #fff;
    border-radius: 12px;
    margin: 8vh auto;
    padding: 16px;
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.25);
    position: relative;
    max-height: 85vh; /* 限制最大高度 */
    overflow-y: auto; /* 内容超长时可滚动 */
  }
  .modal .close-button {
    position: absolute;
    right: 14px;
    top: 10px;
    font-size: 20px;
    cursor: pointer;
    color: #6b7280;
  }
  #url-stats-modal-content p {
    font-size: 14px;
    margin: 8px 0;
    color: #374151;
  }
  #url-stats-modal-content strong {
    color: #111827;
    width: 90px;
    display: inline-block;
  }
</style>

<script src="/static/js/echarts.min.js"></script>

<div class="perf-monitor-container">
  <div class="perf-controls">
