<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>XHunt 数据统计</title>
    <link
      rel="icon"
      type="image/jpeg"
      href="https://oaewcvliegq6wyvp.public.blob.vercel-storage.com/xhunt_new.jpg"
    />
    <link rel="stylesheet" href="/static/css/stats.css" />
  </head>
  <body>
    <div class="container">
      <!-- 认证信息 -->
      <%- include('partials/auth-header', { formatDateTime }) %>

      <!-- 快捷链接 -->
      <%- include('partials/quick-links') %>

      <!-- 页面标题 -->
      <div class="header">
        <h1>📊 XHunt 数据统计</h1>
        <p>实时产品数据监控面板 - <%= formatDateTime() %></p>
      </div>

      <!-- Tab 导航 -->
      <div class="tab-container">
        <div class="tab-nav">
          <button class="tab-btn active" data-tab="overview">
            📊 数据概览
          </button>
          <!-- <button class="tab-btn" data-tab="tags">🏷️ 标签统计</button> -->
          <!-- <button class="tab-btn" data-tab="users">👑 用户排行</button> -->
          <button class="tab-btn" data-tab="dau-details">📱 日活详情</button>
          <button class="tab-btn" data-tab="online-users">🟢 在线用户</button>
          <button class="tab-btn" data-tab="data-export">📤 数据导出</button>
          <button class="tab-btn" data-tab="log-search">🔍 日志搜索</button>
          <!--                <button class="tab-btn" data-tab="kol-tag">🔥 有灵魂的KOL</button>-->
          <!--                <button class="tab-btn" data-tab="specific-users">🎯 特定用户</button>-->
        </div>

        <!-- Tab 内容 -->
        <div class="tab-content">
          <!-- 数据概览 Tab -->
          <div class="tab-pane active" id="overview">
            <%- include('partials/overview-stats', { stats, formatNumber,
            formatDateTime }) %>
          </div>

          <!-- 日活详情 Tab -->
          <div class="tab-pane" id="dau-details">
            <%- include('partials/dau-details-stats') %>
          </div>

          <!-- 在线用户 Tab -->
          <div class="tab-pane" id="online-users">
            <%- include('partials/online-users-stats') %>
          </div>

          <!-- 数据导出 Tab -->
          <div class="tab-pane" id="data-export">
            <%- include('partials/data-export-stats') %>
          </div>

          <!-- 日志搜索 Tab -->
          <div class="tab-pane" id="log-search">
            <%- include('partials/log-search-stats') %>
          </div>
        </div>
      </div>

      <!-- 页面底部信息 -->
      <%- include('partials/footer-info', { formatDateTime }) %>
    </div>

    <script src="/static/js/stats.js?v=<%= new Date().getTime() %>"></script>
  </body>
</html>
