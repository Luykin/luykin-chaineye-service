<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>XHunt Admin</title>
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Cdefs%3E%3ClinearGradient id='grad' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' style='stop-color:%233b82f6;stop-opacity:1' /%3E%3Cstop offset='100%25' style='stop-color:%2310b981;stop-opacity:1' /%3E%3C/linearGradient%3E%3C/defs%3E%3Crect width='100' height='100' rx='20' fill='url(%23grad)'/%3E%3Cpath d='M25,70 L25,55 L35,55 L35,70 M40,70 L40,45 L50,45 L50,70 M55,70 L55,35 L65,35 L65,70 M70,70 L70,25 L80,25 L80,70' fill='white' stroke='white' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3Ccircle cx='30' cy='50' r='3' fill='%23fbbf24'/%3E%3Ccircle cx='45' cy='40' r='3' fill='%23fbbf24'/%3E%3Ccircle cx='60' cy='30' r='3' fill='%23fbbf24'/%3E%3Ccircle cx='75' cy='20' r='3' fill='%23fbbf24'/%3E%3Cpath d='M30,50 L45,40 L60,30 L75,20' stroke='%23fbbf24' stroke-width='2' fill='none' stroke-linecap='round'/%3E%3C/svg%3E"
    />
    <link rel="stylesheet" href="/static/css/stats.css" />
    <style>
      /* 侧边栏图标样式 */
      .nav-icon-svg {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
      }
      .sidebar-nav .tab-btn {
        gap: 12px;
      }
    </style>
  </head>
  <body>
    <!-- 图标库 -->
    <%- include('partials/icons') %>
    
    <!-- 侧边栏 -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <div class="brand">
          <img class="brand-icon" src="/admin/logo" alt="XHunt Logo" />
          <span class="brand-text">XHunt</span>
        </div>
        <div class="brand-subtitle">管理后台</div>
        
        <!-- 固定按钮 -->
        <button class="sidebar-pin" id="sidebarPin" title="固定侧边栏 (Ctrl+B)">
          <svg class="pin-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2v8"/>
            <path d="m5 5 3.5 3.5"/>
            <path d="m19 5-3.5 3.5"/>
            <path d="M12 10v8"/>
            <path d="M8 22h8"/>
          </svg>
        </button>
      </div>
      
      <nav class="sidebar-nav">
        <button class="tab-btn active" data-tab="overview">
          <svg class="nav-icon-svg"><use href="#icon-layout-dashboard"/></svg>
          <span class="nav-text">数据概览</span>
        </button>
        <button class="tab-btn" data-tab="dau-details">
          <svg class="nav-icon-svg"><use href="#icon-users"/></svg>
          <span class="nav-text">日活详情</span>
        </button>
        <button class="tab-btn" data-tab="online-users">
          <svg class="nav-icon-svg"><use href="#icon-activity"/></svg>
          <span class="nav-text">在线用户</span>
        </button>
        <button class="tab-btn" data-tab="cohorts">
          <svg class="nav-icon-svg"><use href="#icon-trending-up"/></svg>
          <span class="nav-text">用户留存</span>
        </button>
        <button class="tab-btn" data-tab="rootdata">
          <svg class="nav-icon-svg"><use href="#icon-database"/></svg>
          <span class="nav-text">Rootdata</span>
        </button>
        <button class="tab-btn" data-tab="notes">
          <svg class="nav-icon-svg"><use href="#icon-file-text"/></svg>
          <span class="nav-text">备注查看</span>
        </button>
        <button class="tab-btn" data-tab="log-search">
          <svg class="nav-icon-svg"><use href="#icon-search"/></svg>
          <span class="nav-text">日志搜索</span>
        </button>
        <button class="tab-btn" data-tab="device-monitor">
          <svg class="nav-icon-svg"><use href="#icon-monitor"/></svg>
          <span class="nav-text">设备监控</span>
        </button>
        <button class="tab-btn" data-tab="version-stats">
          <svg class="nav-icon-svg"><use href="#icon-package"/></svg>
          <span class="nav-text">版本统计</span>
        </button>
        <button class="tab-btn" data-tab="url-stats">
          <svg class="nav-icon-svg"><use href="#icon-link"/></svg>
          <span class="nav-text">接口统计</span>
        </button>
        <button class="tab-btn" data-tab="nacos-messages">
          <svg class="nav-icon-svg"><use href="#icon-megaphone"/></svg>
          <span class="nav-text">公告配置</span>
        </button>
        <button class="tab-btn" data-tab="nacos-campaigns">
          <svg class="nav-icon-svg"><use href="#icon-target"/></svg>
          <span class="nav-text">Earn活动</span>
        </button>
        <button class="tab-btn" data-tab="feature-flags">
          <svg class="nav-icon-svg"><use href="#icon-toggle"/></svg>
          <span class="nav-text">功能开关</span>
        </button>
        <button class="tab-btn" data-tab="perf-monitor">
          <svg class="nav-icon-svg"><use href="#icon-zap"/></svg>
          <span class="nav-text">性能监控</span>
        </button>
        <button class="tab-btn" data-tab="security-violations">
          <svg class="nav-icon-svg"><use href="#icon-shield"/></svg>
          <span class="nav-text">安全拦截</span>
        </button>
        <button class="tab-btn" data-tab="messages">
          <svg class="nav-icon-svg"><use href="#icon-message"/></svg>
          <span class="nav-text">发送私信</span>
        </button>
        <button class="tab-btn" data-tab="data-export">
          <svg class="nav-icon-svg"><use href="#icon-download"/></svg>
          <span class="nav-text">数据导出</span>
        </button>
        <button class="tab-btn" data-tab="reviews-management">
          <svg class="nav-icon-svg"><use href="#icon-message-circle"/></svg>
          <span class="nav-text">评论管理</span>
        </button>
        <button class="tab-btn" data-tab="pro-management">
          <svg class="nav-icon-svg"><use href="#icon-crown"/></svg>
          <span class="nav-text">Pro用户</span>
        </button>
        <button class="tab-btn" data-tab="backup">
          <svg class="nav-icon-svg"><use href="#icon-save"/></svg>
          <span class="nav-text">数据备份</span>
        </button>
        <button class="tab-btn" data-tab="server-command">
          <svg class="nav-icon-svg"><use href="#icon-server"/></svg>
          <span class="nav-text">服务器</span>
        </button>
        <% if (typeof user !== 'undefined' && user && user.role === 'super') { %>
        <div class="nav-divider"></div>
        <button class="tab-btn" data-tab="admin-users">
          <svg class="nav-icon-svg"><use href="#icon-user"/></svg>
          <span class="nav-text">管理员列表</span>
        </button>
        <button class="tab-btn" data-tab="admin-audit-logs">
          <svg class="nav-icon-svg"><use href="#icon-clipboard"/></svg>
          <span class="nav-text">操作记录</span>
        </button>
        <% } %>
        
        <!-- 快捷入口 -->
        <div class="nav-divider"></div>
        <a href="#" class="tab-btn quick-link" id="quick-supabase" target="_blank">
          <svg class="nav-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/></svg>
          <span class="nav-text">Supabase</span>
        </a>
        <a href="https://chrome.google.com/webstore/devconsole/9d25eceb-fe8d-401a-a54e-08499569b9a3" target="_blank" class="tab-btn quick-link">
          <svg class="nav-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
          <span class="nav-text">Chrome 控制台</span>
        </a>
        <a href="https://docs.google.com/document/d/1W4URRutiCIxtYy8oLgEp8wy9yAzRDbNpIbNeXB2oors/edit?tab=t.0" target="_blank" class="tab-btn quick-link">
          <svg class="nav-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
          <span class="nav-text">需求文档</span>
        </a>
        <a href="https://kb.cryptohunt.ai/nacos/" target="_blank" class="tab-btn quick-link">
          <svg class="nav-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22v-5"/><path d="M9 8V2"/><path d="M15 8V2"/><path d="M18 8v5a4 4 0 0 1-4 4h-4a4 4 0 0 1-4-4V8Z"/></svg>
          <span class="nav-text">Nacos 配置</span>
        </a>
      </nav>
      
      <script>
        // Supabase 快捷入口
        document.getElementById('quick-supabase')?.addEventListener('click', async function(ev){
          ev.preventDefault();
          try{
            const r = await fetch('/admin/supabase/link-token', { method:'POST', headers:{ 'Accept':'application/json' } });
            const j = await r.json();
            if(r.status === 403 && j && j.error === '需要先录入生物识别'){
              alert('请先在"账号安全"中录入生物识别（指纹/面容），再使用 Supabase 入口。');
              return;
            }
            if(!j.success || !j.url){ throw new Error(j.error || '生成票据失败'); }
            window.open(j.url, '_blank', 'noopener');
          }catch(ex){ alert('打开失败：' + (ex.message || ex)); }
        });
      </script>
    </aside>

    <!-- 主内容区 -->
    <main class="main-content">
      <!-- 顶部栏 -->
      <header class="top-header">
        <div class="header-left">
          <div class="page-title-wrapper">
            <h1 class="page-title">数据统计面板</h1>
            <div class="live-indicator">
              <span class="live-dot"></span>
              <span class="live-text">实时监控中</span>
            </div>
          </div>
        </div>
        <div class="header-center">
          <div class="current-time">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            <span id="headerTime"><%= formatDateTime() %></span>
          </div>
        </div>
        <div class="header-right">
          <%- include('partials/auth-header', { formatDateTime }) %>
        </div>
      </header>

      <!-- 页面内容 -->
      <div class="content-wrapper">
        <!-- Tab 内容 -->
        <div class="tab-content">
          <!-- 数据概览 Tab -->
          <div class="tab-pane active" id="overview">
            <% if (typeof user !== 'undefined' && user && (user.role === 'super'
            || (Array.isArray(user.permissions) &&
            user.permissions.includes('overview')))) { %> <%-
            include('partials/overview-stats', { stats, formatNumber,
            formatDateTime }) %> <% } else { %>
            <div style="padding: 12px; color: #6b7280">无权限查看该内容</div>
            <% } %>
          </div>

          <!-- 日活详情 Tab -->
          <div class="tab-pane" id="dau-details">
            <%- include('partials/dau-details-stats') %>
          </div>

          <!-- 在线用户 Tab -->
          <div class="tab-pane" id="online-users">
            <%- include('partials/online-users-stats') %>
          </div>

          <!-- Rootdata Tab -->
          <div class="tab-pane" id="rootdata">
            <%- include('partials/rootdata-stats') %>
          </div>

          <!-- 备注查看 Tab -->
          <div class="tab-pane" id="notes">
            <%- include('partials/notes-stats') %>
          </div>

          <!-- 日志搜索 Tab -->
          <div class="tab-pane" id="log-search">
            <%- include('partials/log-search-stats') %>
          </div>

          <!-- 设备监控 Tab -->
          <div class="tab-pane" id="device-monitor">
            <%- include('partials/device-monitor-stats') %>
          </div>

          <!-- 版本统计 Tab -->
          <div class="tab-pane" id="version-stats">
            <%- include('partials/version-stats') %>
          </div>

          <!-- 接口请求统计 Tab -->
          <div class="tab-pane" id="url-stats">
            <%- include('partials/url-stats') %>
          </div>

          <!-- 公告配置 Tab -->
          <div class="tab-pane" id="nacos-messages">
            <%- include('partials/nacos-messages') %>
          </div>

          <!-- Earn 活动配置 Tab -->
          <div class="tab-pane" id="nacos-campaigns">
            <%- include('partials/nacos-campaigns') %>
          </div>

          <!-- 功能开关 Tab -->
          <div class="tab-pane" id="feature-flags">
            <%- include('partials/feature-flags') %>
          </div>

          <!-- 性能监控 Tab -->
          <div class="tab-pane" id="perf-monitor">
            <%- include('partials/perf-monitor-stats') %>
          </div>

          <!-- 安全拦截日志 Tab -->
          <div class="tab-pane" id="security-violations">
            <%- include('partials/security-violations') %>
          </div>

          <!-- 发送私信 Tab -->
          <div class="tab-pane" id="messages">
            <%- include('partials/message-stats') %>
          </div>

          <!-- 数据导出 Tab -->
          <div class="tab-pane" id="data-export">
            <%- include('partials/data-export-stats') %>
          </div>

          <!-- 评论管理 Tab -->
          <div class="tab-pane" id="reviews-management">
            <% if (typeof user !== 'undefined' && user && (user.role === 'super' || (Array.isArray(user.permissions) && user.permissions.includes('reviews-management')))) { %>
            <%- include('partials/reviews-management') %>
            <% } else { %>
            <div style="padding: 12px; color: #6b7280">无权限查看该内容</div>
            <% } %>
          </div>

          <!-- Pro 用户管理 Tab -->
          <div class="tab-pane" id="pro-management">
            <%- include('partials/pro-management-stats') %>
          </div>

          <!-- 数据库备份 Tab -->
          <div class="tab-pane" id="backup">
            <%- include('partials/backup-stats') %>
          </div>

          <!-- 服务器命令 Tab -->
          <div class="tab-pane" id="server-command">
            <%- include('partials/server-command-stats') %>
          </div>

          <% if (typeof user !== 'undefined' && user && user.role === 'super') { %>
          <!-- 管理员列表 Tab -->
          <div class="tab-pane" id="admin-users">
            <%- include('partials/admin-users') %>
          </div>
          <!-- 管理员操作记录 Tab -->
          <div class="tab-pane" id="admin-audit-logs">
            <%- include('partials/admin-audit-logs') %>
          </div>
          <% } %>

          <!-- 用户留存 Tab -->
          <div class="tab-pane" id="cohorts">
            <%- include('partials/daily-cohorts-stats') %>
          </div>
        </div>
      </div>

      <!-- 页面底部信息 -->
      <footer class="main-footer">
        <%- include('partials/footer-info', { formatDateTime }) %>
      </footer>
    </main>

    <script src="/static/js/stats.js?v=<%= new Date().getTime() %>"></script>
    <script>
      // 头部实时时间更新
      (function() {
        const timeEl = document.getElementById('headerTime');
        if (!timeEl) return;
        
        function updateTime() {
          const now = new Date();
          const year = now.getFullYear();
          const month = String(now.getMonth() + 1).padStart(2, '0');
          const day = String(now.getDate()).padStart(2, '0');
          const hours = String(now.getHours()).padStart(2, '0');
          const minutes = String(now.getMinutes()).padStart(2, '0');
          const seconds = String(now.getSeconds()).padStart(2, '0');
          timeEl.textContent = `${year}/${month}/${day} ${hours}:${minutes}:${seconds}`;
        }
        
        updateTime();
        setInterval(updateTime, 1000);
      })();
      
      // 侧边栏固定功能
      (function() {
        const sidebar = document.getElementById('sidebar');
        const pinBtn = document.getElementById('sidebarPin');
        const STORAGE_KEY = 'sidebar-pinned';
        
        // 读取保存的固定状态
        let isPinned = localStorage.getItem(STORAGE_KEY) === 'true';
        
        function updateState() {
          if (isPinned) {
            sidebar.classList.remove('collapsed');
            pinBtn.classList.add('pinned');
            pinBtn.title = '取消固定 (Ctrl+B)';
          } else {
            sidebar.classList.add('collapsed');
            pinBtn.classList.remove('pinned');
            pinBtn.title = '固定侧边栏 (Ctrl+B)';
          }
        }
        
        // 初始化状态
        updateState();
        
        // 点击固定按钮
        pinBtn.addEventListener('click', function() {
          isPinned = !isPinned;
          localStorage.setItem(STORAGE_KEY, isPinned);
          updateState();
        });
        
        // 快捷键 Ctrl+B
        document.addEventListener('keydown', function(e) {
          if ((e.ctrlKey || e.metaKey) && e.key === 'b') {
            e.preventDefault();
            pinBtn.click();
          }
        });
        
        // 桌面端 hover 展开（仅未固定时）
        if (window.innerWidth > 768) {
          sidebar.addEventListener('mouseenter', function() {
            if (!isPinned) {
              sidebar.classList.remove('collapsed');
            }
          });
          
          sidebar.addEventListener('mouseleave', function() {
            if (!isPinned) {
              sidebar.classList.add('collapsed');
            }
          });
        }
        
        // 移动端始终折叠
        if (window.innerWidth <= 768) {
          sidebar.classList.add('collapsed');
          pinBtn.style.display = 'none';
        }
      })();
    </script>
  </body>
</html>
