<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>【new】XHunt 数据统计</title>
    <link rel="stylesheet" href="/static/css/stats.css">
</head>
<body>
    <div class="container">
        <!-- 认证信息 -->
        <%- include('partials/auth-header', { formatDateTime }) %>

        <!-- 快捷链接 -->
        <%- include('partials/quick-links') %>

        <!-- 页面标题 -->
        <div class="header">
            <h1>📊 XHunt 数据统计</h1>
            <p>实时产品数据监控面板 - <%= formatDateTime() %></p>
        </div>

        <!-- Tab 导航 -->
        <div class="tab-container">
            <div class="tab-nav">
                <button class="tab-btn active" data-tab="overview">📊 数据概览</button>
                <button class="tab-btn" data-tab="tags">🏷️ 标签统计</button>
                <button class="tab-btn" data-tab="users">👑 用户排行</button>
<!--                <button class="tab-btn" data-tab="kol-tag">🔥 有灵魂的KOL</button>-->
<!--                <button class="tab-btn" data-tab="specific-users">🎯 特定用户</button>-->
            </div>

            <!-- Tab 内容 -->
            <div class="tab-content">
                <!-- 数据概览 Tab -->
                <div class="tab-pane active" id="overview">
                    <%- include('partials/overview-stats', { stats, formatNumber, formatDateTime }) %>
                </div>

                <!-- 标签统计 Tab -->
                <div class="tab-pane" id="tags">
                    <%- include('partials/tags-stats', { stats, formatNumber }) %>
                </div>

                <!-- 用户排行 Tab -->
                <div class="tab-pane" id="users">
                    <%- include('partials/users-stats', { stats, formatNumber }) %>
                </div>

<!--                &lt;!&ndash; 有灵魂的KOL Tab &ndash;&gt;-->
<!--                <div class="tab-pane" id="kol-tag">-->
<!--                    <%- include('partials/kol-tag-stats', { stats, formatNumber }) %>-->
<!--                </div>-->

<!--                &lt;!&ndash; 特定用户 Tab &ndash;&gt;-->
<!--                <div class="tab-pane" id="specific-users">-->
<!--                    <%- include('partials/specific-users-stats', { stats, formatNumber }) %>-->
<!--                </div>-->
            </div>
        </div>

        <!-- 页面底部信息 -->
        <%- include('partials/footer-info', { formatDateTime }) %>
    </div>

    <script src="/static/js/stats.js"></script>
</body>
</html>
