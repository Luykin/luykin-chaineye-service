<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>管理后台登录</title>
  <script src="/static/js/index.umd.min.js"></script>
  <style>
    body { font-family: -apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Helvetica,Arial; background:#f5f7fb; margin:0; }
    .wrap { max-width: 320px; margin: 12vh auto; background:#fff; border-radius:12px; box-shadow:0 6px 24px rgba(0,0,0,.08); padding:20px; }
    h1 { margin:0 0 16px; font-size:20px; }
    .desc { color:#666; font-size:12px; margin-bottom:16px; }
    .field { margin-bottom:12px; }
    label { display:block; font-size:12px; color:#555; margin-bottom:6px; }
    input { width:100%; padding:10px 12px; border:1px solid #e5e7eb; border-radius:8px; font-size:14px; box-sizing:border-box; }
    button { width:100%; padding:10px 12px; background:#2563eb; color:#fff; border:none; border-radius:8px; font-size:14px; cursor:pointer; box-sizing:border-box; }
    button:disabled { opacity:.6; cursor:not-allowed; }
    .error { color:#dc2626; font-size:12px; min-height:18px; margin-top:8px; }
    .footer { margin-top:16px; color:#888; font-size:12px; text-align:center; }
  </style>
</head>
<body>
  <div class="wrap">
    <h1>🔐 管理后台登录</h1>
    <div class="desc">请输入邮箱和密码登录</div>
    <div class="field">
      <label for="email">邮箱</label>
      <input id="email" type="email" placeholder="you@example.com" autocomplete="username" />
    </div>
    <div class="field">
      <label for="password">密码</label>
      <input id="password" type="password" placeholder="请输入密码" autocomplete="current-password" />
    </div>
    <button id="loginBtn">登录</button>
    <div id="err" class="error"></div>
    <div class="footer">© XHunt Admin</div>
  </div>

  <script>
  (function(){
    const $ = (id) => document.getElementById(id);
    const email = $('email');
    const pwd = $('password');
    const btn = $('loginBtn');
    const err = $('err');

    function setError(m){ err.textContent = m||''; }

    btn.addEventListener('click', async function(){
      setError('');
      const e=email.value.trim(), p=pwd.value;
      if(!e||!p){ setError('请输入邮箱和密码'); return; }
      btn.disabled = true;
      try{
        console.log('[admin-login] start login click');
        const res = await fetch('/admin/login',{
          method:'POST',
          headers:{ 'Content-Type':'application/json', 'Accept':'application/json', 'X-Requested-With':'XMLHttpRequest' },
          body: JSON.stringify({ email:e, password:p })
        });
        console.log('[admin-login] /admin/login status:', res.status, 'ctype:', res.headers.get('content-type'));
        if (!res.ok) {
          const txt = await res.text().catch(()=> '');
          throw new Error('登录失败：' + (txt || ('HTTP ' + res.status)));
        }
        const ctypeLogin = res.headers.get('content-type') || '';
        if (!ctypeLogin.includes('application/json')) {
          const txt = await res.text().catch(()=> '');
          setError('登录响应异常（可能被重定向到登录页）。请刷新重试');
          console.error('[admin-login] unexpected content-type for /admin/login:', ctypeLogin, txt && txt.slice(0,200));
          return;
        }
        const data = await res.json();
        console.log('[admin-login] response:', data);
        if(!data.success){ throw new Error(data.error||'登录失败'); }
        if (data.needsWebAuthn && data.tempToken) {
          // 二次验证：若浏览器不支持 WebAuthn，则给出提示并阻止继续
          try{
            var supports = typeof window.SimpleWebAuthnBrowser !== 'undefined' && await window.SimpleWebAuthnBrowser.browserSupportsWebAuthn();
          }catch(_){ var supports = (typeof window.PublicKeyCredential !== 'undefined'); }
          if (!supports) {
            setError('该账号已启用生物识别登录，请更换支持指纹/FaceID 的浏览器或设备完成验证');
            return;
          }
          // 获取认证参数并调用 WebAuthn
          const optUrl = '/admin/webauthn/authentication/options?tempToken=' + encodeURIComponent(data.tempToken) + '&_ts=' + Date.now();
          console.log('[admin-login] fetching options:', optUrl);
          const optRes = await fetch(optUrl, { credentials:'include', headers: { 'Accept':'application/json', 'X-Requested-With':'XMLHttpRequest' } });
          console.log('[admin-login] options status:', optRes.status, 'ctype:', optRes.headers.get('content-type'));
          if (!optRes.ok) {
            const txt = await optRes.text().catch(()=> '');
            throw new Error('获取认证参数失败：' + (txt || ('HTTP ' + optRes.status)));
          }
          const ctype = optRes.headers.get('content-type') || '';
          if (!ctype.includes('application/json')) {
            const txt = await optRes.text().catch(()=> '');
            throw new Error('认证参数响应异常（可能被重定向到登录页）。请刷新重试：' + (txt ? txt.slice(0,120) : '')); 
          }
          const optData = await optRes.json();
          console.log('[admin-login] options json:', optData);
          if (!optData.success) throw new Error(optData.error || '获取认证参数失败');
          let assertion;
          try {
            console.log('[admin-login] startAuthentication...');
            assertion = await window.SimpleWebAuthnBrowser.startAuthentication(optData.options);
            console.log('[admin-login] assertion obtained');
          } catch (we) {
            throw new Error(we && we.message ? ('认证被取消或失败：' + we.message) : '认证被取消或失败');
          }
          const verifyRes = await fetch('/admin/webauthn/authentication/verify', {
            method:'POST',
            headers:{ 'Content-Type':'application/json', 'Accept':'application/json', 'X-Requested-With':'XMLHttpRequest' },
            credentials:'include',
            body: JSON.stringify({ tempToken: data.tempToken, assertion })
          });
          console.log('[admin-login] verify status:', verifyRes.status, 'ctype:', verifyRes.headers.get('content-type'));
          const verify = await verifyRes.json().catch(()=>({success:false,error:'非JSON响应'}));
          console.log('[admin-login] verify json:', verify);
          if (!verify.success) throw new Error(verify.error || '二次验证失败');
          setError('✅ 二次验证成功，已建立后台会话。请在新标签访问 /api/xhunt/stats 或点击下方链接。');
          const a=document.createElement('a'); a.href = verify.redirect || '/api/xhunt/stats'; a.textContent='进入后台'; a.style.display='block'; a.style.marginTop='8px';
          err.appendChild(a);
          return;
        }
        setError('✅ 登录成功（无二次验证）。请在新标签访问 /api/xhunt/stats 或点击下方链接。');
        const a=document.createElement('a'); a.href = data.redirect || '/api/xhunt/stats'; a.textContent='进入后台'; a.style.display='block'; a.style.marginTop='8px';
        err.appendChild(a);
      }catch(ex){ setError(ex.message||'登录失败'); }
      finally{ btn.disabled = false; }
    });
  })();
  </script>
</body>
</html>
