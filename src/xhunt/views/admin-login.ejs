<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>XHunt Admin</title>
  <script src="/static/js/index.umd.min.js?v=<%= typeof v !== 'undefined' ? v : Date.now() %>"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Crimson+Pro:wght@500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-primary: #0a0b0f;
      --bg-secondary: #11131a;
      --bg-tertiary: #1a1d26;
      --border-subtle: rgba(255,255,255,0.06);
      --border-focus: rgba(245,158,11,0.5);
      --text-primary: #f8fafc;
      --text-secondary: #94a3b8;
      --text-muted: #64748b;
      --accent: #f59e0b;
      --accent-hover: #fbbf24;
      --accent-glow: rgba(245,158,11,0.15);
      --error: #ef4444;
      --error-bg: rgba(239,68,68,0.08);
      --success: #22c55e;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
    }

    /* Animated background gradient */
    .ambient-glow {
      position: fixed;
      width: 600px;
      height: 600px;
      border-radius: 50%;
      filter: blur(120px);
      opacity: 0.15;
      pointer-events: none;
      animation: float 20s ease-in-out infinite;
    }

    .ambient-glow-1 {
      background: radial-gradient(circle, var(--accent) 0%, transparent 70%);
      top: -200px;
      right: -100px;
      animation-delay: 0s;
    }

    .ambient-glow-2 {
      background: radial-gradient(circle, #6366f1 0%, transparent 70%);
      bottom: -200px;
      left: -100px;
      animation-delay: -10s;
    }

    @keyframes float {
      0%, 100% { transform: translate(0, 0) scale(1); }
      25% { transform: translate(50px, -30px) scale(1.1); }
      50% { transform: translate(-30px, 50px) scale(0.95); }
      75% { transform: translate(-50px, -20px) scale(1.05); }
    }

    /* Grid pattern overlay */
    .grid-pattern {
      position: fixed;
      inset: 0;
      background-image: 
        linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
      mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
    }

    .login-container {
      width: 100%;
      max-width: 420px;
      padding: 0 24px;
      position: relative;
      z-index: 1;
    }

    .login-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border-subtle);
      border-radius: 24px;
      padding: 48px 40px;
      box-shadow: 
        0 0 0 1px rgba(255,255,255,0.02) inset,
        0 40px 80px -20px rgba(0,0,0,0.5),
        0 20px 40px -10px rgba(0,0,0,0.3);
      position: relative;
      overflow: hidden;
    }

    .login-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(245,158,11,0.3), transparent);
    }

    .brand {
      text-align: center;
      margin-bottom: 40px;
    }

    .brand-logo {
      width: 56px;
      height: 56px;
      background: linear-gradient(135deg, var(--accent) 0%, #d97706 100%);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
      box-shadow: 
        0 0 0 1px rgba(255,255,255,0.1) inset,
        0 8px 32px rgba(245,158,11,0.3);
      position: relative;
    }

    .brand-logo::after {
      content: '';
      position: absolute;
      inset: -2px;
      background: linear-gradient(135deg, var(--accent), transparent, var(--accent));
      border-radius: 18px;
      z-index: -1;
      opacity: 0.5;
      filter: blur(8px);
    }

    .brand-logo svg {
      width: 28px;
      height: 28px;
      color: white;
    }

    .brand-title {
      font-family: 'Crimson Pro', Georgia, serif;
      font-size: 28px;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin-bottom: 8px;
    }

    .brand-subtitle {
      color: var(--text-secondary);
      font-size: 14px;
      font-weight: 400;
    }

    .form-group {
      margin-bottom: 20px;
      position: relative;
    }

    .form-label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      margin-bottom: 8px;
    }

    .input-wrapper {
      position: relative;
    }

    .form-input {
      width: 100%;
      padding: 14px 16px;
      background: var(--bg-tertiary);
      border: 1px solid var(--border-subtle);
      border-radius: 12px;
      font-size: 15px;
      font-weight: 500;
      color: var(--text-primary);
      transition: all 0.2s ease;
      outline: none;
    }

    .form-input::placeholder {
      color: var(--text-muted);
      font-weight: 400;
    }

    .form-input:hover {
      border-color: rgba(255,255,255,0.12);
      background: color-mix(in oklch, var(--bg-tertiary) 95%, white);
    }

    .form-input:focus {
      border-color: var(--accent);
      background: var(--bg-secondary);
      box-shadow: 0 0 0 3px var(--accent-glow);
    }

    .input-icon {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-muted);
      pointer-events: none;
      transition: color 0.2s ease;
    }

    .form-input:focus + .input-icon {
      color: var(--accent);
    }

    .submit-btn {
      width: 100%;
      padding: 16px 24px;
      margin-top: 8px;
      background: linear-gradient(135deg, var(--accent) 0%, #d97706 100%);
      border: none;
      border-radius: 12px;
      font-family: inherit;
      font-size: 15px;
      font-weight: 600;
      color: white;
      cursor: pointer;
      position: relative;
      overflow: hidden;
      transition: all 0.3s ease;
      box-shadow: 
        0 0 0 1px rgba(255,255,255,0.1) inset,
        0 4px 20px rgba(245,158,11,0.3);
    }

    .submit-btn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
      transform: translateX(-100%);
      transition: transform 0.6s ease;
    }

    .submit-btn:hover:not(:disabled) {
      transform: translateY(-1px);
      box-shadow: 
        0 0 0 1px rgba(255,255,255,0.15) inset,
        0 8px 30px rgba(245,158,11,0.4);
    }

    .submit-btn:hover:not(:disabled)::before {
      transform: translateX(100%);
    }

    .submit-btn:active:not(:disabled) {
      transform: translateY(0);
    }

    .submit-btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      filter: grayscale(0.3);
    }

    .submit-btn.loading .btn-text {
      opacity: 0;
    }

    .submit-btn.loading .btn-loader {
      opacity: 1;
    }

    .btn-content {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .btn-loader {
      position: absolute;
      opacity: 0;
      transition: opacity 0.2s ease;
    }

    .spinner {
      width: 20px;
      height: 20px;
      border: 2px solid rgba(255,255,255,0.3);
      border-top-color: white;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .error-message {
      margin-top: 16px;
      padding: 12px 16px;
      background: var(--error-bg);
      border: 1px solid rgba(239,68,68,0.2);
      border-radius: 10px;
      font-size: 13px;
      color: var(--error);
      display: flex;
      align-items: center;
      gap: 8px;
      opacity: 0;
      transform: translateY(-10px);
      transition: all 0.3s ease;
    }

    .error-message.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .error-icon {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
    }

    .footer {
      margin-top: 32px;
      text-align: center;
      color: var(--text-muted);
      font-size: 12px;
      font-weight: 500;
    }

    .footer span {
      color: var(--text-secondary);
    }

    /* Security badge */
    .security-badge {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      margin-top: 20px;
      padding: 10px 16px;
      background: rgba(34,197,94,0.08);
      border: 1px solid rgba(34,197,94,0.15);
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--success);
    }

    .security-badge svg {
      width: 14px;
      height: 14px;
    }

    /* Responsive */
    @media (max-width: 480px) {
      .login-card {
        padding: 36px 24px;
        border-radius: 20px;
      }

      .brand-title {
        font-size: 24px;
      }

      .ambient-glow {
        width: 400px;
        height: 400px;
        filter: blur(80px);
      }
    }

    /* Reduced motion */
    @media (prefers-reduced-motion: reduce) {
      .ambient-glow {
        animation: none;
      }
      
      .submit-btn::before {
        display: none;
      }
    }
  </style>
</head>
<body>
  <div class="ambient-glow ambient-glow-1"></div>
  <div class="ambient-glow ambient-glow-2"></div>
  <div class="grid-pattern"></div>

  <div class="login-container">
    <div class="login-card">
      <div class="brand">
        <div class="brand-logo">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
            <path d="M2 17l10 5 10-5"/>
            <path d="M2 12l10 5 10-5"/>
          </svg>
        </div>
        <h1 class="brand-title">XHunt Admin</h1>
        <p class="brand-subtitle">管理后台登录</p>
      </div>

      <form id="loginForm" autocomplete="off">
        <div class="form-group">
          <label class="form-label" for="email">邮箱地址</label>
          <div class="input-wrapper">
            <input 
              id="email" 
              class="form-input" 
              type="email" 
              placeholder="admin@example.com" 
              autocomplete="username"
              required
            />
            <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="5" width="20" height="14" rx="2"/>
              <path d="m2 5 10 7 10-7"/>
            </svg>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="password">登录密码</label>
          <div class="input-wrapper">
            <input 
              id="password" 
              class="form-input" 
              type="password" 
              placeholder="••••••••" 
              autocomplete="current-password"
              required
            />
            <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
        </div>

        <button type="submit" id="loginBtn" class="submit-btn">
          <span class="btn-content">
            <span class="btn-text">安全登录</span>
            <span class="btn-loader">
              <span class="spinner"></span>
            </span>
          </span>
        </button>
      </form>

      <div id="err" class="error-message">
        <svg class="error-icon" viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0zM7 4a1 1 0 0 0-1 1v4a1 1 0 0 0 2 0V5a1 1 0 0 0-1-1zm0 8a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/>
        </svg>
        <span class="error-text"></span>
      </div>

      <div class="security-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        WebAuthn 安全验证
      </div>
    </div>

    <div class="footer">
      <span>XHunt</span> — Blockchain Intelligence Platform
    </div>
  </div>

  <script>
  (function(){
    const $ = (id) => document.getElementById(id);
    const form = $('loginForm');
    const email = $('email');
    const pwd = $('password');
    const btn = $('loginBtn');
    const err = $('err');
    const errText = err.querySelector('.error-text');
    const qs = new URLSearchParams(window.location.search);
    const nextRaw = qs.get('next');
    const nextPath = (typeof nextRaw === 'string' && nextRaw.startsWith('/')) ? nextRaw : '/api/xhunt/stats';

    function setError(m) {
      if (m) {
        errText.textContent = m;
        err.classList.add('visible');
      } else {
        err.classList.remove('visible');
        setTimeout(() => { errText.textContent = ''; }, 300);
      }
    }

    function setLoading(loading) {
      btn.disabled = loading;
      btn.classList.toggle('loading', loading);
    }

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      setError('');
      
      const eVal = email.value.trim();
      const pVal = pwd.value;
      
      if (!eVal || !pVal) {
        setError('请输入邮箱和密码');
        return;
      }

      setLoading(true);
      
      try {
        console.log('[admin-login] start login');
        const res = await fetch('/admin/login', {
          method: 'POST',
          headers: { 
            'Content-Type': 'application/json', 
            'Accept': 'application/json', 
            'X-Requested-With': 'XMLHttpRequest' 
          },
          body: JSON.stringify({ email: eVal, password: pVal })
        });
        
        console.log('[admin-login] /admin/login status:', res.status);
        
        if (!res.ok) {
          const txt = await res.text().catch(() => '');
          throw new Error('登录失败：' + (txt || ('HTTP ' + res.status)));
        }

        const ctypeLogin = res.headers.get('content-type') || '';
        if (!ctypeLogin.includes('application/json')) {
          const txt = await res.text().catch(() => '');
          setError('登录响应异常，请刷新重试');
          console.error('[admin-login] unexpected content-type:', ctypeLogin);
          return;
        }

        const data = await res.json();
        console.log('[admin-login] response:', data);
        
        if (!data.success) {
          throw new Error(data.error || '登录失败');
        }

        // WebAuthn 2FA flow
        if (data.needsWebAuthn && data.tempToken) {
          try {
            var supports = typeof window.SimpleWebAuthnBrowser !== 'undefined' && 
              await window.SimpleWebAuthnBrowser.browserSupportsWebAuthn();
          } catch(_) { 
            var supports = (typeof window.PublicKeyCredential !== 'undefined'); 
          }
          
          if (!supports) {
            setError('该账号已启用生物识别登录，请使用支持指纹/FaceID 的设备');
            setLoading(false);
            return;
          }

          const optUrl = '/admin/webauthn/authentication/options?tempToken=' + 
            encodeURIComponent(data.tempToken) + '&_ts=' + Date.now();
          
          console.log('[admin-login] fetching options:', optUrl);
          const optRes = await fetch(optUrl, { 
            credentials: 'include', 
            headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } 
          });
          
          if (!optRes.ok) {
            const txt = await optRes.text().catch(() => '');
            throw new Error('获取认证参数失败：' + (txt || ('HTTP ' + optRes.status)));
          }

          const optData = await optRes.json();
          if (!optData.success) throw new Error(optData.error || '获取认证参数失败');

          let assertion;
          try {
            assertion = await window.SimpleWebAuthnBrowser.startAuthentication(optData.options);
          } catch (we) {
            throw new Error(we?.message ? '认证被取消：' + we.message : '认证被取消');
          }

          const verifyRes = await fetch('/admin/webauthn/authentication/verify', {
            method: 'POST',
            headers: { 
              'Content-Type': 'application/json', 
              'Accept': 'application/json', 
              'X-Requested-With': 'XMLHttpRequest' 
            },
            credentials: 'include',
            body: JSON.stringify({ tempToken: data.tempToken, assertion })
          });

          const verify = await verifyRes.json().catch(() => ({ success: false, error: '非JSON响应' }));
          if (!verify.success) throw new Error(verify.error || '二次验证失败');
          
          window.location.assign(nextPath || verify.redirect || '/api/xhunt/stats');
          return;
        }

        window.location.assign(nextPath || data.redirect || '/api/xhunt/stats');
      } catch (ex) {
        setError(ex.message || '登录失败');
        setLoading(false);
      }
    });

    // Focus email on load
    email.focus();
  })();
  </script>
</body>
</html>
