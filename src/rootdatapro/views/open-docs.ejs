<!doctype html>
<html lang="en" data-lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>RootDataPro Open API</title>
  <style>
    :root {
      --bg: #0b1020;
      --panel: rgba(255,255,255,0.06);
      --panel2: rgba(255,255,255,0.08);
      --text: rgba(255,255,255,0.92);
      --muted: rgba(255,255,255,0.68);
      --line: rgba(255,255,255,0.12);
      --brand: #7c5cff;
      --ok: #22c55e;
      --warn: #f59e0b;
      --bad: #ef4444;
      --codebg: rgba(0,0,0,0.35);
      --shadow: 0 20px 60px rgba(0,0,0,0.45);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji";
      background: radial-gradient(1200px 600px at 20% 0%, rgba(124,92,255,0.35), transparent 60%),
                  radial-gradient(900px 500px at 80% 10%, rgba(34,197,94,0.22), transparent 55%),
                  radial-gradient(1000px 700px at 50% 100%, rgba(59,130,246,0.20), transparent 60%),
                  var(--bg);
      color: var(--text);
      line-height: 1.5;
    }
    a { color: inherit; }

    .container { max-width: 1100px; margin: 0 auto; padding: 20px 14px 64px; }

    .top {
      display: grid;
      gap: 14px;
      padding: 18px;
      background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.04));
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(12px);
    }
    .title { display: flex; flex-wrap: wrap; align-items: center; gap: 10px; }
    .title h1 { margin: 0; font-size: 20px; letter-spacing: 0.2px; }
    .badge {
      font-size: 12px;
      padding: 4px 10px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.06);
      color: var(--muted);
      word-break: break-all;
    }

    .grid { display: grid; grid-template-columns: 1fr; gap: 12px; margin-top: 14px; }
    @media (min-width: 860px) {
      .container { padding: 28px 18px 80px; }
      .title h1 { font-size: 22px; }
      .grid { grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 18px; }
      .top { padding: 20px; }
    }

    .card {
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.05);
      border-radius: 18px;
      padding: 14px;
      box-shadow: 0 14px 40px rgba(0,0,0,0.25);
      backdrop-filter: blur(10px);
      min-width: 0;
    }
    @media (min-width: 860px) {
      .card { padding: 16px; }
    }

    .row { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
    .method {
      font-weight: 700;
      font-size: 12px;
      padding: 3px 8px;
      border-radius: 999px;
      border: 1px solid rgba(34,197,94,0.35);
      background: rgba(34,197,94,0.14);
      color: rgba(220,255,234,0.95);
    }
    .path { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace; font-size: 13px; color: rgba(255,255,255,0.9); }
    .desc { color: var(--muted); font-size: 13px; margin: 8px 0 12px; }

    .kv { display: grid; grid-template-columns: 106px 1fr; gap: 10px; font-size: 13px; margin-top: 10px; }
    @media (min-width: 860px) { .kv { grid-template-columns: 120px 1fr; } }

    .k { color: rgba(255,255,255,0.75); }
    .v { color: rgba(255,255,255,0.92); }

    pre {
      margin: 10px 0 0;
      padding: 12px 12px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.10);
      background: var(--codebg);
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      font-size: 12px;
      line-height: 1.45;
    }
    code { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace; }

    .callout {
      border: 1px solid rgba(245,158,11,0.35);
      background: rgba(245,158,11,0.12);
      border-radius: 16px;
      padding: 12px 14px;
      color: rgba(255,255,255,0.9);
      min-width: 0;
    }
    .callout strong { color: rgba(255,255,255,0.95); }
    .muted { color: var(--muted); }
    .pill {
      font-size: 12px;
      padding: 3px 10px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.05);
      color: var(--muted);
    }
    .footer { margin-top: 18px; color: var(--muted); font-size: 12px; }
    .hr { height: 1px; background: var(--line); margin: 14px 0; }

    .lang {
      display: inline-flex;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.05);
      border-radius: 999px;
      overflow: hidden;
    }
    .lang button {
      appearance: none;
      border: 0;
      background: transparent;
      color: var(--muted);
      padding: 6px 10px;
      font-size: 12px;
      cursor: pointer;
    }
    .lang button.active {
      color: rgba(255,255,255,0.92);
      background: rgba(255,255,255,0.10);
    }

    [data-lang] { display: none; }
    html[data-lang="en"] [data-lang="en"],
    html[data-lang="zh"] [data-lang="zh"] { display: inline; }
  </style>
</head>
<body>
  <script>
    (function () {
      function getLangFromQuery() {
        try {
          var params = new URLSearchParams(location.search);
          var l = (params.get('lang') || '').toLowerCase();
          return l === 'zh' || l === 'cn' ? 'zh' : (l === 'en' ? 'en' : null);
        } catch (e) {
          return null;
        }
      }

      function applyLang(lang) {
        var root = document.documentElement;
        root.setAttribute('data-lang', lang);
        root.setAttribute('lang', lang === 'zh' ? 'zh-CN' : 'en');
        try { localStorage.setItem('open_docs_lang', lang); } catch (e) {}

        var enBtn = document.getElementById('lang-en');
        var zhBtn = document.getElementById('lang-zh');
        if (enBtn && zhBtn) {
          enBtn.classList.toggle('active', lang === 'en');
          zhBtn.classList.toggle('active', lang === 'zh');
        }
      }

      var q = getLangFromQuery();
      var saved = null;
      try { saved = localStorage.getItem('open_docs_lang'); } catch (e) {}

      var lang = q || (saved === 'zh' ? 'zh' : 'en');
      applyLang(lang);

      window.__setOpenDocsLang = applyLang;
    })();
  </script>

  <div class="container">
    <div class="top">
      <div class="title">
        <h1>
          <span data-lang="en">RootDataPro Open API</span>
          <span data-lang="zh">RootDataPro Open API 文档</span>
        </h1>

        <span class="badge">
          <span data-lang="en">Base URL:</span>
          <span data-lang="zh">Base URL：</span>
          <span class="path">https://rootdatapro.online</span>
        </span>

        <span class="lang" role="group" aria-label="Language">
          <button type="button" id="lang-en" onclick="window.__setOpenDocsLang && window.__setOpenDocsLang('en')">EN</button>
          <button type="button" id="lang-zh" onclick="window.__setOpenDocsLang && window.__setOpenDocsLang('zh')">中文</button>
        </span>
      </div>

      <div class="callout">
        <div><strong><span data-lang="en">Authentication (Required)</span><span data-lang="zh">鉴权说明（必须）</span></strong></div>
        <div class="muted" style="margin-top:6px;">
          <span data-lang="en">All endpoints require an <code>APIKey</code> (usage-based billing).</span>
          <span data-lang="zh">所有接口都需要 <code>APIKey</code>（按额度扣费）。</span>
          <br />
          <span data-lang="en">To get an <code>APIKey</code>, contact TG:</span>
          <span data-lang="zh">获取 <code>APIKey</code> 请联系 TG：</span>
          <a href="https://t.me/Niod88" target="_blank" rel="noreferrer">@Niod88</a>
        </div>
        <div class="hr"></div>
        <div class="muted"><span data-lang="en">Header:</span><span data-lang="zh">请求头：</span></div>
        <pre><code>X-API-Key: YOUR_API_KEY</code></pre>
      </div>

      <div class="row">
        <span class="pill"><span data-lang="en">Response: JSON</span><span data-lang="zh">返回格式：JSON</span></span>
        <span class="pill"><span data-lang="en">Error: </span><span data-lang="zh">错误格式：</span>{ success: false, error, message? }</span>
        <span class="pill"><span data-lang="en">Auth: </span><span data-lang="zh">鉴权：</span>X-API-Key</span>
      </div>

      <div class="callout">
        <div><strong><span data-lang="en">Quick Start</span><span data-lang="zh">快速调用示例</span></strong></div>
        <div class="muted" style="margin-top:6px;"><span data-lang="en">Replace </span><code>YOUR_API_KEY</code><span data-lang="en"> with your key.</span><span data-lang="zh">所有示例均需要将 <code>YOUR_API_KEY</code> 替换为你的密钥。</span></div>

        <div class="hr"></div>
        <div class="muted"><span data-lang="en">curl (CLI)</span><span data-lang="zh">curl（命令行）</span></div>
        <pre><code>curl -s 'https://rootdatapro.online/open/quota' \
  -H 'X-API-Key: YOUR_API_KEY'</code></pre>

        <div class="muted" style="margin-top:10px;"><span data-lang="en">JavaScript (Browser / Node 18+ fetch)</span><span data-lang="zh">JavaScript（浏览器 / Node 18+ fetch）</span></div>
        <pre><code>const url = 'https://rootdatapro.online/open/quota';
const res = await fetch(url, {
  method: 'GET',
  headers: {
    'X-API-Key': 'YOUR_API_KEY',
  },
});
const data = await res.json();
console.log(data);</code></pre>

        <div class="muted" style="margin-top:10px;"><span data-lang="en">Python (requests)</span><span data-lang="zh">Python（requests）</span></div>
        <pre><code>import requests

url = 'https://rootdatapro.online/open/quota'
headers = {
    'X-API-Key': 'YOUR_API_KEY',
}
resp = requests.get(url, headers=headers, timeout=30)
print(resp.status_code)
print(resp.json())</code></pre>

        <div class="muted" style="margin-top:10px;"><span data-lang="en">Java (Java 11+ HttpClient)</span><span data-lang="zh">Java（Java 11+ HttpClient）</span></div>
        <pre><code>import java.net.URI;
import java.net.http.HttpClient;
import java.net.http.HttpRequest;
import java.net.http.HttpResponse;

public class Demo {
  public static void main(String[] args) throws Exception {
    HttpClient client = HttpClient.newHttpClient();
    HttpRequest request = HttpRequest.newBuilder()
        .uri(URI.create("https://rootdatapro.online/open/quota"))
        .header("X-API-Key", "YOUR_API_KEY")
        .GET()
        .build();

    HttpResponse&lt;String&gt; response = client.send(request, HttpResponse.BodyHandlers.ofString());
    System.out.println(response.statusCode());
    System.out.println(response.body());
  }
}</code></pre>

        <div class="muted" style="margin-top:8px;"><span data-lang="en">You can also replace the URL with other endpoints, e.g.:</span><span data-lang="zh">你也可以将上面的 URL 替换为任意接口，例如：</span></div>
        <pre><code>https://rootdatapro.online/open/get_item?project_id=123
https://rootdatapro.online/open/get_org?org_id=123
https://rootdatapro.online/open/get_people?people_id=123</code></pre>
      </div>
    </div>

    <div class="grid">
      <div class="card">
        <div class="row">
          <span class="method">GET</span>
          <span class="path">/open/quota</span>
        </div>
        <div class="desc"><span data-lang="en">Check your API key quota, expiry, and status.</span><span data-lang="zh">查询当前 APIKey 的额度/到期/状态信息。</span></div>
        <div class="kv">
          <div class="k"><span data-lang="en">Auth</span><span data-lang="zh">鉴权</span></div><div class="v"><span data-lang="en">Required</span><span data-lang="zh">需要 APIKey</span></div>
          <div class="k"><span data-lang="en">Query</span><span data-lang="zh">Query</span></div><div class="v"><span data-lang="en">None</span><span data-lang="zh">无</span></div>
        </div>
        <pre><code>curl -s 'https://rootdatapro.online/open/quota' \
  -H 'X-API-Key: YOUR_API_KEY' | jq .</code></pre>

      </div>

      <div class="card">
        <div class="row">
          <span class="method">GET</span>
          <span class="path">/open/get_item?project_id=123</span>
        </div>
        <div class="desc"><span data-lang="en">Get project details by <code>project_id</code> (tags, ecosystems, team, investments).</span><span data-lang="zh">根据 <code>project_id</code> 获取项目详情（含标签、生态、团队、投融资信息）。</span></div>
        <div class="kv">
          <div class="k"><span data-lang="en">Auth</span><span data-lang="zh">鉴权</span></div><div class="v"><span data-lang="en">Required (level: 2)</span><span data-lang="zh">需要 APIKey（权限等级：2）</span></div>
          <div class="k"><span data-lang="en">Query</span><span data-lang="zh">Query</span></div><div class="v"><code>project_id</code> (number, <span data-lang="en">required</span><span data-lang="zh">必填</span>)</div>
        </div>
        <pre><code>curl -s 'https://rootdatapro.online/open/get_item?project_id=123' \
  -H 'X-API-Key: YOUR_API_KEY' | jq .</code></pre>

      </div>

      <div class="card">
        <div class="row">
          <span class="method">GET</span>
          <span class="path">/open/get_org?org_id=123</span>
        </div>
        <div class="desc"><span data-lang="en">Get organization details by <code>org_id</code> (tags, categories, team, investments).</span><span data-lang="zh">根据 <code>org_id</code> 获取机构详情（含标签、分类、团队、投融资信息）。</span></div>
        <div class="kv">
          <div class="k"><span data-lang="en">Auth</span><span data-lang="zh">鉴权</span></div><div class="v"><span data-lang="en">Required (level: 2)</span><span data-lang="zh">需要 APIKey（权限等级：2）</span></div>
          <div class="k"><span data-lang="en">Query</span><span data-lang="zh">Query</span></div><div class="v"><code>org_id</code> (number, <span data-lang="en">required</span><span data-lang="zh">必填</span>)</div>
        </div>
        <pre><code>curl -s 'https://rootdatapro.online/open/get_org?org_id=123' \
  -H 'X-API-Key: YOUR_API_KEY' | jq .</code></pre>

      </div>

      <div class="card">
        <div class="row">
          <span class="method">GET</span>
          <span class="path">/open/get_people?people_id=123</span>
        </div>
        <div class="desc"><span data-lang="en">Get person details by <code>people_id</code> (related projects/orgs, investments).</span><span data-lang="zh">根据 <code>people_id</code> 获取人物详情（含关联项目/机构、投融资信息）。</span></div>
        <div class="kv">
          <div class="k"><span data-lang="en">Auth</span><span data-lang="zh">鉴权</span></div><div class="v"><span data-lang="en">Required (level: 2)</span><span data-lang="zh">需要 APIKey（权限等级：2）</span></div>
          <div class="k"><span data-lang="en">Query</span><span data-lang="zh">Query</span></div><div class="v"><code>people_id</code> (number, <span data-lang="en">required</span><span data-lang="zh">必填</span>)</div>
        </div>
        <pre><code>curl -s 'https://rootdatapro.online/open/get_people?people_id=123' \
  -H 'X-API-Key: YOUR_API_KEY' | jq .</code></pre>

      </div>
    </div>

    <div class="footer">
      <div><span data-lang="en">Examples included: curl / JavaScript / Python / Java (X-API-Key).</span><span data-lang="zh">调用示例已提供：curl / JavaScript / Python / Java（均使用 <code>X-API-Key</code>）。</span></div>
    </div>
  </div>
</body>
</html>
