<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>RootDataPro API Enhanced Services</title>


  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Cdefs%3E%3CradialGradient id='g' cx='30%25' cy='30%25' r='70%25'%3E%3Cstop offset='0%25' stop-color='%23FDBA74'/%3E%3Cstop offset='55%25' stop-color='%23F97316'/%3E%3Cstop offset='100%25' stop-color='%23C2410C'/%3E%3C/radialGradient%3E%3C/defs%3E%3Crect x='6' y='6' width='52' height='52' rx='14' fill='url(%23g)'/%3E%3Cpath d='M20 34c0-10 7-18 18-18 3 0 6 .6 8 1.7' fill='none' stroke='%230b1020' stroke-width='6' stroke-linecap='round'/%3E%3Cpath d='M44 30c0 10-7 18-18 18-3 0-6-.6-8-1.7' fill='none' stroke='%23fff' stroke-width='6' stroke-linecap='round' opacity='.9'/%3E%3C/svg%3E" />
  <style>
    :root {
      --bg: #0b1020;
      --panel: rgba(255,255,255,0.06);
      --panel2: rgba(255,255,255,0.08);
      --text: rgba(255,255,255,0.92);
      --muted: rgba(255,255,255,0.68);
      --line: rgba(255,255,255,0.12);
      --brand: #f97316;
      --ok: #22c55e;
      --warn: #f59e0b;
      --bad: #ef4444;
      --brand2: #fb923c;
      --brand3: #fdba74;
      --codebg: rgba(0,0,0,0.35);
      --shadow: 0 20px 60px rgba(0,0,0,0.45);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji";
      background: radial-gradient(1200px 600px at 20% 0%, rgba(124,92,255,0.35), transparent 60%),
                  radial-gradient(900px 500px at 80% 10%, rgba(34,197,94,0.22), transparent 55%),
                  radial-gradient(1000px 700px at 50% 100%, rgba(59,130,246,0.20), transparent 60%),
                  var(--bg);
      color: var(--text);
      line-height: 1.5;
    }
    a { color: inherit; }

    .container { max-width: 1100px; margin: 0 auto; padding: 20px 14px 64px; }

    .top {
      display: grid;
      gap: 14px;
      padding: 18px;
      background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.04));
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(12px);
    }

    .title { display: flex; flex-wrap: wrap; align-items: center; gap: 10px; }
    .title h1 { margin: 0; font-size: 20px; letter-spacing: 0.2px; }

    .badge {
      font-size: 12px;
      padding: 4px 10px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.06);
      color: var(--muted);
      word-break: break-all;
    }

    .lang {
      display: inline-flex;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.05);
      border-radius: 999px;
      overflow: hidden;
    }
    .lang button {
      appearance: none;
      border: 0;
      background: transparent;
      color: var(--muted);
      padding: 6px 10px;
      font-size: 12px;
      cursor: pointer;
    }
    .lang button.active {
      color: rgba(255,255,255,0.92);
      background: rgba(255,255,255,0.10);
    }

    .grid { display: grid; grid-template-columns: 1fr; gap: 12px; margin-top: 14px; }
    @media (min-width: 860px) {
      .container { padding: 28px 18px 80px; }
      .title h1 { font-size: 22px; }
      .grid { grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 18px; }
      .top { padding: 20px; }
    }

    .card {
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.05);
      border-radius: 18px;
      padding: 14px;
      box-shadow: 0 14px 40px rgba(0,0,0,0.25);
      backdrop-filter: blur(10px);
      min-width: 0;
    }
    @media (min-width: 860px) { .card { padding: 16px; } }

    .row { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }

    .method {
      font-weight: 700;
      font-size: 12px;
      padding: 3px 8px;
      border-radius: 999px;
      border: 1px solid rgba(34,197,94,0.35);
      background: rgba(34,197,94,0.14);
      color: rgba(220,255,234,0.95);
    }

    .path { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace; font-size: 13px; color: rgba(255,255,255,0.9); }
    .desc { color: var(--muted); font-size: 13px; margin: 8px 0 12px; }

    .kv { display: grid; grid-template-columns: 106px 1fr; gap: 10px; font-size: 13px; margin-top: 10px; }
    @media (min-width: 860px) { .kv { grid-template-columns: 120px 1fr; } }

    .k { color: rgba(255,255,255,0.75); }
    .v { color: rgba(255,255,255,0.92); }

    pre {
      margin: 10px 0 0;
      padding: 12px 12px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.10);
      background: var(--codebg);
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      font-size: 12px;
      line-height: 1.45;
    }

    code { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace; }

    .callout {
      border: 1px solid rgba(245,158,11,0.35);
      background: rgba(245,158,11,0.12);
      border-radius: 16px;
      padding: 12px 14px;
      color: rgba(255,255,255,0.9);
      min-width: 0;
    }

    .callout strong { color: rgba(255,255,255,0.95); }
    .muted { color: var(--muted); }

    .pill {
      font-size: 12px;
      padding: 3px 10px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.05);
      color: var(--muted);
    }

    .footer { margin-top: 18px; color: var(--muted); font-size: 12px; }
    .hr { height: 1px; background: var(--line); margin: 14px 0; }

    .legal-note {
      border: 1px solid rgba(239, 68, 68, 0.32);
      background: rgba(239, 68, 68, 0.10);
      border-radius: 16px;
      padding: 12px 14px;
      color: rgba(255,255,255,0.92);
    }
    .legal-note strong { color: rgba(255,255,255,0.96); }
    .legal-note a { color: rgba(255,255,255,0.92); text-decoration: underline; text-underline-offset: 2px; }

    .region-gate {
      position: fixed;
      inset: 0;
      z-index: 9999;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 20px;
      background: rgba(0,0,0,0.58);
      backdrop-filter: blur(10px);
    }
    .region-gate.show { display: flex; }

    .region-gate .modal {
      width: min(560px, calc(100vw - 28px));
      border-radius: 18px;
      border: 1px solid rgba(255,255,255,0.14);
      background: linear-gradient(180deg, rgba(255,255,255,0.10), rgba(255,255,255,0.06));
      box-shadow: var(--shadow);
      padding: 16px;
    }

    .region-gate .modal h2 {
      margin: 0;
      font-size: 16px;
      color: rgba(255,255,255,0.95);
    }

    .region-gate .modal p {
      margin: 10px 0 0;
      font-size: 13px;
      color: rgba(255,255,255,0.78);
      line-height: 1.55;
    }

    .region-gate .actions {
      display: flex;
      gap: 10px;
      justify-content: flex-end;
      margin-top: 14px;
      flex-wrap: wrap;
    }

    .region-gate .btn {
      appearance: none;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.06);
      color: rgba(255,255,255,0.92);
      padding: 8px 12px;
      border-radius: 12px;
      font-size: 13px;
      cursor: pointer;
    }

    .region-gate .btn.primary {
      border-color: rgba(249, 115, 22, 0.45);
      background: rgba(249, 115, 22, 0.22);
      color: rgba(255,255,255,0.95);
    }

    .region-gate .btn.danger {
      border-color: rgba(239, 68, 68, 0.45);
      background: rgba(239, 68, 68, 0.18);
      color: rgba(255,255,255,0.95);
    }

    .llm-select {
      appearance: none;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.06);
      color: rgba(255,255,255,0.92);
      padding: 6px 10px;
      border-radius: 12px;
      font-size: 13px;
      outline: none;
    }

    .btn-sm {
      appearance: none;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.06);
      color: rgba(255,255,255,0.92);
      padding: 7px 10px;
      border-radius: 12px;
      font-size: 13px;
      cursor: pointer;
    }

    .btn-sm.primary {
      border-color: rgba(249, 115, 22, 0.45);
      background: rgba(249, 115, 22, 0.22);
      color: rgba(255,255,255,0.95);
    }

    .features-list {
      margin: 10px 0 0;
      padding-left: 18px;
      color: rgba(255,255,255,0.90);
    }
    .features-list li { margin: 6px 0; }
    details > summary { cursor: pointer; }
    details > summary::marker { color: var(--brand); }

    .construction-banner {
      margin-top: 48px;
      padding: 20px 24px;
      border-radius: 18px;
      border: 1px solid rgba(251, 146, 60, 0.4);
      background: linear-gradient(135deg, rgba(251, 146, 60, 0.15), rgba(234, 88, 12, 0.1));
      display: flex;
      align-items: center;
      gap: 16px;
      animation: pulse-border 3s infinite;
    }

    @keyframes pulse-border {
      0% { border-color: rgba(251, 146, 60, 0.4); }
      50% { border-color: rgba(251, 146, 60, 0.8); }
      100% { border-color: rgba(251, 146, 60, 0.4); }
    }

    .construction-banner svg {
      width: 32px;
      height: 32px;
      flex-shrink: 0;
      color: #F97316;
    }

    .construction-banner .text-content h3 {
      margin: 0 0 4px;
      font-size: 16px;
      color: #FDBA74;
    }

    .construction-banner .text-content p {
      margin: 0;
      font-size: 13px;
      color: rgba(253, 186, 116, 0.8);
    }

    .card.coming-soon {
      opacity: 0.55;
      filter: saturate(0.9);
    }

    .card.coming-soon .method {
      border-color: rgba(245,158,11,0.35);
      background: rgba(245,158,11,0.12);
      color: rgba(255,255,255,0.85);
    }

    .soon-tag {
      font-size: 12px;
      padding: 3px 10px;
      border-radius: 999px;
      border: 1px dashed rgba(245,158,11,0.45);
      background: rgba(245,158,11,0.08);
      color: rgba(255,255,255,0.82);
    }

    .soon-note {
      margin-top: 10px;
      font-size: 12px;
      color: rgba(255,255,255,0.65);
    }
  </style>
</head>
