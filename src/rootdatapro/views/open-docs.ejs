          enBtn.classList.toggle('active', lang === 'en');
          zhBtn.classList.toggle('active', lang === 'zh');
        }
      }

      window.__openDocsSetLang = setLang;

      function bindLangButtons() {
        var enBtn = document.getElementById('lang-en');
        var zhBtn = document.getElementById('lang-zh');
        if (enBtn) enBtn.addEventListener('click', function () { setLang('en'); if (window.__openDocsSyncRepeats) window.__openDocsSyncRepeats(); });
        if (zhBtn) zhBtn.addEventListener('click', function () { setLang('zh'); if (window.__openDocsSyncRepeats) window.__openDocsSyncRepeats(); });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function () {
          bindLangButtons();
          setLang(getLang());
          if (window.__openDocsSyncRepeats) window.__openDocsSyncRepeats();
        });
      } else {
        bindLangButtons();
        setLang(getLang());
        if (window.__openDocsSyncRepeats) window.__openDocsSyncRepeats();
      }
    })();
  </script>

