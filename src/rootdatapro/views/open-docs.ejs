  <script>
    (function () {
      try {
        var region = window.__CLIENT_REGION__ || null;
        var isMainland = region === 'CN';
        var dismissed = false;
        try { dismissed = localStorage.getItem('region_gate_dismissed') === '1'; } catch (e) {}

        var gate = document.getElementById('region-gate');
        var btnExit = document.getElementById('region-exit');
        var btnContinue = document.getElementById('region-continue');

        function show() {
          if (!gate) return;
          gate.classList.add('show');
          gate.setAttribute('aria-hidden', 'false');
        }

        function hide() {
          if (!gate) return;
          gate.classList.remove('show');
          gate.setAttribute('aria-hidden', 'true');
        }

        if (btnExit) {
          btnExit.addEventListener('click', function () {
            try { location.href = 'about:blank'; } catch (e) { hide(); }
          });
        }

        if (btnContinue) {
          btnContinue.addEventListener('click', function () {
            try { localStorage.setItem('region_gate_dismissed', '1'); } catch (e) {}
            hide();
          });
        }

        if (isMainland && !dismissed) {
          show();
        }
      } catch (e) {
        // ignore
      }
    })();
  </script>

